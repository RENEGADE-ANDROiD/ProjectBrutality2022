#library "Marauder"
#include "zcommon.acs"

// SUPERSEDED: zscript/Monsters/PB_MarauderSupport.zc (removed from LOADACS.txt).

// Marauder addon — support scripts. Rebuild with acc (see AGENTS.md ACS workflow).

script 1346 (void) {
	while (true) {
		TakeInventory("ShieldUp", 1);
		TakeInventory("CanBeStunned", 1);
		TakeInventory("CantUseShotgun", 1);
		TakeInventory("CantUseAxe", 1);
			if (CheckInventory("MarauderDied") == 1) {
				terminate;
			}
		delay (1);
	}
}