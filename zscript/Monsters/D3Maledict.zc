	Stop;



	Death.Saw:
	Death.Cut:
		TNT1 A 0;
		TNT1 A 0 A_BossDeath;
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
		TNT1 A 0 A_StartSound("MLDD01");
		TNT1 A 0 A_JumpIf(Flight == 1, "DeathNoHead1");
		TNT1 A 0 A_JumpIf(Flight == 2, "DeathNoHead2");
		TNT1 AAAA 0 A_SpawnProjectile ("NashGoreBloodSpurt", 90, -55, random (0, 360), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("NashGoreBloodSpurt", 90, -55, random (0, 360), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("Brutal_LiquidBlood3", 90, -55, random (0, 360), 2, random (0, 40));
		TNT1 A 0 A_SpawnProjectile("XDeathHeadD3Maledict", 90, -55, random (10, 15), 2, random (80, 90));
		D3MJ P 6;
		D3MJ Q 6;
		D3MJ R 6;
		D3MJ S 6;
		TNT1 AAAA 0 A_SpawnProjectile ("NashGoreBloodSpurt", 220, 0, random (0, 360), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("NashGoreBloodSpurt", 220, 0, random (0, 360), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("Brutal_LiquidBlood3", 220, 0, random (0, 360), 2, random (0, 40));
		D3MJ T 8;
		D3MJ UV 7;
	FallNoHead2:
		D3MJ WXYZ 6;
	FallLoopNoHead:
		D3MJ Z 1 A_CheckFloor("SpawnCorpseNoHead");
	Loop;

	DeathNoHead1:
		TNT1 A 0;
		D3MJ WXYZ 6;
	DeathLoopNoHead1:
		D3MJ Z 1 A_CheckFloor("SpawnCorpseNoHead");
