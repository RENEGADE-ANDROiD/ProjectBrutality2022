	Death.Fire:
	Death.Burn:
	TNT1 A 0;
	TNT1 A 0 A_JumpIfInTargetInventory("HasIncendiaryWeapon",1,"Death.Incinerate");
	TNT1 A 0 A_BossDeath;
	TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
	TNT1 A 0
		{
		if (Flight == 0)
