	DeathNoHead2:
		TNT1 A 0;
		D3MJ WXYZ 6;
	DeathLoopNoHead2:
		D3MJ Z 1 A_CheckFloor("SpawnCorpseNoHead");
	Loop;


	SpawnCorpseNoHead:
		TNT1 A 0;
		TNT1 A 0 A_StartSound("Corpse/Fall",CHAN_6);
		TNT1 A 0 A_SpawnItem ("GrowingBloodPool");
		TNT1 A 0 A_SpawnItem("DeadD3MaledictNoHead");
	Stop;

	XDeath:
	Death.Explosiveimpact:
	Death.Explosives: 
	Death.Landmine:
		TNT1 A 0;
		TNT1 A 0 A_BossDeath;
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
		TNT1 A 0 A_SpawnItem("BloodSplasher3");
		TNT1 AAAAAAAAAAAAAA 0 A_SpawnProjectile ("BloodMistXXBig", 30, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (70, 90));
		TNT1 AAAAAAAAAAAAAA 0 A_SpawnProjectile ("BloodMistXXBig", 100, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (20, 90));
		TNT1 AA 0 A_SpawnProjectile ("XDeath1", 32, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 160));
		TNT1 AAAAA 0 A_SpawnProjectile ("XDeath2", 32, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 160));
		TNT1 AAAAAAA 0 A_SpawnProjectile ("XDeath3", 32, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 160));
		TNT1 AAAAAAA 0 A_SpawnProjectile ("XDeath4", 32, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 160));
		TNT1 A 0 A_SpawnProjectile ("XDeath4b", 32, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 160));
		TNT1 AAAAA 0 A_SpawnProjectile ("SuperGoreSpawner2", 10, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 180));
		TNT1 AAAAAAAAAA 0 A_SpawnProjectile ("SuperGoreSpawner2", 0, 0, random (0, 180), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 180));
		TNT1 AAAAA 0 A_SpawnProjectile ("SuperGoreSpawner2", 25, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 180));
		TNT1 AAAAAAAAAA 0 A_SpawnProjectile ("SuperGoreSpawner2", 35, 0, random (0, 180), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 180));
		TNT1 AAAAAAAAAAAAAAAAAA 0 A_SpawnProjectile ("SuperGoreMist", 54, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (0, 90));
		TNT1 A 0 A_SpawnItem ("GiantBloodSpot");
		TNT1 A 0 A_SpawnProjectile ("XDeathHeadD3Maledict", 94, 0, random (0, 360), 2, random (0, 360));
		TNT1 AA 0 A_SpawnProjectile ("XDeathWingD3Maledict", 80, 0, random (0, 360), 2, random (0, 360));
		TNT1 A 0 A_SpawnProjectile ("XDeathHumpD3Maledict", 80, 0, random (0, 360), 2, random (0, 360));
		TNT1 AA 0 A_SpawnProjectile ("XDeathFeetD3Maledict", 25, 0, random (0, 360), 2, random (0, 360));
		TNT1 A 0 A_SpawnProjectile ("XDeathTailD3Maledict", 32, 0, random (0, 360), 2, random (0, 360));
	Stop;


	Death.Ice:
	Death.IceExplosion:
	Death.Freeze:
	Death.Frost:
		TNT1 A 0;
		TNT1 A 0 A_BossDeath;
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
