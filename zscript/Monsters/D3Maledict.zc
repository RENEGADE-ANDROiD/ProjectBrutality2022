		if (Flight == 1)
				{A_SpawnItemEx ("BurningD3Maledict2",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);}
		if (Flight == 2)
				{A_SpawnItemEx ("BurningD3Maledict3",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);}
		}
	Stop;

	Death.Execution:
		TNT1 A 0 A_StopAllSounds;
		TNT1 A 0 A_FaceTarget;
		TNT1 A 0 A_NoBlocking;
		TNT1 A 0 A_GiveToTarget("BPtoken",5);
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		Stop;
	}
}


Class MaledictFlamethrowerMissile: FastProjectile
{
Default
{
  Radius 3;
  Height 3;
  Speed 30;
  Projectile;
  +GETOWNER;
  +NOBLOCKMAP;
  +NOTELEPORT;
  +DONTSPLASH;
  +MISSILE;
  +FORCEXYBILLBOARD;
  +THRUSPECIES;
  +THRUACTORS;
  Damage 3;
  -RIPPER;
  +NOBLOOD;
  +NOBLOODDECALS;
  +BLOODLESSIMPACT;
  -BLOODSPLATTER;
  RenderStyle "Add";
  DamageType "Fire";
  Scale 0.7;
  Alpha 1.0;
  Gravity 0;
}
	States
	{
	Spawn:
		TNT1 A 0;
		TNT1 A 0 {bTHRUACTORS = 0;}
		FIR5 ABC 1 BRIGHT;
		FIR3 A 1 BRIGHT;
		EXPL A 0 A_SpawnProjectile ("SmallFireTrail", 6, 0, 0, 2, random (0, 10));
		FIR3 B 1 BRIGHT;
		TNT1 A 0 A_Explode(4, 80, 0);
		EXPL A 0 A_SpawnProjectile ("SmallFireTrail", 6, 0, 0, 2, random (0, 30));
		FIR3 D 1 BRIGHT;
		FIR3 E 1 BRIGHT;
		EXPL A 0 A_SpawnProjectile ("SmallFireTrail", 6, 0, 0, 2, random (0, 50));
		FIR3 F 1 BRIGHT;
		TNT1 A 0 A_Explode(4, 80, 0);
		EXPL A 0 A_SpawnProjectile ("SmallFireTrail", 6, 0, 0, 2, random (-10, 60));
		FIR3 G 1 BRIGHT;
		FIR3 H 1 BRIGHT;
		EXPL A 0 A_SpawnProjectile ("SmallFireTrail", 6, 0, 0, 2, random (-60, 80));
		FIR3 I 1 BRIGHT;
		TNT1 A 0 A_Explode(4, 80, 0);
		EXPL A 0 A_SpawnProjectile ("FlamethrowerFireParticles", 6, 0, 0, 2, random (10, 20));
		FIR3 JKL 1 BRIGHT;
		TNT1 A 0 A_Explode(4, 125, 0);
		EXPL A 0 A_SpawnProjectile ("FlamethrowerFireParticles", 6, 0, random (0, 360), 2, random (10, 90));
		TNT1 A 0 A_Playsound("Afrit/Hellfire");
		Stop;
	Death:
		TNT1 A 0 A_Explode(4, 50, 0);
		EXPL AA 0 A_SpawnProjectile ("FlamethrowerFireParticles", 6, 0, random (0, 360), 2, random (10, 90));
	Stop;
	}
}

Class Shul: Actor
{
float sc;
float scu;
Default
{
  +CLIENTSIDEONLY;
  -SOLID;
  +NOCLIP;
  +THRUACTORS;
  +NOGRAVITY;
  +DONTFALL;
  +NOTELEPORT;
  -PUSHABLE;
  +NODAMAGETHRUST;
  +NOTARGET;
  +NORADIUSDMG;
  +INVULNERABLE;
  +NOBLOOD;
  +NOBLOODDECALS;
  +SHOOTABLE;
  +NOICEDEATH;
  +DONTTHRUST;
  RenderStyle "Add";
  Alpha 0;
  +ROLLSPRITE;
  Scale 0.0;
}
  States
	{
	Spawn:
		TNT1 A 0;
		TNT1 A 0
		{
		sc = self.Scale.Y;
		scu = sc+0.05;
		}
		TNT1 A 0 A_SetRoll(random(0, 359));
		TNT1 A 0 A_SetScale((Scale.Y)*1.3, Scale.Y);
		TNT1 AAAAAAAAAA 1 Bright Light("PortalLight_Red")
			{
			A_SetScale((Scale.Y+scu)*1.3, Scale.Y+scu);
			A_FadeIn(0.2);
			}
		TNT1 AAAAAAAAAA 1 Bright Light("PortalLight_Red")
			{A_SetScale((Scale.Y+scu)*1.3, Scale.Y+scu);
			A_FadeOut(0.16);
			}
	Stop;

	Death:
		TNT1 AA 1 Bright
			{A_SetScale((Scale.Y+(scu*5))*1.3, Scale.Y+(scu*5));
			A_FadeOut(0.5);
			}
	Stop;
	}
}
