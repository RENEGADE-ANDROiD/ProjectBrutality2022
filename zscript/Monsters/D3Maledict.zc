	Stop;


	Death.Shrink:
		TNT1 A 0;
		TNT1 A 0 A_KillChildren ("ShieldBreak", KILS_FOILINVUL, "D3HGPortalEffect");
		TNT1 A 0 A_NoBlocking;
		TNT1 A 1 A_StartSound("Shrink", 3);
