		D3MD K WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	DragonFlyLoopS11:
		D3MD L WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
		TNT1 A 0 {NumShots = NumShots+1;}


		TNT1 A 0 {distance = TrDistance(self, target);}
		TNT1 A 0 {if (NumShots > 0 || distance < 100)	{bFRIGHTENED = false;}	}
		TNT1 A 0 A_JumpIf(NumShots < 2, "DragonFlyLoopContinue");
		TNT1 A 0 A_JumpIf(distance > 1200, "DragonFlyLoopContinue");
		TNT1 A 0 A_CheckSight("DragonFlyLoopContinue");
		TNT1 A 0 A_Jump(256, "DragonAttack");


	DragonAttack:
