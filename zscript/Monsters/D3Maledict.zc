	AttackLandNoSummon:
		TNT1 A 0;
		TNT1 A 0 A_Jump(256, "FireBallsLand", "CastMeteorsLand");
	Goto SeeContinue;

	Missile:
		TNT1 A 0;
		TNT1 A 0 A_Jumpif(flight == 1, "PrepareAttackFloat");
		TNT1 A 0 A_JumpIf( flight == 2, "DragonFlyLoop");		
		TNT1 A 0 {NumShots = 0;}
		TNT1 A 0 {distance = TrDistance(self, target);}

		TNT1 A 0 A_JumpIf(distance > 4000, "SeeContinue");
		TNT1 A 0 A_JumpIf(distance < 400, "TorchLand");

		TNT1 A 0 {CeilingHeight = int(CeilingZ - FloorZ);}
		TNT1 A 0 A_JumpIf(CeilingHeight < 260, "FireBallsLand");

		TNT1 A 0 A_Jump(256, "FireBallsLand", "SummonLand", "CastMeteorsLand");



	SummonLand:
		TNT1 A 0;
		TNT1 A 0 CountReinforcements("PB_LostSoul", GetCVar("D3MaledictLSCount"), "AttackLandNoSummon");
		TNT1 A 0 A_FaceTarget;
		TNT1 A 0 A_StartSound("MLDSPLS1", CHAN_BODY);
		D3MA LMNO 6 A_FaceTarget;
		TNT1 A 0 {Height = 250;}
		TNT1 A 0 SpawnReinforcement("PB_LostSoul",0, -90, 60, self, self, target, "SkullAttack", 0, 0, "D3Maledict", 1, 0, 0);
		TNT1 A 0 A_SpawnItemEx ("SeekersTeleportEffect", 0, -90, 30, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		D3MA S 18 A_FaceTarget;
		D3MA T 13 A_FaceTarget;
		D3MA S 4 A_FaceTarget;
		D3MA T 18 A_FaceTarget;
		D3MA S 6 A_FaceTarget;
		TNT1 A 0 SpawnReinforcement("PB_LostSoul",0, 90, 60, self, self, target, "SkullAttack", 0, 0, "D3Maledict", 1, 0, 0);
		TNT1 A 0 A_SpawnItemEx ("SeekersTeleportEffect", 0, 90, 30, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		D3MA T 10 A_FaceTarget;
		D3MA S 13 A_FaceTarget;
		D3MA T 7 A_FaceTarget;
		TNT1 A 0 SpawnReinforcement("PB_LostSoul",0, -90, 60, self, self, target, "SkullAttack", 0, 0, "D3Maledict", 1, 0, 0);
		TNT1 A 0 A_SpawnItemEx ("SeekersTeleportEffect", 0, -90, 30, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		D3MA S 12 A_FaceTarget;
		D3MA T 4 A_FaceTarget;
		D3MA S 4 A_FaceTarget;
		TNT1 A 0 SpawnReinforcement("PB_LostSoul",0, 90, 60, self, self, target, "SkullAttack", 0, 0, "D3Maledict", 1, 0, 0);
		TNT1 A 0 A_SpawnItemEx ("SeekersTeleportEffect", 0, 90, 30, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		D3MA T 9 A_FaceTarget;
		D3MA S 4 A_FaceTarget;
		D3MA T 10 A_FaceTarget;
		D3MA S 6 A_FaceTarget;
		D3MA T 7 A_FaceTarget;
		TNT1 A 0 SpawnReinforcement("PB_LostSoul",0, -90, 60, self, self, target, "SkullAttack", 0, 0, "D3Maledict", 1, 0, 0);
		TNT1 A 0 A_SpawnItemEx ("SeekersTeleportEffect", 0, -90, 60, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		D3MA S 15 A_FaceTarget;
		D3MA ONML 6 A_FaceTarget;
	Goto SeeContinue;


	CastMeteorsLand:
		TNT1 A 0;
		TNT1 A 0 A_FaceTarget;
		D3MA LMNO 6 A_FaceTarget;
		TNT1 A 0 {Height = 250;}
		TNT1 A 0 A_StartSound("MLDSPLA1", CHAN_BODY);
		D3MA T 15 A_FaceTarget;
		D3MA S 6 A_FaceTarget;
		TNT1 A 0 A_StartSound("MLDSPLA2", CHAN_BODY, CHANF_OVERLAP);
		D3MA T 6 A_FaceTarget;
		D3MA S 3 A_FaceTarget;
		TNT1 A 0 A_SpawnItemEx("Shul", 60, 0, 160);
		TNT1 AAAAAAAAA 0 A_SpawnItemEx("ObeliskTrailSpark", 60, random(-5,5), random(155,165), 0, 0, 0, 0, 128, 0);
		TNT1 A 0 A_SpawnProjectile ("MaledictCometAttack",28,0,0,0);
		D3MA T 36 A_FaceTarget;
		D3MA ONML 6 A_FaceTarget;
	Goto SeeContinue;


	FireBallsLand:
		TNT1 A 0;
		TNT1 A 0 A_FaceTarget;
		D3MA LMNOP 6 A_FaceTarget;
		TNT1 A 0 {Height = 250;}
	FireBallsLandContinue:
		TNT1 A 0;
		TNT1 A 0 A_FaceTarget;
		D3MA Q 4
		{
		A_SpawnProjectile("NewImpBall", 60, 0, 0, 0);
		A_SpawnProjectile("NewImpBall", 60, 0, random(-15,15), CMF_OFFSETPITCH, random(-3,3));
		A_SpawnProjectile("NewImpBall", 60, 0, random(-15,15), CMF_OFFSETPITCH, random(-3,3));
		}
		
		TNT1 A 0 {NumShots = NumShots+1;}
		TNT1 A 0 A_JumpIf(NumShots < 5, "FireBallsLandContinue");
		TNT1 A 0 A_Jump(256, "LandFireBreathEnd");

	TorchLand:
		TNT1 A 0;
		TNT1 A 0 A_FaceTarget;
		D3MA LMNOP 6 A_FaceTarget;
	TorchLandContinue:
		TNT1 A 0;
		TNT1 A 0 A_FaceTarget;
		D3MA Q 2
		{
		A_SpawnProjectile("MaledictFlamethrowerMissile", 60, 0, 0, 0);
		A_SpawnProjectile("MaledictFlamethrowerMissile", 60, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
		A_SpawnProjectile("MaledictFlamethrowerMissile", 60, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
		}
		TNT1 A 0 {NumShots = NumShots+1;}
		TNT1 A 0 A_JumpIf(NumShots < 30, "TorchLandContinue");



	LandFireBreathEnd:
		D3MA RL 6;
	Goto SeeContinue;
	
	Pain:
		TNT1 A 0 A_StopSound(CHAN_BODY);
		TNT1 A 0 A_JumpIf (Flight == 1, "PainFloat");
		D3MF K 4;
		D3MF K 4 A_Pain;
	Goto SeeContinue;


	PainFloat:
		TNT1 A 0;
		TNT1 A 0 
			{
			if (FlightFrame == 0)
			{
				return ResolveState("PainFloatS1");
			}
			else if (FlightFrame == 1)
			{
				return ResolveState("PainFloatS2");
			}
			else if (FlightFrame == 2)
			{
				return ResolveState("PainFloatS3");
			}
			else if (FlightFrame == 3)
			{
				return ResolveState("PainFloatS4");
			}
			else if (FlightFrame == 4)
			{
				return ResolveState("PainFloatS5");
			}
			else if (FlightFrame == 5)
			{
				return ResolveState("PainFloatS6");
			}
			else if (FlightFrame == 6)
			{
				return ResolveState("PainFloatS7");
			}
			else if (FlightFrame == 7)
			{
				return ResolveState("PainFloatS8");
			}
			else if (FlightFrame == 8)
			{
				return ResolveState("PainFloatS9");
			}
			else if (FlightFrame == 9)
			{
				return ResolveState("PainFloatS10");
			}
			else if (FlightFrame == 10)
			{
				return ResolveState("PainFloatS11");
			}
			else if (FlightFrame == 11)
			{
				return ResolveState("PainFloatS0");
			}
			else
			{
				return ResolveState(null);
			}
		}

	PainFloatS0:
		TNT1 A 0;
		TNT1 A 0 {NumShots = 0;}
		TNT1 A 0 {FlightFrame=0; A_StartSound("D3Maledict/float", CHAN_BODY, CHANF_OVERLAP);}
		D3MG A WF;
		TNT1 A 0 A_Pain;
	PainFloatS1:
		D3MG B WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS2:
		D3MG C WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS3:
		D3MG D WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS4:
