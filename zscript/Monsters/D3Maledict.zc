	PainFloatS5:
		D3MG F WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS6:
		TNT1 A 0 A_Pain;
		D3MG G WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS7:
		D3MG H WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS8:
		D3MG I WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS9:
		D3MG J WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS10:
		D3MG K WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	PainFloatS11:
		D3MG L WF;
		TNT1 A 0 {FlightFrame++; NumShots++;}
		TNT1 A 0 A_JumpIf(NumShots > 3, "FloatLoop");
	Goto FloatLoop;


	Death:
		TNT1 A 0;
		TNT1 A 0 A_JumpIfInTargetInventory("HasIncendiaryWeapon",1,"Death.Incinerate");
		TNT1 A 0 A_JumpIfIntargetInventory("SSGSelected", 1, "Death.SSG");
		TNT1 A 0 A_JumpIfIntargetInventory("MinigunSelected", 1, "Death.Railgun");
		TNT1 A 0 A_JumpIfIntargetInventory("NewChaingunSelected", 1, "Death.Railgun");
		TNT1 A 0 A_JumpIfIntargetInventory("MG42Selected", 1, "Death.Railgun");
		TNT1 A 0 A_JumpIfIntargetInventory("QSGSelected", 1, "Death.SSG");

		TNT1 A 0 A_BossDeath;
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
		TNT1 A 0 A_StartSound("MLDD01");
		TNT1 A 0 A_JumpIf(Flight == 1, 7);
		TNT1 A 0 A_JumpIf(Flight == 2, 8);
		D3MF LMNO 6;
		D3MF P 8;
		D3MF QR 7;
		D3MF STUV 6;
	FallLoop:
		D3MF V 1 A_CheckFloor("SpawnCorpse");
	Loop;

	SpawnCorpse:
		TNT1 A 0 A_StartSound("Corpse/Fall",CHAN_6);
		TNT1 A 0 A_SpawnItem ("GrowingBloodPool");
		TNT1 A 0 A_SpawnItem("DeadD3Maledict");
	Stop;


	Death.SSG:
		TNT1 A 0 A_BossDeath;
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
		TNT1 A 0 A_FaceTarget;
		TNT1 A 0 A_SpawnProjectile ("XDeathWingD3Maledict", 91, -24, random (170, 190), 2, random (0, 40));
		TNT1 A 0 A_SpawnProjectile ("XDeathWingD3Maledict", 91, 24, random (170, 190), 2, random (0, 40));
		TNT1 A 0 A_SpawnProjectile("XDeathHeadD3Maledict", 90, -55, random (10, 15), 2, random (80, 90));
		TNT1 A 0 A_SpawnProjectile ("XDeathHumpD3Maledict", 80, 0, random (0, 360), 2, random (0, 360));
		TNT1 AAA 0 A_SpawnItem("Muchblood2");
		TNT1 AAA 0 bright A_SpawnProjectile ("SuperGoreSpawner", 55, 0, random (170, 190), 2, random (0, 40));
		TNT1 AAAAAAAAAA 0 A_SpawnItemEX("NashgoreGibs", 0, 0, 0, random (4, 12), 0, random (4, 12), random(0, 360));
		TNT1 AA 0 A_SpawnProjectile ("MeatDeath", 0, 0, random (0, 360), 2, random (0, 160));
		TNT1 AA 0 A_SpawnProjectile ("XDeath1", 52, 0, random (170, 190), 2, random (0, 40));
		TNT1 A 0 A_SpawnProjectile ("XDeath2", 52, 0, random (170, 190), 2, random (0, 40));
		TNT1 A 0 A_SpawnProjectile ("XDeath3", 52, 0, random (170, 190), 2, random (0, 40));
		TNT1 AAA 0 A_SpawnProjectile ("Instestin", 32, 0, random (150, 210), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("Brutal_FlyingBlood", 52, 0, random (170, 190), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("Brutal_FlyingBloodFaster", 52, 0, random (170, 190), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("Brutal_FlyingBloodMuchFaster", 52, 0, random (170, 190), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("SuperWallRedBlood", 52, 0, random (170, 190), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("SuperWallRedBlood", 56, 0, random (170, 190), 2, random (0, 40));
		TNT1 AAA 0 A_SpawnProjectile ("BloodMistBig", 50, 0, random (0, 360), 2, random (30, 90));
		TNT1 A 0 A_Jump(256, "HalfSelect");


	Death.Railgun:
		TNT1 A 0 A_BossDeath;
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
		TNT1 AAAAA 0 A_SpawnItemEX("NashgoreGibs", 50, 0, 0, random (4, 12), 0, random (4, 12), random(0, 360));
		TNT1 AAA 0 A_SpawnProjectile ("MeatDeathsmall", 50, 0, random (0, 360), 2, random (0, 160));
		TNT1 AAA 0 A_SpawnProjectile ("Instestin", 52, 0, random (150, 210), 2, random (0, 40));
		TNT1 AAAA 0 A_SpawnProjectile ("brutal_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40));
		TNT1 A 0 A_SpawnProjectile ("XDeath1", 60, 0, random (0, 360), 2, random (0, 160));
		TNT1 A 0 A_SpawnProjectile ("RipHalfD3MaledictUpper", 60, 0, random (0, 360), 2, random (0, 160));
		TNT1 A 0 Bright A_SpawnItem ("Big_Blood", 0, 30);
	HalfSelect:
		TNT1 A 0;
		TNT1 A 0
		{
		if (Flight == 0)
				{A_SpawnItemEx ("RipHalfD3MaledictLower1",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);}
		if (Flight == 1)
				{A_SpawnItemEx ("RipHalfD3MaledictLower2",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);}
		if (Flight == 2)
				{A_SpawnItemEx ("RipHalfD3MaledictLower3",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);}
		}
	Stop;



	Death.Incinerate:
		TNT1 A 0;
		TNT1 A 0 A_BossDeath;
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
