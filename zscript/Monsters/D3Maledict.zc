		TNT1 A 0 A_SpawnItemEx ("SeekersTeleportEffect", 0, -90, 30, 0, 0, 0, 0, SXF_NOCHECKPOSITION);

		TNT1 A 0 A_StartSound("D3Maledict/float", CHAN_BODY, CHANF_OVERLAP);
		D3MC ABOPEF WF A_FaceTarget;
		TNT1 A 0 SpawnReinforcement("PB_LostSoul",0, 90, 60, self, self, target, "SkullAttack", 0, 0, "D3Maledict", 1, 0, 0);
		TNT1 A 0 A_SpawnItemEx ("SeekersTeleportEffect", 0, 90, 30, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		D3MC STIJWX WF A_FaceTarget;

	Goto FloatLoop;

	CastMeteorsFloat:
		TNT1 A 0;
		TNT1 A 0 A_FaceTarget;
		TNT1 A 0 A_StartSound("MLDSPLA1", CHAN_BODY);
		D3MC MNOP WF A_FaceTarget;
		D3MC E WF A_FaceTarget;
		D3MC E WF/2 A_FaceTarget;
		TNT1 A 0 A_StartSound("MLDSPLA2", CHAN_BODY, CHANF_OVERLAP);
		D3MC R WF/2 A_FaceTarget;
		D3MC STU WF A_FaceTarget;
		TNT1 A 0 A_SpawnItemEx("Shul", 60, 0, 220);
		TNT1 AAAAAAAAA 0 A_SpawnItemEx("ObeliskTrailSpark", 60, random(-5,5), random(215,225), 0, 0, 0, 0, 128, 0);
		TNT1 A 0 A_SpawnProjectile ("MaledictCometAttack",28,0,0,0);
		D3MC JKL 4 A_FaceTarget;
	Goto FloatLoop;

	DragonAttackReload:
		TNT1 A 0;
		TNT1 A 0 {FlyClose = 0;}
		TNT1 A 0 {FlyTorchNums = FlyTorchNums - 1;}
		TNT1 A 0 {CeilingHeight = int(CeilingZ - FloorZ);}
		TNT1 A 0 {
				if (FlyTorchNums < 1)
					{
					if (CeilingHeight >= 120)
						{
						FlyTorchNums = 0;
						Flight = 1;
						return ResolveState("DragonFlyLoopEnd");
						}
					else
						{
						return ResolveState("PrepareDragonAttack");
						}
					}
				else
					{
					return ResolveState(null);
					}
				}
		TNT1 A 0 A_Jump(256, "PrepareDragonAttack2");

	DragonFlyLoopEnd:
		TNT1 A 0;
		TNT1 A 0
				{
				FlyTorchNums = 0;
				Flight = 1;
				bFRIGHTENED = false;
				bNOPAIN = false;
				}
		D3MA U 4 ThrustThing(0, 3, 0);
		D3MA U 4 ThrustThing(0, 2, 0);
		D3MA U 4 ThrustThing(0, 1, 0);
		TNT1 A 0 A_ScaleVelocity(0);
	Goto FloatLoop;


	DragonFlyLoopEndToTorch:
		TNT1 A 0;
		TNT1 A 0 {bNOPAIN = false;}
		TNT1 A 0
				{
				FlyTorchNums = 0;
				Flight = 1;
				bFRIGHTENED = false;
				}
		D3MA U 4 ThrustThing(0, 3, 0);
		D3MA U 4 ThrustThing(0, 2, 0);
		D3MA U 4 ThrustThing(0, 1, 0);
		TNT1 A 0 A_ScaleVelocity(0);
	Goto TorchFloat;


	PrepareDragonAttack:
		TNT1 A 0;
		TNT1 A 0 {Flight = 2; FlyTorchNums = random(1, 3); bNOPAIN = true;}
	PrepareDragonAttack2:
		TNT1 A 0 {bFRIGHTENED = true;}
		TNT1 A 0 A_ScaleVelocity(0);
		TNT1 A 0 {Height = 80; Speed = 40;}
		TNT1 A 0 {NumShots = 0;}
	DragonFlyLoopStart:
		D3MA O 4;
	DragonFlyLoop:
		TNT1 A 0;
		TNT1 A 0 {bNOPAIN = true;}
		TNT1 A 0 A_Jump(256, FlightFrame);
	DragonFlyLoopContinue:
		TNT1 A 0 {FlightFrame = 0; distance = TrDistance(self, target);}	
		TNT1 A 0 {
		if (distance <= 100 || 120 >= int(CeilingZ - FloorZ))
					{
					FlyTorchNums = 0;
					Flight = 1;
					bFRIGHTENED = false;
					return ResolveState("DragonFlyLoopEndToTorch");
					}
				else
					{
					A_StartSound("D3Maledict/fastfloat", CHAN_BODY, CHANF_OVERLAP);
					return ResolveState(null);
					}
			}

		D3MD A WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	DragonFlyLoopS1:
		D3MD B WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	DragonFlyLoopS2:
		D3MD C WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	DragonFlyLoopS3:
		D3MD D WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
