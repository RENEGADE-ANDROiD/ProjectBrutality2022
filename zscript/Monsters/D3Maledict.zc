	FD2:
		TNT1 A 0;
		TNT1 A 0 A_SpawnItem("FrozenD3Maledict2");
	Stop;


	Death.Blackhole:
		TNT1 A 0 A_BossDeath;
		TNT1 A 0 A_PB_DropStormcastBossLoot;
		TNT1 A 0 {bSHOOTABLE = false; bSOLID = false;}
