Class D3HGPortalEffect : Actor
{
	Default
	{
		+NOINTERACTION
	}
	States
	{
	Spawn:
		TNT1 A 1;
		Stop;
	}
}

Class D3Maledict : Actor
{
  int NumShots;
  int flight;
  int flightframe;
  int metonce;
  int flylandchance;
  int CeilingHeight;
  int flyclose;
  double distance;
  const wf = 4;
  const FlyTorchDist = 1600;
  int FlyTorchNums;
  int AttackChance;
  int Anger;
  Mixin SummonerFunctions;
Default
{
  Health 10000;
  Radius 50;
  Height 120;
  Scale 1;
  Mass 500000;
  Speed 12;
  MeleeRange 100;
  PainChance 10;
  PainChance "Fire", 0;
  PainChance "Burn", 0;
  PainChance "Flame", 0;
  damagefactor "BFG", 0.38;
  damagefactor "Plasma", 0.75;
  damagefactor "Freeze", .25;
  damagefactor "Ice", .25;
  damagefactor "Frost", .25;
  damagefactor "Disintegrate", .38;
  damagefactor "GreenFire", .38;
  damagefactor "Fire", .28;
  damagefactor "Burn", .28;
  damagefactor "Incinerate", .28;
  damagefactor "HKFT", 0.05;
  damagefactor "SSG", .75;
  damagefactor "Blast", .75;
  damagefactor "Cut", .75;
  damagefactor "Explosive", 1.5;
  damagefactor "Avoid", 0.0;
  damagefactor "killme", 0.0;
  damagefactor "Decaptate", 0.95;
  damagefactor "Head", 0.75;
  damagefactor "Stomp", 0.0;
  damagefactor "GibRemoving", 0.0;
  damagefactor "Trample", 0.0;
  damagefactor "TeleportRemover", 0.0;
  damagefactor "CauseObjectsToSplash", 0.0;
  PainChance "GloryFire", 255;
  PainChance "BloodPunch", 255;
  Monster;
  +DONTRIP;
  +SOLID;
  +DONTHARMSPECIES;
  +THRUSPECIES;
  +BOSS;
  +BOSSDEATH;
  +FLOORCLIP;
  +NORADIUSDMG;
  +DONTMORPH;
  +NODAMAGETHRUST;
  PainSound "D3Maledict/Pain";
  DeathSound "MLDD01";
  Obituary "%o could not stand up to the Hell Guardian.";

  PainChance "Taunt", 255;
  PainChance "Siphon", 255;
  PainChance "Cut", 2;
  PainChance "Saw", 2;
  PainChance "Disintegrate", 5;
  PainChance "IceExplosion", 50;
  PainChance "Ice", 20;
  PainChance "Frost", 20;
  PainChance "Explosive", 255;
  DropItem "Demonpickup2", 255;
  DropItem "Demonpickup2", 25;
  DropItem "DemonStrengthRune", 25;
  DropItem "Crucible", 50;
  WoundHealth 1000;
}

	action void A_PB_DropStormcastBossLoot()
	{
		let cv = CVar.FindCVar("pb_NoStormcastWeapon");
		if (cv && cv.GetInt() != 0)
			return;
		A_SpawnItemEx("Stormcast", 0, 0, 32, 0, 0, 0, random(0, 359), SXF_NOCHECKPOSITION);
	}

	void AngryAttack()
	{
		if(Self.Health > 0 && target && target.Health > 0 && CheckSight(target))
			{
			Anger = 128-((10000-(10000-self.health))*0.128);
			if (Anger > 128) {anger = 128;}
			AttackChance = random(0,256);
			if ( Anger >= AttackChance && TrDistance(self, target) > 100 )
				{SetState(FindState("Missile"));}
			else return;
			}
	}

	States
	{

	Wound:
		"####" "#" 1
		{
			if(GetCvar("be_ExecutionsON"))
			{
				if(countinv("FinisherToken")==0)
				{								
					A_SpawnItemEx("BaronHighlight",0,0,0,0,0,0,0,SXF_SETMASTER|SXF_NOCHECKPOSITION);
					A_GiveInventory("FinisherToken",1);
				}
				
				if(GetCvar("be_MonsterStagger")==1)
				{
					bNOGRAVITY = false;
					return ResolveState("Stagger");
				}
				else
				{
					return ResolveState(null);
				}
			}
			return ResolveState(null);
		}
		Goto See;
	Stagger:
		D3MK A 0
		{
			if(getcvar("be_ExecutionHighlight")==1)
			{	return ResolveState("PrepareStaggerHighlight");}
			else
			{	return ResolveState("StagLooper");	}
		}
		Goto StagLooper;
	PrepareStaggerHighlight:
		D3MK A 0;
		Goto StagLooper;
	
	StagLooper:
		"####" "#" 4
		{
			if(!countinv("FinisherToken"))
			{
				if (flight > 0)
					{bNOGRAVITY = true;}
				return ResolveState("See");
			}
			if(getcvar("be_NoisyStagger") && countinv("PainSoundToken"))
			{ 
				A_Pain(); 
				A_TakeInventory("PainSoundToken");
			}
			return ResolveState(null);
		}
		"####" "#" 0;
		Loop;

	Death.Crucible:
		TNT1 A 0 A_SpawnItemEx("GloryHightPinataSpawn2",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360));
	Goto Death.cut;

	Pain.GloryFire:
		TNT1 A 0 A_Jump(192, "See");
		TNT1 A 0 A_SpawnItemEx("FlamePinataSpawn",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360));
	Goto Pain;
		
	Death.GloryFire:
		TNT1 A 0 A_SpawnItemEx("FlamePinataSpawn",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360));
	Goto Death.Fire;
   
	Death.BloodPunch:
		TNT1 A 0	A_GiveToTarget("BloodPunchKilled",1);
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH);
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH);
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH);
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH);
		TNT1 A 0	A_SpawnItemEx("GloryHightPinataSpawn2",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360));
	Goto Death;
   
	Pain.BloodPunch:
		TNT1 A 0	A_GiveToTarget("BloodPunchKilled",1);
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH);
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH);
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH);
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH);
	Goto Pain;


	Spawn:
		TNT1 A 0;
		TNT1 A 0 {Height = 160;}
		TNT1 A 0 A_StartSound("MLDSTLP", CHAN_BODY);
		D3MB B 52 A_Look;
		D3MB A 76 A_Look;
		D3MB B 60 A_Look;
		D3MB A 74 A_Look;
	Loop;

	See:
		TNT1 A 0;
		TNT1 A 0 A_ScaleVelocity(0);
		TNT1 A 0
		{
		if (flight == 1 && metonce == 1)
			{
			return ResolveState("FloatLoop");
			}
		else
			{
			return ResolveState(null);
			}
		}

		TNT1 A 0
		{
		if (flight == 2 && metonce == 1)
			{
			return ResolveState("DragonAttackReload");
			}
		else
			{
			return ResolveState(null);
			}
		}


		TNT1 A 0
		{
		if (flight == 0 && metonce == 1)
			{
			return ResolveState("SeeContinue");
			}
		else
			{
			return ResolveState(null);
			}
		}

		TNT1 A 0 A_FaceTarget;
		TNT1 A 0 {Height = 120;}
		TNT1 A 0 {metonce = 1;}
		D3MB BCD 7;
		TNT1 A 0 A_StartSound("MLDAC02", CHAN_BODY, CHANF_OVERLAP);
		D3MB EF 7;
		TNT1 A 0 A_StartSound("MLDAC01", CHAN_BODY, CHANF_OVERLAP);
		D3MB GFGFGFGFGFGF 5;
		D3MB F 9;
		D3MB GFGF 5;
		TNT1 A 0 A_StartSound("MLDAC02", CHAN_BODY, CHANF_OVERLAP);
		D3MB HIJK 6;
		D3MA E 6;
	SeeContinue:
		TNT1 A 0;
		TNT1 A 0 {flylandchance = flylandchance+2;}
		TNT1 A 0 {Height = 120; Speed = 12; bFRIGHTENED = false;}
		TNT1 A 0 A_Jump( flight ==1, "FloatLoop");
		TNT1 A 0 A_Jump( flight ==2, "FloatLoop");
		TNT1 A 0 AngryAttack();
		TNT1 A 0 A_StartSound("D3Maledict/Step", CHAN_BODY, CHANF_OVERLAP);
		D3MA A 2 A_Chase;
		D3MA AA 4 A_Chase;
		D3MA A 2 A_Chase;
		D3MA BBB 4 A_Chase;
		TNT1 A 0 A_StartSound("D3Maledict/Step", CHAN_BODY, CHANF_OVERLAP);
		D3MA C 2 A_Chase;
		D3MA CC 4 A_Chase;
		D3MA C 2 A_Chase;
		D3MA DDD 4 A_Chase;
		TNT1 A 0 A_Jump(flylandchance, "TakeOff");
	Loop;


	TakeOff:
		TNT1 A 0;
		TNT1 A 0 {CeilingHeight = int(CeilingZ - FloorZ);}
		TNT1 A 0
				{
				if (CeilingHeight < 280)
					{
					if (flylandchance > 256) {flylandchance = 256;}
					return ResolveState("SeeContinue");
					}
				else
					{
					return ResolveState(null);
					}
				}

		TNT1 A 0 {bNOPAIN = true;}
		TNT1 A 0 {flylandchance = 0;}
		D3MA A 2;
		D3ME ABC 2;
		D3ME C 6;
		TNT1 A 0 A_StartSound("MLDFL01", CHAN_BODY, CHANF_OVERLAP);
		D3ME D 2;
		D3MC DEEFF 2 {ThrustThingZ(0, 20, 0, 0);}
		TNT1 A 0 A_ScaleVelocity(0);
		TNT1 A 0
		{
		bNOGRAVITY = true;
		bFLOAT = true;
		bNOPAIN = false;
		bFRIGHTENED = false;
		flight = 1;
		}
		D3MC GHIJKL 2;

	FloatLoop:
		TNT1 A 0;
		TNT1 A 0 {flylandchance = flylandchance+2;}
		TNT1 A 0 A_JumpIf( flight == 2, "DragonAttackReload");
		TNT1 A 0 {Height = 250; Speed = 20; bFRIGHTENED = false;  flight = 1;}
		TNT1 A 0 A_ScaleVelocity(0);
		TNT1 A 0 AngryAttack();

	TNT1 A 0 
		{
			if (FlightFrame == 0)
			{
				return ResolveState("FloatLoopS1");
			}
			else if (FlightFrame == 1)
			{
				return ResolveState("FloatLoopS2");
			}
			else if (FlightFrame == 2)
			{
				return ResolveState("FloatLoopS3");
			}
			else if (FlightFrame == 3)
			{
				return ResolveState("FloatLoopS4");
			}
			else if (FlightFrame == 4)
			{
				return ResolveState("FloatLoopS5");
			}
			else if (FlightFrame == 5)
			{
				return ResolveState("FloatLoopS6");
			}
			else if (FlightFrame == 6)
			{
				return ResolveState("FloatLoopS7");
			}
			else if (FlightFrame == 7)
			{
				return ResolveState("FloatLoopS8");
			}
			else if (FlightFrame == 8)
			{
				return ResolveState("FloatLoopS9");
			}
			else if (FlightFrame == 9)
			{
				return ResolveState("FloatLoopS10");
			}
			else if (FlightFrame == 10)
			{
				return ResolveState("FloatLoopS11");
			}
			else if (FlightFrame == 11)
			{
				return ResolveState("FloatLoopS0");
			}
			else
			{
				return ResolveState(null);
			}
		}

	FloatLoopS0:
		TNT1 A 0 {FlightFrame=0; A_StartSound("D3Maledict/float", CHAN_BODY, CHANF_OVERLAP);}
		D3MC A WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS1:
		D3MC B WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS2:
		D3MC C WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS3:
		D3MC D WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS4:
		D3MC E WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS5:
		D3MC F WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS6:
		D3MC G WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS7:
		D3MC H WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS8:
		D3MC I WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS9:
		D3MC J WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS10:
		D3MC K WF {FlightFrame++;}
		TNT1 A 0 A_Chase;
	FloatLoopS11:
		D3MC L WF {FlightFrame++;}
		TNT1 A 0 A_Chase;

		TNT1 A 0 A_Jump(flylandchance, "LandingStart");
		TNT1 A 0 {distance = TrDistance(self, target);}
		TNT1 A 0 A_JumpIf(distance > 1000, "PrepareDragonAttack");

	Goto FloatLoop;
	
	LandingStart:
		TNT1 A 0;
		TNT1 A 0 {flylandchance = 0;}
		TNT1 A 0 A_ScaleVelocity(0);
	Goto landing;

	Landing:
		TNT1 A 0;
		TNT1 A 0 {bNOPAIN = true;}
		TNT1 A 0 A_Jump(256, FlightFrame);
		D3MC ABCDEFGHIJKL 4;

		TNT1 A 0
		{
		bNOGRAVITY = false;
		bFLOAT = false;
		bTHRUACTORS = true;
		flight = 0;
		}
		
	LandingContinue:
		D3MC A 2 A_CheckFloor("LandingEnd");
		TNT1 A 0
		{
		if(waterlevel >= 1) {SetState(FindState("LandingEnd"));}
		}
	Loop;
	LandingEnd:
		TNT1 A 0 A_StartSound("MLDFL02", CHAN_BODY, CHANF_OVERLAP);
		TNT1 A 0 Radius_Quake (6, 35, 0, 22, 0);
		D3MC BC 2;
		D3ME DCBA 2;
		TNT1 A 0 {
		bTHRUACTORS = false;
		bNOPAIN = false;
		}


		TNT1 A 0
			{
			Vector2 move = AngleToVector(0, radius*1.5);
			Vector2 ptry = self.pos.xy + move;
			if (!self.TryMove(ptry, height))
				{
				return ResolveState("TakeOff");
				}
			else
				{
				return ResolveState(null);
				}
			}

		TNT1 A 0 
				{
				if (TestMobjLocation() == false)
				{
				return ResolveState("TakeOff");
				}
			else
				{
				return ResolveState(null);
				}
			}

	Goto SeeContinue;

	Melee:
		TNT1 A 0;
		TNT1 A 0 A_JumpIf( flight == 1, "PrepareAttackFloat");
		TNT1 A 0 {
				if (flight == 2)
					{
					FlyTorchNums = 0;
					Flight = 1;
					bFRIGHTENED = false;
					FlyClose = 1;
					return ResolveState("DragonAttack");
					}
				else
					{
					return ResolveState(null);
					}
				}


		TNT1 A 0 A_FaceTarget;
		TNT1 A 0 {bSPRITEFLIP = random(0,1);}
		TNT1 A 0 A_FaceTarget;
		TNT1 A 0 A_StartSound("MLDBT01");
		D3MA EFG 4;
		D3MA G 7;
		D3MA H 4;
		TNT1 A 0 A_CustomMeleeAttack(80, "", "", "BHFT");
		D3MA I 4;
		D3MA JKE 4;
		TNT1 A 0 {bSPRITEFLIP = false;}
	Goto SeeContinue;

	AttackFloatNoSummon:
		TNT1 A 0;
		TNT1 A 0 A_Jump(256, "FireBAllsFloat", "PrepareDragonAttack");
	Goto FloatLoop;


	PrepareAttackFloat:
		TNT1 A 0;
		TNT1 A 0 A_Jump(80, "PrepareDragonAttack");
		TNT1 A 0 A_Jump(256, FlightFrame);
		D3MC ABCDEFGHIJKL WF A_FaceTarget;

		TNT1 A 0 {NumShots = 0;}
		TNT1 A 0 {distance = TrDistance(self, target);}

		TNT1 A 0 A_JumpIf(distance < 400, "TorchFloat");
		TNT1 A 0 A_Jump(256, "FireBAllsFloat", "SummonFloat", "CastMeteorsFloat");

	FireBallsFloat:
		TNT1 A 0;
		TNT1 A 0 A_StartSound("D3Maledict/float", CHAN_BODY, CHANF_OVERLAP);
		TNT1 A 0 A_FaceTarget;
		D3MC M WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC N WF A_SpawnProjectile("NewImpBall", 250, 0, 0, 0);
		TNT1 A 0 A_FaceTarget;
		D3MC O WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC P WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC Q WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC R WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC S WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC T WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC U WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC V WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC W WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
		D3MC X WF A_SpawnProjectile("NewImpBall", 250, 0, random(-5,5), CMF_OFFSETPITCH, random(-3,3));
		TNT1 A 0 A_FaceTarget;
	Goto FloatLoop;



	TorchFloat:
		TNT1 A 0;

	TNT1 A 0 
		{
			if (FlightFrame == 1)
			{
				return ResolveState("TorchFloatS1");
			}
			else if (FlightFrame == 2)
			{
				return ResolveState("TorchFloatS2");
			}
			else if (FlightFrame == 3)
			{
				return ResolveState("TorchFloatS3");
			}
			else if (FlightFrame == 4)
			{
				return ResolveState("TorchFloatS4");
			}
			else if (FlightFrame == 5)
			{
				return ResolveState("TorchFloatS5");
			}
			else if (FlightFrame == 6)
			{
				return ResolveState("TorchFloatS6");
			}
			else if (FlightFrame == 7)
			{
				return ResolveState("TorchFloatS7");
			}
			else if (FlightFrame == 8)
			{
				return ResolveState("TorchFloatS8");
			}
			else if (FlightFrame == 9)
			{
				return ResolveState("TorchFloatS9");
			}
			else if (FlightFrame == 10)
			{
				return ResolveState("TorchFloatS10");
			}
			else if (FlightFrame == 11)
			{
				return ResolveState("TorchFloatS11");
			}

			else
			{
				return ResolveState(null);
			}
		}
	
		TNT1 A 0 A_StartSound("D3Maledict/float", CHAN_BODY, CHANF_OVERLAP);
		TNT1 A 0 A_FaceTarget;
		D3MC M WF/2
		{
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, 0, 0);
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
		}
		TNT1 A 0 A_FaceTarget;
		D3MC M WF/2
		{
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, 0, 0);
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
		}

	TNT1 A 0 {FlightFrame ++;}
	TorchFloatS1:
		TNT1 A 0 A_FaceTarget;
		D3MC N WF/2
		{
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, 0, 0);
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
		}
		TNT1 A 0 A_FaceTarget;
		D3MC N WF/2
		{
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, 0, 0);
		A_SpawnProjectile("MaledictFlamethrowerMissile", 250, 0, random(-10,10), CMF_OFFSETPITCH, random(-3,3));
