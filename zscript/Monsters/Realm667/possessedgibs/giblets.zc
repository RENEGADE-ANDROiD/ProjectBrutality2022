//================================== Giblets ==================================
class PGGiblet : Actor
{
	int rolldir;
	override void PostBeginPlay()
	{
		rolldir = randompick(-20,-15,15,20);
		frame = random(0,7);
		Super.PostBeginPlay();
	}
	Default
	{
		+NOTONAUTOMAP
		+RANDOMIZE;
		+ROLLSPRITE;
		+ROLLCENTER;
		DeathSound "PossessedGibs/splat";
	}
	States
	{
	FadeGib:
		#### # 1
		{
			A_FadeOut(0.1);
		}
		Loop;
	}

	action void rollgibs()
	{
		invoker.roll += invoker.rolldir;
		if (invoker.pos.z == invoker.floorz)
		{
			invoker.A_SpawnDebris("PGbloodDebris");
			invoker.destroy();
		}
	}
}

class PGGibArm : PGGiblet
{
	Default
	{
		Health 2;
	}
	States
	{
	Spawn:
		VGAR # 1 rollgibs();
		Loop;
	}
}

