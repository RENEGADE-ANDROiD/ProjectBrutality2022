//=================================== Blood ===================================
class PGblood : Actor
{
	Default
	{
		+NOTONAUTOMAP
		+NOBLOCKMAP;
		+NOTELEPORT;
		+RANDOMIZE;
		-ALLOWPARTICLES;
		scale 0.667;
		DeathSound "PossessedGibs/splat";
	}
	States
	{
	Spawn:
		VBLO ABCD 2 A_JumpIf(pos.z <= floorz, "Death");
		Loop;
	Death:
		VBLS A 0 
		{
			for (int i = 0; i < 360; i += 30)
			{
				if (GetZAt(24, 0, i) != floorz)	destroy();
			}
			vel = (0,0,0);
			bNOINTERACTION = true;
			bFLATSPRITE = true;
			frame = random(0,6);
			scale = (1.4,1.4);
		}
		#### # 0 A_Jump(256,"FadeS","FadeS","FadeS","FadeS","FadeM","FadeM","FadeM","FadeL");
	FadeS:
		#### # 5
		{
			A_FadeOut(0.01);
		}
		Loop;
	FadeM:
		#### # 10
		{
			A_FadeOut(0.01);
		}
		Loop;
	FadeL:
		#### # 15
		{
			A_FadeOut(0.01);
		}
		Loop;
	}
}

class PGbloodDebris : PGblood
{
	Default
	{
		Health 3;
	}
}

class PGbloodDebrisXL : PGblood
{
	Default
	{
		Health 9;
	}
}

//============================== Gibs Projectile ==============================
class PGProjectile : Actor
{
	static const Name gibsprites[] = { "VGTO", "VGBO", "VGAR", "VGHE" };
	int rolldir;
	override void PostBeginPlay() 
    {
		Super.PostBeginPlay();
		rolldir = randompick(-25,-15,15,25);
		sprite = GetSpriteIndex(gibsprites[random(0, gibsprites.Size() - 1)]);
		frame = random(0,7);
		A_StartSound("PossessedGibs/throw", CHAN_WEAPON, CHANF_OVERLAP);
    }
	
	Default
	{
		Radius 6;
		Height 8;
		Speed 17;
		FastSpeed 26;
		Damage 2;
		Projectile;
		Species "PossessedGibs";
		+THRUSPECIES;
		+ROLLSPRITE;
		+ROLLCENTER;
		SeeSound "PossessedGibs/shot";
		DeathSound "PossessedGibs/gibs";
		Decal "pgBloodSplat";
	}
	States
	{
	Spawn:
		#### # 0 Nodelay A_Jump(128,"Chunk");
	Gibs:
		#### # 1
		{
			roll += rolldir;
		}
		Loop;
	Chunk:
		VBSH AB 4;
		Loop;
	Death:
		VBSH C 4 A_SpawnDebris("PGbloodDebris");
		VBSH D 4;
		Stop;
	}
}

// Ephemeral organ/gib streak used only by PossessedGibsSlither tendril lash.
class PGTendrilLashSeg : Actor
{
	Default
	{
		+NOGRAVITY
		+NOBLOCKMAP
		+DROPOFF
		+NOTELEPORT
		+NOTONAUTOMAP
		+ROLLSPRITE
		+ROLLCENTER
		RenderStyle "Add";
		Alpha 0.6;
	}
	override void PostBeginPlay()
	{
		Super.PostBeginPlay();
		sprite = GetSpriteIndex(GibSpritePick(random(0, 3)));
		frame = random(0, 5);
		roll = frandom(0, 360);
		double sx = frandom(0.28, 0.5);
		scale = (random(0, 1) ? sx : -sx, frandom(1.15, 2.1));
	}

	static Name GibSpritePick(int i)
	{
		switch (i & 3)
		{
		case 0: return 'VGTO';
		case 1: return 'VGBO';
		case 2: return 'VGAR';
		default: return 'VGHE';
		}
	}
	States
	{
	Spawn:
		#### # 2
		{
			roll += 22;
			A_FadeOut(0.1);
		}
		Loop;
	}
}