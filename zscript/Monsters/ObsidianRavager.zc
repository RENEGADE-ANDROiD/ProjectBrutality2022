Class ObsidianMark01: Actor
{
  int NumAvoids;
  int FMaster;
  double distance;
  int numteleports;
Default
{
  Tag "Obsidian mark";
  Health 480;
  Radius 30;
  Height 89;
  Scale 0.4;
  Mass 3000;
  Speed 7;
  Species "ObsidianRavager";
  Obituary "%o was too close to the obsidian mark";
  Monster;
  DamageFactor "Crush", 10.0;
  DamageFactor "TeleportRemover", 0.0;
  DamageFactor "GibRemoving", 0.0;
  DamageFactor "CauseObjectsToSplash", 0.0;
  DamageFactor "Head", 1.0;
  DamageFactor "MinorHead", 1.0;
  DamageFactor "SSG", 1.2;
  DamageFactor "Avoid", 0.0;
  DamageFactor "KillMe", 0.0;
  DamageFactor "Fatality", 0.8;
  DamageFactor "Burn", 0.1;
  DamageFactor "Flame", 0.1;
  DamageFactor "Fire", 0.1;
  DamageFactor "Acid", 0.35;
  DamageFactor "ExtremePunches", 3.0;
  DamageFactor "Disintegrate", 0.15;
  DamageFactor "GreenFire", 0.1;
  DamageFactor "Bullet", 0.5;
  DamageFactor "Railgun", 1.2;
  DamageFactor "CutLess", 0.25;
  DamageFactor "Explosive", 1.0;
  DamageFactor "Blast", 1.0;
  DamageFactor "SuperKick", 0.6;
  DamageFactor "ExplosiveImpact", 0.5;
  DamageFactor "Shotgun", 0.7;
  DamageFactor "Freeze", 0.6;
  DamageFactor "Nailgun", 0.7;
  DamageFactor "GibRemoving", 0.0;
  DamageFactor "Crucible", 1.0;
  DamageFactor "GloryFire", 0.25;
  DamageFactor "BloodPunch", 0.8;
  PainChance "Disintegrate", 256;
  PainChance "Head", 120;
  PainChance "Saw", 100;
  PainChance "Cut", 100;
  PainChance "Kick", 256;
  PainChance "SSG", 256;
  PainChance "Stun", 256;
  PainChance "Siphon", 256;
  PainChance "ExtremePunches", 256;
  PainChance "Explosive", 256;
  PainChance "MustTeleport", 256;
  DamageFactor "Blood", 0.0;
  DamageFactor "BlueBlood", 0.0;
  DamageFactor "GreenBlood", 0.0;
  +LOOKALLAROUND;
  +NOGRAVITY;
  +FLOAT;
  +NOICEDEATH;
  -COUNTKILL;
  +NOBLOODDECALS;
  BloodType "NullBlood";

  +DONTHARMSPECIES;
  +THRUSPECIES;

  +DONTTHRUST;
  +NOINFIGHTSPECIES;
  +DONTMORPH;
  +DONTFALL;

}
  states
    {
	Spawn:
		TNT1 A 0;
		NULL AAAAAAAAAAAA 2;
		TNT1 A 0 A_ScaleVelocity(0);
		TNT1 A 0 A_SpawnItemEx ("MarksTeleportEffect", 0, 0, 54, 0, 0, 0, SXF_NOCHECKPOSITION);
		TNT1 A 0 A_ScaleVelocity(0);
		V05A A 5 A_Look;
		V05A A 0
			{ if (Master)
			{distance = Distance3D(Master);}
			}
		V05A A 0 A_Jumpif (Master && distance > 400, "FollowMaster");
	Loop;

	Idle:
		TNT1 A 0;
		V05A A 5 A_Look;
	Loop;
		
	Pain.MustTeleport:
		"####" "#" 0;
		"####" "#" 0 {Health = health+1;}
	Goto MoveToMaster;

	See:
		"####" "#" 0;
		"####" "#" 2 Bright A_Wander;
		"####" "#" 0
			{ if (Master)
			{distance = Distance3D(Master);}
			}
		"####" "#" 0 A_Jumpif (Master && distance > 400, "FollowMaster");
	Loop;

	Pain.Disintegrate:
	"####" "#" 2 Bright
		{
		A_FaceTarget();
		A_StartSound("LGLoop", CHAN_5);
		A_SpawnItemEx("ChaosBallVeryBigExplode", 0, random(-20,20), random(15,65));
		}
	Goto See;
/*
	Missile:
		"####" "#" 0;
		"####" "#" 0 A_JumpIf (Master && fMaster > 0, "FollowMaster");
		"####" "#" 0 Light("ShadowBall") { A_SpawnProjectile("ChaosBall",54,0); A_SpawnItem("RedFlare22" ,0, 54); }
	Goto See;
*/
	FollowMaster:
		"####" "#" 0;
		"####" "#" 0 {bFRIENDLY = true;}
		"####" "#" 0 {FMaster = 1;}
	FollowMasterContinue:
		"####" "#" 0;
		"####" "#" 0 A_Jumpif (Master && distance < 250, "Returned");
		"####" "#" 0
			{ if (Master)
			{distance = Distance3D(Master);}
			}
		"####" "#" 0 {if (Master && distance > 600) {numteleports = numteleports + 1;} else {numteleports = 0;}}
		"####" "#" 0 A_Jumpif (Master && distance > 250 && numteleports > 100, "MoveToMaster");
		"####" "#" 0 {if (Master){A_TransferPointer(AAPTR_DEFAULT, AAPTR_TARGET, AAPTR_MASTER, AAPTR_DEFAULT);}}
		"####" "#" 2 Bright A_Chase;
	Loop;

    MoveToMaster:
		"####" "#" 0;
		"####" "#" 0 {bTHRUACTORS = true;}
		"####" "#" 0 A_SpawnItemEx ("MarksTeleportEffect", 0, 0, 54, 0, 0, 0, SXF_NOCHECKPOSITION);
		"####" "#" 0 {if (Master){Warp(master, RandomPick(-15, 15), RandomPick(-15, 15), random(1, 5), WARPF_STOP|WARPF_NOCHECKPOSITION|WARPF_TOFLOOR );}}
		"####" "#" 0 {numteleports = 0;}
		"####" "#" 0 A_SpawnItemEx ("MarksTeleportEffect", 0, 0, 54, 0, 0, 0, SXF_NOCHECKPOSITION);
	Goto Returned;

	Returned:
		"####" "#" 0;
		"####" "#" 0 {bTHRUACTORS = false;}
		"####" "#" 0 {bNOINFIGHTING = true;}
		"####" "#" 0 {bFRIENDLY = false;}
		"####" "#" 0 {FMaster = 0;}
		"####" "#" 0 A_ClearTarget;
		"####" "#" 0 {if (Master){A_TransferPointer(AAPTR_DEFAULT, AAPTR_TARGET, AAPTR_MASTER, AAPTR_TARGET);}}
	Goto See;

	Death:
	XDeath:
		"####" "#" 0;
		"####" "#" 2 Bright;
		TNT1 A 0 A_NoBlocking;
		TNT1 A 0 A_StartSound ("IceBreakSmall");
		TNT1 AAAAAA 0 A_SpawnProjectile ("ObsidianCrystalsBlackDustMed", Random(5,40), Random(5,40), random (0, 360), 2, random (0, 160), SXF_NOCHECKPOSITION);
		TNT1 AAAAAA 0 A_SpawnProjectile ("ObsidianChunk", Random(5,40), Random(5,40), random (0, 360), 2, random (0, 160),SXF_NOCHECKPOSITION);
	Stop;
		}
}


