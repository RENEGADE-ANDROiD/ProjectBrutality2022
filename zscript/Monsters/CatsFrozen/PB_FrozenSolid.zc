// Cat's Frozen Addon fold — 8-angle frozen-solid corpse actors (sprites under SPRITES/Monsters/CatsFrozenFrozen/).
// No BD22-only gore actors in death chains; IceShard1 / CryoSmoke3 / DetectFloorIce / IceBlood / FROSTY helpers only.

class PB_FrozenSolidBase : Actor
{
	Default
	{
		Health 20;
		Mass 999999;
		Friction 0.1;
		PainChance "Ice", 0;
		damagefactor "Ice", 0.0;
		PainChance "Freeze", 0;
		damagefactor "Freeze", 0.0;
		PainChance "Frost", 0;
		damagefactor "Frost", 0.0;
		PainChance "Head", 256;
		DamageFactor "Head", 10.0;
		+SOLID;
		+SHOOTABLE;
		+PUSHABLE;
		+NOBLOOD;
		+NOBLOODDECALS;
		+NOBLOCKMONST;
		-COUNTKILL;
		+NOTARGET;
		+NEVERTARGET;
		+CANTSEEK;
		-FORCEXYBILLBOARD;
	}
}

class PB_FrozenSolidImp : PB_FrozenSolidBase
{
	Default
	{
		Scale 1.04;
		Radius 18;
		Height 48;
	}
	States
	{
	Spawn:
		TNT1 A 0;
		Goto Idle;
	Idle:
		IFZD A 800;
		Goto Thaw;
	Thaw:
		IFZD A 2;
		TNT1 A 0 A_PlaySound("ICEBRK1", 7);
		IFZD A 50;
		IFZD B 2;
		IFZD A 50;
		IFZD B 2;
		IFZD A 50;
		IFZD B 2;
		IFZD A 25;
		IFZD B 2;
		IFZD A 25;
		IFZD B 2;
		IFZD A 10;
		IFZD B 2;
		IFZD A 10;
		IFZD B 2;
		IFZD A 10;
		IFZD B 2;
		IFZD A 2;
		IFZD B 2;
		TNT1 A 0 A_ChangeFlag("SHOOTABLE", 0);
		TNT1 A 0 A_ChangeFlag("SOLID", 0);
		TNT1 A 0 A_StopSound(7);
		TNT1 A 0 A_PlaySound("IceBreakSmall", 3);
		TNT1 AAA 0 A_CustomMissile("IceShard1", random(15, 45), 0, random(0, 360), 2, random(20, 140));
		TNT1 AAA 0 A_CustomMissile("IceShard1", random(15, 45), 0, random(0, 360), 2, random(20, 140));
		TNT1 A 0 A_NoBlocking;
		Stop;
	Death:
	Death.Head:
		TNT1 A 0 A_NoBlocking;
		TNT1 A 0 A_PlaySound("IceBreakSmall", 3);
		TNT1 AAAAA 0 A_CustomMissile("IceShard1", random(15, 45), 0, random(0, 360), 2, random(20, 140));
		TNT1 AAA 0 A_CustomMissile("IceShard1", random(15, 45), 0, random(0, 360), 2, random(20, 140));
		TNT1 AA 0 Bright A_SpawnItemEx("CryoSmoke3", 0, 0, 20, random(10, 30) * 0.04, 0, random(0, 10) * 0.04, random(1, 360), SXF_CLIENTSIDE | SXF_NOCHECKPOSITION, 64);
		TNT1 A 0 A_SpawnItemEx("DetectFloorIce", 0, 0, 1, 0, 0, 0, 0, SXF_NOCHECKPOSITION, 0);
		TNT1 A 0 A_SpawnItemEx("DetectCeilIce", 0, 0, 1, 0, 0, 0, 0, SXF_NOCHECKPOSITION, 0);
		TNT1 A 0 A_CustomMissile("IceBlood", 36, 0, random(0, 360), 2, random(25, 85));
		IFZD C 300;
		IFZD CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC 1 A_FadeOut(0.01);
		Stop;
	}
}

