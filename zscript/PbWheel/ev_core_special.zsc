	void specialWheel_Equipment() {
				wheelSpecials.Clear();
				let pl = PlayerPawn(players[consoleplayer].mo);
				if (pl == null) { return; }

				iconScale = (1.3, 1.3);
				
				PB_SpecialWheel_Mode equip_frag = new ("PB_SpecialWheel_Mode");
				equip_frag.specialIcon = TexMan.CheckForTexture("HFRAGY",TexMan.Type_Any);
				equip_frag.specialName = "WW_FragGrenadeSelected";
				equip_frag.specialAlias = "Frag Grenade";
				equip_frag.specialPriority = 1;
				equip_frag.iconScale = iconScale;
				if (WheelSliceIsUsable(pl, equip_frag.specialName)) { wheelSpecials.Push(equip_frag); }
				
				PB_SpecialWheel_Mode equip_mine = new ("PB_SpecialWheel_Mode");
				equip_mine.specialIcon = TexMan.CheckForTexture("HMINEY",TexMan.Type_Any);
				equip_mine.specialName = "WW_ProximityMineSelected";
				equip_mine.specialAlias = "Prox. Mine";
				equip_mine.specialPriority = 2;
				equip_mine.iconScale = iconScale;
				if (WheelSliceIsUsable(pl, equip_mine.specialName)) { wheelSpecials.Push(equip_mine); }
				
				PB_SpecialWheel_Mode equip_stun = new ("PB_SpecialWheel_Mode");
				equip_stun.specialIcon = TexMan.CheckForTexture("HSTUNY",TexMan.Type_Any);
				equip_stun.specialName = "WW_StunGrenadeSelected";
				equip_stun.specialAlias = "Stun Grenade";
				equip_stun.specialPriority = 3;
				equip_stun.iconScale = iconScale;
				if (WheelSliceIsUsable(pl, equip_stun.specialName)) { wheelSpecials.Push(equip_stun); }
				
		let cvNoMolotov = CVar.GetCVar("pb_NoMolotov", players[consoleplayer]);
				if (cvNoMolotov && cvNoMolotov.GetInt() == 0) {
				PB_SpecialWheel_Mode equip_molotov = new ("PB_SpecialWheel_Mode");
					equip_molotov.specialIcon = TexMan.CheckForTexture("MOLOV0",TexMan.Type_Any);
					equip_molotov.specialName = "WW_MolotovSelected";
					equip_molotov.specialAlias = "Molotov Cocktail";
					equip_molotov.specialPriority = 4;
					equip_molotov.iconScale = iconScale;
					if (WheelSliceIsUsable(pl, equip_molotov.specialName)) { wheelSpecials.Push(equip_molotov); }
				}
				
				PB_SpecialWheel_Mode equip_leech = new ("PB_SpecialWheel_Mode");
				equip_leech.specialIcon = TexMan.CheckForTexture("HLECHY",TexMan.Type_Any);
				equip_leech.specialName = "WW_LeechSelected";
				equip_leech.specialAlias = "Leech";
				equip_leech.specialPriority = 5;
				equip_leech.iconScale = iconScale;
				if (WheelSliceIsUsable(pl, equip_leech.specialName)) { wheelSpecials.Push(equip_leech); }
				
				iconScale = (0.2, 0.2);
				PB_SpecialWheel_Mode flame_belch = new ("PB_SpecialWheel_Mode");
				flame_belch.specialIcon = TexMan.CheckForTexture("graphics/HUD/Flame_Belch.png",TexMan.Type_Any);
				flame_belch.specialName = "GK_FlamebelchSelected";
				flame_belch.specialAlias = "Flame Belch";
				flame_belch.specialPriority = 6;
				flame_belch.iconScale = iconScale;
				if (WheelSliceIsUsable(pl, flame_belch.specialName)) { wheelSpecials.Push(flame_belch); }
				
				PB_SpecialWheel_Mode ice_bomb = new ("PB_SpecialWheel_Mode");
				ice_bomb.specialIcon = TexMan.CheckForTexture("graphics/HUD/Ice_Bomb.png",TexMan.Type_Any);
				ice_bomb.specialName = "GK_IcebombSelected";
				ice_bomb.specialAlias = "Ice Bomb";
				ice_bomb.specialPriority = 7;
				ice_bomb.iconScale = iconScale;
				if (WheelSliceIsUsable(pl, ice_bomb.specialName)) { wheelSpecials.Push(ice_bomb); }
				
			iconScale = (1.3, 1.3);
			if(pl.FindInventory("HasRevGun")) {
					PB_SpecialWheel_Mode equip_revgun = new ("PB_SpecialWheel_Mode");
					equip_revgun.specialIcon = TexMan.CheckForTexture("HREVCY",TexMan.Type_Any);
					equip_revgun.specialName = "WW_RevGunSelected";
					equip_revgun.specialAlias = "Quick Launcher";
					equip_revgun.specialPriority = 8;
					equip_revgun.iconScale = iconScale;
					if (WheelSliceIsUsable(pl, equip_revgun.specialName)) { wheelSpecials.Push(equip_revgun); }
				}
				
				if (wheelSpecials.Size() < 1)
				{
					pl.A_Print("\cgNo \ctequipment \c-to select");
					return;
				}

				specialWheel_handleMouse();
	}

	Override Void NetworkProcess(ConsoleEvent e)
	{
		if (!e) return;
		if (!playeringame[consoleplayer]) return;
		let pmo = players[consoleplayer].mo;
		if (!pmo) return;
		if (players[consoleplayer].ReadyWeapon == NULL) 
         {
             return;
         }
			if(e.name == 'PBEquipSpecialOn')
		{

			if (pmo.FindInventory("CantWeaponSpecial"))
			{
				wheelShow.Clear();
				wheelIsOpen = false;
				noWheel = true;
				return;
			}
			else
				noWheel = false;
		
            if (wheelIsOpen) { return; }
			

			if (pmo.FindInventory("Melee_Attacks")){
				specialWheel_Equipment();
				return;
			}
			

			else { return; }
		}
		
		else if(!noWheel && e.name == 'PBEquipSpecialOff' || players[consoleplayer].ReadyWeapon.GetClassName() != selectedWeapon)
		{
			if(!(players[consoleplayer].ReadyWeapon.GetClassName() != selectedWeapon))
			{
				if(wheelShow.Size()>0)
				{
					int curSelMod = wheelShow[currentSelection];
					pmo.A_GiveInventory(wheelSpecials[curSelMod].specialName);
					pmo.A_GiveInventory("ToggleEquipment");
					S_StartSound("menu/choose",5);
				}
			}
			pmo.A_TakeInventory("PlayerWheelOpen");
			wheelSort = false;
			wheelIsOpen = false;
		}
	
	if(e.name == 'PBWeaponSpecialOn')
		{
			if (pmo.FindInventory("CantWeaponSpecial"))

			{
				wheelShow.Clear();
				wheelIsOpen = false;
				noWheel = true;
				return;
			}
			else
				noWheel = false;
		
            if (wheelIsOpen) { return; }
			
			//Check if equipped valid wheel-based weapon
			
			 
			switch(players[consoleplayer].ReadyWeapon.GetClassName()) {
					
				case 'PB_Carbine':
					specialWheel_Carbine();
					return;
				
				case 'PB_SuperGL':
					specialWheel_SGL();
					return;

				case 'PB_Excavator':
					specialWheel_Excavator();
					return;
					
				case 'PB_QuadSG':
				specialWheel_QSG();
				return;

				case 'Rifle':
					if (pmo.FindInventory("DMRUpgraded")) {
						specialWheel_Rifle();
						return;
					}
					else {
						pmo.A_GiveInventory("GoWeaponSpecialAbility");
						selectedWeapon = players[consoleplayer].ReadyWeapon.GetClassName();
						wheelShow.Clear();
						wheelIsOpen = false;
						noWheel = true;
						return;
					}
				
				case 'PB_SMG':
					specialWheel_SMG();
					return;
					
				case 'PB_Pistol':
					specialWheel_Pistol();
					return;
					
				case 'PB_Shotgun':
					if (pmo.FindInventory("Zoomed")) {
						pmo.A_GiveInventory("GoWeaponSpecialAbility");
						selectedWeapon = players[consoleplayer].ReadyWeapon.GetClassName();
						wheelShow.Clear();
						wheelIsOpen = false;
						noWheel = true;
						return;
					}
					else {
						specialWheel_Shotgun();
						return;
					}
				case 'PB_CSSG':
					specialWheel_CSSG();
					return;

				case 'HASG':
					specialWheel_HASG();
					return;
				
				case 'PB_Minigun':
					specialWheel_Minigun();
					return;

				case 'DemonTechMinigun':
					specialWheel_DTechMinigun();
					return;

				case 'HellPistoler':
					specialWheel_HellPistoler();
					return;

				case 'PB_NeoHMG':
					specialWheel_NeoHMG();
					return;
					
				case 'PB_RocketLauncher':
					specialWheel_RocketLauncher();
					return;

				case 'LeverAction':
					specialWheel_LeverAction();
					return;

				case 'PB_M1Plasma':
					specialWheel_M1Plasma();
					return;

				case 'PB_PulseCannon':
					specialWheel_PulseCannon();
					return;

				case 'PB_M41A':
					specialWheel_M41A();
					return;

				case 'PB_XM21':
					if (pmo.FindInventory("XM21RifleUpgrade"))
					{
						specialWheel_XM21();
					}
					else
					{
						pmo.A_GiveInventory("GoWeaponSpecialAbility");
						selectedWeapon = players[consoleplayer].ReadyWeapon.GetClassName();
						wheelShow.Clear();
						wheelIsOpen = false;
						noWheel = true;
					}
					return;
					
				default:
					pmo.A_GiveInventory("GoWeaponSpecialAbility");
					selectedWeapon = players[consoleplayer].ReadyWeapon.GetClassName();
					wheelShow.Clear();
					wheelIsOpen = false;
					noWheel = true;
					return;
			}

		}
		
		else if(!noWheel && e.name == 'PBWeaponSpecialOff' || players[consoleplayer].ReadyWeapon.GetClassName() != selectedWeapon)
		{
			
			if(!(players[consoleplayer].ReadyWeapon.GetClassName() != selectedWeapon))
			{
				if(wheelShow.Size()>0)
				{
					int curSelMod = wheelShow[currentSelection];
					pmo.A_GiveInventory(wheelSpecials[curSelMod].specialName);
					pmo.A_GiveInventory("GoWeaponSpecialAbility");
					S_StartSound("menu/choose",5);
				}
			}
			pmo.A_TakeInventory("PlayerWheelOpen");
			wheelSort = false;
			wheelIsOpen = false;
		}

	}

}
