	// Same resource rules as BaseWeapon "WheelCancelEquipment" / throw states â€” hide wheel slices you cannot use.
	bool WheelSliceIsUsable(PlayerPawn pl, String specialName)
	{
		if (pl == null) { return true; }
		if (specialName == "WW_FragGrenadeSelected") { return pl.CountInv("HandGrenadeAmmo") > 0; }
		if (specialName == "WW_ProximityMineSelected") { return pl.CountInv("MineAmmo") > 0; }
		if (specialName == "WW_StunGrenadeSelected") { return pl.CountInv("StunGrenadeAmmo") > 0; }
		if (specialName == "WW_MolotovSelected") { return pl.CountInv("HandMolotovAmmo") > 0; }
		if (specialName == "WW_LeechSelected") { return pl.CountInv("HasLeech") > 0; }
		if (specialName == "WW_RevGunSelected") { return pl.CountInv("MiniHellRocketAmmo") > 0; }
		if (specialName == "GK_FlamebelchSelected" || specialName == "GK_IcebombSelected")
		{
			if (!playeringame[consoleplayer]) { return false; }
			let cv = CVar.GetCVar("be_ExecutionsON", players[consoleplayer]);
			return cv ? cv.GetBool() : false;
		}
		return true;
	}

