	Override Void NetworkProcess(ConsoleEvent e)
	{
		if (!e) return;
		if (!playeringame[consoleplayer]) return;

		if (e.name == 'PBWeaponWheelOff')
		{
			let pmo = players[consoleplayer].mo;
			if (pmo && weaponPickWheel && !noWheel && wheelIsOpen && wheelShow.Size() > 0
				&& players[consoleplayer].ReadyWeapon
				&& players[consoleplayer].ReadyWeapon.GetClassName() == selectedWeapon)
			{
				int oi = wpick_OuterSel;
				if (oi >= 0 && oi < wpick_SlotNums.Size())
				{
					int st = wpick_SlotStart[oi];
					int cnt = wpick_SlotCount[oi];
					int ii = wpick_InnerSel;
					if (ii < 0) ii = 0;
					if (ii >= cnt) ii = cnt - 1;
					String cn = wpick_WeaponFlat[st + ii];
					Class<Weapon> wcls = cn;
					if (wcls)
					{
						let wi = Weapon(pmo.FindInventory(wcls));
						if (wi)
							players[consoleplayer].PendingWeapon = wi;
					}
				}
				S_StartSound("menu/choose", 5);
			}
			weaponPickWheel = false;
			if (pmo)
				pmo.A_TakeInventory("PlayerWheelOpen");
			wheelSort = false;
			wheelIsOpen = false;
			return;
		}

		let pmo = players[consoleplayer].mo;
		if (!pmo) return;
		if (e.name == 'PBWeaponWheelOn' && !players[consoleplayer].ReadyWeapon)
			weaponPickWheel_HealReadyWeaponIfNeeded(PlayerPawn(pmo));
		if (players[consoleplayer].ReadyWeapon == NULL) 
         {
             return;
         }

		if (e.name == 'PBWeaponWheelOn')
		{
			if (pmo.FindInventory("CantWeaponSpecial"))
			{
				wheelShow.Clear();
				wheelIsOpen = false;
				weaponPickWheel = false;
				noWheel = true;
				return;
			}
			noWheel = false;
			if (wheelIsOpen)
				return;
			specialWheel_WeaponPick(pmo);
			return;
		}

			if(e.name == 'PBEquipSpecialOn')
		{

			if (pmo.FindInventory("CantWeaponSpecial"))
			{
				wheelShow.Clear();
				wheelIsOpen = false;
				weaponPickWheel = false;
				noWheel = true;
				return;
			}
			else
				noWheel = false;
		
            if (wheelIsOpen) { return; }
			weaponPickWheel = false;
			

			if (pmo.FindInventory("Melee_Attacks")){
				specialWheel_Equipment();
				return;
			}
			

			else { return; }
		}
		
		else if(!noWheel && e.name == 'PBEquipSpecialOff' || players[consoleplayer].ReadyWeapon.GetClassName() != selectedWeapon)
		{
			if (weaponPickWheel && e.name == 'PBEquipSpecialOff')
				return;
			if(!(players[consoleplayer].ReadyWeapon.GetClassName() != selectedWeapon))
			{
				if(wheelShow.Size()>0)
				{
					int curSelMod = wheelShow[currentSelection];
					pmo.A_GiveInventory(wheelSpecials[curSelMod].specialName);
					pmo.A_GiveInventory("ToggleEquipment");
					S_StartSound("menu/choose",5);
				}
			}
			pmo.A_TakeInventory("PlayerWheelOpen");
			wheelSort = false;
			wheelIsOpen = false;
		}
	
	if(e.name == 'PBWeaponSpecialOn')
		{
			if (pmo.FindInventory("CantWeaponSpecial"))

			{
				wheelShow.Clear();
				wheelIsOpen = false;
				weaponPickWheel = false;
				noWheel = true;
				return;
			}
			else
				noWheel = false;
		
            if (wheelIsOpen) { return; }
			weaponPickWheel = false;
			
			switch(players[consoleplayer].ReadyWeapon.GetClassName()) {
					
				case 'PB_Carbine':
					specialWheel_Carbine();
					return;
				
				case 'PB_SuperGL':
					specialWheel_SGL();
					return;

				case 'PB_Excavator':
					specialWheel_Excavator();
					return;
					
				case 'PB_QuadSG':
				specialWheel_QSG();
				return;

				case 'Rifle':
					if (pmo.FindInventory("DMRUpgraded")) {
						specialWheel_Rifle();
						return;
					}
					else {
						pmo.A_GiveInventory("GoWeaponSpecialAbility");
						selectedWeapon = players[consoleplayer].ReadyWeapon.GetClassName();
						wheelShow.Clear();
						wheelIsOpen = false;
						noWheel = true;
						return;
					}
				
				case 'PB_SMG':
					specialWheel_SMG();
					return;
					
				case 'PB_Pistol':
					specialWheel_Pistol();
					return;

				case 'PB_Axe':
					specialWheel_Axe();
					return;
					
				case 'PB_Shotgun':
					if (pmo.FindInventory("Zoomed")) {
						pmo.A_GiveInventory("GoWeaponSpecialAbility");
						selectedWeapon = players[consoleplayer].ReadyWeapon.GetClassName();
						wheelShow.Clear();
						wheelIsOpen = false;
						noWheel = true;
						return;
					}
					else {
						specialWheel_Shotgun();
						return;
					}
				case 'PB_CSSG':
					specialWheel_CSSG();
					return;

				case 'HASG':
					specialWheel_HASG();
					return;
				
				case 'PB_Minigun':
					specialWheel_Minigun();
					return;

				case 'PB_MetalSniper':
					specialWheel_MetalSniper();
					return;

				case 'HellPistoler':
					specialWheel_HellPistoler();
					return;

				case 'ProSurv_Ballista':
					specialWheel_ProSurv_Ballista();
					return;

				case 'PB_CryoElectroRifle':
					specialWheel_PB_CryoElectroRifle();
					return;

				case 'PB_DarkMatterRifle':
					specialWheel_PB_DarkMatterRifle();
					return;

				case 'PB_NeoHMG':
					specialWheel_NeoHMG();
					return;
					
				case 'PB_RocketLauncher':
					specialWheel_RocketLauncher();
					return;

				case 'LeverAction':
					specialWheel_LeverAction();
					return;

				case 'PB_M1Plasma':
					specialWheel_M1Plasma();
					return;

				case 'PB_M41A':
					specialWheel_M41A();
					return;

				case 'PB_XM21':
					if (pmo.FindInventory("XM21RifleUpgrade"))
					{
						specialWheel_XM21();
					}
					else
					{
						pmo.A_GiveInventory("GoWeaponSpecialAbility");
						selectedWeapon = players[consoleplayer].ReadyWeapon.GetClassName();
						wheelShow.Clear();
						wheelIsOpen = false;
						noWheel = true;
					}
					return;
					
				default:
					pmo.A_GiveInventory("GoWeaponSpecialAbility");
					selectedWeapon = players[consoleplayer].ReadyWeapon.GetClassName();
					wheelShow.Clear();
					wheelIsOpen = false;
					noWheel = true;
					return;
			}

		}
		
		else if(!noWheel && e.name == 'PBWeaponSpecialOff' || players[consoleplayer].ReadyWeapon.GetClassName() != selectedWeapon)
		{
			if (weaponPickWheel && e.name == 'PBWeaponSpecialOff')
				return;
			
			if(!(players[consoleplayer].ReadyWeapon.GetClassName() != selectedWeapon))
			{
				if(wheelShow.Size()>0)
				{
					int curSelMod = wheelShow[currentSelection];
					pmo.A_GiveInventory(wheelSpecials[curSelMod].specialName);
					pmo.A_GiveInventory("GoWeaponSpecialAbility");
					S_StartSound("menu/choose",5);
				}
			}
			pmo.A_TakeInventory("PlayerWheelOpen");
			wheelSort = false;
			wheelIsOpen = false;
		}

	}

}
