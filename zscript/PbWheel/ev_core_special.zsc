	// Same ammo/charge gates as BaseWeapon wheel cancel / throw — omit unusable WW_* slices.
	bool WheelSliceIsUsable(PlayerPawn pl, String specialName)
	{
		if (pl == null) { return true; }
		if (specialName == "WW_FragGrenadeSelected") { return pl.CountInv("HandGrenadeAmmo") > 0; }
		if (specialName == "WW_ProximityMineSelected") { return pl.CountInv("MineAmmo") > 0; }
		if (specialName == "WW_StunGrenadeSelected") { return pl.CountInv("StunGrenadeAmmo") > 0; }
		if (specialName == "WW_ShieldGrenadeSelected") { return pl.CountInv("ShieldGrenadeAmmo") > 0; }
		if (specialName == "WW_VoidGrenadeSelected") { return pl.CountInv("VoidGrenadeAmmo") > 0; }
		if (specialName == "WW_MolotovSelected") { return pl.CountInv("HandMolotovAmmo") > 0; }
		if (specialName == "WW_LeechSelected")
			return pl.CountInv("HasLeech") > 0 || pl.CountInv("PB_DTech") >= 4;
		if (specialName == "WW_RevGunSelected") { return pl.CountInv("MiniHellRocketAmmo") > 0; }
		if (specialName == "WW_HookSelected")
			return pl.CountInv("PB_HookToken") > 0 || pl.CountInv("HookAmmo") > 0
				|| pl.CountInv("AlreadyHaveMeatHook") > 0;
		if (specialName == "WW_FreezenadeSelected") return pl.CountInv("FreezenadeAmmo") > 0;
		if (specialName == "WW_PB_CF_SnowCasterSelected") return pl.CountInv("PB_CF_SnowCasterAmmo") > 0;
		if (specialName == "WW_PB_CF_FreezeBotSelected") return pl.CountInv("PB_CF_FreezeBotDeployAmmo") > 0;
		if (specialName == "WW_PB_CF_IceWallSelected") return pl.CountInv("PB_CF_IceWallGenAmmo") > 0;
		if (specialName == "WW_PB_CF_HoloDecoySelected") return pl.CountInv("PB_CF_HoloDecoyAmmo") > 0;
		if (specialName == "WW_PB_CF_TeslaTurretSelected") return pl.CountInv("PB_CF_TeslaTurretAmmo") > 0;
		if (specialName == "WW_PB_CF_FlameTurretSelected") return pl.CountInv("PB_CF_FlameTurretAmmo") > 0;
		if (specialName == "WW_PB_CF_FreezeMineSelected") return pl.CountInv("PB_CF_FreezeMineAmmo") > 0;
		if (specialName == "Select_LeverAction_HellMode") return pl.CountInv("LeverActionHellTier") >= 1;
		return true;
	}

	void specialWheel_LeverAction()
	{
		wheelSpecials.Clear();
