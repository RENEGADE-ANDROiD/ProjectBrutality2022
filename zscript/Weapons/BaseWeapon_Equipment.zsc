extend class PB_WeaponBase
{
	States
	{
		//NEW EQUIPMENT SYSTEM
		UseEquipment:
			TNT1 A 0 {
				A_ClearOverlays(3,65);
				A_GunFlash("Null"); //Fixes the Minigun heat overlay oversight
				A_TakeInventory("Zoomed", 1);
				A_TakeInventory("RailgunInfrared", 1);
				A_Zoomfactor(1.0);
				A_GiveInventory("KeepLaserDeactivated",1);
				if (CountInv("DualWieldingM41A") >= 1 && invoker is "PB_M41A")
				{
					A_Overlay(10, "IdleLeft_Overlay", false);
					A_Overlay(11, "IdleRight_Overlay", false);
				}
			}
			TNT1 A 0 A_TakeInventory("UseEquipment", 1);
			TNT1 A 0 A_GiveInventory("KeepLaserDeactivated",1);
			TNT1 A 0 A_JumpIfInventory("MolotovSelected", 1, "ThrowMolotov");
			TNT1 A 0 A_JumpIfInventory("FreezenadeSelected", 1, "ThrowFreezenade");
			TNT1 A 0 A_JumpIfInventory("FragGrenadeSelected", 1, "ThrowGrenade");
			TNT1 A 0 A_JumpIfInventory("ProximityMineSelected", 1, "ThrowMine");
			TNT1 A 0 A_JumpIfInventory("StunGrenadeSelected", 1, "ThrowStun");
			TNT1 A 0 A_JumpIfInventory("ShieldGrenadeSelected", 1, "ThrowShield");
			TNT1 A 0 A_JumpIfInventory("VoidGrenadeSelected", 1, "ThrowVoid");
			TNT1 A 0 A_JumpIfInventory("LeechSelected", 1, "ThrowLeech");
			TNT1 A 0 A_JumpIfInventory("RevGunSelected", 1, "FireRevGun");
			TNT1 A 0 A_JumpIfInventory("HookSelected", 1, "UseHookEquipment");
			TNT1 A 0 A_JumpIfInventory("PB_CF_SnowCasterSelected", 1, "UseSnowCasterEquipment");
			TNT1 A 0 A_JumpIfInventory("PB_CF_FreezeBotSelected", 1, "DeployPB_CFFreezeBot");
			TNT1 A 0 A_JumpIfInventory("PB_CF_IceWallSelected", 1, "DeployPB_CFIceWall");
			TNT1 A 0 A_JumpIfInventory("PB_CF_HoloDecoySelected", 1, "DeployPB_CFHoloDecoy");
			TNT1 A 0 A_JumpIfInventory("PB_CF_TeslaTurretSelected", 1, "DeployPB_CFTeslaTurret");
			TNT1 A 0 A_JumpIfInventory("PB_CF_FlameTurretSelected", 1, "DeployPB_CFFlameTurret");
			TNT1 A 0 A_JumpIfInventory("PB_CF_FreezeMineSelected", 1, "DeployPB_CFFreezeMine");
			//More stuff to come.....
			
			
			Goto GoingToReady;
		
		UseHookEquipment:
			TNT1 A 0 A_JumpIfInventory("PB_HookToken", 1, "UseHookEquipmentFire");
			TNT1 A 0 A_JumpIfInventory("HookAmmo", 1, "UseHookEquipmentFire");
			TNT1 A 0 A_JumpIfInventory("AlreadyHaveMeatHook", 1, "UseHookEquipmentFire");
			TNT1 A 0 A_Print("\cgPick up the \ctMeat Hook\c- first.");
			TNT1 A 0 A_TakeInventory("UseEquipment", 1);
			Goto GoingToReady;
		UseHookEquipmentFire:
			TNT1 A 0 A_GiveInventory("PB_FireGrapplePulse", 1);
			TNT1 A 0 A_TakeInventory("UseEquipment", 1);
			Goto GoingToReady;
		
		WheelCancelEquipment:
			TNT1 A 0 {
				A_SetInventory("WW_ProximityMineSelected",0);
				A_SetInventory("WW_StunGrenadeSelected",0);
				A_SetInventory("WW_ShieldGrenadeSelected",0);
				A_SetInventory("WW_VoidGrenadeSelected",0);
				A_SetInventory("WW_LeechSelected",0);
				A_SetInventory("WW_FragGrenadeSelected",0);
				A_SetInventory("WW_RevGunSelected",0);
				A_SetInventory("WW_MolotovSelected",0);
				A_SetInventory("WW_HookSelected",0);
				A_SetInventory("WW_FreezenadeSelected",0);
				A_SetInventory("WW_PB_CF_SnowCasterSelected",0);
				A_SetInventory("WW_PB_CF_FreezeBotSelected",0);
				A_SetInventory("WW_PB_CF_IceWallSelected",0);
				A_SetInventory("WW_PB_CF_HoloDecoySelected",0);
				A_SetInventory("WW_PB_CF_TeslaTurretSelected",0);
				A_SetInventory("WW_PB_CF_FlameTurretSelected",0);
				A_SetInventory("WW_PB_CF_FreezeMineSelected",0);
				A_SetInventory("GK_FlamebelchSelected",0);
				A_SetInventory("GK_IcebombSelected",0);
				A_SetInventory("CantWeaponSpecial",0);
			}
			Goto Equipment_Toggle_Handler_Overlay;
		
		SwitchEquipment:	
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		TNT1 A 0 {
			if(CountInv("WW_ProximityMineSelected") && CountInv("ProximityMineSelected") >=1)
				{A_Print("\coAlready using: \ctProximity Mine"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_StunGrenadeSelected") && CountInv("StunGrenadeSelected") >=1)
				{A_Print("\coAlready using: \ctStun Grenade"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_ShieldGrenadeSelected") && CountInv("ShieldGrenadeSelected") >=1)
				{A_Print("\coAlready using: \ctShield Grenade"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_VoidGrenadeSelected") && CountInv("VoidGrenadeSelected") >=1)
				{A_Print("\coAlready using: \ctVoid Grenade"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_LeechSelected") && CountInv("LeechSelected") >=1)
				{A_Print("\coAlready using: \ctLeech"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_FragGrenadeSelected") && CountInv("FragGrenadeSelected") >=1)
				{A_Print("\coAlready using: \ctFrag Grenade"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_RevGunSelected") && CountInv("RevGunSelected") >=1)
				{A_Print("\coAlready using: \ctRevenant Launcher"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_MolotovSelected") && CountInv("MolotovSelected") >=1)
				{A_Print("\coAlready using: \ctMolotov cocktail"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_HookSelected") && CountInv("HookSelected") >=1)
				{A_Print("\coAlready using: \ctMeat Hook"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_FreezenadeSelected") && CountInv("FreezenadeSelected") >=1)
				{A_Print("\coAlready using: \ctFreezenade"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_PB_CF_SnowCasterSelected") && CountInv("PB_CF_SnowCasterSelected") >=1)
				{A_Print("\coAlready using: \ctSnow Caster"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_PB_CF_FreezeBotSelected") && CountInv("PB_CF_FreezeBotSelected") >=1)
				{A_Print("\coAlready using: \ctFreezebot"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_PB_CF_IceWallSelected") && CountInv("PB_CF_IceWallSelected") >=1)
				{A_Print("\coAlready using: \ctIce Wall"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_PB_CF_HoloDecoySelected") && CountInv("PB_CF_HoloDecoySelected") >=1)
				{A_Print("\coAlready using: \ctHolo Decoy"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_PB_CF_TeslaTurretSelected") && CountInv("PB_CF_TeslaTurretSelected") >=1)
				{A_Print("\coAlready using: \ctTesla Turret"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_PB_CF_FlameTurretSelected") && CountInv("PB_CF_FlameTurretSelected") >=1)
				{A_Print("\coAlready using: \ctFlame Turret"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_PB_CF_FreezeMineSelected") && CountInv("PB_CF_FreezeMineSelected") >=1)
				{A_Print("\coAlready using: \ctFreeze Mine"); return ResolveState("WheelCancelEquipment");}
			if(CountInv("WW_ProximityMineSelected") >=1)
				{
				if(CountInv("MineAmmo") <=0)
					{A_Print("\cgNo \ctproximity mines \c-remaining"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_StunGrenadeSelected") >=1)
				{
				if(CountInv("StunGrenadeAmmo") <=0)
					{A_Print("\cgNo \ctstun grenades \c-remaining"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_ShieldGrenadeSelected") >=1)
				{
				if(CountInv("ShieldGrenadeAmmo") <=0)
					{A_Print("\cgNo \ctshield grenades \c-remaining"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_VoidGrenadeSelected") >=1)
				{
				if(CountInv("VoidGrenadeAmmo") <=0)
					{A_Print("\cgNo \ctvoid grenades \c-remaining"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_LeechSelected") >=1)
				{
				if(CountInv("HasLeech") <=0 && CountInv("PB_DTech") < 4)
					{A_Print("\cgNo \ctleeches \c-remaining"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_RevGunSelected") >=1)
				{
				if(CountInv("MiniHellRocketAmmo") <=0)
					{A_Print("\cgRevenant launcher out of \ctrockets"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_FragGrenadeSelected") >=1)
				{
				if(CountInv("HandGrenadeAmmo") <=0)
					{A_Print("\cgNo \ctfrag grenades \c-remaining"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_MolotovSelected") >=1)
				{
				if(CountInv("HandMolotovAmmo") <=0)
					{A_Print("\cgNo \ctmolotov cocktails \c-remaining"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_HookSelected") >=1)
				{
				if(CountInv("PB_HookToken") <=0 && CountInv("HookAmmo") <=0 && CountInv("AlreadyHaveMeatHook") <=0)
					{A_Print("\cgYou don't have the \ctMeat Hook\c-"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_FreezenadeSelected") >=1)
				{
				if(CountInv("FreezenadeAmmo") <=0)
					{A_Print("\cgNo \ctfreezenades \c-remaining"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_PB_CF_SnowCasterSelected") >=1)
				{
				if(CountInv("PB_CF_SnowCasterAmmo") <=0)
					{A_Print("\cgSnow Caster \c-out of charge"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_PB_CF_FreezeBotSelected") >=1)
				{
				if(CountInv("PB_CF_FreezeBotDeployAmmo") <=0)
					{A_Print("\cgNo \ctFreezebot \c-deploy kits left"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_PB_CF_IceWallSelected") >=1)
				{
				if(CountInv("PB_CF_IceWallGenAmmo") <=0)
					{A_Print("\cgNo \ctIce Wall \c-generators left"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_PB_CF_HoloDecoySelected") >=1)
				{
				if(CountInv("PB_CF_HoloDecoyAmmo") <=0)
					{A_Print("\cgNo \ctHolo Decoys \c-left"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_PB_CF_TeslaTurretSelected") >=1)
				{
				if(CountInv("PB_CF_TeslaTurretAmmo") <=0)
					{A_Print("\cgNo \ctTesla Turret \c-kits left"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_PB_CF_FlameTurretSelected") >=1)
				{
				if(CountInv("PB_CF_FlameTurretAmmo") <=0)
					{A_Print("\cgNo \ctFlame Turret \c-kits left"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("WW_PB_CF_FreezeMineSelected") >=1)
				{
				if(CountInv("PB_CF_FreezeMineAmmo") <=0)
					{A_Print("\cgNo \ctFreeze Mines \c-left"); return ResolveState("WheelCancelEquipment");}
				}
			if(CountInv("GK_FlamebelchSelected") >=1)
				{ 
					A_Print("\cdEquipment: \ctFlame Belch"); 
					A_SetInventory("FlameBelchSelected",1);
					A_SetInventory("IceBombSelected",0);
					A_SetInventory("MolotovSelected",0);
					A_SetInventory("HookSelected",0);
					A_SetInventory("FreezenadeSelected",0);
					A_SetInventory("PB_CF_SnowCasterSelected",0);
					A_SetInventory("PB_CF_FreezeBotSelected",0);
					A_SetInventory("PB_CF_IceWallSelected",0);
					A_SetInventory("PB_CF_HoloDecoySelected",0);
					A_SetInventory("PB_CF_TeslaTurretSelected",0);
					A_SetInventory("PB_CF_FlameTurretSelected",0);
					A_SetInventory("PB_CF_FreezeMineSelected",0);
					A_PlaySound("FLMDRAW", CHAN_UI);
					return ResolveState("WheelCancelEquipment");
				}
			if(CountInv("GK_IcebombSelected") >=1)
				{ 
					A_Print("\cdEquipment: \ctIce Bomb"); 
					A_SetInventory("FlameBelchSelected",0);
					A_SetInventory("IceBombSelected",1);
					A_SetInventory("MolotovSelected",0);
					A_SetInventory("HookSelected",0);
					A_SetInventory("FreezenadeSelected",0);
					A_SetInventory("PB_CF_SnowCasterSelected",0);
					A_SetInventory("PB_CF_FreezeBotSelected",0);
					A_SetInventory("PB_CF_IceWallSelected",0);
					A_SetInventory("PB_CF_HoloDecoySelected",0);
					A_SetInventory("PB_CF_TeslaTurretSelected",0);
					A_SetInventory("PB_CF_FlameTurretSelected",0);
					A_SetInventory("PB_CF_FreezeMineSelected",0);
					A_PlaySound("weapons/freezer/reload1", CHAN_UI);
					return ResolveState("WheelCancelEquipment");
				}
			return ResolveState(null);
			}
		TNT1 A 0 {
				if(CountInv("WW_ProximityMineSelected") >=1)
					{ 
						A_Print("\cdEquipment: \ctProximity Mine"); 
