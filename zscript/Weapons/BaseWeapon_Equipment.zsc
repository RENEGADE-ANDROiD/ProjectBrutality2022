		Goto Equipment_Toggle_Handler_Overlay;

	LeechBeam:
		SYNP WXYZWXYZWXYZ 1 BRIGHT;
		SYNP WXYZWXYZWXYZ 1 BRIGHT;
		SYNP WXYZWXYZWXYZ 1 BRIGHT;
		SYNP WXYZWXYZWXYZ 1 BRIGHT;
		Stop;

	ThrowLeech:
		TNT1 A 0 A_ZoomFactor(1.0);
		TNT1 A 0 A_TakeInventory("ADSMode", 1);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_JumpIfInventory("PB_DTech", 4, 2);
		TNT1 A 0 A_Print("\coNot enough \ctdemon tech \c-");
		Goto GoingToReady;
		TNT1 A 0 A_PlaySound("SiphonGrowl");
		SYNP GHIJGHIHIJGJIHG 2;
		SYNP G 1 Offset(-2,40);
		SYNP H 1 Offset(-4,50);
		SYNP I 1 Offset(-6,60);
		SYNP J 1 Offset(-8,70);
		TNT1 A 0 Offset(0,32);
		SYNP KLMNO 1;

		TNT1 A 0 A_Overlay(-5, "LeechBeam");
		TNT1 A 0 A_PlaySound("SiphonActive", 3, 1.0, true);

	LeechHold:
		SYNP ABCDEF 2 {
			A_FireBullets(0, 0, -1, 3, "SiphonPuff", FBF_NORANDOM);
			A_TakeInventory("PB_DTech", 4);
		}
		TNT1 A 0 A_JumpIfInventory("PB_DTech", 4, "LeechCheckHold");
		Goto LeechRelease;

	LeechCheckHold:
		TNT1 A 0 A_JumpIf(PressingUser1(), "LeechHold");
		Goto LeechRelease;

	LeechRelease:
		TNT1 A 0 A_StopSound(3);
		TNT1 A 0 A_PlaySound("SiphonGrowl", 3);
		SYNP ONMLK 1;
		TNT1 A 0 A_WeaponOffset(0,32);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		Goto GoingToReady2;
		
			
	ThrowStun:
		TNT1 A 0 A_ZoomFactor(1.0);
		TNT1 A 0 A_TakeInventory("ADSMode", 1);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_JumpIfInventory("StunGrenadeAmmo", 1, 2);
		TNT1 A 0 A_Print("\cgNo \ctstun grenades \c-left");
		Goto GoingToReady;
		STND BCDEF 1;
		STND F 1 Offset(-2,34);
		TNT1 A 0 A_PlaySound("StunGrenadeArm", 2);
		STND GHGHGHGHGHGH 1;
		
		HND1 I 1 A_PlaySound("THRGRN", 1);
		TNT1 A 0 A_TakeInventory("StunGrenadeAmmo", 1);
		HND1 J 1 A_FireCustomMissile("ThrownStunGrenade",0,0,0,0,0,0);
		HND1 KLMNOPQ 1;
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		Goto GoingToReady2;
		
	ThrowShield:
		TNT1 A 0 A_ZoomFactor(1.0);
		TNT1 A 0 A_TakeInventory("ADSMode", 1);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_JumpIfInventory("ShieldGrenadeAmmo", 1, 2);
		TNT1 A 0 A_Print("\cgNo \ctshield grenades \c-left");
		Goto GoingToReady;
		SGGR A 1;
		SGGR A 1 Offset(-2,34);
		TNT1 A 0 A_PlaySound("StunGrenadeArm", 2);
		SGGR AAAAAAAAAAAA 1;
		
		HND1 I 1 A_PlaySound("THRGRN", 1);
		TNT1 A 0 A_TakeInventory("ShieldGrenadeAmmo", 1);
		HND1 J 1 A_FireCustomMissile("ThrownShieldGrenade",0,0,0,0,0,0);
		HND1 KLMNOPQ 1;
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		Goto GoingToReady2;

	ThrowVoid:
		TNT1 A 0 A_ZoomFactor(1.0);
		TNT1 A 0 A_TakeInventory("ADSMode", 1);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_JumpIfInventory("VoidGrenadeAmmo", 1, 2);
		TNT1 A 0 A_Print("\cgNo \ctvoid grenades \c-left");
		Goto GoingToReady;
		VGR1 A 1;
		VGR1 A 1 Offset(-2,34);
		TNT1 A 0 A_PlaySound("StunGrenadeArm", 2);
		VGR1 AAAAAAAAAAAA 1;

		HND1 I 1 A_PlaySound("THRGRN", 1);
		TNT1 A 0 A_TakeInventory("VoidGrenadeAmmo", 1);
		HND1 J 1 A_FireCustomMissile("ThrownVoidGrenade",0,0,0,0,0,0);
		HND1 KLMNOPQ 1;
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		Goto GoingToReady2;
		
	ThrowFreezenade:
		TNT1 A 0 A_ZoomFactor(1.0);
		TNT1 A 0 A_TakeInventory("ADSMode", 1);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_JumpIfInventory("FreezenadeAmmo", 1, 2);
		TNT1 A 0 A_Print("\cgNo \ctfreezenades \c-left");
		Goto GoingToReady;
		HND1 I 1 A_PlaySound("THRGRN", 1);
		TNT1 A 0 A_TakeInventory("FreezenadeAmmo", 1);
		HND1 J 1 A_FireCustomMissile("Freezenade",0,0,0,0,0,0);
		HND1 KLMNOPQ 1;
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		Goto GoingToReady2;
		
	UseSnowCasterEquipment:
		TNT1 A 0 A_ZoomFactor(1.0);
		TNT1 A 0 A_TakeInventory("ADSMode", 1);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_JumpIfInventory("PB_CF_SnowCasterAmmo", 1, 2);
		TNT1 A 0 A_Print("\cgSnow Caster \c-out of charge");
		Goto GoingToReady;
		TNT1 A 0 A_PlaySound("coldcst", CHAN_WEAPON);
		HND1 AB 4;
		TNT1 A 0 A_TakeInventory("PB_CF_SnowCasterAmmo", 1);
		TNT1 A 0 A_SpawnItemEx("PBCF_CF_SnowCasterEmitter", 0, 0, 32, 0, 0, 0, 0, SXF_SETMASTER|SXF_NOCHECKPOSITION);
		HND1 CD 4;
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		Goto GoingToReady2;
		
	DeployPB_CFFreezeBot:
		TNT1 A 0 A_ZoomFactor(1.0);
		TNT1 A 0 A_TakeInventory("ADSMode", 1);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_JumpIfInventory("PB_CF_FreezeBotDeployAmmo", 1, 2);
		TNT1 A 0 A_Print("\cgNo \ctFreezebot \c-kits left");
		Goto GoingToReady;
		TNT1 A 0 A_PlaySound("Plasma/BeepLow", CHAN_WEAPON);
		TNT1 A 0 A_TakeInventory("PB_CF_FreezeBotDeployAmmo", 1);
		TNT1 A 0 A_SpawnItemEx("PBCF_CF_FreezeBotTurret", 56, 0, 8, 0, 0, 0, 0, SXF_SETMASTER|SXF_NOCHECKPOSITION);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		Goto GoingToReady2;
		
	DeployPB_CFIceWall:
		TNT1 A 0 A_ZoomFactor(1.0);
		TNT1 A 0 A_TakeInventory("ADSMode", 1);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_JumpIfInventory("PB_CF_IceWallGenAmmo", 1, 2);
		TNT1 A 0 A_Print("\cgNo \ctIce Wall \c-generators left");
		Goto GoingToReady;
		TNT1 A 0 A_PlaySound("weapons/freezer/reload1", CHAN_WEAPON);
		TNT1 A 0 A_TakeInventory("PB_CF_IceWallGenAmmo", 1);
		TNT1 A 0 A_SpawnItemEx("PBCF_CF_IceWallSegment", 56, 0, 0, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		TNT1 A 0 A_SpawnItemEx("PBCF_CF_IceWallSegment", 104, 0, 0, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		TNT1 A 0 A_SpawnItemEx("PBCF_CF_IceWallSegment", 152, 0, 0, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		TNT1 A 0 A_SpawnItemEx("PBCF_CF_IceWallSegment", 200, 0, 0, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		TNT1 A 0 A_TakeInventory("UseEquipment", 1);
		TNT1 A 0 A_TakeInventory("ToggleEquipment", 1);
		Goto GoingToReady2;
		
