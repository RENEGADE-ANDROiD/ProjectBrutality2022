	action StateLabel PB_ExecuteImp() {
		A_GiveInventory("ExecutionToken", 1, AAPTR_PLAYER_GETTARGET);
		StateLabel result;
		FLineTraceData RemoteRay;
		bool wallcheck = LineTrace(
		   angle,
		   120,
		   pitch,
		   TRF_THRUACTORS,
		   offsetz: height-12,
		   data: RemoteRay
		);
		if ((Pos.Z-floorz) > 8) {
			A_Warp(AAPTR_PLAYER_GETTARGET, 0, 0, 54, WARPF_USECALLERANGLE|WARPF_NOCHECKPOSITION);
			return "Execution_Imp3";
		}
		if (wallcheck && RemoteRay.HitType == TRACE_HitWall)
			return "Execution_Imp2";
		int selector = random(1, 5);
		switch (selector) {
		case 1: result = "Execution_Imp1"; break;
		case 2: result = "Execution_Imp2"; break;
		case 3: result = "Execution_Imp3"; break;
		case 4: result = "Execution_Imp_CrossZomb1"; break;
		case 5: result = "Execution_Imp_CrossZ5"; break;
		default: result = "Execution_Imp1"; break;
		}
		return result;
	}
	
