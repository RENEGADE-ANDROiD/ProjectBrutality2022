	}
	action void PB_VisualLaser(int mode) {}

	action void PB_FireAltBFGRail()
	{
		PlayerPawn pp = PlayerPawn(invoker.owner);
		if (!pp || !pp.player)
			return;

		FLineTraceData t;
		double vz = pp.height * 0.5 - pp.floorclip + pp.AttackZOffset * pp.player.crouchFactor;
		bool hit = pp.LineTrace(pp.angle, 8000, pp.pitch, 0, vz, data: t);

		Vector3 startpos = (pp.pos.XY, pp.pos.Z + vz);
		Vector3 destpos = t.HitLocation;
		Vector3 toHit = Level.Vec3Diff(startpos, destpos);
		double toHitLen = toHit.length();
		Vector3 dirToHit = toHitLen > 0 ? toHit.unit() : (1, 0, 0);

		if (t.HitType == TRACE_HitWall && t.HitLine)
		{
			double na = atan2(t.HitLine.delta.Y, t.HitLine.delta.X) - 90.;
			if (t.LineSide == 1)
				na += 180.;
			Vector3 wallN = (cos(na), sin(na), 0);
			destpos -= wallN * 2;
		}
		else
			destpos -= dirToHit * 2;

		Vector3 dif = Level.Vec3Diff(startpos, destpos);
		Vector3 dir = dif.unit();
		double dis = dif.length();

		int q = int(dis / 30) + 1;

		Vector3 actpos = (pp.pos.XY, pp.pos.Z + vz);
		double alf = clamp(0.5 + sin(level.time * 15), 0.25, 1.0);
		for (int i = 1; i <= q; i++)
		{
			actpos += dir * 30;
			PB_DrawBFGrailparticle(actpos, alf, i, min(i, 20));
		}

		if (t.HitActor)
		{
			Actor v = t.HitActor;
			int dmg = 40 * random(1, 2);
			if (v && v.bIsMonster && v.health > 0 && !v.IsFriend(pp))
				v.DamageMobj(pp, pp, dmg, 'Desintegrate');
		}

		if (hit)
		{
			Actor p = Spawn("BFGBeamPuff", destpos);
			if (p)
				p.target = pp;
		}
	}

	action void PB_DrawBFGrailparticle(vector3 where, double alfa = 1.0, int it = 0, int spac = 30)
	{
		PlayerPawn pp = PlayerPawn(invoker.owner);
		if (!pp)
			return;

		FSpawnParticleParams bfgrail;
		int fm = random(1, 5);
		bfgrail.Texture = TexMan.CheckForTexture(String.Format("DLI%dG0R0", fm));
		bfgrail.Color1 = "FFFFFF";
		bfgrail.Style = STYLE_Add;
		bfgrail.Flags = SPF_ROLL | SPF_FULLBRIGHT | SPF_NOTIMEFREEZE;
		bfgrail.Vel = (0, 0, 0);
		bfgrail.Startroll = random(0, 360);
		bfgrail.RollVel = randompick(-15, 15, 30, -30);
		bfgrail.StartAlpha = 1.0;
		bfgrail.FadeStep = 0.1;
		bfgrail.Size = random(20, 32);
		bfgrail.SizeStep = -12;
		bfgrail.Lifetime = random(2, 3);
		bfgrail.Pos = where + (random(-spac, spac), random(-spac, spac), random(-spac, spac));
		Level.SpawnParticle(bfgrail);

		FSpawnParticleParams BFGFLAR;
		string flart = "LENGA0";
		switch (random(1, 4))
		{
		case 1:
			break;
		case 2:
			flart = "L2NGA0";
			break;
		case 3:
			flart = "DB59L0";
			break;
		case 4:
			flart = "SRKGN0";
			break;
		}
		BFGFLAR.Texture = TexMan.CheckForTexture(flart);
		BFGFLAR.Color1 = "FFFFFF";
		BFGFLAR.Style = STYLE_Add;
		BFGFLAR.Flags = SPF_ROLL | SPF_FULLBRIGHT | SPF_NOTIMEFREEZE;
		BFGFLAR.Vel = (0, 0, 0);
		BFGFLAR.Startroll = random(0, 360);
		BFGFLAR.RollVel = 0;
		BFGFLAR.StartAlpha = alfa;
		BFGFLAR.FadeStep = alfa > 0.1 ? 0.1 : 0.0;
		BFGFLAR.Size = random(25, 30);
		BFGFLAR.SizeStep = -5;
		BFGFLAR.Lifetime = 2;
		BFGFLAR.Pos = where;
		Level.SpawnParticle(BFGFLAR);

		FSpawnParticleParams ciclepx;
		ciclepx.Texture = TexMan.CheckForTexture("YAE6A0");
		ciclepx.Color1 = "FFFFFF";
		ciclepx.Style = STYLE_Add;
		ciclepx.Flags = SPF_ROLL | SPF_FULLBRIGHT;
		ciclepx.Vel = (0, 0, 0);
		ciclepx.Startroll = it * 2;
		ciclepx.RollVel = 0;
		ciclepx.StartAlpha = 0.90;
		ciclepx.FadeStep = 0.1;
		ciclepx.Size = 30;
		ciclepx.SizeStep = 0;
		ciclepx.Lifetime = 1;

		ciclepx.Pos = where;

		double ps = -it * spac;
		ps += (level.time * 20) % 360;

		Quat fr = Quat.FromAngles(pp.angle, pp.pitch, ps);

		Vector3 ofss = fr * (0, 0, spac);
		ciclepx.Pos += ofss;

		Level.SpawnParticle(ciclepx);
	}
	
