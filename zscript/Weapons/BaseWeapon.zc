	action void LedgeReach(float HeightDecrease)
	{
		let plr = PlayerPawnBase(self);
		plr.LedgeHeightMax = (plr.LedgeHeight - Height * HeightDecrease * 1.0f);
		A_Stop();
		SetOrigin((Pos.X, Pos.Y, plr.LedgeHeightMax), True);
	}
	
	action state PB_RespectIfNeeded()
	{
		Actor own = invoker.owner;
		bool shouldHelmet = ACS_NamedExecuteWithResult("ToggleHelmetAnimation",0,0,0) == 0 && own.CountInv("IntroductionSequence") == 0;
		bool shouldRespect = invoker.respectInventoryItem != "" && own.CountInv(invoker.respectInventoryItem) == 0;
		bool dontRespect = Cvar.FindCVar('pb_respectweapons').GetBool() == false && own.CountInv(invoker.respectInventoryItem) == 0;
		if (shouldHelmet)
		{
			own.GiveInventory("IntroductionSequence",1);
			return invoker.resolveState("HelmetAnimation");
		}	
		else if (dontRespect)
		{
			own.GiveInventory(invoker.respectInventoryItem,1);
			if(!invoker.owner || !invoker.owner.player || !invoker.owner.player.ReadyWeapon)
				return invoker.A_Jump(256,"SelectAnimation");
			let rw = invoker.owner.player.ReadyWeapon;
			if(rw.GetClassName() == "PB_MG42") {
				own.SetInventory("MG42HeatLevel",0);
				return invoker.A_Jump(256,"SelectAnimation");
			}
			if(rw.GetClassName() == "PB_SuperGL"){ //Thanks to 7Soul on the ZDoom Forums for posting on getting a selected weapon
				A_SetCurrentGrenadeType("Impact");
				return invoker.A_Jump(256,"SelectAnimation");
				}
			if(rw.GetClassName() == "PB_RocketLauncher"){
				PB_SetCurrentRocketMode("Standard");
				return invoker.A_Jump(256,"SelectAnimation");
				}
			else {
			return invoker.A_Jump(256,"SelectAnimation");
			}
		}
		else if (shouldRespect)
		{
			own.GiveInventory(invoker.respectInventoryItem,1);
			return invoker.resolveState("WeaponRespect");
		}
		else
		{
			return invoker.A_Jump(256,"SelectAnimation");
		}
	}

	// Shims for add-on weapons that expect newer-PB helper actions (e.g. Ballista from CRASH pack)
	action void PB_IncrementHeat(int amount, bool secondBarrel = false) {}
	// Transfers from reserve pool into magazine in steps of "per" until mag reaches "magMax" (CRASH Tech Blaster reload)
	action void PB_AmmoIntoMag(name mag, name pool, int magMax, int per)
	{
		int n;
		for (n = 0; n < 512 && CountInv(mag) < magMax && CountInv(pool) >= per; n++)
		{
			A_TakeInventory(pool, per);
			A_GiveInventory(mag, per);
		}
	}
	// Clientside props when transferring ammo mag->pool (no pickup).
	action void PB_SpawnLooseRounds(class<Actor> cls, int count, double xoff = 8, double zoff = 20)
	{
		if (!cls || count < 1)
			return;
		if (!player || !player.mo)
			return;

		for (int i = 0; i < count; i++)
		{
			double ox = xoff + frandom(-3, 3);
			double oz = zoff + frandom(-3, 3);
			double vx = frandom(2.0, 7.0);
			double vy = frandom(-5.0, 5.0);
			double vz = frandom(1.0, 8.0);
			A_SpawnItemEx(cls, ox, 0, oz, vx, vy, vz, random(0, 359), SXF_ABSOLUTEMOMENTUM);
		}
	}
	// Magazine dump back to pool (e.g. NeoHMG Unload) â€” per-unit to stay consistent with AmmoIntoMag
	action void PB_DumpMagToPool(name mag, name pool, int per, class<Actor> looseFx = null)
	{
		int n;
		for (n = 0; n < 512 && CountInv(mag) > 0; n++)
		{
			int before = CountInv(mag);
			A_TakeInventory(mag, per);
			int taken = before - CountInv(mag);
			if (taken < 1)
				break;
			A_GiveInventory(pool, taken);
			if (looseFx)
				PB_SpawnLooseRounds(looseFx, taken);
		}
	}
	action void PB_CheckBarrelPlace1() {}
	action void PB_CheckBarrelThrow1() {}
	action void PB_CheckBarrelIdle1() {}
	action void PB_ReFire (StateLabel st = 'Fire')
	{
		A_Refire (st);
	}
	action void PB_FireBullets (name type, int amount, double angle, double offs, double height, double pitch)
	{
		Vector2 spread;
		for (int i = amount; i > 0; i--)
		{
			spread.x = frandom(-angle, angle);
			spread.y = frandom(-pitch, pitch);
			if (i == amount)
			{
				spread.x *= PB_HitFeedback_Math.LinearMap(pb_weapon_recoil_mod_horizontal, 0.0, 1.0, 1.0, 0.2);
				spread.y *= PB_HitFeedback_Math.LinearMap(pb_weapon_recoil_mod_vertical, 0.0, 1.0, 1.0, 0.2);
			}
			A_FireProjectile (type, spread.x, 0, offs, height, FPF_NOAUTOAIM, spread.y);
		}
	}
	action void PB_CheckAmmoFire() {}
	// PB 2022 originally took only (mag, pool, per). Extra optional args are
	// signature-compatible with PB Staging's PB_UnloadMag so ported staging
	// weapons (Deagle, etc.) compile without per-call adapter shims:
	//   * `goal`        â€” leave at least this many rounds in the mag
	//   * `xoff` / `zoff` â€” visual round-spawn offset
	//   * `spawnRound`  â€” optional actor to spawn per transfer (loose round)
	//   * `secondary`   â€” currently unused; reserved for dual-wield parity
	action void PB_UnloadMag(name mag, name pool, int per,
							 int goal = 0,
							 double xoff = 0, double zoff = 0,
							 class<Actor> spawnRound = null,
							 bool secondary = false)
	{
		if (CountInv(mag) < goal + per)
			return;
		A_TakeInventory(mag, per);
		A_GiveInventory(pool, per);
		if (spawnRound)
			PB_SpawnLooseRounds(spawnRound, per, xoff, zoff);
	}
