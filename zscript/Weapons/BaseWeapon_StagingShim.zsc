// PB 2022 staging-parity extend on PB_WeaponBase (from PB Staging `BaseWeapon_Functions.zsc` signatures).
// Fold/port notes: AGENTS.md §4 bullet **ZSCRIPT.zc master `#include` band — staging weapon shim** (IsReloading
// inventory vs staging `PlayerPawnBase.reloading`, `PB_WeaponRaise` omissions, `GunFireSmoke` vs barrel smoke,
// heavy muzzle helpers not back-filled, `PB_SpawnCasing` 7-arg PB2022 vs staging 9-arg).

Extend class PB_WeaponBase
{
	// ------------------------------------------------------------------
	// State â€” mirrors the equivalent fields on staging's PB_WeaponBase.
	// ------------------------------------------------------------------

	bool chamberEmpty, leftChamberEmpty;
	bool magEmpty,     leftMagEmpty;
	bool magUnloaded,  leftMagUnloaded;

	uint8 barrelHeat, leftBarrelHeat;
	int overheat, leftOverheat;
	int maxOverheat;
	property MaxOverheat : maxOverheat;
	int overheatCoolingRate;
	property OverheatCoolingRate : overheatCoolingRate;

	float lowAmmoVol;
	uint16 sustainedFire;

	string smokeColor;
	property MuzzleSmokeColor : smokeColor;

	// Optional left-hand ammo pool for dual-wield (staging: ammotypeleft).
	class<Ammo> AmmoTypeLeft;
	Ammo AmmoLeft;
	Property AmmoTypeLeft : AmmoTypeLeft;

	// PB_DynamicTail pitch knob (Deagle/Revolver/Carbine). Staging exposes this on PB_WeaponBase;
	// PB 2022's PB_DynamicTail body is a no-op so the value is currently advisory only.
	float tailPitch;
	Property TailPitch : tailPitch;

	// Reserveâ†’mag refill ratio used by staging's reload helpers. PB 2022's
	// PB_AmmoIntoMag already takes an explicit `per` argument so this is
	// surfaced as advisory state (so staging weapon defaults parse cleanly)
	// and is not consulted by the existing helper.
	int reserveToMagAmmoFactor;
	Property ReserveToMagAmmoFactor : reserveToMagAmmoFactor;

	// ------------------------------------------------------------------
	// Aim-mode cvar read (toggle vs hold). Used by Revolver, etc.
	// ------------------------------------------------------------------
	action bool PB_GetAimMode()
	{
		return CVar.GetCVar("pb_toggle_aim_hold", Player).GetBool();
	}

	// ------------------------------------------------------------------
	// Input query â€” per-frame button-held check (BT_* bitmask).
	// Staging's BaseWeapon exposes this; PB 2022's already has the common
	// PressingFire/Altfire/Reload/User1 wrappers but not the generic form.
	// ------------------------------------------------------------------
	action bool IsHoldingInput(int which)
	{
		return player.cmd.buttons & which;
	}

	// ------------------------------------------------------------------
	// PSprite convenience setters used by staging weapon animations.
	// ------------------------------------------------------------------
	action void A_SetWeaponFrame(int frame)
	{
		let psp = player.GetPSprite(OverlayID());
		if(psp) psp.frame = frame;
	}

	action void A_SetWeaponSpriteEx(String str)
	{
		let psp = player.GetPSprite(OverlayID());
		if(psp) psp.sprite = GetSpriteIndex(str);
	}

	// A_SetFlashWeaponSprite and A_SetSpawnSprite already live in
	// zscript/Weapons/BaseWeapon.zc (lines 807/813); not duplicated here.

	action void A_GunFlash2()
	{
		player.mo.PlayAttacking();
	}

	action void A_LegOverlay(int layer, statelabel st)
	{
		A_Overlay(layer, st);
	}

	action void A_FlashOverlay(int layer = -3, statelabel st = "MuzzleFlash")
	{
		A_Overlay(layer, st);
		A_OverlayFlags(layer, PSPF_RENDERSTYLE, true);
		A_OverlayRenderStyle(layer, STYLE_Add);
	}

	// ------------------------------------------------------------------
	// Muzzle-smoke color hook (staging uses it via PB_GunSmokeSpawn).
	// PB 2022 still relies on the existing PB_GunSmoke helper; color just
	// lives on the weapon for future wiring.
	// ------------------------------------------------------------------
	action void PB_SetMuzzleSmokeColor(string col)
	{
		invoker.smokeColor = col;
	}

	// ------------------------------------------------------------------
	// Chamber / magazine state getters & setters.
	// ------------------------------------------------------------------
	action void PB_SetChamberEmpty(bool set, bool dual = false)
	{
		if(dual) invoker.leftChamberEmpty = set;
		else     invoker.chamberEmpty     = set;
	}

	action void PB_SetMagEmpty(bool set, bool dual = false)
	{
		if(dual) invoker.leftMagEmpty = set;
		else     invoker.magEmpty     = set;
	}

	action void PB_SetMagUnloaded(bool set, bool dual = false)
	{
		if(dual) invoker.leftMagUnloaded = set;
		else     invoker.magUnloaded     = set;
	}

	action bool PB_GetChamberEmpty(bool dual = false)
	{
		return dual ? invoker.leftChamberEmpty : invoker.chamberEmpty;
	}

	action bool PB_GetMagEmpty(bool dual = false)
	{
		return dual ? invoker.leftMagEmpty : invoker.magEmpty;
	}

	action bool PB_GetMagUnloaded(bool dual = false)
	{
		return dual ? invoker.leftMagUnloaded : invoker.magUnloaded;
	}

	// ------------------------------------------------------------------
	// Reload flag. Staging tracks this on PlayerPawnBase.reloading;
	// PB 2022 uses an inventory token "IsReloading" (defined in PBRIFLE.dec).
	// ------------------------------------------------------------------
	action void PB_SetReloading(bool set)
	{
		A_SetInventory("IsReloading", set ? 1 : 0);
	}

	// ------------------------------------------------------------------
	// Overheat knobs (MG42, nailgun, plasma cooldown loops).
	// ------------------------------------------------------------------
	action void PB_ModifyOverheat(int mod, bool dual = false)
	{
		if(dual)
			invoker.leftOverheat = clamp(invoker.leftOverheat + mod, 0, invoker.maxOverheat);
		else
			invoker.overheat = clamp(invoker.overheat + mod, 0, invoker.maxOverheat);
	}

	action void PB_SetOverheat(int set, bool dual = false)
	{
		if(dual)
			invoker.leftOverheat = clamp(set, 0, invoker.maxOverheat);
		else
			invoker.overheat = clamp(set, 0, invoker.maxOverheat);
	}

	action int PB_GetOverheat(bool dual = false)
	{
		return dual ? invoker.leftOverheat : invoker.overheat;
	}

	action void PB_SetOverheatCoolingRate(int rate)
	{
		invoker.overheatCoolingRate = rate;
	}

	// ------------------------------------------------------------------
	// Heat bump used by staging weapons with barrel-heat visuals.
	// PB 2022's BaseWeapon.zc already declares PB_IncrementHeat as an
	// empty stub (int amount, bool secondBarrel) â€” we promote it to an
	// actual increment here. Signature kept compatible with both conventions
	// via parameter defaults.
	// NOTE: This replaces the PB_WeaponBase stub at BaseWeapon.zc:871.
	// ------------------------------------------------------------------

	// ------------------------------------------------------------------
	// Barrel-heat cooldown smoke â€” emitted periodically while the weapon
	// is over 0 heat. Uses PB 2022's GunFireSmoke actor instead of staging's
	// PB_BarrelHeatSmoke (which isn't shipped here).
	// ------------------------------------------------------------------
	action void PB_CoolDownBarrel(double posOfsx = 0, double posOfsy = 0, double posOfsz = 0,
								  double velOfsx = 0, double velOfsy = 0, double velOfsz = 0,
								  double scaleadjust = 1, double alphaadjust = 1, bool nodual = false)
	{
		bool useLeft = (posOfsx > 0) && !nodual;

		if((!useLeft && invoker.barrelHeat     < 1) ||
		   ( useLeft && invoker.leftBarrelHeat < 1))
			return;

		if(level.MapTime % 3 == 0)
		{
			A_FireCustomMissile("GunFireSmoke",
				0, 0,
				posOfsy,
				posOfsz,
				0, 0);
		}

		if(useLeft)
			invoker.leftBarrelHeat--;
		else
			invoker.barrelHeat--;
	}

	// ------------------------------------------------------------------
	// PB_CheckReload â€” unified reload-entry router.
	// Picks between "unloaded reload", "empty reload", "chamber load", or
	// "already full" based on chamber/mag flags + reserve counts.
	// ------------------------------------------------------------------
	action state PB_CheckReload(statelabel unloadedReload,
								statelabel emptyReload,
								statelabel loadChamber,
								statelabel fullAlready,
								statelabel noAmmo,
								int full,
								int equal = 1,
								bool dual = false)
	{
		int amount1 = CountInv(invoker.ammotype1);
		int amount2 = dual
			? (invoker.ammotypeleft ? CountInv(invoker.ammotypeleft) : 0)
			: CountInv(invoker.ammotype2);

		if(amount1 < equal)
			return ResolveState(noAmmo);

		A_SetInventory("DualFireReload", 0);
		A_SetInventory("Zoomed",         0);
		A_ZoomFactor(1.0);
		A_SetCrosshair(-1);
		A_ClearOverlays(10, 11);
		PB_SetReloading(true);

		if(fullAlready && full > 0 && amount2 >= full
		   && !PB_GetChamberEmpty(dual) && !PB_GetMagUnloaded(dual))
			return ResolveState(fullAlready);

		if(unloadedReload && PB_GetMagUnloaded(dual))
			return ResolveState(unloadedReload);

		if(loadChamber && PB_GetChamberEmpty(dual) && !PB_GetMagEmpty(dual) && !PB_GetMagUnloaded(dual))
			return ResolveState(loadChamber);

		if(emptyReload && PB_GetChamberEmpty(dual))
			return ResolveState(emptyReload);

		return ResolveState(null);
	}

	// ------------------------------------------------------------------
	// PB_jumpIfNoAmmo â€” early-exit from the Fire state into a reload.
	// ------------------------------------------------------------------
	action state PB_jumpIfNoAmmo(statelabel reloadstate = "Reload",
								 int min = 1,
								 bool chamber = true,
								 bool secondary = true,
								 string emptysound = "weapons/empty")
	{
		bool needsReload =
			  PB_GetChamberEmpty()
		   || (PB_GetMagUnloaded() && !chamber)
		   || (!secondary && invoker.ammotype1 && CountInv(invoker.ammotype1) < min)
		   || ( secondary && invoker.ammotype2 && CountInv(invoker.ammotype2) < min);

		if(needsReload)
		{
			if(emptysound.Length() > 0)
				A_StartSound(emptysound, 0);
			return ResolveState(reloadstate);
		}
		return ResolveState(null);
	}

	// ------------------------------------------------------------------
	// PB_TakeAmmo â€” take N from a pool and flip mag/chamber-empty flags.
	// ------------------------------------------------------------------
	action void PB_TakeAmmo(class<Inventory> ammoType, int takeNum,
							int emptyMag = 1, int emptyChamber = 0, bool dual = false)
	{
		A_TakeInventory(ammoType, takeNum, TIF_NOTAKEINFINITE);

		if(CountInv(ammoType) <= emptyMag)
			PB_SetMagEmpty(true, dual);

		if(CountInv(ammoType) <= emptyChamber
		   || (PB_GetMagUnloaded(dual) && emptyChamber > -1))
			PB_SetChamberEmpty(true, dual);
	}

	// ------------------------------------------------------------------
	// Low-ammo click/warning sound scaled to remaining mag fraction.
	// ------------------------------------------------------------------
	action void PB_LowAmmoSoundWarning(string type = "default",
									   string ammoItem = "SuperMario64ForTheXboxOne",
									   int ammoUse = 1)
	{
		Ammo count;
		if(ammoItem == "SuperMario64ForTheXboxOne")
			count = invoker.ammo2;
		else
			count = Ammo(FindInventory(ammoItem));

		if(!count)
			return;

		int lowammocount     = ceil(count.maxamount * 0.25);
		int currentammocount = count.amount;

		sound sndName = "weapons/lowammo/"..type;

		currentammocount /= ammoUse;
		lowammocount     /= ammoUse;

		invoker.lowAmmoVol = 0.7;

		if(currentammocount <= lowammocount)
		{
			double clickvolume = clamp(
				PB_HitFeedback_Math.LinearMap(currentammocount, 1.0, lowammocount, 1.0, 0.70),
				0.7, 1.0);
			invoker.lowAmmoVol = clickvolume;
			A_StartSound(sndName, CHAN_AUTO, CHANF_OVERLAP, clickvolume, ATTN_STATIC,
						 frandompick(0.98, 1.0));

			if(currentammocount == 1)
				A_StartSound("weapons/lowammo/sweetener", CHAN_AUTO, CHANF_OVERLAP,
							 1.0, ATTN_STATIC);
		}
	}

	action void PB_ResetSustainedFire()
	{
		invoker.sustainedFire = 0;
	}

	action bool PB_CanDualWield()
	{
		return (invoker.amount > 1);
	}

	// ------------------------------------------------------------------
	// Upgrade-path handoff helpers. Used when a weapon upgrades into or
	// downgrades out of a higher-tier variant (e.g. Revolver â†’ Deagle).
	// ------------------------------------------------------------------
	action void PB_TakeIfUpgrade(string oldweap = "")
	{
		if(oldweap.Length() == 0) return;

		let pbw = PB_WeaponBase(FindInventory(oldweap));
		if(pbw)
		{
			pbw.akimboMode = false;
			A_SetInventory(oldweap, 0);
		}
	}

	action void PB_SelectIfUpgrade(string upgrade = "")
	{
		if(upgrade.Length() == 0) return;
		if(!CountInv(upgrade)) return;

		A_SetAkimbo(false);
		A_SelectWeapon(upgrade);
	}

	// ------------------------------------------------------------------
	// PB_SetSpriteIfUnload / PB_SetDualSpriteIfUnload.
	// Promoted from staging's Deagle.zs so ANY weapon can swap its ready
	// sprite based on chamber state without duplicating the helper.
	// ------------------------------------------------------------------
	action void PB_SetSpriteIfUnload(string sp, bool dual = false)
	{
		if(PB_GetChamberEmpty(dual))
			A_SetOverlaySprite(OverlayID(), sp);
	}

	action void PB_SetDualSpriteIfUnload(string leftUnl, string rightUnl, string unloaded)
	{
		bool rightEmpty = PB_GetChamberEmpty();
		bool leftEmpty  = PB_GetChamberEmpty(true);

		if(rightEmpty && leftEmpty)
		{
			A_SetOverlaySprite(OverlayID(), unloaded);
			return;
		}
		if(rightEmpty)
		{
			A_SetOverlaySprite(OverlayID(), rightUnl);
			return;
		}
		if(leftEmpty)
		{
			A_SetOverlaySprite(OverlayID(), leftUnl);
			return;
		}
	}

	// ------------------------------------------------------------------
	// Dual-wield action dispatchers used by staging Deagle/Revolver/PlasmaM1.
	// These just route through A_DoPBWeaponAction (already in PB 2022) plus
	// the weapon-specific FireLeft_Overlay / FireRight_Overlay / StopDualWield
	// states the ported weapon must provide. Safe to call even if those
	// states are absent â€” ResolveState returns null and the caller falls
	// through to idle.
	// ------------------------------------------------------------------
	action state A_DoPBDualAction(int reservenum = 1)
	{
		if(CountInv(invoker.ammotype1) >= reservenum)
		{
			A_SetInventory("DualFireReload", 0);
			if(PB_GetChamberEmpty())
				A_GiveInventory("DualFireReload", 1);
			if(PB_GetChamberEmpty(true))
				A_GiveInventory("DualFireReload", 1);
		}

		if(!PB_CanDualWield())
			return ResolveState("StopDualWield");

		return A_DoPBWeaponAction(WRF_ALLOWRELOAD | WRF_NOFIRE);
	}

	action state A_DoPBLeftAction(int minammo = 1)
	{
		int firemodecvar = CVar.GetCVar("SingleDualFire", player).GetInt();
		let ammoLeftType = invoker.ammotypeleft ? invoker.ammotypeleft : invoker.ammotype2;

		if(CountInv(ammoLeftType) >= minammo && !PB_GetChamberEmpty(true))
		{
			switch(firemodecvar)
			{
				case 0:
					if(PressingFire() && !A_IsFiringRightWeapon() && CountInv("DualFiring") == 0)
						return ResolveState("FireLeft_Overlay");
					break;
				case 1:
					if(PressingFire() && !A_IsFiringLeftWeapon())
						return ResolveState("FireLeft_Overlay");
					break;
				case 2:
					if(PressingAltFire() && !A_IsFiringLeftWeapon())
						return ResolveState("FireLeft_Overlay");
					break;
			}
		}
		else
		{
			switch(firemodecvar)
			{
				case 0:
					if(JustPressed(BT_ATTACK) && !A_IsFiringRightWeapon() && CountInv("DualFiring") == 0)
						A_StartSound("weapons/empty", 10, CHANF_OVERLAP);
					break;
				case 1:
					if(JustPressed(BT_ATTACK) && !A_IsFiringLeftWeapon())
						A_StartSound("weapons/empty", 10, CHANF_OVERLAP);
					break;
				case 2:
					if(JustPressed(BT_ALTATTACK) && !A_IsFiringLeftWeapon())
						A_StartSound("weapons/empty", 10, CHANF_OVERLAP);
					break;
			}
			if(!PB_GetChamberEmpty() && CountInv(invoker.ammotype2) >= minammo)
				A_SetInventory("DualFiring", 1);
		}
		return ResolveState(null);
	}

	action state A_DoPBRightAction(int minammo = 1)
	{
		int firemodecvar = CVar.GetCVar("SingleDualFire", player).GetInt();
		let ammoLeftType = invoker.ammotypeleft ? invoker.ammotypeleft : invoker.ammotype2;

		if(CountInv(invoker.ammotype2) >= minammo && !PB_GetChamberEmpty())
		{
			switch(firemodecvar)
			{
				case 0:
					if(PressingFire() && !A_IsFiringLeftWeapon() && CountInv("DualFiring") == 1)
						return ResolveState("FireRight_Overlay");
					break;
				case 1:
					if(PressingAltFire() && !A_IsFiringRightWeapon())
						return ResolveState("FireRight_Overlay");
					break;
				case 2:
					if(PressingFire() && !A_IsFiringRightWeapon())
						return ResolveState("FireRight_Overlay");
					break;
			}
		}
		else
		{
			switch(firemodecvar)
			{
				case 0:
					if(JustPressed(BT_ATTACK) && !A_IsFiringLeftWeapon() && CountInv("DualFiring") == 1)
						A_StartSound("weapons/empty", 10, CHANF_OVERLAP);
					break;
				case 1:
					if(JustPressed(BT_ALTATTACK) && !A_IsFiringRightWeapon())
						A_StartSound("weapons/empty", 10, CHANF_OVERLAP);
					break;
				case 2:
					if(JustPressed(BT_ATTACK) && !A_IsFiringRightWeapon())
						A_StartSound("weapons/empty", 10, CHANF_OVERLAP);
					break;
			}
			if(!PB_GetChamberEmpty(true) && CountInv(ammoLeftType) >= minammo)
				A_SetInventory("DualFiring", 0);
		}
		return ResolveState(null);
	}

	// ------------------------------------------------------------------
	// PB_WeaponRaise â€” "select" wrapper that plays the raise sound and
	// registers the standard PB kick/melee/equip overlays. Mirrors staging
	// flow so ported weapons can do:
	// and skip PB 2022's SelectFirstPersonLegs chain.
	// ------------------------------------------------------------------
	action void PB_WeaponRaise(string upSnd = "")
	{
		A_WeaponOffset(0, 32);
		if(upSnd.Length() > 0)
			A_StartSound(upSnd, 32);

		A_SetRoll(0);
		A_ZoomFactor(1.0);

		A_StopSound(1);
		A_StopSound(CHAN_VOICE);
		A_StopSound(5);
		A_StopSound(6);
		A_StopSound(7);
		A_StopSound(CHAN_AUTO);

		A_SetInventory("Spin",              0);
		A_SetInventory("CantWeaponSpecial", 0);
		A_SetInventory("MG42Selected",      0);
		A_SetInventory("Grabbing_A_Ledge",  0);
		A_SetInventory("RandomHeadExploder",0);
		A_SetInventory("DualFireReload",    0);
		A_SetInventory("Kicking",           0);
		A_SetInventory("Zoomed",            0);

		A_ClearOverlays(-999, -999);
		A_Overlay(-777,  "Melee_Equipment_Handler_Overlay");
		A_Overlay(-778,  "KickHandler_Overlay");
		A_Overlay(-779,  "Equipment_Toggle_Handler_Overlay");
		A_Overlay(-10, "FirstPersonLegsStand");

		PB_SetUsingKick(false);
		PB_SetUsingMelee(false);
		PB_SetUsingEquipment(false);
		PB_SetExecutingEnemy(false);
		PB_SetReloading(false);
	}

	// ------------------------------------------------------------------
	// Lightweight muzzle smoke / flash effect stubs.
	// Staging ships PB_GunSmoke_Deagle / PB_MuzzleFlashEffects that drive
	// PB_MuzzleSpark / PB_GunFireSmoke / PB_CasingEjectionSmoke (none of
	// which are present in PB 2022). These wrappers fall back to PB 2022's
	// existing GunFireSmoke actor so ported staging weapons compile and
	// still produce visible muzzle smoke. Per-weapon ports can override
	// for a fancier look later without touching every call-site.
	// ------------------------------------------------------------------
	action void PB_GunSmoke_Deagle(double xOff = 0, double yOff = 0, double zOff = 6)
	{
		A_FireProjectile("GunFireSmoke", 0, false, yOff, zOff, FPF_NOAUTOAIM, 0);
	}

	action void PB_MuzzleFlashEffects(double xOff = 0, double yOff = 0, double zOff = 6)
	{
		// Intentionally empty â€” PB 2022 already draws a flash overlay via
		// here that depend on PB_MuzzleSpark; revisit if/when that actor
		// is folded in.
	}
}
