				A_SetPitch(pitch-0.2);
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NK");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NK");}
				ThrustThingZ(0,2,0,0);
			}
			
			P2NK TU 1 {
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NK");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NK");}
				ThrustThingZ(0,2,0,0);
			}




			TNT1 A 0 {
				A_SetPitch(Pitch+20.0, SPF_INTERPOLATE);
				A_SetAngle(Angle-8.8, SPF_INTERPOLATE);
				A_SetRoll(roll+96, SPF_INTERPOLATE);
			}




			MC3S ABCD 1 {
				//A_SetRoll(roll+6);
				A_SetPitch(pitch+1);
				//A_SetAngle(angle-4);
				ThrustThingZ(0,2,0,0);
			}
			// Frame 2: 4 Ticks
			TNT1 A 0 A_StartSound("Machete/Yum", CHAN_AUTO);
			MC3S EFGHIJ 1 {
				//A_SetRoll(roll+6);
				A_SetPitch(pitch+2);
				//A_SetAngle(angle-6);
			}

			TNT1 A 0 {
			A_SetRoll(0, SPF_INTERPOLATE);
			A_Recoil(4);
			//ThrustThingZ(0,34,0,0);
			}
			TNT1 A 0 PB_UnsetPlayerExecutionProperties();
			Goto GoingToReady2;

		Execution_ESoul:
		//hands
		"####" AAAAAA 1 ;
			tttt a 0 A_SpawnItemEx("PB_ESoul_Execution", 41, 0,30,0,0,0,0,SXF_NOCHECKPOSITION|SXF_SETMASTER);

			TNT1 A 0 {
				A_SetPitch(Pitch+12.0);
			}
			P2NK ABCDEFGHIJKLMNOPQRSTUV 0;
			P3NK ABCDEFGHIJKLMNOPQRSTUV 0;
			P4NK ABCDEFGHIJKLMNOPQRSTUV 0;
			P2NO ABCDEFGHIJKLMNOPQRSTUVW 0;
			P3NO ABCDEFGHIJKLMNOPQRSTUVW 0;
			P4NO ABCDEFGHIJKLMNOPQRSTUVW 0;
			
			P1NK ABCDEE 1 {
				A_SetPitch(pitch+1.0);
