			}
			
			P1NK FG 1 {
				A_SetPitch(pitch-6.0);
				A_SetRoll(roll+9);
				A_SetAngle(angle+12.0);
			}
			TNT1 A 0 {
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
				A_StartSound("execution/impact", CHAN_AUTO);
				A_ZoomFactor(1.0);
			}
			P2NK HIJKLMNO 1 {
				A_SetRoll(roll+8);
