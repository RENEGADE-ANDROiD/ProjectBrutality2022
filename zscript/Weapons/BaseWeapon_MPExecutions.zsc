extend class PB_WeaponBase
{
	States
	{
	//Generic Execution (For placeholders)
		Execution_Generic:
			TNT1 A 0  {
				//A_SetPitch(0, SPF_INTERPOLATE);
				A_ZoomFactor(1.1);
			}	
			TNT1 A 0 A_Jump(256, "Generic1", "Generic2", "Generic3");
		
		Generic1:
			// Load blood variation sprites into virtual memory
			P2NK ABCDEFGHIJKLMNOPQRSTUV 0;
			P3NK ABCDEFGHIJKLMNOPQRSTUV 0;
			P4NK ABCDEFGHIJKLMNOPQRSTUV 0;
			P2NO ABCDEFGHIJKLMNOPQRSTUVW 0;
			P3NO ABCDEFGHIJKLMNOPQRSTUVW 0;
			P4NO ABCDEFGHIJKLMNOPQRSTUVW 0;
			
			P1NK ABCDEE 1 {  
				A_SetPitch(pitch-1.5);
				A_SetRoll(roll-5);
				A_SetAngle(angle-7.0);
			}
			TNT1 A 0 {
				A_StartSound("weapons/ultrwhoosh", CHAN_AUTO);
				A_ZoomFactor(1.15);
			}
			
			P1NK FG 1 {
				A_SetPitch(pitch+7.0);
				A_SetRoll(roll+9);
				A_SetAngle(angle+16.0);
			}
			TNT1 A 0 {
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
				A_StartSound("execution/impact", CHAN_AUTO);
				A_ZoomFactor(1.25);
			}
			P2NK HIJKLMNO 1 {
				A_SetRoll(roll+10);
				A_SetAngle(angle+3);
				A_SetPitch(pitch+2);
				
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NK");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NK");}
				
					
			}
			
			P2NK PQRS 1 {
				A_SetRoll(roll-18);
				A_SetAngle(angle-2);
				A_SetPitch(pitch-4);
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NK");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NK");}
			}
			
			P2NK TU 1 {
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NK");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NK");}
			}
			P2NO ABCD 1 {
				A_SetRoll(roll+4);
				A_SetAngle(angle+0.5);
				A_SetPitch(pitch-2.0);
				
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NO");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NO");}
			}
			TNT1 A 0 {
				A_StartSound("weapons/ultrwhoosh", CHAN_AUTO);
				A_ZoomFactor(1.3);
			}
			P2NO EF 1 {
				A_SetRoll(roll-34);
				A_SetAngle(angle-15.0);
				A_SetPitch(pitch+5.0);
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NO");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NO");}
			}
			TNT1 A 0 {
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
				A_StartSound("gore/heavyimpact", CHAN_AUTO);
				A_ZoomFactor(1.15);
			}
			//28
			P2NO GHIJKLMN 1 {
				A_SetRoll(roll+3);
				A_SetAngle(angle+5);
				A_SetPitch(pitch+2);
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NO");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NO");}
			}
			
			P2NO OPQ 1 {
				A_SetRoll(0, SPF_INTERPOLATE);
				A_SetAngle(angle+6);
				A_SetPitch(pitch-15);
				if(PB_GetExecutionBlueBlood()) {A_SetWeaponSprite("P3NO");}
				if(PB_GetExecutionGreenBlood()) {A_SetWeaponSprite("P4NO");}
			}
			
			TNT1 A 2;
			TNT1 A 1 PB_UnsetPlayerExecutionProperties();
			TNT1 A 0 A_SetInventory("CantWeaponSpecial",0);
			Goto GoingToReady2;
		Generic2:
			TNT1 AAA 1 {
				A_ZoomFactor(1.26);
				A_SetRoll(roll+20);
				A_SetAngle(angle+15);
				A_SetPitch(pitch+11);
			}
			TNT1 A 0 {
				A_StartSound("weapons/ultrwhoosh", CHAN_AUTO);
			}
			P1NH DEF 1 {
				A_SetRoll(roll-25);
				A_SetAngle(angle-17);
				A_SetPitch(pitch-18);
			}
			P1NH G 1 {
				A_SetRoll(roll-6);
				A_SetAngle(angle-2);
				A_SetPitch(pitch-1);
				A_ZoomFactor(1.1);
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
				A_StartSound("execution/impact", CHAN_AUTO);
			}
			P1NH HIJKL 1 {
				A_ZoomFactor(1.0);
				A_SetRoll(roll+5);
				A_SetAngle(angle+9);
				A_SetPitch(pitch+8);
			}
			P1NH M 1;
			TNT1 A 4;
			TNT1 A 0 {
				A_Overlay(-9,"Generic2_Overlay");
				A_SetRoll(0,SPF_INTERPOLATE);
				A_StartSound("KICK", CHAN_AUTO );
				A_OverlayFlags(-9,PSPF_PLAYERTRANSLATED, true);
			}
			TNT1 A 7;
			TNT1 A 2;
			TNT1 A 6;
			TNT1 A 3;
			TNT1 A 1 PB_UnsetPlayerExecutionProperties();
			TNT1 A 0 A_SetInventory("CantWeaponSpecial",0);
			Goto GoingToReady2;
		Generic2_Overlay:
			KIC5 AB 1 {
				A_SetRoll(roll+9);
				A_SetAngle(angle-9);
				A_SetPitch(pitch-2);
			}
			KIC5 CD 1 {
				A_SetRoll(roll+9);
				A_SetAngle(angle-8);
				A_SetPitch(pitch-2);
			}
			KIC5 DDD 1 {
				A_ZoomFactor(1.3);
				A_SetRoll(roll + 14);
				A_SetAngle(angle-14);
				A_SetPitch(pitch+8);
			}
			KIC5 EF 1 {
				A_SetRoll(roll+5);
				A_SetPitch(pitch-5);
				A_SetAngle(angle+4);
			}
			KIC5 G 1 {
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
				A_StartSound("execution/impact", CHAN_AUTO);
			}
			KIC5 H 1 A_ZoomFactor(1.1);
			KIC5 JKLM 1 {
				A_SetRoll(roll-10);
				A_SetAngle(angle+13);
				A_SetPitch(pitch-15);
				}
			Stop;
		Generic3:
			TNT1 AAA 1 {
				A_SetRoll(roll+12);
				A_SetAngle(angle+6);
				A_SetPitch(pitch+2);
				A_ZoomFactor(0.9);
			}
			TNT1 A 0 {
				A_StartSound("weapons/ultrwhoosh", CHAN_AUTO);
			}
			P1NI DEFG 1 {
				A_SetRoll(roll-14);
				A_SetAngle(angle-9);
				A_SetPitch(pitch-3);
				A_ZoomFactor(0.8);
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
				A_StartSound("execution/impact", CHAN_AUTO);
			}
			P1NI HIJKL 1 {
				A_ZoomFactor(1.1);
				A_SetRoll(roll-10);
				A_SetAngle(angle-8);
				A_SetPitch(pitch+1);
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
			}
			P1NI M 1;
			TNT1 AAA 1 {
				A_SetRoll(roll+2);
				A_SetAngle(angle+1);
				A_SetPitch(pitch+1);
			}
			TNT1 A 0 {
				A_Overlay(-9,"Generic3_Overlay");
				A_SetRoll(0,SPF_INTERPOLATE);
				A_StartSound("KICK", CHAN_AUTO );
				A_OverlayFlags(-9,PSPF_PLAYERTRANSLATED, true);
			}
			TNT1 A 7;
			TNT1 A 2;
			TNT1 A 6;
			TNT1 A 3;
			TNT1 A 1 PB_UnsetPlayerExecutionProperties();
			TNT1 A 0 A_SetInventory("CantWeaponSpecial",0);
			Goto GoingToReady2;
		Generic3_Overlay:
			KIC4 AB 1 {
				A_ZoomFactor(1.19);
				A_SetRoll(roll+18);
				A_SetAngle(angle+14);
				A_SetPitch(pitch+5);
			}
			KIC4 CD 1 {
				A_SetRoll(roll+12);
				A_SetAngle(angle+14);
				A_SetPitch(pitch+2);
			}
			KIC4 DDD 1 {
				A_SetRoll(roll-9);
				A_SetPitch(pitch+1);
			}
			KIC4 EF 1 {
				A_ZoomFactor(1.2);
				A_SetRoll(roll-5);
				A_SetPitch(pitch-6);
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
			}
			KIC4 G 1 {
				A_FireProjectile("ShakeYourAss",0,0,0,0,0,0);
				A_StartSound("execution/impact", CHAN_AUTO);
			}
			KIC4 H 1 A_ZoomFactor(1.15);
			KIC4 JKLM 1;
			Stop;
		Execution_Cricoso: //Cricoso is a "funny" (note the quotes) way of saying drug addicts in Latin America.
			TNT1 A 0  {
				A_SpawnItemEx("PB_CrackoDemon_Execution", 32, 0,0,0,0,0,0,SXF_NOCHECKPOSITION|SXF_SETMASTER);
				A_SetPitch(0, SPF_INTERPOLATE);
				A_ZoomFactor(1.35);
			}
			TNT1 AAAA 0 A_SetPitch(pitch+2, SPF_INTERPOLATE);
			//LLego
			PHON ABBC 1 ;
			TNT1 AAAA 0 A_SetPitch(pitch+2, SPF_INTERPOLATE);
			PHON DDEE 1 ;
			TNT1 AAAA 0 A_SetPitch(pitch+0, SPF_INTERPOLATE);
			//L
			PHON FG 2;
			PHON HI 2;
			PHON FG 2;
			PHON HI 2;
			PHON FG 2;
			PHON HI 2;
			PHON FG 2;
			PHON HI 2;
			PHON FG 2;
			PHON HI 2;
			PHON FG 2;
			PHON HI 2;
			//Fuera
			PHON JIJ 1 ;
			PHON JJIJJ 1 ;
			TNT1 AAAA 0 A_SetPitch(pitch-5, SPF_INTERPOLATE);
			PHON KKL 1 ;
			PHON LMN 1 ;
			TNT1 AAAA 0 A_SetPitch(pitch-6, SPF_INTERPOLATE);
			PHON NOO 1;
			TNT1 AAAA 0 A_SetPitch(pitch-7, SPF_INTERPOLATE);
			PHON PP 1 ;
			TNT1 AAAA 0 A_SetPitch(pitch-7, SPF_INTERPOLATE);
			TNT1 A 0 PB_UnsetPlayerExecutionProperties();
			Goto GoingToReady2;


		Execution_HellDuke:
		//hands
		"####" AAAAAA 1 ;
			tttt a 0 A_SpawnItemEx("PB_HellDuke_Execution_1", 41, 0,0,0,0,0,0,SXF_NOCHECKPOSITION|SXF_SETMASTER);
			TNT1 A 0  {
				A_SetPitch(0, SPF_INTERPOLATE);
				A_ZoomFactor(0.8);
				ThrustThingZ(0,18,0,0);
				A_SetAngle(Angle+40);
			}
			PKUP ABC 3 {
			A_SetAngle(Angle+5);
			A_SetPitch(pitch-5);
			A_SetRoll(roll-5);
			}
		//Grab!
			PKUP D 10 ;
			TNT1 A 0 A_StartSound("NECK_BRK",6);
			TNT1 A 0 A_SetRoll(roll-5);
			PKUP DE 4 ;
			TNT1 A 0 A_StartSound("NECK_BRK",6);
			TNT1 A 0 A_SetRoll(roll+5);
			PKUP DE 4 ;
			TNT1 A 0 A_StartSound("misc/xdeath2",6);
			TNT1 A 0 A_SetRoll(roll-5);
			PKUP D 10 ;
			TNT1 A 0 {
					A_SetRoll(roll+5);
					A_ZoomFactor(0.7);
					}
			PKUP DEF 2 {
			A_SetAngle(Angle-12);
			A_SetPitch(pitch+3);
			}
			P1NH LKJ 3 {
			A_SetAngle(Angle+20);
			A_SetPitch(pitch-15);
			A_SetRoll(roll-5);
			}
			TNT1 A 0
					{
					A_SetRoll(roll-5);
					A_ZoomFactor(0.9);
					A_Recoil(4);
					}
			THEF BCD 3 {
			A_SetAngle(Angle-20);
			A_SetPitch(pitch+15);
			A_SetRoll(roll+5);
			}
			TNT1 A 0 PB_UnsetPlayerExecutionProperties();
		Goto GoingToReady2;

		Execution_ObsidianRavager:
		//hands
		"####" AAAAAA 1 ;
		    tttt a 0 A_SpawnItemEx("PB_ObsidianRavager_Execution", 41, 0,0,0,0,0,0,SXF_NOCHECKPOSITION|SXF_SETMASTER);
			CL1M ABCD 1 {
				A_SetPitch(Pitch-12.0, SPF_INTERPOLATE);
			}
			TNT1 A 0 A_StartSound("ledgeclimb",6);
			//TNT1 A 0 ThrustThingZ(0,35,0,0);
			CL1M EFGH 1 {
				ThrustThingZ(0,18,0,0);
				}
			CL1M IJKL 1 {
				ThrustThingZ(0,18,0,0);
				A_SetPitch(Pitch+12.0, SPF_INTERPOLATE);
				}
			
			HNDF ABCDE 1 A_SetRoll(roll+2.0, SPF_INTERPOLATE);
			HNDF FGHI 1 {
				A_SetRoll(roll+2.0, SPF_INTERPOLATE);
				ThrustThingZ(0,1,0,0);
				}
			TNT1 A 0 A_StartSound("OPNGRN",0);
			HNDF JKLMNOPQR 1 {
				A_SetRoll(roll+2.0, SPF_INTERPOLATE);
				ThrustThingZ(0,1,0,0);
				}
		    00HK PQRSTUVW 1 {
				ThrustThingZ(0,1,0,0);
				}
			TNT1 A 0 {
			A_SetRoll(0, SPF_INTERPOLATE);
			A_Recoil(7);
			//ThrustThingZ(0,34,0,0);
			}
			TNT1 A 0 PB_UnsetPlayerExecutionProperties();
			Goto GoingToReady2;

		Execution_Director:
		//hands
		"####" AAAAAA 1 ;
			tttt a 0 A_SpawnItemEx("PB_Director_Execution", 41, 0,0,0,0,0,0,SXF_NOCHECKPOSITION|SXF_SETMASTER);

			//12 ticks for climb

			TNT1 A 0 {
				A_SetPitch(Pitch+12.0);
			}
			CL1M ABCD 1 {
				A_SetPitch(Pitch-3.0, SPF_INTERPOLATE);
			}
			TNT1 A 0 A_StartSound("ledgeclimb",6);
			CL1M EFGH 1 {
				ThrustThingZ(0,30,0,0);
				}
			CL1M IJKL 1 {
				ThrustThingZ(0,30,0,0);
				}

			TNT1 AAAA 0 A_SetPitch(pitch+3, SPF_INTERPOLATE);

			//8 ticks to tighten your arms

			PHON ABBC 1 {
				ThrustThingZ(0,2,0,0);
				}
			TNT1 AAAA 0 A_SetPitch(pitch+2, SPF_INTERPOLATE);
			PHON DDEE 1 {
				ThrustThingZ(0,2,0,0);
				}
			TNT1 AAAA 0 A_SetPitch(pitch+0, SPF_INTERPOLATE);

			TNT1 A 0 A_ZoomFactor(1.5);
			//48 ticks
			PHON FGHIFGHIFGHIFGHIFGHIFGHI 2 {
				ThrustThingZ(0,2,0,0);
				}

			//8 ticks
			PHON JIJ 1 {
				ThrustThingZ(0,2,0,0);
				}
			PHON JJIJJ 1 {
				ThrustThingZ(0,2,0,0);
				}
			TNT1 AAAA 0 A_SetPitch(pitch-5, SPF_INTERPOLATE);


			TNT1 A 0 A_ZoomFactor(1.0);
			//11 ticks
			PHON KKLLMN 1 {
				ThrustThingZ(0,2,0,0);
				}
			TNT1 AAAA 0 A_SetPitch(pitch-6, SPF_INTERPOLATE);
			PHON NOO 1 {
				ThrustThingZ(0,2,0,0);
				}
			TNT1 AAAA 0 A_SetPitch(pitch-7, SPF_INTERPOLATE);
			PHON PP 1 {
				ThrustThingZ(0,2,0,0);
				}

			TNT1 A 1 {A_SetPitch(pitch+39, SPF_INTERPOLATE);}
			TNT1 A 1 {A_SetPitch(pitch+39, SPF_INTERPOLATE);}

			STNG BCDEF 1 {
				ThrustThingZ(0,2,0,0);
				}
			STNG F 1 {
				ThrustThingZ(0,2,0,0);
				}
			TNT1 A 0 A_StartSound("StunGrenadeArm", 2);
			STNG GIJJJIHGKLMNOP 1 {
				ThrustThingZ(0,2,0,0);
				}
			TNT1 A 0 A_ZoomFactor(1.3);

		    00HK PQRSTUVW 1 {
				ThrustThingZ(0,1,0,0);
				}

			TNT1 A 0 A_ZoomFactor(1.0);

			TNT1 A 0 A_SetPitch(0, SPF_INTERPOLATE);
			TNT1 A 0 A_Recoil(4);
			TNT1 A 0 PB_UnsetPlayerExecutionProperties();
			Goto GoingToReady2;

		Execution_DarkLord:
		//hands
		"####" AAAAAA 1 ;
		    TNT1 A 0 A_SpawnItemEx("PB_DarkLord_Execution_1", 41, 0,0,0,0,0,0,SXF_NOCHECKPOSITION|SXF_SETMASTER);
			TNT1 A 0 {
