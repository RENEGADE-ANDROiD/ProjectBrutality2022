		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_Imp_CrossZ5")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_ShotgunGuy1")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_ShotgunGuy2")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_ShotgunGuy3")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_ShotgunGuy4")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_ShotgunGuy5")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_ShotgunGuy6")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_ShotgunGuy_CrossImp1")) return true;
