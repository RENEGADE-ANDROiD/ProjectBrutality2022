	ui bool BlockyEnabled() const
	{
		if (!playeringame[consoleplayer]) return false;
		let cv = CVar.GetCVar("pb_pda_blocky", players[consoleplayer]);
		return cv ? cv.GetBool() : true;
	}

	ui int PB_PDA_PreviewGapPx() const
	{
		return max(10, int(double(PB_PDA_PREVIEW_GAP_768) * double(Screen.GetHeight()) / 768.0));
	}

	ui int PB_PDA_PreviewWidthPx() const
	{
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		int w = int(double(PB_PDA_PREVIEW_WIDTH_768) * double(sh) / 768.0);
		int lo = int(double(sw) * 0.17);
		int hi = int(double(sw) * 0.36);
		return clamp(w, lo, hi);
	}

	ui int PB_PDA_BlockyDescClipRight() const
	{
		int sw = Screen.GetWidth();
		if (!BlockyEnabled())
			return sw - 32;
		int safeRight = sw - 32 + pdaBlockyXOffset;
		return safeRight - PB_PDA_PreviewWidthPx() - PB_PDA_PreviewGapPx();
	}

	ui void GetBlockyMetrics(out int originX, out int originY,
	                         out int cols, out int rows,
	                         out int tileW, out int tileH, out int padding) const
	{
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		cols    = PB_PDA_BLOCKY_COLS;
		rows    = PB_PDA_BLOCKY_ROWS;
		padding = max(2, sh / 110);
		int gridLeftPad = padding * 2;
		int gridTopPad  = sh / 6;
		int gridBotPad  = sh / 8;
		int gridW       = (sw / 2) - gridLeftPad - padding;
		int gridH       = sh - gridTopPad - gridBotPad;
		tileW = max(48, (gridW - padding * (cols - 1)) / cols);
		tileH = max(44, (gridH - padding * (rows - 1)) / rows);
		originX = gridLeftPad;
		originY = gridTopPad;
	}

	ui void DrawBlockyTile(int x, int y, int w, int h,
	                       bool hovered, bool locked, double alpha) const
	{
		if (locked)
		{
			Screen.Dim(color(26, 26, 26), 0.55 * alpha, x, y, w, h);
			Screen.DrawLine(x,         y,         x + w - 1, y,         "Gray", int(140 * alpha));
			Screen.DrawLine(x,         y + h - 1, x + w - 1, y + h - 1, "Gray", int(140 * alpha));
			return;
		}
		Color baseCol;
		if (hovered) baseCol = color(50, 110, 150);
		else baseCol = color(25, 50, 65);
		Screen.Dim(baseCol, hovered ? 0.85 * alpha : 0.55 * alpha, x, y, w, h);
		Color border;
		if (hovered) border = color(120, 220, 255);
		else border = color(80, 150, 180);
		int bAlpha = int((hovered ? 230 : 170) * alpha);
		Screen.DrawLine(x,         y,         x + w - 1, y,         border, bAlpha);
		Screen.DrawLine(x,         y + h - 1, x + w - 1, y + h - 1, border, bAlpha);
		Screen.DrawLine(x,         y,         x,         y + h - 1, border, bAlpha);
		Screen.DrawLine(x + w - 1, y,         x + w - 1, y + h - 1, border, bAlpha);
		if (hovered)
		{
			int c = max(3, h / 10);
			Color cc = color(100, 220, 120);
			int cA = int(220 * alpha);
			Screen.DrawLine(x + 2,         y + 2,     x + 2 + c, y + 2,     cc, cA);
			Screen.DrawLine(x + 2,         y + 2,     x + 2,     y + 2 + c, cc, cA);
			Screen.DrawLine(x + w - 3 - c, y + 2,     x + w - 3, y + 2,     cc, cA);
			Screen.DrawLine(x + w - 3,     y + 2,     x + w - 3, y + 2 + c, cc, cA);
			Screen.DrawLine(x + 2,         y + h - 3, x + 2 + c, y + h - 3, cc, cA);
			Screen.DrawLine(x + 2,         y + h - 3 - c, x + 2, y + h - 3, cc, cA);
			Screen.DrawLine(x + w - 3 - c, y + h - 3, x + w - 3, y + h - 3, cc, cA);
			Screen.DrawLine(x + w - 3,     y + h - 3 - c, x + w - 3, y + h - 3, cc, cA);
		}
	}

	ui void DrawBlockyLabel(font fnt, string txt, int x, int y, int w, int h,
	                        bool hovered, double alpha, bool alignTop = false) const
	{
		if (!fnt || txt.length() < 1) return;
		string s = txt;
		s.Replace("\n", " ");
		int maxW = w - 6;
		while (s.length() > 0 && fnt.StringWidth(s) > maxW)
			s = s.Mid(0, s.length() - 1);
		if (s.length() < txt.length() && s.length() >= 2)
		{
			s.DeleteLastCharacter();
			s = s .. "..";
		}
		int textColor = hovered ? Font.CR_OLIVE : Font.CR_GREEN;
		int tx = x + (w - fnt.StringWidth(s)) / 2;
		int pad = max(2, h / 14);
		int ty = alignTop ? (y + pad) : (y + (h - fnt.GetHeight()) / 2);
		Screen.DrawText(fnt, textColor, tx, ty, s, DTA_Alpha, alpha);
	}

	ui string BlockyNormalizeClassString(string cn) const
	{
		return PB_PDA_NormClassStr(cn);
	}

	ui TextureID BlockyFirstFrameOfState(State st) const
	{
		TextureID nullTex;
		for (int n = 0; n < 48 && st; n++)
		{
			TextureID tid = st.GetSpriteTexture(0);
			if (PDA_WeaponStrip_TextureRenderable(tid))
			{
				string tn = TexMan.GetName(tid);
				if (tn.Length() >= 4 && tn.Mid(0, 4) ~== "TNT1")
				{
					st = st.NextState;
					continue;
				}
				if (PDA_ShouldSuppressWeaponPlayerSideArt(tn))
				{
					st = st.NextState;
					continue;
				}
				return tid;
			}
			st = st.NextState;
		}
		return nullTex;
	}

	ui TextureID ResolveBlockyWeaponIconTex(string cn)
	{
		TextureID nullTex;
		cn = BlockyNormalizeClassString(cn);
		if (cn.Length() < 1) return nullTex;
		int hit = blockyWeaponIconKeys.Find(cn);
		if (hit < blockyWeaponIconKeys.Size())
		{
			TextureID cached = blockyWeaponIconVals[hit];
			if (cached.IsValid())
				return cached;
			blockyWeaponIconKeys.Delete(hit);
			blockyWeaponIconVals.Delete(hit);
		}
		if (blockyWeaponIconMissed.Find(cn) < blockyWeaponIconMissed.Size())
			return nullTex;
		TextureID resolved;
		Name nm = cn;
		readonly<Actor> adef = GetDefaultByType((class<Actor>)(nm));
		{
			readonly<Inventory> idef = GetDefaultByType((class<Inventory>)(nm));
			if (idef && idef.Icon.IsValid())
				resolved = idef.Icon;
		}
		if (!resolved.IsValid() && adef)
		{
			resolved = BlockyFirstFrameOfState(adef.SpawnState);
		}
		if (!resolved.IsValid())
		{
			readonly<Weapon> wdef = GetDefaultByType((class<Weapon>)(nm));
			if (wdef && wdef.AltHUDIcon.IsValid())
				resolved = wdef.AltHUDIcon;
		}
		if (!resolved.IsValid() && adef)
		{
			string iconLump = cn .. "ICON";
			TextureID ic = TexMan.CheckForTexture(iconLump, TexMan.Type_Any);
			if (ic.IsValid())
				resolved = ic;
			else
			{
				State rd = adef.FindStateByString("Ready", true);
				if (rd)
					resolved = BlockyFirstFrameOfState(rd);
			}
		}
		if (resolved.IsValid())
		{
			blockyWeaponIconKeys.Push(cn);
			blockyWeaponIconVals.Push(resolved);
		}
		else
		{
			blockyWeaponIconMissed.Push(cn);
		}
		return resolved;
	}

	ui TextureID ResolveBlockyMonsterIconTex(string cn)
	{
		TextureID nullTex;
		cn = BlockyNormalizeClassString(cn);
		if (cn.Length() < 1) return nullTex;
		int hit = blockyMonsterIconKeys.Find(cn);
		if (hit < blockyMonsterIconKeys.Size())
		{
			TextureID cached = blockyMonsterIconVals[hit];
			if (cached.IsValid())
				return cached;
			blockyMonsterIconKeys.Delete(hit);
			blockyMonsterIconVals.Delete(hit);
		}
		if (blockyMonsterIconMissed.Find(cn) < blockyMonsterIconMissed.Size())
			return nullTex;
		Name nm = cn;
		readonly<Actor> adef = GetDefaultByType((class<Actor>)(nm));
		if (!adef)
		{
			blockyMonsterIconMissed.Push(cn);
			return nullTex;
		}
		TextureID resolved = BlockyFirstFrameOfState(adef.SpawnState);
		if (!resolved.IsValid())
			resolved = BlockyFirstFrameOfState(adef.SeeState);
		if (!resolved.IsValid())
			resolved = BlockyFirstFrameOfState(adef.FindState('Idle'));
		if (resolved.IsValid())
		{
			blockyMonsterIconKeys.Push(cn);
			blockyMonsterIconVals.Push(resolved);
		}
		else
		{
			blockyMonsterIconMissed.Push(cn);
		}
		return resolved;
	}

	ui TextureID ResolveBlockyTileIcon(int slotIndex, int objectType)
	{
		TextureID nullTex;
		string cn = "";
		if (objectType == 3)
		{
			if (slotIndex < 0 || slotIndex >= pdaWeapTextArray.Size()) return nullTex;
			cn = pdaWeapTextArray[slotIndex].PDAWeapClassName;
			return ResolveBlockyWeaponIconTex(cn);
		}
		if (objectType == 6)
		{
			if (slotIndex < 0 || slotIndex >= PDAMonsterIconClass.Size()) return nullTex;
			cn = PDAMonsterIconClass[slotIndex];
			return ResolveBlockyMonsterIconTex(cn);
		}
		if (objectType == 7)
		{
			if (slotIndex < 0 || slotIndex >= PDAEquipIconClass.Size()) return nullTex;
			cn = PDAEquipIconClass[slotIndex];
			return ResolveBlockyEquipIconTex(cn);
		}
		return nullTex;
	}

	ui TextureID ResolveBlockyEquipIconTex(string cn)
	{
		TextureID nullTex;
		cn = BlockyNormalizeClassString(cn);
		if (cn.Length() < 1) return nullTex;
		int hit = blockyEquipIconKeys.Find(cn);
		if (hit < blockyEquipIconKeys.Size())
		{
			TextureID cached = blockyEquipIconVals[hit];
			if (cached.IsValid())
				return cached;
			blockyEquipIconKeys.Delete(hit);
			blockyEquipIconVals.Delete(hit);
		}
		if (blockyEquipIconMissed.Find(cn) < blockyEquipIconMissed.Size())
			return nullTex;
		TextureID resolved;
		if (cn == "PB_CF_FreezeMineAmmo")
		{
			TextureID mineIcon = TexMan.CheckForTexture("graphics/pywheel/Equip_Mine.png", TexMan.Type_Any);
			if (!mineIcon.IsValid()) mineIcon = TexMan.CheckForTexture("GRAPHICS/pywheel/Equip_Mine.png", TexMan.Type_Any);
			if (!mineIcon.IsValid()) mineIcon = TexMan.CheckForTexture("Equip_Mine", TexMan.Type_Any);
			if (mineIcon.IsValid())
				resolved = mineIcon;
		}
		Name nm = cn;
		readonly<Inventory> idef = GetDefaultByType((class<Inventory>)(nm));
		if (!resolved.IsValid() && idef && idef.Icon.IsValid())
			resolved = idef.Icon;
		if (!resolved.IsValid() && idef)
			resolved = BlockyFirstFrameOfState(idef.SpawnState);
		if (!resolved.IsValid()
			&& (cn == "AlreadyHaveMeatHook" || cn == "PB_HookToken" || cn == "HookAmmo"))
		{
			TextureID hookIcon = TexMan.CheckForTexture("SPRITES/equipment/Hook/H00KA0.png", TexMan.Type_Any);
			if (!hookIcon.IsValid()) hookIcon = TexMan.CheckForTexture("H00KA0", TexMan.Type_Any);
			if (!hookIcon.IsValid()) hookIcon = TexMan.CheckForTexture("graphics/Equipments/hook.png", TexMan.Type_Any);
			if (hookIcon.IsValid())
				resolved = hookIcon;
		}
		if (!resolved.IsValid() && cn == "HasLeech")
		{
			TextureID leechIcon = TexMan.CheckForTexture("graphics/pywheel/Equip_Leech.png", TexMan.Type_Any);
			if (!leechIcon.IsValid()) leechIcon = TexMan.CheckForTexture("Equip_Leech", TexMan.Type_Any);
			if (leechIcon.IsValid())
				resolved = leechIcon;
		}
		if (resolved.IsValid())
		{
			blockyEquipIconKeys.Push(cn);
			blockyEquipIconVals.Push(resolved);
		}
		else
			blockyEquipIconMissed.Push(cn);
		return resolved;
	}

	ui void DrawBlockyTileIcon(TextureID iconTex, int x, int y, int w, int h,
	                           int labelBottomY, double alpha,
	                           double iconScaleMul = 1.0) const
	{
		int pad = max(2, h / 14);
		int iconTop = labelBottomY + pad / 2;
		int iconBottom = y + h - pad;
		if (iconBottom <= iconTop + 2) return;
		double slotH = double(iconBottom - iconTop);
		slotH = min(slotH, h * 0.58);
		double cx = double(x) + double(w) * 0.5;
		double cy = double(iconTop) + slotH * 0.5;
		if (!iconTex.IsValid())
		{
			Screen.DrawText(BigFont, Font.CR_OLIVE, int(cx - BigFont.StringWidth("?") / 2),
				int(cy - BigFont.GetHeight() / 2), "?",
				DTA_Alpha, alpha,
				DTA_ScaleX, iconScaleMul, DTA_ScaleY, iconScaleMul);
			return;
		}
		Vector2 texSize = TexMan.GetScaledSize(iconTex);
		if (texSize.X < 1 || texSize.Y < 1)
		{
			Screen.DrawText(BigFont, Font.CR_OLIVE, int(cx - BigFont.StringWidth("?") / 2),
				int(cy - BigFont.GetHeight() / 2), "?",
				DTA_Alpha, alpha,
				DTA_ScaleX, iconScaleMul, DTA_ScaleY, iconScaleMul);
			return;
		}
		double maxH = slotH * 0.92;
		double maxW = double(w - pad * 2);
		double scale = min(maxW / texSize.X, maxH / texSize.Y);
		double dw = texSize.X * scale * iconScaleMul;
		double dh = texSize.Y * scale * iconScaleMul;
		Screen.DrawTexture(iconTex, false, cx, cy,
			DTA_DestWidthF, dw, DTA_DestHeightF, dh,
			DTA_KeepRatio, true,
			DTA_Alpha, alpha,
			DTA_CenterOffset, true);
	}

	ui int BlockySectionTotal(int objType) const
	{
		if (objType == 6) return PDAMonsterStrings.Size();
		if (objType == 7) return pdaEquipTextArray.Size();
		return pdaWeapTextArray.Size();
	}

	ui void StampBlockyBackExitFooter(int gridPadding, int sh)
	{
		if (!NonMainMenu)
		{
			for (int h = 0; h < UiObjects.Size(); h++)
			{
				PB_PDAUi_Object ho = UiObjects[h];
				if (!ho) continue;
				if (ho.BackButtonTrue || (ho.ExitButtonTrue && !ho.MainHubBlockyExit))
				{
					ho.ImagePos = (-9999, -9999);
					ho.ImageSize = (1, 1);
				}
			}
			return;
		}
		font f = SmallFont;
		if (!f) return;
		double pts = clamp(double(sh) / 240.0, 2.0, 6.0);
		int pad = PB_PDA_BLOCKY_PAGE_ARROW_HIT_PAD;
		double backW = f.StringWidth("BACK") * pts;
		double sepW = f.StringWidth(" / ") * pts;
		double exitW = f.StringWidth("EXIT") * pts;
		double gh = f.GetHeight() * pts;
		int anchorX = max(8, gridPadding * 2);
		int anchorY = sh - int(gh + 0.5) - max(8, sh / 64);
		for (int i = 0; i < UiObjects.Size(); i++)
		{
			PB_PDAUi_Object o = UiObjects[i];
			if (!o) continue;
			if (o.BackButtonTrue)
			{
				o.ImagePos = (anchorX - pad, anchorY - pad);
				o.ImageSize = (int(backW + 2 * pad + 0.5), int(gh + 2 * pad + 0.5));
			}
			else if (o.ExitButtonTrue && !o.MainHubBlockyExit)
			{
				int exitLeft = anchorX + int(backW + sepW + 0.5) - pad;
				o.ImagePos = (exitLeft, anchorY - pad);
				o.ImageSize = (int(exitW + 2 * pad + 0.5), int(gh + 2 * pad + 0.5));
			}
		}
	}

	ui void ApplyBlockyLayout()
	{
		if (!BlockyEnabled())
		{
			pdaBlockyXOffset = 0;
			if (descriptiondialog)
			{
				int sw0 = Screen.GetWidth();
				descriptiondialog.ImagePos.x = sw0 / 2;
				descriptiondialog.InitialImagePos.x = descriptiondialog.ImagePos.x;
				UpArrowPos.x = descriptiondialog.ImagePos.x + pdaDescLargestStrW;
				DownArrowPos.x = UpArrowPos.x;
			}
			return;
		}
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		int safeRight = sw - 32;
		int originX, originY, cols, rows, tileW, tileH, padding;
		GetBlockyMetrics(originX, originY, cols, rows, tileW, tileH, padding);
		int gridLeftUn = originX;
		int compositionW = safeRight - gridLeftUn;
		pdaBlockyXOffset = (sw - compositionW) / 2 - gridLeftUn;
		int off = pdaBlockyXOffset;
		if (descriptiondialog)
		{
			descriptiondialog.ImagePos.x = sw / 2 + off;
			descriptiondialog.InitialImagePos.x = descriptiondialog.ImagePos.x;
			UpArrowPos.x = descriptiondialog.ImagePos.x + pdaDescLargestStrW;
			DownArrowPos.x = UpArrowPos.x;
		}
		int pageSize = cols * rows;
		if (pageSize >= 1)
		{
		int weapVisible = 0;
		int monVisible  = 0;
		int eqVisible   = 0;
		for (int i = 0; i < UiObjects.Size(); i++)
		{
			if (!UiObjects[i] || UiObjects[i].dontdraw) continue;
			if (UiObjects[i].objecttype == 3) ++weapVisible;
			else if (UiObjects[i].objecttype == 6) ++monVisible;
			else if (UiObjects[i].objecttype == 7) ++eqVisible;
		}
		int weapMaxPage = (weapVisible > 0) ? (weapVisible - 1) / pageSize : 0;
		int monMaxPage  = (monVisible  > 0) ? (monVisible  - 1) / pageSize : 0;
		int eqMaxPage   = (eqVisible   > 0) ? (eqVisible   - 1) / pageSize : 0;
		pdaBlockyWeapPage    = clamp(pdaBlockyWeapPage, 0, weapMaxPage);
		pdaBlockyMonsterPage = clamp(pdaBlockyMonsterPage, 0, monMaxPage);
		pdaBlockyEquipPage   = clamp(pdaBlockyEquipPage, 0, eqMaxPage);
		int weapSlot = 0;
		int monSlot  = 0;
		int eqSlot   = 0;
		for (int i = 0; i < UiObjects.Size(); i++)
		{
			if (!UiObjects[i]) continue;
			if (UiObjects[i].objecttype != 3 && UiObjects[i].objecttype != 6 && UiObjects[i].objecttype != 7) continue;
			if (UiObjects[i].dontdraw)
			{
				UiObjects[i].ImagePos  = (-9999, -9999);
				UiObjects[i].ImageSize = (1, 1);
				continue;
			}
			bool isMon = (UiObjects[i].objecttype == 6);
			bool isEq  = (UiObjects[i].objecttype == 7);
			int slot   = isEq ? eqSlot++ : (isMon ? monSlot++ : weapSlot++);
			int curPage   = isEq ? pdaBlockyEquipPage : (isMon ? pdaBlockyMonsterPage : pdaBlockyWeapPage);
			int entryPage = slot / pageSize;
			if (entryPage != curPage)
			{
				UiObjects[i].ImagePos  = (-9999, -9999);
				UiObjects[i].ImageSize = (1, 1);
				continue;
			}
			int idxOnPage = slot % pageSize;
			int row = idxOnPage / cols;
			int col = idxOnPage % cols;
			UiObjects[i].ImagePos  = (originX + off + col * (tileW + padding),
			                           originY + row * (tileH + padding));
			UiObjects[i].ImageSize = (tileW, tileH);
		}
		}
		StampBlockyBackExitFooter(padding, sh);
	}

	ui string PDA_PreviewSegCaption(bool weapon, bool equip, int seg) const
	{
		if (equip)
		{
			switch (seg)
			{
			case 0: return "Pickup";
			case 1: return "Throw";
			case 2: return "Active";
			case 3: return "Death";
			case 4: return "XDeath";
			default: return "";
			}
		}
		if (weapon)
		{
			switch (seg)
			{
			case 0: return "Pickup";
			case 1: return "Ready";
			case 2: return "Fire";
			case 3: return "Flash";
			case 4: return "Hold";
			case 5: return "Overlay";
			default: return "";
			}
		}
		switch (seg)
		{
		case 0: return "Spawn";
		case 1: return "See";
		case 2: return "Missile";
		case 3: return "Melee";
		case 4: return "Pain";
		case 5: return "Death";
		default: return "";
		}
	}

	ui void EnsurePdaDescAutosizeScale(double pdaTextScale, int paneWidth, int columnAvailH)
	{
		int sec = 0;
		if (WeaponMenuOpened)
			sec = 1;
		else if (MonsterMenuOpened)
			sec = 2;
		else if (EquipmentMenuOpened)
			sec = 3;
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		string txt = descriptiondialog ? descriptiondialog.todraw : "";
		bool miss = (sec != pdaDescAutosizeCacheSection)
			|| (sec == 1 && (currentindex != pdaDescAutosizeCacheWeap
				|| WeaponTextMode != pdaDescAutosizeCacheWtm))
			|| (sec == 2 && currentMonsterIndex != pdaDescAutosizeCacheMon)
			|| (sec == 3 && (currentEquipmentIndex != pdaDescAutosizeCacheEq
				|| WeaponTextMode != pdaDescAutosizeCacheWtm))
			|| (paneWidth != pdaDescAutosizeCachePaneW)
			|| (columnAvailH != pdaDescAutosizeCachePaneH)
			|| (sw != pdaDescAutosizeCacheSw)
			|| (sh != pdaDescAutosizeCacheSh)
			|| (txt != pdaDescAutosizeCacheSource);
		if (!miss)
			return;

		pdaDescAutosizeCacheSection = sec;
		pdaDescAutosizeCacheWeap = currentindex;
		pdaDescAutosizeCacheMon = currentMonsterIndex;
		pdaDescAutosizeCacheEq = currentEquipmentIndex;
		pdaDescAutosizeCacheWtm = WeaponTextMode;
		pdaDescAutosizeCachePaneW = paneWidth;
		pdaDescAutosizeCachePaneH = columnAvailH;
		pdaDescAutosizeCacheSw = sw;
		pdaDescAutosizeCacheSh = sh;
		pdaDescAutosizeCacheSource = txt;

		font df = (descriptiondialog && descriptiondialog.usefont != NULL)
			? descriptiondialog.usefont
			: SmallFont;

		int colH = columnAvailH;
		if (colH < 0)
			colH = 0;

		double basePaneTextScale = pdaTextScale * 0.68 * 0.88;
		double referenceScale = basePaneTextScale * PB_PDA_DESC_AUTOSIZE_MAX_MUL;
		double floorScale = basePaneTextScale * PB_PDA_DESC_AUTOSIZE_FALLBACK_MIN_MUL;

		int rightMargin = max(14, paneWidth / 28);
		int wrapAvailPx = paneWidth - rightMargin;
		if (wrapAvailPx < 24)
			wrapAvailPx = 24;

		double lh = df.GetHeight();
		if (lh < 1.0)
			lh = 1.0;

		double paneVerticalPadding = double(PB_PDA_DESC_PLATE_INTERIOR_PAD * 2);

		int minFromFrac = (colH > 0)
			? max(1, int(PB_PDA_DESC_PLATE_MIN_HEIGHT_FRAC * double(colH)))
			: 1;
		double maxScaleRef = basePaneTextScale * PB_PDA_DESC_AUTOSIZE_MAX_MUL;
		int minFromLines = int(ceil(4.0 * lh * maxScaleRef)) + PB_PDA_DESC_PLATE_INTERIOR_PAD * 2;
		int MIN_PLATE_H = max(minFromFrac, minFromLines);
		if (colH > 0 && MIN_PLATE_H > colH)
			MIN_PLATE_H = colH;

		int maxByFrac = (colH > 0)
			? max(MIN_PLATE_H, int(double(colH) * PB_PDA_DESC_PLATE_MAX_HEIGHT_FRAC))
			: MIN_PLATE_H;
		int MAX_PLATE_H = colH > 0 ? min(colH, maxByFrac) : MIN_PLATE_H;
		if (MAX_PLATE_H < MIN_PLATE_H)
			MAX_PLATE_H = MIN_PLATE_H;

		int innerMaxBudget = MAX_PLATE_H - PB_PDA_DESC_PLATE_INTERIOR_PAD * 2;
		if (innerMaxBudget < 1)
			innerMaxBudget = 1;

		double scale = referenceScale;
		BrokenLines bl;
		int lineCount = 1;
		string wt = "";

		for (int iter = 0; iter < 40; iter++)
		{
			if (scale < floorScale)
				scale = floorScale;
			double scaleSafe = scale < 0.01 ? 0.01 : scale;
			int wrapW = max(24, int(double(wrapAvailPx) / scaleSafe * PB_PDA_DESC_WRAP_W_FRAC));
			bl = df.BreakLines(txt, wrapW);
			lineCount = bl.Count();
			if (lineCount < 1)
				lineCount = 1;

			wt = "";
			for (int li = 0; li < lineCount; li++)
			{
				if (li > 0)
					wt = wt .. "\n";
				wt = wt .. bl.StringAt(li);
			}

			double textBlock = double(lineCount) * lh * scaleSafe * PB_PDA_DESC_TEXT_HEIGHT_PAD_MUL;
			double desiredPlateF = textBlock + paneVerticalPadding;

			if (desiredPlateF <= double(MAX_PLATE_H))
			{
				int plate = int(ceil(desiredPlateF));
				if (plate < MIN_PLATE_H)
					plate = MIN_PLATE_H;
				if (plate > MAX_PLATE_H)
					plate = MAX_PLATE_H;
				int inner = plate - PB_PDA_DESC_PLATE_INTERIOR_PAD * 2;
				if (inner < 1)
					inner = 1;
				if (textBlock <= double(inner) + 2.0)
				{
					pdaDescAutosizeCachedText = wt;
					pdaDescAutosizeCachedScale = scaleSafe;
					pdaDescPaneAutosizedH = plate;
					return;
				}
				plate = int(ceil(textBlock + paneVerticalPadding));
				if (plate < MIN_PLATE_H)
					plate = MIN_PLATE_H;
				if (plate <= MAX_PLATE_H)
				{
					pdaDescAutosizeCachedText = wt;
					pdaDescAutosizeCachedScale = scaleSafe;
					pdaDescPaneAutosizedH = plate;
					return;
				}
			}

			double shrink = (double(innerMaxBudget) * PB_PDA_DESC_AUTOSIZE_FILL)
				/ max(textBlock, 1.0);
			if (shrink >= 0.995)
				shrink = 0.92;
			scale *= shrink;
			scale = max(scale, floorScale);
		}

		if (scale < floorScale)
			scale = floorScale;
		if (scale < 0.01)
			scale = 0.01;

		double scaleFin = scale < 0.01 ? 0.01 : scale;
		int wrapLast = max(24, int(double(wrapAvailPx) / scaleFin * PB_PDA_DESC_WRAP_W_FRAC));
		bl = df.BreakLines(txt, wrapLast);
		lineCount = bl.Count();
		if (lineCount < 1)
			lineCount = 1;
		wt = "";
		for (int li = 0; li < lineCount; li++)
		{
			if (li > 0)
				wt = wt .. "\n";
			wt = wt .. bl.StringAt(li);
		}
		double textBlockLast = double(lineCount) * lh * scaleFin * PB_PDA_DESC_TEXT_HEIGHT_PAD_MUL;
		if (textBlockLast > double(innerMaxBudget))
		{
			scaleFin *= double(innerMaxBudget) * PB_PDA_DESC_AUTOSIZE_FILL / max(textBlockLast, 1.0);
			scaleFin = max(scaleFin, floorScale);
			if (scaleFin < 0.01)
				scaleFin = 0.01;
			wrapLast = max(24, int(double(wrapAvailPx) / scaleFin * PB_PDA_DESC_WRAP_W_FRAC));
			bl = df.BreakLines(txt, wrapLast);
			lineCount = bl.Count();
			if (lineCount < 1)
				lineCount = 1;
			wt = "";
			for (int li = 0; li < lineCount; li++)
			{
				if (li > 0)
					wt = wt .. "\n";
				wt = wt .. bl.StringAt(li);
			}
		}

		pdaDescAutosizeCachedText = wt;
		pdaDescAutosizeCachedScale = scaleFin;
		pdaDescPaneAutosizedH = MAX_PLATE_H;
	}

	ui void DrawBlockyPreviewPane(double pdaTextScale, double gAlpha, bool weapMode, bool equipMode)
	{
		if (!BlockyEnabled() || !NonMainMenu)
			return;
		if (pdaPreviewPaneW < 4 || pdaPreviewPaneH < 4)
			return;
		Screen.Dim(color(32, 36, 48), 0.62 * gAlpha, pdaPreviewPaneX, pdaPreviewPaneY, pdaPreviewPaneW, pdaPreviewPaneH);
		TextureID drawTex;
		bool haveAnim = pdaPrevFrames.Size() > 0;
		if (haveAnim && pdaPrevCurFrame >= 0 && pdaPrevCurFrame < pdaPrevFrames.Size())
			drawTex = pdaPrevFrames[pdaPrevCurFrame];
		if (!drawTex.IsValid() && weapMode && currentindex >= 0 && currentindex < pdaWeapTextArray.Size())
			drawTex = ResolveBlockyWeaponIconTex(pdaWeapTextArray[currentindex].PDAWeapClassName);
		if (!drawTex.IsValid() && !weapMode && !equipMode && currentMonsterIndex >= 0 && currentMonsterIndex < PDAMonsterIconClass.Size())
			drawTex = ResolveBlockyMonsterIconTex(PDAMonsterIconClass[currentMonsterIndex]);
		if (!drawTex.IsValid() && equipMode && currentEquipmentIndex >= 0 && currentEquipmentIndex < PDAEquipIconClass.Size())
			drawTex = ResolveBlockyEquipIconTex(PDAEquipIconClass[currentEquipmentIndex]);
		if (!drawTex.IsValid())
			return;
		Vector2 ts = TexMan.GetScaledSize(drawTex);
		if (ts.X < 0.5 || ts.Y < 0.5)
			return;
		double targetH = double(pdaPreviewPaneH) * 0.86;
		double targetW = double(pdaPreviewPaneW) * 0.92;
		double sc = min(targetH / ts.Y, targetW / ts.X);
		double dw = ts.X * sc;
		double dh = ts.Y * sc;
		double cx = double(pdaPreviewPaneX) + double(pdaPreviewPaneW) * 0.5;
		double cy = double(pdaPreviewPaneY) + double(pdaPreviewPaneH) * 0.44;
		int clipL = pdaPreviewPaneX + 2;
		int clipT = pdaPreviewPaneY + 2;
		int clipR = pdaPreviewPaneX + pdaPreviewPaneW - 2;
		int clipB = pdaPreviewPaneY + pdaPreviewPaneH - 2;
		Screen.DrawTexture(drawTex, false, cx, cy,
			DTA_DestWidthF, dw, DTA_DestHeightF, dh,
			DTA_Alpha, gAlpha, DTA_CenterOffset, true,
			DTA_ClipLeft, clipL, DTA_ClipTop, clipT, DTA_ClipRight, clipR, DTA_ClipBottom, clipB);
		if (haveAnim && pdaPrevCurFrame >= 0 && pdaPrevCurFrame < pdaPrevSegIdx.Size())
		{
			string cap = PDA_PreviewSegCaption(weapMode, equipMode, pdaPrevSegIdx[pdaPrevCurFrame]);
			if (cap.Length() > 0)
			{
				double capS = pdaTextScale * 0.52;
				int capY = pdaPreviewPaneY + pdaPreviewPaneH - int(double(SmallFont.GetHeight()) * capS) - 8;
				Screen.DrawText(SmallFont, Font.CR_GREEN, pdaPreviewPaneX + 8, capY, cap,
					DTA_ScaleX, capS, DTA_ScaleY, capS,
					DTA_Alpha, gAlpha,
					DTA_ClipLeft, clipL, DTA_ClipTop, clipT, DTA_ClipRight, clipR, DTA_ClipBottom, clipB);
			}
		}
	}

	ui void SyncBlockyPageArrowHitboxes(double pdaTextScale)
	{
		if (!PDAMode || UiObjects.Size() < 1) return;
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		int midX = sw / 2;

		if (AchievementsMenuOpened && BlockyEnabled())
		{
			font pageFont = NULL;
			for (int pi = 0; pi < UiObjects.Size(); pi++)
			{
				PB_PDAUi_Object po = UiObjects[pi];
				if (po && po.objecttype == 4 && po.usefont)
				{
					pageFont = po.usefont;
					break;
				}
			}
			double pageVisH = SmallFont.GetHeight() * pdaTextScale
				* PB_PDA_BLOCKY_PAGE_ARROW_VIS_MUL;
			if (pageFont)
				pageVisH = pageFont.GetHeight() * pdaTextScale
					* PB_PDA_BLOCKY_PAGE_ARROW_VIS_MUL;
			double om = PB_PDA_BLOCKY_PAGE_ARROW_OUTSIDE_MARGIN;
			int listLeft, listTop, listRight, listBottom;
			PDA_AchievementBrowseListMetrics(listLeft, listTop, listRight, listBottom);
			int arrowX = (listLeft + listRight) / 2;
			UpArrowPos = (arrowX, double(listTop) - pageVisH - om);
			DownArrowPos = (arrowX, double(listBottom) + om);
		}
		else if (BlockyEnabled() && descriptiondialog != null)
		{
			font pageFont = NULL;
			for (int pi = 0; pi < UiObjects.Size(); pi++)
			{
				PB_PDAUi_Object po = UiObjects[pi];
				if (po && po.objecttype == 4 && po.usefont)
				{
					pageFont = po.usefont;
					break;
				}
			}
			double pageVisH = SmallFont.GetHeight() * pdaTextScale
				* PB_PDA_BLOCKY_PAGE_ARROW_VIS_MUL;
			if (pageFont)
				pageVisH = pageFont.GetHeight() * pdaTextScale
					* PB_PDA_BLOCKY_PAGE_ARROW_VIS_MUL;
			double om = PB_PDA_BLOCKY_PAGE_ARROW_OUTSIDE_MARGIN;
			double clipTop = double(descriptiondialog.descClipY);
			double clipBottom = double(descriptiondialog.descClipH);
			UpArrowPos.y = clipTop - pageVisH - om;
			DownArrowPos.y = clipBottom + om;
			double catRowY = clipBottom + om + pageVisH + PB_PDA_BLOCKY_CAT_ARROW_BELOW_DESC;
			double paneLeft = double(descriptiondialog.ImagePos.x);
			double paneStrW = double(pdaDescLargestStrW);
			double descColRight = double(PB_PDA_BlockyDescClipRight());
			int catPad = PB_PDA_BLOCKY_CAT_ARROW_HIT_PAD;
			double catMul = pdaTextScale * PB_PDA_BLOCKY_CAT_ARROW_VIS_MUL;

			for (int ci = 0; ci < UiObjects.Size(); ci++)
			{
				PB_PDAUi_Object co = UiObjects[ci];
				if (!co) continue;
				if (co.objecttype != 12 && co.objecttype != 13) continue;
				if (co.usefont == NULL || !co.toDraw) continue;
				font cf = co.usefont;
				double visW = cf.StringWidth(co.toDraw) * catMul;
				double visH = cf.GetHeight() * catMul;
				int chw = int(visW + 2 * catPad);
				int chh = int(visH + 2 * catPad);
				Vector2 catAt;
				if (co.objecttype == 12)
				{
					catAt = (paneLeft, catRowY);
					LeftCatArrowVisPos = catAt;
				}
				else
				{
					double rightWant = paneLeft + paneStrW;
					double rightMax = descColRight - visW - 4.0;
					if (rightMax < paneLeft)
						rightMax = paneLeft;
					catAt = (min(rightWant, rightMax), catRowY);
					RightCatArrowVisPos = catAt;
				}
				int chx = int(catAt.X) - catPad;
				int chy = int(catAt.Y) - catPad;
				if (chy + chh > sh - 8)
					chy = max(0, sh - 8 - chh);
				if (chx + chw > sw - 8)
					chx = max(midX + 2, sw - 8 - chw);
				if (chx < 0) chx = 0;
				co.ImagePos = (chx, chy);
				co.ImageSize = (chw, chh);
			}
		}
		else if (!BlockyEnabled() && descriptiondialog != null)
		{
			font legFont = NULL;
			for (int qi = 0; qi < UiObjects.Size(); qi++)
			{
				PB_PDAUi_Object qo = UiObjects[qi];
				if (qo && qo.objecttype == 4 && qo.usefont)
				{
					legFont = qo.usefont;
					break;
				}
			}
			double ah = legFont ? legFont.GetHeight() * pdaTextScale
				: SmallFont.GetHeight() * pdaTextScale;
			double om = PB_PDA_BLOCKY_PAGE_ARROW_OUTSIDE_MARGIN;
			UpArrowPos.y = double(descriptiondialog.descClipY) - ah - om;
			DownArrowPos.y = double(descriptiondialog.descClipH) + om;
		}

		for (int i = 0; i < UiObjects.Size(); i++)
		{
			PB_PDAUi_Object o = UiObjects[i];
			if (!o) continue;
			if (o.objecttype != 4 && o.objecttype != 5) continue;
			if (o.usefont == NULL || !o.toDraw) continue;
			font f = o.usefont;
			if (!BlockyEnabled())
			{
				if (o.objecttype == 4)
					o.ImagePos = UpArrowPos;
				else
					o.ImagePos = DownArrowPos;
				o.ImageSize.X = f.StringWidth(o.toDraw) * pdaTextScale;
				o.ImageSize.Y = f.GetHeight() * pdaTextScale;
				continue;
			}
			int pad = PB_PDA_BLOCKY_PAGE_ARROW_HIT_PAD;
			double baseMul = pdaTextScale * PB_PDA_BLOCKY_PAGE_ARROW_VIS_MUL;
			double visW = f.StringWidth(o.toDraw) * baseMul;
			double visH = f.GetHeight() * baseMul;
			int hw = int(visW + 2 * pad);
			int hh = int(visH + 2 * pad);
			Vector2 basePos = (o.objecttype == 4) ? UpArrowPos : DownArrowPos;
			int hx = int(basePos.X) - pad;
			int hy = int(basePos.Y) - pad;
			if (hy + hh > sh - 8)
				hy = max(0, sh - 8 - hh);
			if (hx + hw > sw - 8)
				hx = max(midX + 2, sw - 8 - hw);
			o.ImagePos = (hx, hy);
			o.ImageSize = (hw, hh);
		}
	}

	ui void StampBlockyMainMenuTiles()
	{
		if (!BlockyEnabled())
		{
			for (int z = 0; z < UiObjects.Size(); z++)
			{
				PB_PDAUi_Object zo = UiObjects[z];
				if (zo && (zo.MainHubBlockyExit || zo.MainHubBlockySlot || zo.MainHubBlockyAchievements))
				{
					zo.ImagePos = (-9999, -9999);
					zo.ImageSize = (1, 1);
				}
			}
			return;
		}
		if (NonMainMenu)
		{
			for (int z = 0; z < UiObjects.Size(); z++)
			{
				PB_PDAUi_Object zo = UiObjects[z];
				if (zo && (zo.MainHubBlockyExit || zo.MainHubBlockySlot || zo.MainHubBlockyAchievements))
				{
					zo.ImagePos = (-9999, -9999);
					zo.ImageSize = (1, 1);
				}
			}
			return;
		}
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		int margin = max(12, sw / 42);
		int gap = max(6, margin / 3);
		int botReserve = sh / 5;
		int tileW = (sw - margin * 2 - gap * 2) / 3;
		int tileH = clamp(sh / 3, 120, sh - botReserve - margin * 2);
		int y0 = margin + sh / 16;
		int exitH = clamp(int(double(tileH) * 0.88), 72, tileH);
		int vGap = max(gap, tileH / 2);
		int exitY = y0 + tileH + vGap;
		bool xpOn = PB_EventHandler.PB_XP_RewardsOn();
		bool achOn = PB_EventHandler.PB_AchievementsOn();
		int footerCount = 1;
		if (xpOn)
			footerCount++;
		if (achOn)
			footerCount++;
		int availableW = sw - margin * 2;
		int footerGap = gap;
		int footerGaps = max(0, footerCount - 1);
		int btnW = max(120, (availableW - footerGap * footerGaps) / footerCount);
		int cx = margin;
		for (int i = 0; i < UiObjects.Size(); i++)
		{
			PB_PDAUi_Object o = UiObjects[i];
			if (!o)
				continue;
			if (o.MainHubBlockySlot)
			{
				if (!xpOn)
				{
					o.ImagePos = (-9999, -9999);
					o.ImageSize = (1, 1);
				}
				else
				{
					o.ImagePos = (cx, exitY);
					o.ImageSize = (btnW, exitH);
					cx += btnW + footerGap;
				}
				continue;
			}
			if (o.MainHubBlockyAchievements)
			{
				if (!achOn)
				{
					o.ImagePos = (-9999, -9999);
					o.ImageSize = (1, 1);
				}
				else
				{
					o.ImagePos = (cx, exitY);
					o.ImageSize = (btnW, exitH);
					cx += btnW + footerGap;
				}
				continue;
			}
			if (o.MainHubBlockyExit)
			{
				o.ImagePos = (cx, exitY);
				o.ImageSize = (btnW, exitH);
				continue;
			}
			int col = -1;
			if (o.objecttype == 1)
				col = 0;
			else if (o.objecttype == 2)
				col = 1;
			else if (o.objecttype == 14)
				col = 2;
			else
				continue;
			int x0 = margin + col * (tileW + gap);
			o.ImagePos = (x0, y0);
			o.ImageSize = (tileW, tileH);
		}
	}

	ui TextureID PDA_EquipRingTex(int k) const
	{
		switch (k)
		{
		case 0:
			return TexMan.CheckForTexture("HFRAGY", TexMan.Type_Any);
		case 1:
			return TexMan.CheckForTexture("HMINEY", TexMan.Type_Any);
		case 2:
			return TexMan.CheckForTexture("HSTUNY", TexMan.Type_Any);
		case 3:
			return TexMan.CheckForTexture("SGGRA0", TexMan.Type_Any);
		case 4:
			return TexMan.CheckForTexture("VGR1A0", TexMan.Type_Any);
		case 5:
			return TexMan.CheckForTexture("MOLOV0", TexMan.Type_Any);
		case 6:
			return TexMan.CheckForTexture("HLECHY", TexMan.Type_Any);
		case 7:
			return TexMan.CheckForTexture("HREVCY", TexMan.Type_Any);
		case 8:
			{
				TextureID hk = TexMan.CheckForTexture("graphics/Equipments/hook.png", TexMan.Type_Any);
				if (!hk.IsValid())
					hk = TexMan.CheckForTexture("H00KA0", TexMan.Type_Any);
				return hk;
			}
		case 9:
			{
				TextureID fn = TexMan.CheckForTexture("FGNDH0", TexMan.Type_Any);
				if (!fn.IsValid())
					fn = TexMan.CheckForTexture("graphics/pywheel/grenade_cryo.png", TexMan.Type_Any);
				return fn;
			}
		case 10:
			return TexMan.CheckForTexture("BXPLA0", TexMan.Type_Any);
		case 11:
			return TexMan.CheckForTexture("FZBLA0", TexMan.Type_Any);
		case 12:
			{
				TextureID iw = TexMan.CheckForTexture("CMSTA0", TexMan.Type_Any);
				if (!iw.IsValid())
					iw = TexMan.CheckForTexture("BXPLA0", TexMan.Type_Any);
				return iw;
			}
		case 13:
			return TexMan.CheckForTexture("PLAYE1", TexMan.Type_Any);
		case 14:
			return TexMan.CheckForTexture("ELPDA0", TexMan.Type_Any);
		case 15:
			return TexMan.CheckForTexture("F1REA0", TexMan.Type_Any);
		case 16:
			return TexMan.CheckForTexture("FZBLA0", TexMan.Type_Any);
		default:
			break;
		}
		TextureID zz;
		return zz;
	}

	// cx/cy = center of the layout box (maxW x maxH). DTA_CenterOffset aligns texture center to that point.
	// clipToMaxBox: only for UI tiles that must stay inside a slot; corner weapon/mode HUD must not clip
	// (cover-fit + DTA_Clip* was cutting wide/tall Inventory.Icon art at the box edge).
	ui void DrawClipFittedTexture(TextureID tex, double cx, double cy, double maxW, double maxH, double alpha, bool coverFit = false, bool clipToMaxBox = false) const
	{
		if (!tex.IsValid())
			return;
		Vector2 ts = TexMan.GetScaledSize(tex);
		if (ts.X < 1 || ts.Y < 1)
			return;
		double sc = coverFit ? max(maxW / ts.X, maxH / ts.Y) : min(maxW / ts.X, maxH / ts.Y);
		double dw = ts.X * sc;
		double dh = ts.Y * sc;
		if (clipToMaxBox)
		{
			int clipL = int(cx - maxW * 0.5);
			int clipT = int(cy - maxH * 0.5);
			int clipR = int(cx + maxW * 0.5);
			int clipB = int(cy + maxH * 0.5);
			Screen.DrawTexture(tex, false, cx, cy,
				DTA_DestWidthF, dw, DTA_DestHeightF, dh,
				DTA_Alpha, alpha, DTA_CenterOffset, true,
				DTA_ClipLeft, clipL, DTA_ClipTop, clipT, DTA_ClipRight, clipR, DTA_ClipBottom, clipB);
			return;
		}
		Screen.DrawTexture(tex, false, cx, cy,
			DTA_DestWidthF, dw, DTA_DestHeightF, dh,
			DTA_Alpha, alpha, DTA_CenterOffset, true);
	}

	ui void DrawPDAEquipmentWheelRing(int cx, int cy, double radius, double alpha, double pulseMul) const
	{
		int n = 17;
		for (int k = 0; k < n; k++)
		{
			TextureID tid = PDA_EquipRingTex(k);
			if (!tid.IsValid())
				continue;
			double ang = (360.0 / n) * k - 90.0;
			double rads = ang * 3.14159265358979323846 / 180.0;
			double ix = double(cx) + cos(rads) * radius * pulseMul;
			double iy = double(cy) + sin(rads) * radius * pulseMul;
			Vector2 texSize = TexMan.GetScaledSize(tid);
			if (texSize.X < 1 || texSize.Y < 1)
				continue;
			double box = 24.0 * pulseMul;
			double sc = min(box / texSize.X, box / texSize.Y);
			double dw = texSize.X * sc;
			double dh = texSize.Y * sc;
			Screen.DrawTexture(tid, false, ix, iy,
				DTA_DestWidthF, dw, DTA_DestHeightF, dh,
				DTA_Alpha, alpha, DTA_CenterOffset, true);
		}
	}

	override void RenderOverlay(RenderEvent e)
	{
		if (!e) return;
		if (gamestate == GS_TITLELEVEL) return;
		bool coldStart = gametic < PB_PDA_UI_INIT_MIN_GAMETIC;
		bool hideHUD = false;
		if (playeringame[consoleplayer])
		{
			let plr = players[consoleplayer];
			if (plr && plr.mo && plr.mo.CountInv("CameraRunner") > 0) hideHUD = true;
		}
		if (!coldStart && !hideHUD)
		{
			DrawPB2022WeaponPickupOverlay();
			DrawPB2022WeaponModeOverlay();
		}
		bool dashEffectOn = false;
		if (playeringame[consoleplayer])
		{
			let cvDash = CVar.GetCVar("pb_dasheffect", players[consoleplayer]);
			if (cvDash) { dashEffectOn = cvDash.GetBool(); }
		}
		if (!coldStart && !hideHUD && dashAlpha > 0 && dashEffectOn)
		{
			TextureID dashTex = TexMan.CheckForTexture("graphics/hud/fullscrn/pb_dashoverlay.png", TexMan.Type_Any);
			if (dashTex)
			{
				Screen.DrawTexture(dashTex, false,
					Screen.GetWidth() / 2.0, Screen.GetHeight() / 2.0,
					DTA_DestWidth, Screen.GetWidth(), DTA_DestHeight, Screen.GetHeight(),
					DTA_Alpha, dashAlpha,
					DTA_CenterOffset, true,
					DTA_ScaleX, dashScale, DTA_ScaleY, dashScale
				);
			}
		}
		if (!coldStart && !hideHUD && !PDAMode && !KatanaDualChoiceMode)
			DrawGloryKillFuelHud();
		if (gametic >= PB_PDA_UI_INIT_MIN_GAMETIC
			&& MouseX == 1 && MouseY == 1 && !MousePositionSet
			&& (PDAMode || KatanaDualChoiceMode))
		{
			SendNetworkEvent("modifymousepos",Screen.GetWidth() / 2,Screen.GetHeight() / 2);
		}
		if (PDAMode == true)
		{
			if (!PDA_TryEnsureUiObjects(true))
				return;
			globalPDAAlpha = 1.0;
			TextureID cursortex = Texman.CheckForTexture("ZCURSOR",TexMan.Type_Any);
			double pdaTextScale = clamp(Screen.GetHeight() / 240.0, 2.0, 6.0);
			bool blockyOn = BlockyEnabled();
			ApplyBlockyLayout();
			StampBlockyMainMenuTiles();
			SyncBlockyPageArrowHitboxes(pdaTextScale);
			int pdaDescClipRight = PB_PDA_BlockyDescClipRight();
			{
				int sw = Screen.GetWidth();
				int sr = sw - 32 + (blockyOn ? pdaBlockyXOffset : 0);
				pdaPreviewPaneW = blockyOn ? PB_PDA_PreviewWidthPx() : 0;
				pdaPreviewPaneX = sr - pdaPreviewPaneW;
				pdaPreviewPaneY = (descriptiondialog != null) ? descriptiondialog.descClipY : 0;
				pdaPreviewPaneH = (descriptiondialog != null)
					? (descriptiondialog.descClipH - descriptiondialog.descClipY) : 0;
			}
			PB_PDAUiBackdrop.DrawFullScreen(globalPDAAlpha);
			if (AchievementsMenuOpened)
				DrawPDAAchievementBrowse(globalPDAAlpha);
			if (UiObjects.Size() >= 1)
			{
				for (int i = 0; i < UiObjects.Size(); i++)
				{
					if (AchievementsMenuOpened)
					{
						if (UiObjects[i].objecttype != 4 && UiObjects[i].objecttype != 5
							&& !UiObjects[i].BackButtonTrue
							&& !(UiObjects[i].ExitButtonTrue && !UiObjects[i].MainHubBlockyExit))
						{
							UiObjects[i].notdrawn = true;
							continue;
						}
					}
					if (UiObjects[i].dontdraw == true)
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (!blockyOn && UiObjects[i].MainHubBlockyExit)
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (UiObjects[i].MainHubBlockySlot && (!blockyOn || !PB_EventHandler.PB_XP_RewardsOn()))
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (UiObjects[i].MainHubBlockyAchievements
						&& (!blockyOn || !PB_EventHandler.PB_AchievementsOn() || NonMainMenu))
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (UiObjects[i].MainHubBlockyExit
						&& (MonsterMenuOpened || WeaponMenuOpened || EquipmentMenuOpened))
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (UiObjects[i].objecttype == 1 && (MonsterMenuOpened || WeaponMenuOpened || EquipmentMenuOpened))
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (uiObjects[i].objecttype == 2 && (WeaponMenuOpened || MonsterMenuOpened || EquipmentMenuOpened))
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (uiObjects[i].objecttype == 14 && (WeaponMenuOpened || MonsterMenuOpened || EquipmentMenuOpened))
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (uiObjects[i].NonMainMenuOnly && !NonMainMenu)
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (uiObjects[i].MonsterMenuOnly == true && MonsterMenuOpened == false)
					{
						UiObjects[i].notdrawn = true;
						continue;
					}
					if (uiObjects[i].WeaponMenuOnly == true && WeaponMenuOpened == false)
					{
						uiObjects[i].notdrawn = true;
						continue;
					}
					if (uiObjects[i].EquipmentMenuOnly == true && EquipmentMenuOpened == false)
					{
						uiObjects[i].notdrawn = true;
						continue;
					}
					if (uiObjects[i].NonMainMenuOnly == true && !NonMainMenu)
					{
						uiObjects[i].notdrawn = true;
						continue;
					}
					if (blockyOn && !NonMainMenu && (UiObjects[i].objecttype == 1 || UiObjects[i].objecttype == 2 || UiObjects[i].objecttype == 14))
					{
						bool hovered = UiObjects[i].MouseOvered;
						double pulseMul = hovered
							? (1.0 + PB_PDA_BLOCKY_ICON_PULSE_AMP * sin(gametic * 0.15))
							: 1.0;
						int bx = int(UiObjects[i].ImagePos.x);
						int by = int(UiObjects[i].ImagePos.y);
						int bw = int(UiObjects[i].ImageSize.x);
						int bh = int(UiObjects[i].ImageSize.y);
						DrawBlockyTile(bx, by, bw, bh, hovered, false, globalPDAAlpha);
						int bandH = max(BigFont.GetHeight() + 10, bh / 5);
						int contentBottom = by + bh - bandH - 6;
						int midX = bx + bw / 2;
						int midCont = by + (contentBottom - by) / 2;
						double slotW = bw * 0.94 * pulseMul;
						double slotH = (contentBottom - by - 8) * pulseMul;
						TextureID anim;
						if (UiObjects[i].objecttype == 2 && pdaMainWeapFrames.Size() > 0)
							anim = pdaMainWeapFrames[pdaMainWeapCur];
						else if (UiObjects[i].objecttype == 1 && pdaMainMonFrames.Size() > 0)
							anim = pdaMainMonFrames[pdaMainMonCur];
						else if (UiObjects[i].objecttype == 14 && pdaMainEquipFrames.Size() > 0)
							anim = pdaMainEquipFrames[pdaMainEquipCur];
						if (anim.IsValid())
							DrawClipFittedTexture(anim, midX, midCont, slotW, slotH, globalPDAAlpha * 0.92, false, true);
						Screen.Dim(color(6, 10, 18), 0.62 * globalPDAAlpha, bx + 4, contentBottom - 4, bw - 8, bandH + 8);
						string lab = UiObjects[i].toDraw;
						double lblSc = pdaTextScale * 0.72;
						double lw = BigFont.StringWidth(lab) * lblSc;
						double lx = bx + (bw - lw) / 2;
						double ly = by + bh - bandH - 4;
						Screen.DrawText(BigFont, hovered ? Font.CR_OLIVE : Font.CR_GREEN, lx, ly, lab,
							DTA_ScaleX, lblSc, DTA_ScaleY, lblSc,
							DTA_Alpha, globalPDAAlpha);
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (blockyOn && UiObjects[i].MainHubBlockyAchievements && PB_EventHandler.PB_AchievementsOn() && !NonMainMenu)
					{
						bool hovered = UiObjects[i].MouseOvered;
						int bx = int(UiObjects[i].ImagePos.x);
						int by = int(UiObjects[i].ImagePos.y);
						int bw = int(UiObjects[i].ImageSize.x);
						int bh = int(UiObjects[i].ImageSize.y);
						DrawBlockyTile(bx, by, bw, bh, hovered, false, globalPDAAlpha);
						double lblSc = pdaTextScale * 0.62;
						string lab = UiObjects[i].toDraw;
						double lw = BigFont.StringWidth(lab) * lblSc;
						double lx = bx + (bw - lw) / 2;
						double ly = by + bh * 0.1;
						Screen.DrawText(BigFont, hovered ? Font.CR_OLIVE : Font.CR_GREEN,
							lx, ly, lab,
							DTA_ScaleX, lblSc, DTA_ScaleY, lblSc,
							DTA_Alpha, globalPDAAlpha);
						int unlocked = 0, total = 0;
						if (gametic - pdaAchCacheGametic > 28)
						{
							let achHandler = VUAS_AchievementHandler.GetHandler();
							unlocked = 0;
							total = 0;
							if (achHandler)
							{
								total = achHandler.achievements.Size();
								for (int ai = 0; ai < total; ai++)
								{
									if (achHandler.achievements[ai].isUnlocked)
										unlocked++;
								}
							}
							pdaAchUnlockedCache = unlocked;
							pdaAchTotalCache = total;
							pdaAchCacheGametic = gametic;
						}
						else
						{
							unlocked = pdaAchUnlockedCache;
							total = pdaAchTotalCache;
						}
						string sub = total > 0
							? String.Format("%d / %d unlocked", unlocked, total)
							: "View progress";
						double statSc = clamp(pdaTextScale * 0.46, 2.5, 5.5);
						double tw = BigFont.StringWidth(sub) * statSc;
						for (int fit = 0; fit < 6 && tw > bw - 16; fit++)
						{
							statSc *= 0.9;
							tw = BigFont.StringWidth(sub) * statSc;
						}
						double tx = bx + (bw - tw) / 2;
						double ty = by + bh * 0.52;
						Screen.DrawText(BigFont, hovered ? Font.CR_OLIVE : Font.CR_GRAY,
							tx, ty, sub,
							DTA_ScaleX, statSc, DTA_ScaleY, statSc,
							DTA_Alpha, globalPDAAlpha * 0.95);
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (blockyOn && UiObjects[i].MainHubBlockyExit && !NonMainMenu)
					{
						bool hovered = UiObjects[i].MouseOvered;
						int bx = int(UiObjects[i].ImagePos.x);
						int by = int(UiObjects[i].ImagePos.y);
						int bw = int(UiObjects[i].ImageSize.x);
						int bh = int(UiObjects[i].ImageSize.y);
						DrawBlockyTile(bx, by, bw, bh, hovered, false, globalPDAAlpha);
						double lblSc = pdaTextScale * 0.72;
						string lab = UiObjects[i].toDraw;
						double lw = BigFont.StringWidth(lab) * lblSc;
						double lx = bx + (bw - lw) / 2;
						double ly = by + (bh - BigFont.GetHeight() * lblSc) / 2;
						Screen.DrawText(BigFont, hovered ? Font.CR_OLIVE : Font.CR_GREEN,
							lx, ly, lab,
							DTA_ScaleX, lblSc, DTA_ScaleY, lblSc,
							DTA_Alpha, globalPDAAlpha);
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (blockyOn && UiObjects[i].MainHubBlockySlot && PB_EventHandler.PB_XP_RewardsOn() && !NonMainMenu)
					{
						bool hovered = UiObjects[i].MouseOvered;
						int bx = int(UiObjects[i].ImagePos.x);
						int by = int(UiObjects[i].ImagePos.y);
						int bw = int(UiObjects[i].ImageSize.x);
						int bh = int(UiObjects[i].ImageSize.y);
						DrawBlockyTile(bx, by, bw, bh, hovered, false, globalPDAAlpha);
						double lblSc = pdaTextScale * 0.68;
						string lab = UiObjects[i].toDraw;
						double lw = BigFont.StringWidth(lab) * lblSc;
						double lx = bx + (bw - lw) / 2;
						double ly = by + bh * 0.08;
						Screen.DrawText(BigFont, hovered ? Font.CR_OLIVE : Font.CR_GREEN,
							lx, ly, lab,
							DTA_ScaleX, lblSc, DTA_ScaleY, lblSc,
							DTA_Alpha, globalPDAAlpha);
						int xpV = 0, rkV = 0, spV = 0;
						if (playeringame[consoleplayer])
						{
							let mo = players[consoleplayer].mo;
							if (mo)
							{
								xpV = mo.CountInv("PB_XPBank");
								rkV = mo.CountInv("PB_XPRank");
								spV = mo.CountInv("PB_RewardSpin");
							}
						}
						string sub1 = String.Format("XP: %d    RANK: %d", xpV, rkV);
						string sub2 = String.Format("PTS: %d  (%d to spin)", spV, PB_XPRewardsHandler.SpinCost());
						double statSc = clamp(pdaTextScale * 0.46, 2.5, 5.5);
						int statPad = max(8, bh / 22);
						int margin = max(8, bw / 28);
						for (int fit = 0; fit < 6; fit++)
						{
							double twA = BigFont.StringWidth(sub1) * statSc;
							double twB = BigFont.StringWidth(sub2) * statSc;
							if (max(twA, twB) + statPad * 2 <= bw - margin * 2)
								break;
							statSc *= 0.9;
						}
						double lineH = BigFont.GetHeight() * statSc;
						double tw1 = BigFont.StringWidth(sub1) * statSc;
						double tw2 = BigFont.StringWidth(sub2) * statSc;
						int boxW = int(max(tw1, tw2) + statPad * 2 + 0.5);
						int boxH = int(lineH * 2.2 + statPad * 2 + 0.5);
						boxW = min(boxW, bw - margin * 2);
						int boxX = bx + (bw - boxW) / 2;
						double titleBottom = ly + BigFont.GetHeight() * lblSc + bh * 0.04;
						double availBot = by + bh - margin;
						double extraY = (availBot - titleBottom) - boxH;
						if (extraY < 0)
							extraY = 0;
						int boxY = int(titleBottom + extraY * 0.5 + 0.5);
						if (boxY + boxH > by + bh - margin)
							boxY = max(int(titleBottom + 0.5), by + bh - margin - boxH);
						Screen.Dim(color(4, 8, 14), 0.72 * globalPDAAlpha, boxX, boxY, boxW, boxH);
						{
							int brA = int(clamp(200 * globalPDAAlpha, 80, 255));
							Screen.DrawLine(boxX, boxY, boxX + boxW - 1, boxY, "Gray", brA);
							Screen.DrawLine(boxX, boxY + boxH - 1, boxX + boxW - 1, boxY + boxH - 1, "Gray", brA);
							Screen.DrawLine(boxX, boxY, boxX, boxY + boxH - 1, "Gray", brA);
							Screen.DrawLine(boxX + boxW - 1, boxY, boxX + boxW - 1, boxY + boxH - 1, "Gray", brA);
						}
						double tx = boxX + (boxW - tw1) / 2;
						double ty = double(boxY) + statPad;
						double statAlph = globalPDAAlpha * 0.98;
						for (int ox = -1; ox <= 1; ox++)
						{
							for (int oy = -1; oy <= 1; oy++)
							{
								if (ox == 0 && oy == 0)
									continue;
								Screen.DrawText(BigFont, Font.CR_BLACK, tx + ox, ty + oy, sub1,
									DTA_ScaleX, statSc, DTA_ScaleY, statSc,
									DTA_Alpha, statAlph * 0.55);
							}
						}
						Screen.DrawText(BigFont, Font.CR_GREEN, tx, ty, sub1,
							DTA_ScaleX, statSc, DTA_ScaleY, statSc,
							DTA_Alpha, statAlph);
						ty += lineH * 1.12;
						double tx2 = boxX + (boxW - tw2) / 2;
						for (int ox2 = -1; ox2 <= 1; ox2++)
						{
							for (int oy2 = -1; oy2 <= 1; oy2++)
							{
								if (ox2 == 0 && oy2 == 0)
									continue;
								Screen.DrawText(BigFont, Font.CR_BLACK, tx2 + ox2, ty + oy2, sub2,
									DTA_ScaleX, statSc, DTA_ScaleY, statSc,
									DTA_Alpha, statAlph * 0.55);
							}
						}
						Screen.DrawText(BigFont, Font.CR_OLIVE, tx2, ty, sub2,
							DTA_ScaleX, statSc, DTA_ScaleY, statSc,
							DTA_Alpha, statAlph);
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (blockyOn && (UiObjects[i].objecttype == 3 || UiObjects[i].objecttype == 6 || UiObjects[i].objecttype == 7)
						&& UiObjects[i].ImagePos.x > -1000 && UiObjects[i].todraw)
					{
						bool hovered = UiObjects[i].MouseOvered;
						bool selected = (UiObjects[i].objecttype == 3 && WeaponMenuOpened
							&& UiObjects[i].entrynumber == currentindex)
							|| (UiObjects[i].objecttype == 6 && MonsterMenuOpened
							&& UiObjects[i].entrynumber == currentMonsterIndex)
							|| (UiObjects[i].objecttype == 7 && EquipmentMenuOpened
							&& UiObjects[i].entrynumber == currentEquipmentIndex);
						double iconPulseMul = (hovered || selected)
							? (1.0 + PB_PDA_BLOCKY_ICON_PULSE_AMP * sin(gametic * 0.15))
							: 1.0;
						int bx = int(UiObjects[i].ImagePos.x);
						int by = int(UiObjects[i].ImagePos.y);
						int bw = int(UiObjects[i].ImageSize.x);
						int bh = int(UiObjects[i].ImageSize.y);
						DrawBlockyTile(bx, by, bw, bh,
							hovered, false, globalPDAAlpha);
						font lblFont = UiObjects[i].usefont != NULL ? UiObjects[i].usefont : SmallFont;
						DrawBlockyLabel(lblFont, UiObjects[i].toDraw,
							bx, by, bw, bh,
							hovered, globalPDAAlpha, true);
						int labelBottom = by + max(2, bh / 14) + lblFont.GetHeight();
						TextureID tileIc = ResolveBlockyTileIcon(UiObjects[i].entrynumber, UiObjects[i].objecttype);
						DrawBlockyTileIcon(tileIc, bx, by, bw, bh, labelBottom,
							globalPDAAlpha, iconPulseMul);
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (blockyOn && (UiObjects[i].objecttype == 4 || UiObjects[i].objecttype == 5)
						&& UiObjects[i].usefont != NULL && UiObjects[i].todraw)
					{
						font arf = UiObjects[i].usefont;
						double arrBase = pdaTextScale * PB_PDA_BLOCKY_PAGE_ARROW_VIS_MUL;
						double arrPulse = UiObjects[i].MouseOvered
							? (1.0 + PB_PDA_BLOCKY_ICON_PULSE_AMP * sin(gametic * 0.15))
							: 1.0;
						double arrDraw = arrBase * arrPulse;
						Vector2 arrAt = (UiObjects[i].objecttype == 4) ? UpArrowPos : DownArrowPos;
						Screen.DrawText(arf, UiObjects[i].fontcolor,
							arrAt.x, arrAt.y, UiObjects[i].toDraw,
							DTA_ScaleX, arrDraw, DTA_ScaleY, arrDraw,
							DTA_Alpha, globalPDAAlpha);
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (blockyOn && (UiObjects[i].objecttype == 12 || UiObjects[i].objecttype == 13)
						&& UiObjects[i].usefont != NULL && UiObjects[i].todraw)
					{
						font crf = UiObjects[i].usefont;
						double catBase = pdaTextScale * PB_PDA_BLOCKY_CAT_ARROW_VIS_MUL;
						double catPulse = UiObjects[i].MouseOvered
							? (1.0 + PB_PDA_BLOCKY_ICON_PULSE_AMP * sin(gametic * 0.15))
							: 1.0;
						double catDraw = catBase * catPulse;
						Vector2 catAt = (UiObjects[i].objecttype == 12)
							? LeftCatArrowVisPos : RightCatArrowVisPos;
						Screen.DrawText(crf, UiObjects[i].fontcolor,
							catAt.x, catAt.y, UiObjects[i].toDraw,
							DTA_ScaleX, catDraw, DTA_ScaleY, catDraw,
							DTA_Alpha, globalPDAAlpha);
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (blockyOn && UiObjects[i].BackButtonTrue
						&& UiObjects[i].usefont != NULL)
					{
						font bbf = UiObjects[i].usefont;
						int hitPad = PB_PDA_BLOCKY_PAGE_ARROW_HIT_PAD;
						double bx = UiObjects[i].ImagePos.x + hitPad;
						double by = UiObjects[i].ImagePos.y + hitPad;
						double sepX = bx + bbf.StringWidth("BACK") * pdaTextScale;
						double exitX = sepX + bbf.StringWidth(" / ") * pdaTextScale;
						Screen.DrawText(bbf, UiObjects[i].fontcolor, bx, by, "BACK",
							DTA_ScaleX, pdaTextScale, DTA_ScaleY, pdaTextScale,
							DTA_Alpha, globalPDAAlpha);
						Screen.DrawText(bbf, Font.CR_OLIVE, sepX, by, " / ",
							DTA_ScaleX, pdaTextScale, DTA_ScaleY, pdaTextScale,
							DTA_Alpha, globalPDAAlpha);
						int exitCol = Font.CR_GREEN;
						for (int exi = 0; exi < UiObjects.Size(); exi++)
						{
							PB_PDAUi_Object exo = UiObjects[exi];
							if (exo && exo.ExitButtonTrue)
							{
								exitCol = exo.fontcolor;
								break;
							}
						}
						Screen.DrawText(bbf, exitCol, exitX, by, "EXIT",
							DTA_ScaleX, pdaTextScale, DTA_ScaleY, pdaTextScale,
							DTA_Alpha, globalPDAAlpha);
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (blockyOn && UiObjects[i].ExitButtonTrue)
					{
						UiObjects[i].notdrawn = false;
						continue;
					}
					if (UiObjects[i].todraw)
					{
						Screen.DrawText(UiObjects[i].usefont,UiObjects[i].fontcolor,UiObjects[i].ImagePos.x,UiObjects[i].ImagePos.y,UiObjects[i].toDraw,
							DTA_ScaleX, pdaTextScale, DTA_ScaleY, pdaTextScale,
							DTA_Alpha, globalPDAAlpha);
						uiObjects[i].notdrawn = false;
					}
					else if (UiObjects[i].DialogPicture)
					{
						Screen.DrawTexture(UiObjects[i].DialogPicture,false,UiObjects[i].ImagePos.x,UiObjects[i].ImagePos.y,DTA_CleanNoMove_1,true,DTA_Alpha,globalPDAAlpha);
						UiObjects[i].notdrawn = false;
					}
					else UiObjects[i].notdrawn = true;
				}
			}
			if (descriptiondialog != null && NonMainMenu == true && !AchievementsMenuOpened)
			{
				int paneRight = int(min(UpArrowPos.X, pdaDescClipRight));
				if (blockyOn)
					paneRight = pdaDescClipRight;
				int paneWidth = paneRight - int(descriptiondialog.ImagePos.X);
				if (paneWidth < 0) paneWidth = 0;
				int columnAvailH = descriptiondialog.descClipH - descriptiondialog.descClipY;
				if (columnAvailH < 0)
					columnAvailH = 0;
				EnsurePdaDescAutosizeScale(pdaTextScale, paneWidth, columnAvailH);
				double pdaDescScale = pdaDescAutosizeCachedScale;
				int paneAutosizedH = pdaDescPaneAutosizedH;
				int paneTop = int(descriptiondialog.descClipY);
				Screen.dim(color(75,75,75),globalPDAAlpha,descriptiondialog.ImagePos.X,paneTop,paneWidth,paneAutosizedH);
				Screen.SetClipRect(int(descriptiondialog.ImagePos.x), paneTop, paneWidth, paneAutosizedH);
				double textY = double(paneTop + PB_PDA_DESC_PLATE_INTERIOR_PAD);
				int clipBot = paneTop + paneAutosizedH;
				string descBody = pdaDescAutosizeCachedText.length() > 0
					? pdaDescAutosizeCachedText
					: descriptiondialog.todraw;
				int descClipRightDraw = int(descriptiondialog.ImagePos.x) + paneWidth;
				Screen.DrawText(descriptiondialog.usefont,Font.CR_GREEN,descriptiondialog.ImagePos.x,
					textY, descBody,
					DTA_ScaleX, pdaDescScale, DTA_ScaleY, pdaDescScale,
					DTA_ClipTop, paneTop,
					DTA_ClipBottom, clipBot,
					DTA_ClipRight, descClipRightDraw,
					DTA_Alpha, globalPDAAlpha);
				Screen.ClearClipRect();
				if (blockyOn && NonMainMenu && (WeaponMenuOpened || MonsterMenuOpened || EquipmentMenuOpened))
					DrawBlockyPreviewPane(pdaTextScale, globalPDAAlpha, WeaponMenuOpened, EquipmentMenuOpened);
			}
			double pdaCursorScale = clamp(Screen.GetHeight() / 540.0, 1.5, 3.5);
			double pdaCursorH = 32.0 * pdaCursorScale;
			Vector2 cursorNative = TexMan.GetScaledSize(cursortex);
			double cursorAspect = (cursorNative.X > 0 && cursorNative.Y > 0)
				? cursorNative.X / cursorNative.Y
				: 1.0;
			double pdaCursorW = pdaCursorH * cursorAspect;
			double pdaCursorAnchorOfsX = pdaCursorW * 0.22;
			double pdaCursorAnchorOfsY = pdaCursorH * 0.25;
			Screen.DrawTexture(cursortex, false,
				double(MouseX) + pdaCursorAnchorOfsX,
				double(MouseY) + pdaCursorAnchorOfsY,
				DTA_DestWidthF, pdaCursorW, DTA_DestHeightF, pdaCursorH,
				DTA_CenterOffset, true);
		}
		if (!hideHUD && KatanaDualChoiceMode)
			DrawKatanaDualChoiceOverlay();
	}

	void PB_KatanaDualChoiceClearPreview()
	{
		katDualFrL.Clear();
		katDualTiL.Clear();
		katDualSegL.Clear();
		katDualFrR.Clear();
		katDualTiR.Clear();
		katDualSegR.Clear();
		katDualCurL = katDualCurR = 0;
		katDualRemL = katDualRemR = 0;
		katDualLastGtL = katDualLastGtR = 0;
	}

	void PB_KatanaDualChoiceBuildPreviews(int variant)
	{
		PB_KatanaDualChoiceClearPreview();
		if (variant == 0)
		{
			PDA_WeaponStrip_AppendFullWeapon('PB_ArgentSith', katDualFrL, katDualTiL, katDualSegL, true,
				PB_PDA_WEAPON_PREVIEW_STRIP_MAX,
				PB_PDA_WEAPON_PREVIEW_PICKUP_TICS, PB_PDA_WEAPON_PREVIEW_SPAWN_SEEK,
				PB_PDA_WEAPON_PREVIEW_READY_MAX, PB_PDA_WEAPON_PREVIEW_READY_SEEK,
				PB_PDA_WEAPON_PREVIEW_READY_TICS, PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP,
				PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_FLASH_TICS, PB_PDA_WEAPON_PREVIEW_FLASH_SEEK,
				true, PB_PDA_WEAPON_PREVIEW_OVERLAY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_OVERLAY_MAX_STEPS);
			PDA_WeaponStrip_AppendFullWeapon('PB_BeamKatana', katDualFrR, katDualTiR, katDualSegR, true,
				PB_PDA_WEAPON_PREVIEW_STRIP_MAX,
				PB_PDA_WEAPON_PREVIEW_PICKUP_TICS, PB_PDA_WEAPON_PREVIEW_SPAWN_SEEK,
				PB_PDA_WEAPON_PREVIEW_READY_MAX, PB_PDA_WEAPON_PREVIEW_READY_SEEK,
				PB_PDA_WEAPON_PREVIEW_READY_TICS, PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP,
				PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_FLASH_TICS, PB_PDA_WEAPON_PREVIEW_FLASH_SEEK,
				true, PB_PDA_WEAPON_PREVIEW_OVERLAY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_OVERLAY_MAX_STEPS);
		}
		else
		{
			PDA_WeaponStrip_AppendFullWeapon('PB_BeamKatana', katDualFrL, katDualTiL, katDualSegL, true,
				PB_PDA_WEAPON_PREVIEW_STRIP_MAX,
				PB_PDA_WEAPON_PREVIEW_PICKUP_TICS, PB_PDA_WEAPON_PREVIEW_SPAWN_SEEK,
				PB_PDA_WEAPON_PREVIEW_READY_MAX, PB_PDA_WEAPON_PREVIEW_READY_SEEK,
				PB_PDA_WEAPON_PREVIEW_READY_TICS, PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP,
				PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_FLASH_TICS, PB_PDA_WEAPON_PREVIEW_FLASH_SEEK,
				true, PB_PDA_WEAPON_PREVIEW_OVERLAY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_OVERLAY_MAX_STEPS);
			PDA_WeaponStrip_AppendFullWeapon('PB_ArgentSith', katDualFrR, katDualTiR, katDualSegR, true,
				PB_PDA_WEAPON_PREVIEW_STRIP_MAX,
				PB_PDA_WEAPON_PREVIEW_PICKUP_TICS, PB_PDA_WEAPON_PREVIEW_SPAWN_SEEK,
				PB_PDA_WEAPON_PREVIEW_READY_MAX, PB_PDA_WEAPON_PREVIEW_READY_SEEK,
				PB_PDA_WEAPON_PREVIEW_READY_TICS, PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP,
				PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_FLASH_TICS, PB_PDA_WEAPON_PREVIEW_FLASH_SEEK,
				true, PB_PDA_WEAPON_PREVIEW_OVERLAY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_OVERLAY_MAX_STEPS);
		}
	}

	void PB_KatanaDualChoiceResetPreviewAnims()
	{
		int g = gametic;
		if (katDualFrL.Size() > 0 && katDualTiL.Size() == katDualFrL.Size())
		{
			katDualCurL = 0;
			katDualRemL = max(1, katDualTiL[0]);
			katDualLastGtL = g;
		}
		else
		{
			katDualCurL = 0;
			katDualRemL = 1;
			katDualLastGtL = g;
		}
		if (katDualFrR.Size() > 0 && katDualTiR.Size() == katDualFrR.Size())
		{
			katDualCurR = 0;
			katDualRemR = max(1, katDualTiR[0]);
			katDualLastGtR = g;
		}
		else
		{
			katDualCurR = 0;
			katDualRemR = 1;
			katDualLastGtR = g;
		}
	}

	void PB_KatanaDualAdvancePreviewAnims()
	{
		if (!KatanaDualChoiceMode)
			return;
		while (katDualFrL.Size() > 0 && katDualTiL.Size() == katDualFrL.Size()
			&& gametic >= katDualLastGtL + katDualRemL)
		{
			katDualLastGtL += katDualRemL;
			katDualCurL++;
			if (katDualCurL >= katDualFrL.Size())
				katDualCurL = 0;
			katDualRemL = max(1, katDualTiL[katDualCurL]);
		}
		while (katDualFrR.Size() > 0 && katDualTiR.Size() == katDualFrR.Size()
			&& gametic >= katDualLastGtR + katDualRemR)
		{
			katDualLastGtR += katDualRemR;
			katDualCurR++;
			if (katDualCurR >= katDualFrR.Size())
				katDualCurR = 0;
			katDualRemR = max(1, katDualTiR[katDualCurR]);
		}
	}

	ui void PB_KatanaDualChoiceGetTileLayout(out int lx, out int ly, out int lw, out int lh,
		out int rx, out int ry, out int rw, out int rh) const
	{
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		int pad = max(10, sh / 54);
		int gap = max(10, pad / 2);
		int top = max(28, sh / 22);
		int bot = max(pad * 2 + SmallFont.GetHeight(), sh / 14);
		int fullH = sh - top - bot;
		if (fullH < 120)
			fullH = max(120, sh / 2);
		int fullW = (sw - pad * 2 - gap) / 2;
		if (fullW < 80)
			fullW = max(80, sw / 2 - gap);
		lh = max(96, int(double(fullH) * PB_KATANA_DUAL_TILE_FRAC));
		lw = max(72, int(double(fullW) * PB_KATANA_DUAL_TILE_FRAC));
		rw = lw;
		rh = lh;
		int pairW = lw + gap + rw;
		lx = (sw - pairW) / 2;
		rx = lx + lw + gap;
		int availH = sh - top - bot;
		int y0 = top + max(0, (availH - lh) / 2);
		ly = y0;
		ry = y0;
	}

	ui void DrawKatanaDualWeaponInTileArea(int x, int y, int w, int h, TextureID iconTex,
		bool hovered, double alpha, double iconScaleMul = 1.0) const
	{
		int pad = max(2, h / 16);
		int iconTop = y + pad;
		int iconBottom = y + h - pad;
		if (iconBottom <= iconTop + 2)
			return;
		double slotH = double(iconBottom - iconTop);
		slotH = min(slotH, h * 0.92);
		double cx = double(x) + double(w) * 0.5;
		double cy = double(iconTop) + slotH * 0.5;
		if (!iconTex.IsValid())
		{
			Screen.DrawText(BigFont, Font.CR_OLIVE, int(cx - BigFont.StringWidth("?") / 2),
				int(cy - BigFont.GetHeight() / 2), "?",
				DTA_Alpha, alpha,
				DTA_ScaleX, iconScaleMul, DTA_ScaleY, iconScaleMul);
			return;
		}
		Vector2 texSize = TexMan.GetScaledSize(iconTex);
		if (texSize.X < 1 || texSize.Y < 1)
		{
			Screen.DrawText(BigFont, Font.CR_OLIVE, int(cx - BigFont.StringWidth("?") / 2),
				int(cy - BigFont.GetHeight() / 2), "?",
				DTA_Alpha, alpha,
				DTA_ScaleX, iconScaleMul, DTA_ScaleY, iconScaleMul);
			return;
		}
		double maxH = slotH * 0.92;
		double maxW = double(w - pad * 2);
		double scale = min(maxW / texSize.X, maxH / texSize.Y);
		double dw = texSize.X * scale * iconScaleMul;
		double dh = texSize.Y * scale * iconScaleMul;
		if (hovered)
		{
			dw *= 1.04;
			dh *= 1.04;
		}
		Screen.DrawTexture(iconTex, false, cx, cy,
			DTA_DestWidthF, dw, DTA_DestHeightF, dh,
			DTA_KeepRatio, true,
			DTA_Alpha, alpha,
			DTA_CenterOffset, true);
	}

	ui void DrawKatanaDualChoiceOverlay()
	{
		if (!KatanaDualChoiceMode)
			return;
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		Screen.Dim("black", 0.58, 0, 0, sw, sh);
		int lx, ly, lw, lh, rx, ry, rw, rh;
		PB_KatanaDualChoiceGetTileLayout(lx, ly, lw, lh, rx, ry, rw, rh);
		bool hoverL = MouseX >= lx && MouseX < lx + lw && MouseY >= ly && MouseY < ly + lh;
		bool hoverR = MouseX >= rx && MouseX < rx + rw && MouseY >= ry && MouseY < ry + rh;
		int refWpx = max(BigFont.StringWidth("Sith Lord"), BigFont.StringWidth("Jedi Master"));
		int bh0 = max(1, BigFont.GetHeight());
		double lblScCap = double(lh) * PB_KATANA_DUAL_LABEL_MAX_FRAC_OF_TILE_H / double(bh0);
		double hiSc = min(3.75, max(1.05, lblScCap));
		double lblScL = clamp(double(lw - 12) / double(max(1, refWpx)), 1.05, hiSc);
		double lblScR = clamp(double(rw - 12) / double(max(1, refWpx)), 1.05, hiSc);
		bool sithLeft = (KatanaDualVariant == 0);
		int leftCol = sithLeft ? Font.CR_RED : Font.CR_LIGHTBLUE;
		int rightCol = sithLeft ? Font.CR_LIGHTBLUE : Font.CR_RED;
		int labelBarH = int(ceil(BigFont.GetHeight() * max(lblScL, lblScR))) + max(6, lh / 20);
		labelBarH = min(labelBarH, max(10, int(double(lh) * (PB_KATANA_DUAL_LABEL_MAX_FRAC_OF_TILE_H + 0.04))));
		DrawBlockyTile(lx, ly, lw, lh, hoverL, false, 1.0);
		DrawBlockyTile(rx, ry, rw, rh, hoverR, false, 1.0);
		{
			string lt = sithLeft ? "Sith Lord" : "Jedi Master";
			string ltFull = lt;
			int maxW = lw - 10;
			while (lt.length() > 0 && int(BigFont.StringWidth(lt) * lblScL) > maxW)
				lt = lt.Mid(0, lt.length() - 1);
			if (lt.length() < ltFull.length() && lt.length() >= 2)
			{
				lt.DeleteLastCharacter();
				lt = lt .. "..";
			}
			double lcx = lx + (lw - BigFont.StringWidth(lt) * lblScL) / 2.0;
			double lcy = ly + (labelBarH - BigFont.GetHeight() * lblScL) / 2.0;
			int lc = hoverL ? Font.CR_OLIVE : leftCol;
			Screen.DrawText(BigFont, lc, int(lcx), int(lcy), lt,
				DTA_ScaleX, lblScL, DTA_ScaleY, lblScL);
		}
		{
			string rt = sithLeft ? "Jedi Master" : "Sith Lord";
			string rtFull = rt;
			int maxWr = rw - 10;
			while (rt.length() > 0 && int(BigFont.StringWidth(rt) * lblScR) > maxWr)
				rt = rt.Mid(0, rt.length() - 1);
			if (rt.length() < rtFull.length() && rt.length() >= 2)
			{
				rt.DeleteLastCharacter();
				rt = rt .. "..";
			}
			double rcx = rx + (rw - BigFont.StringWidth(rt) * lblScR) / 2.0;
			double rcy = ry + (labelBarH - BigFont.GetHeight() * lblScR) / 2.0;
			int rc = hoverR ? Font.CR_OLIVE : rightCol;
			Screen.DrawText(BigFont, rc, int(rcx), int(rcy), rt,
				DTA_ScaleX, lblScR, DTA_ScaleY, lblScR);
		}
		TextureID texL;
		TextureID texR;
		if (katDualFrL.Size() > 0 && katDualCurL >= 0 && katDualCurL < katDualFrL.Size())
			texL = katDualFrL[katDualCurL];
		if (katDualFrR.Size() > 0 && katDualCurR >= 0 && katDualCurR < katDualFrR.Size())
			texR = katDualFrR[katDualCurR];
		int bodyY = ly + labelBarH;
		int bodyH = max(8, lh - labelBarH);
		DrawKatanaDualWeaponInTileArea(lx, bodyY, lw, bodyH, texL, hoverL, 1.0, 1.0);
		bodyY = ry + labelBarH;
		bodyH = max(8, rh - labelBarH);
		DrawKatanaDualWeaponInTileArea(rx, bodyY, rw, bodyH, texR, hoverR, 1.0, 1.0);
		string hint = "Click a tile to choose your path.";
		double hintSc = clamp(sh / 480.0, 1.0, 1.85);
		int hw = int(SmallFont.StringWidth(hint) * hintSc);
		int hx = (sw - hw) / 2;
		int hy = sh - max(28, sh / 18);
		Screen.DrawText(SmallFont, Font.CR_GOLD, hx, hy, hint,
			DTA_ScaleX, hintSc, DTA_ScaleY, hintSc);
		TextureID cursortex = TexMan.CheckForTexture("ZCURSOR", TexMan.Type_Any);
		if (cursortex.IsValid())
		{
			double pdaCursorScale = clamp(Screen.GetHeight() / 540.0, 1.5, 3.5);
			double pdaCursorH = 32.0 * pdaCursorScale;
			Vector2 cursorNative = TexMan.GetScaledSize(cursortex);
			double cursorAspect = (cursorNative.X > 0 && cursorNative.Y > 0)
				? cursorNative.X / cursorNative.Y
				: 1.0;
			double pdaCursorW = pdaCursorH * cursorAspect;
			double pdaCursorAnchorOfsX = pdaCursorW * 0.22;
			double pdaCursorAnchorOfsY = pdaCursorH * 0.25;
			Screen.DrawTexture(cursortex, false,
				double(MouseX) + pdaCursorAnchorOfsX,
				double(MouseY) + pdaCursorAnchorOfsY,
				DTA_DestWidthF, pdaCursorW, DTA_DestHeightF, pdaCursorH,
				DTA_CenterOffset, true);
		}
	}

	void PB_KatanaDualChoiceClose()
	{
		PB_KatanaDualChoiceClearPreview();
		KatanaDualChoiceMode = 0;
		KatanaDualVariant = 0;
		if (KatanaDualFrozenPlr >= 0 && KatanaDualFrozenPlr < MAXPLAYERS && playeringame[KatanaDualFrozenPlr])
			players[KatanaDualFrozenPlr].timefreezer &= ~(1 << KatanaDualFrozenPlr);
		KatanaDualFrozenPlr = -1;
		SetPlayerProperty(1, 0, 4);
		Level.SetFrozen(false);
		MouseX = 1;
		MouseY = 1;
		MousePositionSet = false;
		MouseClicked = false;
		MouseHeldDown = false;
		HeldDownTics = 0;
	}

	void PB_KatanaDualChoiceApplyPick(bool sith, int plrnum)
	{
		if (plrnum < 0 || plrnum >= MAXPLAYERS || !playeringame[plrnum])
			return;
		let mo = players[plrnum].mo;
		if (!mo)
		{
			PB_KatanaDualChoiceClose();
			return;
		}
		mo.TakeInventory("PB_KatanaChoicePickSith", 0x7fffffff);
		mo.TakeInventory("PB_KatanaChoicePickJedi", 0x7fffffff);
		if (sith)
			mo.GiveInventory("PB_KatanaChoicePickSith", 1);
		else
			mo.GiveInventory("PB_KatanaChoicePickJedi", 1);
		PB_KatanaDualChoiceClose();
	}

	ui bool InitializeUiObjects()
	{
		if (!playeringame[consoleplayer]) { return false; }
		let pmo = players[consoleplayer].mo;
		if (!pmo) { return false; }
		PB_PDAWeaponContainer weaptextcontainer = PB_PDAWeaponContainer(pmo.FindInventory("PB_PDAWeaponContainer",true));
		if (!weaptextcontainer) { return false; }
		blockyWeaponIconKeys.Clear();
		blockyWeaponIconVals.Clear();
		blockyMonsterIconKeys.Clear();
		blockyMonsterIconVals.Clear();
		blockyWeaponIconMissed.Clear();
		blockyMonsterIconMissed.Clear();
		blockyEquipIconKeys.Clear();
		blockyEquipIconVals.Clear();
		blockyEquipIconMissed.Clear();
		pdaPrevUILastQueuedKey = "";
		SendNetworkEvent("pdaprevclear");
		currentMonsterIndex = -1;
		currentEquipmentIndex = -1;
		double pdaTextScale = clamp(Screen.GetHeight() / 240.0, 2.0, 6.0);
		PDAWeaponExtraTexts.Copy(weaptextcontainer.PDAWeaponExtraTexts);
		PDAWeaponHeaders.Copy(weaptextcontainer.PDAWeaponHeaders);
		PDAWeaponTexts.Copy(weaptextcontainer.PDAWeaponTexts);
		PDAMonsterStrings.Copy(weaptextcontainer.PDAMonsterStrings);
		PDAMonsterTexts.Copy(weaptextcontainer.PDAMonsterTexts);
		PDAMonsterIconClass.Copy(weaptextcontainer.PDAMonsterIconClass);
		PDAWeaponTextVSize.Copy(weaptextcontainer.PDAWeaponTextVSize);
		PDAWeaponTextHSize.Copy(weaptextcontainer.PDAWeaponTextHSize);
		pdaWeapTextArray.Copy(weaptextcontainer.pdaWeapTextArray);
		PDAEquipStrings.Copy(weaptextcontainer.PDAEquipStrings);
		PDAEquipTexts.Copy(weaptextcontainer.PDAEquipTexts);
		PDAEquipHeaders.Copy(weaptextcontainer.PDAEquipHeaders);
		PDAEquipExtraTexts.Copy(weaptextcontainer.PDAEquipExtraTexts);
		PDAEquipIconClass.Copy(weaptextcontainer.PDAEquipIconClass);
		pdaEquipTextArray.Copy(weaptextcontainer.pdaEquipTextArray);
		int largeststringwidth = weaptextcontainer.largeststringwidth;
		pdaDescLargestStrW = largeststringwidth;
		let descdialog = new("PB_PDAUi_Object");
		descdialog.todraw = "Select a entry to \nview its description";
		descdialog.UnSelectable = true;
		descdialog.InitializeUiObject();
		descdialog.ImagePos = (Screen.GetWidth() / 2,Screen.GetHeight() / 10);
		descdialog.InitialImagePos = descdialog.ImagePos;
		descdialog.descClipY = descdialog.ImagePos.Y;
		{
			int clipSh = Screen.GetHeight();
			int descMargin = max(52, clipSh / 14);
			descdialog.descClipH = clipSh - descMargin;
		}
		descriptiondialog = descdialog;
		double om0 = PB_PDA_BLOCKY_PAGE_ARROW_OUTSIDE_MARGIN;
		double initArrH = SmallFont.GetHeight() * pdaTextScale;
		if (BlockyEnabled())
			initArrH *= PB_PDA_BLOCKY_PAGE_ARROW_VIS_MUL;
		UpArrowPos = (largeststringwidth + descdialog.ImagePos.X,
			descdialog.descClipY - initArrH - om0);
		DownArrowPos = (UpArrowPos.x, descdialog.descClipH + om0);
		let UpArrowDialog = new("PB_PDAUi_Object");
		UpArrowDialog.Objecttype = 4;
		UpArrowDialog.ImagePos = UpArrowPos;
		UpArrowDialog.todraw = "\x1a";
		UpArrowDialog.NonMainMenuOnly = true;
		UpArrowDialog.InitializeUiObject(confont);
		UiObjects.Push(UpArrowDialog);
		PB_PDAUi_Object DownArrowDialog = new("PB_PDAUi_Object");
		DownArrowDialog.ImagePos = DownArrowPos;
		DownArrowDialog.todraw = "\x1b";
		DownArrowDialog.ObjectType = 5;
		DownArrowDialog.NonMainMenuOnly = true;
		DownArrowDialog.InitializeUiObject(confont);
		UiObjects.Push(DownArrowDialog);
		PB_PDAUi_Object LeftArrowDialog = new("PB_PDAUi_Object");
		double catRowY = double(descdialog.descClipH)
			+ (BlockyEnabled()
				? (om0 + initArrH + PB_PDA_BLOCKY_CAT_ARROW_BELOW_DESC)
				: (SmallFont.GetHeight() * pdaTextScale));
		LeftArrowDialog.ImagePos = (descdialog.imagepos.x, catRowY);
		LeftArrowDialog.todraw = "<";
		LeftArrowDialog.ObjectType = 12;
		LeftArrowDialog.NonMainMenuOnly = true;
		LeftArrowDialog.InitializeUiObject();
		UiObjects.Push(LeftArrowDialog);
		PB_PDAUi_Object RightArrowDialog = new("PB_PDAUi_Object");
		RightArrowDialog.ImagePos = (descdialog.imagepos.x + largeststringwidth, catRowY);
		RightArrowDialog.todraw = ">";
		RightArrowDialog.ObjectType = 13;
		RightArrowDialog.NonMainMenuOnly = true;
		RightArrowDialog.InitializeUiObject();
		UiObjects.Push(RightArrowDialog);
		Vector2 monstertextpos = (Screen.GetWidth() / 5,Screen.GetHeight() / 5);
		Vector2 prevtextpos = (0,0);
		for (int ii = 0; ii < pdaWeapTextArray.Size(); ++ii)
		{
			let weapontext = new("PB_PDAUi_Object");
			weapontext.entrynumber = ii;
			weapontext.WeaponMenuOnly = true;
			weapontext.dontdraw = !pdaWeapTextArray[ii].found;
			weapontext.pdaWeapTextArray = pdaWeapTextArray[ii];
			weapontext.toDraw = pdaWeapTextArray[ii].PDAWeaponHeader;
			weapontext.ImagePos = prevtextpos;
			prevtextpos.y += SmallFont.GetHeight() * pdaTextScale;
			weapontext.InitializeUiObject();
			weapontext.objecttype = 3;
			UiObjects.Push(weapontext);
		}
		prevtextpos = (0,0);
		for (int i = 0; i < PDAMonsterStrings.Size(); ++i)
		{
			let monstertext = new("PB_PDAUi_Object");
			monstertext.MonsterMenuOnly = true;
			monstertext.dontdraw = (i >= weaptextcontainer.PDAMonsterFound.Size()
				|| !weaptextcontainer.PDAMonsterFound[i]);
			monstertext.entrynumber = i;
			monstertext.objecttype = 6;
			monstertext.toDraw = PDAMonsterStrings[i];
			monstertext.ImagePos = prevtextpos;
			prevtextpos.y += SmallFont.GetHeight() * pdaTextScale;
			monstertext.InitializeUiObject();
			UiObjects.Push(monstertext);
		}
		prevtextpos = (0, 0);
		for (int ei = 0; ei < pdaEquipTextArray.Size(); ++ei)
		{
			let equipentry = new("PB_PDAUi_Object");
			equipentry.EquipmentMenuOnly = true;
			equipentry.dontdraw = (ei >= weaptextcontainer.PDAEquipFound.Size()
				|| !weaptextcontainer.PDAEquipFound[ei]);
			equipentry.entrynumber = ei;
			equipentry.objecttype = 7;
			equipentry.toDraw = PDAEquipStrings[ei];
			equipentry.pdaEquipRow = pdaEquipTextArray[ei];
			equipentry.ImagePos = prevtextpos;
			prevtextpos.y += SmallFont.GetHeight() * pdaTextScale;
			equipentry.InitializeUiObject();
			UiObjects.Push(equipentry);
		}
		let BackDialog = new("PB_PDAUi_Object");
		BackDialog.todraw = BlockyEnabled() ? "BACK" : "Back";
		BackDialog.InitializeUiObject();
		BackDialog.BackButtonTrue = true;
		BackDialog.NonMainMenuOnly = true;
		BackDialog.ImagePos = (0,Screen.GetHeight() - BackDialog.ImageSize.y);
		uiObjects.Push(BackDialog);
		let dialog = new("PB_PDAUi_Object");
		dialog.toDraw = BlockyEnabled() ? "EXIT" : "Exit";
		dialog.InitializeUiObject();
		dialog.exitbuttontrue = True;
		let monsterdialog = new("PB_PDAUi_Object");
		monsterdialog.objecttype = 1;
		monsterdialog.toDraw = monsterDialog.GetString();
		monsterdialog.InitializeUiObject(BigFont);
		monsterdialog.ImagePos = (Screen.GetWidth() / 4, Screen.GetHeight() / 2);
		uiObjects.Push(monsterdialog);
		let weapondialog = new("PB_PDAUi_Object");
		weapondialog.objecttype = 2;
		weapondialog.toDraw = "Weapons";
		weapondialog.InitializeUiObject(BigFont);
		weapondialog.ImagePos = (MonsterDialog.ImagePos.x,MonsterDialog.ImagePos.y + MonsterDialog.ImageSize.y);
		uiObjects.Push(weapondialog);
		let equipmentdialog = new("PB_PDAUi_Object");
		equipmentdialog.objecttype = 14;
		equipmentdialog.toDraw = equipmentdialog.GetString();
		equipmentdialog.InitializeUiObject(BigFont);
		equipmentdialog.ImagePos = (weapondialog.ImagePos.x, weapondialog.ImagePos.y + weapondialog.ImageSize.y);
		uiObjects.Push(equipmentdialog);
		let mainHubSlotBtn = new("PB_PDAUi_Object");
		mainHubSlotBtn.objecttype = 16;
		mainHubSlotBtn.MainHubBlockySlot = true;
		mainHubSlotBtn.toDraw = "REWARD SPIN";
		mainHubSlotBtn.InitializeUiObject(BigFont);
		uiObjects.Push(mainHubSlotBtn);
		let mainHubAchBtn = new("PB_PDAUi_Object");
		mainHubAchBtn.objecttype = 17;
		mainHubAchBtn.MainHubBlockyAchievements = true;
		mainHubAchBtn.toDraw = "ACHIEVEMENTS";
		mainHubAchBtn.InitializeUiObject(BigFont);
		uiObjects.Push(mainHubAchBtn);
		let mainHubExitBtn = new("PB_PDAUi_Object");
		mainHubExitBtn.objecttype = 15;
		mainHubExitBtn.toDraw = "EXIT";
		mainHubExitBtn.InitializeUiObject(BigFont);
		mainHubExitBtn.ExitButtonTrue = true;
		mainHubExitBtn.MainHubBlockyExit = true;
		uiObjects.Push(mainHubExitBtn);
		if (!BlockyEnabled())
			dialog.ImagePos = ((Screen.GetWidth() ) - Screen.GetWidth()/4, (Screen.GetHeight() ) - Screen.GetHeight()/4);
		else
			dialog.ImagePos = (0, Screen.GetHeight() - dialog.ImageSize.y);
		UiObjects.Push(dialog);
		ApplyBlockyLayout();
		SyncBlockyPageArrowHitboxes(pdaTextScale);
		SendNetworkEvent("addbaseweapons");
		return true;
	}

	override bool InputProcess(InputEvent e)
	{
		if (gamestate == GS_TITLELEVEL || gametic < PB_PDA_UI_INIT_MIN_GAMETIC) return false;
		if (!e) return false;
		if (!PDAMode && !KatanaDualChoiceMode) return false;
		int mouseinput = 0;
		bool relevant = false;
		if (e.Type == InputEvent.Type_Mouse)
		{
			relevant = true;
		}
		else if (e.KeyScan == InputEvent.Key_Mouse1 && e.Type == InputEvent.Type_KeyDown)
		{
			mouseinput = 1;
			relevant = true;
		}
		else if (e.KeyScan == InputEvent.Key_Mouse1 && e.Type == InputEvent.Type_KeyUp)
		{
			mouseinput = 2;
			relevant = true;
		}
		if (!relevant) return false;
		SendNetworkEvent("input", e.mouseX, e.mouseY, mouseinput);
		return true;
	}
}
