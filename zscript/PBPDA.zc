	bool PDA_Play_UseFireLikeWalkBreak(string segLabel)
	{
		return segLabel ~== "Fire" || segLabel ~== "AltFire" || segLabel ~== "Hold";
	}

	clearscope bool PDA_WeaponStrip_TextureRenderable(TextureID tid) const
	{
		if (!tid.IsValid())
			return false;
		Vector2 sz = TexMan.GetScaledSize(tid);
		return sz.X > 0 && sz.Y > 0;
	}

	void PDA_WeaponStrip_PushFrame(Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int segIdx, TextureID tid, int tics, int hardCap)
	{
		if (!PDA_WeaponStrip_TextureRenderable(tid) || outFr.Size() >= hardCap)
			return;
		if (tics < 1)
			tics = 1;
		outFr.Push(tid);
		outTi.Push(tics);
		if (useSeg)
			outSeg.Push(segIdx);
	}

	bool PDA_WeaponStrip_TryPushFrame(State st, readonly<Actor> def,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int segIdx, int forcedTics, bool filterPlayerBody, int authoredTicCap,
		int hardCap)
	{
		if (!st || !def || outFr.Size() >= hardCap)
			return false;
		TextureID tid = st.GetSpriteTexture(0);
		bool ok = PDA_WeaponStrip_TextureRenderable(tid);
		if (ok)
		{
			string tn = TexMan.GetName(tid);
			if (tn.Length() >= 4 && tn.Mid(0, 4) ~== "TNT1")
				ok = false;
			else if (filterPlayerBody && PDA_ShouldSuppressWeaponStripArt(def, tn))
				ok = false;
		}
		if (!ok)
			return false;
		int tic = (forcedTics >= 0) ? forcedTics : st.tics;
		if (tic < 1)
			tic = 1;
		if (forcedTics < 0)
		{
			int minTic = min(PB_PDA_WEAPON_PREVIEW_BODY_MIN_TICS, authoredTicCap);
			tic = clamp(tic, minTic, authoredTicCap);
		}
		PDA_WeaponStrip_PushFrame(outFr, outTi, outSeg, useSeg, segIdx, tid, tic, hardCap);
		return true;
	}

	void PDA_WeaponStrip_AppendPickup(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int pickupTics, int spawnSeek, int segPickup)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (!def)
			return;
		State st = def.FindStateByString("Spawn", true);
		if (!st)
			return;
		int steps = 0;
		while (st && steps < spawnSeek && outFr.Size() < hardCap)
		{
			TextureID tid = st.GetSpriteTexture(0);
			bool ok = PDA_WeaponStrip_TextureRenderable(tid);
			if (ok)
			{
				string tn = TexMan.GetName(tid);
				if (tn.Length() >= 4 && tn.Mid(0, 4) ~== "TNT1")
					ok = false;
				else if (PDA_ShouldSuppressWeaponStripArt(def, tn))
					ok = false;
			}
			if (ok)
			{
				PDA_WeaponStrip_PushFrame(outFr, outTi, outSeg, useSeg, segPickup, tid, pickupTics, hardCap);
				return;
			}
			State nx = st.NextState;
			if (!nx || nx == st)
				break;
			if (PDA_Main_FireWalk_ShouldStopBeforeState(def, nx))
				break;
			st = nx;
			steps++;
		}
	}

	void PDA_WeaponStrip_AppendReady(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		int readyMax, int readySeek, int readyFixedTic, int readyAuthoredTicCap, int segReady)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (!def)
			return;
		State st = def.FindStateByString("Ready", true);
		if (!st)
			return;
		int pushed = 0;
		int steps = 0;
		while (st && pushed < readyMax && steps < readySeek && outFr.Size() < hardCap)
		{
			if (PDA_WeaponStrip_TryPushFrame(st, def, outFr, outTi, outSeg, useSeg, segReady,
				readyFixedTic, true, readyAuthoredTicCap, hardCap))
				pushed++;
			State nx = st.NextState;
			if (!nx || nx == st)
				break;
			if (PDA_Main_FireWalk_ShouldStopBeforeState(def, nx))
				break;
			st = nx;
			steps++;
		}
	}

	void PDA_WeaponStrip_AppendFlashSlice(readonly<Actor> def,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int flashTics, int flashSeek, int segFlash)
	{
		if (!def || outFr.Size() >= hardCap)
			return;
		State fl = def.FindStateByString("Flash", true);
		if (!fl)
			return;
		int steps = 0;
		while (fl && steps < flashSeek && outFr.Size() < hardCap)
		{
			TextureID tid = fl.GetSpriteTexture(0);
			bool ok = PDA_WeaponStrip_TextureRenderable(tid);
			if (ok)
			{
				string tn = TexMan.GetName(tid);
				if (tn.Length() >= 4 && tn.Mid(0, 4) ~== "TNT1")
					ok = false;
				else if (PDA_ShouldSuppressWeaponStripArt(def, tn))
					ok = false;
			}
			if (ok)
			{
				PDA_WeaponStrip_PushFrame(outFr, outTi, outSeg, useSeg, segFlash, tid, flashTics, hardCap);
				return;
			}
			State nx = fl.NextState;
			if (!nx || nx == fl)
				break;
			fl = nx;
			steps++;
		}
	}

	void PDA_WeaponStrip_AppendFireLike(Name nm, string label, int segIdx, bool insertFlashSlice,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int fireAuthoredTicCap, int flashTics, int flashSeek, int segFlash)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (!def)
			return;
		State st = def.FindStateByString(label, true);
		if (!st)
			return;
		int steps = 0;
		while (st && steps < PB_PDA_WEAPON_PREVIEW_FIRE_MAX_HOPS && outFr.Size() < hardCap)
		{
			if (PDA_WeaponStrip_TryPushFrame(st, def, outFr, outTi, outSeg, useSeg, segIdx,
				-1, true, fireAuthoredTicCap, hardCap)
				&& insertFlashSlice)
				PDA_WeaponStrip_AppendFlashSlice(def, outFr, outTi, outSeg, useSeg, hardCap,
					flashTics, flashSeek, segFlash);
			State nx = st.NextState;
			if (!nx || nx == st)
				break;
			if (PDA_Play_UseFireLikeWalkBreak(label)
				&& PDA_Main_FireWalk_ShouldStopBeforeState(def, nx))
				break;
			st = nx;
			steps++;
		}
	}

	void PDA_WeaponStrip_AppendPrimaryFireWithDispatchFallbacks(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int fireAuthoredTicCap, int flashTics, int flashSeek, int segFlash)
	{
		int szBefore = outFr.Size();
		PDA_WeaponStrip_AppendFireLike(nm, "Fire", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "FireShrink", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "SemiFire", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "ChargeFire", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "Hold2", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "FireHip", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "FireADS", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "Fire_ADS", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "DoFireHMG", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "M41S1Body", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "M41S2Body", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "FireCryoPellets", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "FireCryoShot", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "Firing_Single", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
		if (outFr.Size() > szBefore)
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "CyclingAnimation", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireAuthoredTicCap, flashTics, flashSeek, segFlash);
	}

	void PDA_WeaponStrip_AppendPB_DemonExterminatorPreview(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		int fireTicCap, int flashTics, int flashSeek)
	{
		if (nm != 'PB_DemonExterminator')
			return;
		PDA_WeaponStrip_AppendFireLike(nm, "FireModeLaserOK", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "FireModeIncinOK", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "FireModeSoulOK", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "AltModeLaserOK", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "AltModeIncinOK", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "AltModeSoulOK", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
	}

