	void PDA_WeaponStrip_AppendOverlayIfPresent(Name nm, string ovlLabel,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int segOverlay, int overlayMaxSteps, int overlayTicCap)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (!def)
			return;
		State st = def.FindStateByString(ovlLabel, true);
		if (!st)
			return;
		int steps = 0;
		while (st && steps < overlayMaxSteps && outFr.Size() < hardCap)
		{
			PDA_WeaponStrip_TryPushFrame(st, def, outFr, outTi, outSeg, useSeg, segOverlay,
				-1, true, overlayTicCap, hardCap);
			State nx = st.NextState;
			if (!nx || nx == st)
				break;
			if (PDA_Main_FireWalk_ShouldStopBeforeState(def, nx))
				break;
			st = nx;
			steps++;
		}
	}

	void PDA_WeaponStrip_AppendFullWeapon(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		int pickupTics, int spawnSeek,
		int readyMax, int readySeek, int readyFixedTic, int readyAuthoredTicCap,
		int fireTicCap, int flashTics, int flashSeek,
		bool includeOverlays, int overlayTicCap, int overlayMaxSteps)
	{
		readonly<Weapon> wchk = GetDefaultByType((class<Weapon>)(nm));
		if (!wchk)
			return;
		PDA_WeaponStrip_AppendPickup(nm, outFr, outTi, outSeg, useSeg, hardCap, pickupTics, spawnSeek,
			PB_PDA_WEAPON_PREVIEW_SEG_PICKUP);
		if (nm == 'PB_Deagle')
		{
			PDA_WeaponStrip_AppendPB_DeaglePreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				readyFixedTic, fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'BDPBattleRifle')
		{
			PDA_WeaponStrip_AppendBDPBattleRiflePreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'Rifle')
		{
			PDA_WeaponStrip_AppendRiflePreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'PB_M1Plasma')
		{
			PDA_WeaponStrip_AppendM1PlasmaPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'PB_Flamethrower')
		{
			PDA_WeaponStrip_AppendFlamethrowerPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		int effReadyMax = readyMax;
		int effReadyFixedTic = readyFixedTic;
		if (nm == 'BioAcidLauncher' || nm == 'PB_CyberdemonRL' || nm == 'PB_NeoHMG'
			|| nm == 'PB_Excavator' || nm == 'PB_M41A' || nm == 'PB_CryoElectroRifle'
			|| nm == 'PB_CryoCannon' || nm == 'PB_CryoASG' || nm == 'PB_Fusil' || nm == 'Paingiver'
			|| nm == 'PB_RiotShieldModule')
		{
			effReadyMax = max(1, readyMax / 4);
			effReadyFixedTic = max(1, readyFixedTic / 4);
		}
		else if (nm == 'VorpalBlade')
		{
			effReadyMax = max(1, readyMax / 5);
			effReadyFixedTic = max(1, readyFixedTic / 5);
		}
		else if (nm == 'PB_MetalSniper')
		{
			effReadyMax = 1;
		}
		if (nm != 'HellPistoler' && nm != 'Paingiver')
		{
			PDA_WeaponStrip_AppendReady(nm, outFr, outTi, outSeg, useSeg, hardCap,
				effReadyMax, readySeek, effReadyFixedTic, readyAuthoredTicCap, PB_PDA_WEAPON_PREVIEW_SEG_READY);
		}
		if (nm == 'PB_RiotShieldModule')
		{
			PDA_WeaponStrip_AppendRiotShieldPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'PB_Chainsaw')
		{
