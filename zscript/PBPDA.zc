	void PDA_WeaponStrip_AppendPB_DeaglePreview(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		int readyFixedTic, int fireTicCap, int flashTics, int flashSeek)
	{
		if (nm != 'PB_Deagle')
			return;
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (def)
		{
			int effReadyTic = max(1, readyFixedTic / 4);
			State st = def.FindStateByString("PDA_Preview_Deagle_Ready", true);
			int steps = 0;
			while (st && steps < PB_PDA_WEAPON_PREVIEW_READY_SEEK && outFr.Size() < hardCap)
			{
				PDA_WeaponStrip_TryPushFrame(st, def, outFr, outTi, outSeg, useSeg,
					PB_PDA_WEAPON_PREVIEW_SEG_READY, effReadyTic, true, fireTicCap, hardCap);
				State nx = st.NextState;
				if (!nx || nx == st)
					break;
				st = nx;
				steps++;
			}
		}
		PDA_WeaponStrip_AppendFireLike(nm, "PDA_Preview_Deagle_Fire", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "PDA_Preview_Deagle_AdsFire", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "PDA_Preview_Deagle_AltAds", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "PDA_Preview_Deagle_Reload", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
	}

