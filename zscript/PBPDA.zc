class PB_PDAWeapTextContainer
{
	string PDAWeaponText;
	string PDAWeaponHeader;
	string PDAWeaponExtraText;
	string PDAWeaponTextVSize, PDAWeaponTextHSize;
	string PDAWeapClassName;
	bool found;
}

class PB_PDAEquipTextContainer
{
	string PDAEquipHeader;
	string PDAEquipText;
	string PDAEquipExtraText;
	string PDAEquipClassName;
	bool found;
}

class PB_PDAWeaponContainer : Inventory
{
	Array<String> PDAWeaponExtraTexts;
	Array<String> PDAWeaponHeaders;
	Array<String> PDAWeaponTexts;
	Array<String> PDAMonsterTexts;
	Array<String> PDAMonsterStrings;
	Array<String> PDAMonsterIconClass;
	Array<bool> PDAMonsterFound;
	Array<String> PDAWeaponStrings;
	Array<Double> PDAWeaponTextVSize,PDAWeaponTextHSize;
	Array<String> CollectedWeapons;
	Array<PB_PDAWeapTextContainer> pdaWeapTextArray;
	int largestStringWidth;
	Array<String> PDA_CodexMonsterClassNames;
	Array<Class<Actor> > PDA_CodexMonsterClasses;
	Array<int> PDA_CodexMonsterSlots;

	Array<String> PDAEquipStrings;
	Array<String> PDAEquipTexts;
	Array<String> PDAEquipHeaders;
	Array<String> PDAEquipExtraTexts;
	Array<String> PDAEquipIconClass;
	Array<bool> PDAEquipFound;
	Array<PB_PDAEquipTextContainer> pdaEquipTextArray;
	Array<String> PDA_CodexEquipClassNames;
	Array<Class<Inventory> > PDA_CodexEquipClasses;
	Array<int> PDA_CodexEquipSlots;

	const PB_PDA_DESC_BREAK_WIDTH = 180;

	void ClearCodexMonsterRegistry()
	{
		PDA_CodexMonsterClassNames.Clear();
		PDA_CodexMonsterClasses.Clear();
		PDA_CodexMonsterSlots.Clear();
	}

	void ClearCodexEquipRegistry()
	{
		PDA_CodexEquipClassNames.Clear();
		PDA_CodexEquipClasses.Clear();
		PDA_CodexEquipSlots.Clear();
	}

	void RegisterEquipmentCodexClass(string cls, int slot)
	{
		PDA_CodexEquipClassNames.Push(cls);
		Name nmCls = cls;
		PDA_CodexEquipClasses.Push((class<Inventory>)(nmCls));
		PDA_CodexEquipSlots.Push(slot);
		if (PDA_DebugOn())
		{
			string okstr = PDA_CodexEquipClasses[PDA_CodexEquipClasses.Size() - 1] ? "ok" : "NULL";
			Console.PrintF("[PDA-DBG] equip register slot=" .. slot .. " cls='" .. cls .. "' resolved=" .. okstr);
		}
	}

	void TryUnlockEquipmentCodexSlot(int i)
	{
		if (i < 0 || i >= PDA_CodexEquipClasses.Size())
			return;
		int sl = PDA_CodexEquipSlots[i];
		if (sl < 0 || sl >= PDAEquipFound.Size() || PDAEquipFound[sl])
			return;
		PDAEquipFound[sl] = true;
		EventHandler.SendNetworkEvent("FoundEquip:" .. sl);
		if (PDA_DebugOn())
		{
			Console.PrintF("[PDA-DBG] equip tier slot=" .. sl .. " reg='" .. PDA_CodexEquipClassNames[i] .. "'");
			Console.PrintF("[PDA-DBG] equip unlock slot=" .. sl);
		}
	}

	void NotifyEquipmentInventoryGranted(class<Inventory> itemtype)
	{
		if (!itemtype || !owner || !owner.player) return;
		if (PDA_CodexEquipClasses.Size() < 1) return;
		for (class<Object> oc = itemtype; oc != null; oc = oc.GetParentClass())
		{
			class<Inventory> ic = (class<Inventory>)(oc);
			if (!ic) continue;
			for (int i = 0; i < PDA_CodexEquipClasses.Size(); i++)
			{
				if (PDA_CodexEquipClasses[i] == null) continue;
				if (ic != PDA_CodexEquipClasses[i]) continue;
				TryUnlockEquipmentCodexSlot(i);
				return;
			}
		}
	}

	void SweepEquipmentCodexFromPawn(PlayerPawn a)
	{
		if (!a || PDA_CodexEquipClasses.Size() < 1)
			return;
		for (int i = 0; i < PDA_CodexEquipClasses.Size(); i++)
		{
			class<Inventory> ic = PDA_CodexEquipClasses[i];
			if (ic == null)
				continue;
			int sl = PDA_CodexEquipSlots[i];
			if (sl >= 0 && sl < PDAEquipFound.Size() && PDAEquipFound[sl])
				continue;
			if (!a.FindInventory(ic))
				continue;
			TryUnlockEquipmentCodexSlot(i);
		}
	}

	static bool PDA_DebugOn()
	{
		return false;
	}

	void RegisterMonsterCodexClass(string cls, int slot)
	{
		PDA_CodexMonsterClassNames.Push(cls);
		Name nmCls = cls;
		PDA_CodexMonsterClasses.Push((class<Actor>)(nmCls));
		PDA_CodexMonsterSlots.Push(slot);
		if (PDA_DebugOn())
		{
			string okstr = PDA_CodexMonsterClasses[PDA_CodexMonsterClasses.Size() - 1] ? "ok" : "NULL";
			Console.PrintF("[PDA-DBG] register slot=" .. slot .. " cls='" .. cls .. "' resolved=" .. okstr);
		}
	}

	void ApplyMonsterCodexKill(Actor dead)
	{
		if (!dead || !dead.bIsMonster) return;
		if (PDA_CodexMonsterClasses.Size() < 1)
		{
			if (PDA_DebugOn()) Console.PrintF("[PDA-DBG] kill abort: registry empty");
			return;
		}
		bool dbg = PDA_DebugOn();
		string deadName = "" .. dead.GetClassName();
		if (dbg)
			Console.PrintF("[PDA-DBG] kill thing class=" .. deadName .. " registrySize=" .. PDA_CodexMonsterClasses.Size());
		for (class<Object> ty = dead.GetClass(); ty != null; ty = ty.GetParentClass())
		{
			if ((class<Actor>)(ty) == null) continue;
			bool tierHit = false;
			for (int i = 0; i < PDA_CodexMonsterClasses.Size(); i++)
			{
				if (PDA_CodexMonsterClasses[i] == null) continue;
				if ((class<Actor>)(ty) != PDA_CodexMonsterClasses[i]) continue;
				tierHit = true;
				int sl = PDA_CodexMonsterSlots[i];
				if (dbg)
					Console.PrintF("[PDA-DBG] hit slot=" .. sl .. " codex='" .. PDA_CodexMonsterClassNames[i] .. "'");
				if (sl >= 0 && sl < PDAMonsterFound.Size() && !PDAMonsterFound[sl])
				{
					PDAMonsterFound[sl] = true;
					EventHandler.SendNetworkEvent("FoundMonster:" .. sl);
					if (dbg) Console.PrintF("[PDA-DBG] unlock slot=" .. sl .. " sent FoundMonster netevent");
				}
				else if (dbg)
				{
					Console.PrintF("[PDA-DBG] slot=" .. sl .. " already-found or out-of-range (foundSize=" .. PDAMonsterFound.Size() .. ")");
				}
			}
			if (tierHit) return;
		}
		if (dbg) Console.PrintF("[PDA-DBG] no tier matched for class=" .. deadName);
	}

	Default
	{
		+INVENTORY.UNDROPPABLE
		Inventory.PickupMessage "You got the PDA!";
	}
	override void AttachToOwner(Actor other)
	{
		Super.AttachToOwner(other);
		InitializePDATexts();
		SyncWeaponCodexFromOwner(PlayerPawn(other));
	}
	static clearscope double lerp(double v0, double v1, double t)
	{
		return (1 - t) * v0 + t * v1;
	}
	void InitializePDATexts()
	{
		int lump = Wads.FindLump("PDAMONST");
		string stuff = Wads.ReadLump(lump);
		stuff.Split(PDAMonsterStrings,",");
		ClearCodexMonsterRegistry();
		PDAMonsterTexts.Clear();
		PDAMonsterIconClass.Clear();
		PDAMonsterFound.Clear();
		Array<String> mtBlocks;
		int lumpMt = Wads.CheckNumForFullName("PDAMONSTT");
		if (lumpMt >= 0)
		{
			string mtstuff = Wads.ReadLump(lumpMt);
			mtstuff.Split(mtBlocks, "#");
		}
		for (int mi = 0; mi < PDAMonsterStrings.Size(); mi++)
		{
			string desc = "";
			string stats = "";
			string clsbundle = "";
			string firstMonsterCls = "";
			if (mi < mtBlocks.Size())
			{
				string blk = mtBlocks[mi];
				blk.Replace("\r", "");
				while (blk.length() > 0 && (blk.ByteAt(0) == 10 || blk.ByteAt(0) == 13))
					blk = blk.Mid(1, blk.length() - 1);
				Array<String> mf;
				blk.Split(mf, "$");
				if (mf.Size() >= 4)
				{
					desc = mf[1];
					clsbundle = mf[2];
					stats = mf[3];
				}
				else if (mf.Size() >= 3)
				{
					desc = mf[1];
					clsbundle = mf[2];
				}
			}
			if (desc == "")
				desc = "No dossier text available for this catalogue index.";
			string composed = PDAMonsterStrings[mi] .. "\n\n" .. desc;
			if (stats != "")
				composed = composed .. "\n\n" .. stats;
			BrokenLines monWrap = SmallFont.BreakLines(composed, PB_PDA_DESC_BREAK_WIDTH);
			string wrappedMon = "";
			for (int ml = 0; ml < monWrap.Count(); ml++)
			{
				if (ml > 0) wrappedMon = wrappedMon .. "\n";
				wrappedMon = wrappedMon .. monWrap.StringAt(ml);
			}
			PDAMonsterTexts.Push(wrappedMon);
			if (clsbundle != "")
			{
				Array<String> clsParts;
				clsbundle.Split(clsParts, ",");
				for (int ci = 0; ci < clsParts.Size(); ci++)
				{
					string tok = clsParts[ci];
					tok.Replace("\n", "");
					tok.Replace(" ", "");
					if (tok.length() < 1) continue;
					if (firstMonsterCls == "") firstMonsterCls = tok;
					RegisterMonsterCodexClass(tok, mi);
				}
			}
			PDAMonsterIconClass.Push(firstMonsterCls);
			PDAMonsterFound.Push(false);
		}
		if (PDA_CodexMonsterClasses.Size() < 1 && PDAMonsterStrings.Size() > 0)
		{
			Console.PrintF("[PDA] WARNING: monster codex empty after init (PDAMONSTT load failed?). Killed monsters will not unlock catalogue rows.");
		}
		int weaplump = Wads.FindLump("PDAWEAP");
		string weapstuff = Wads.ReadLump(weaplump);
		weapstuff.Split(PDAWeaponStrings,",");
		int weaptlump = Wads.FindLump("PDAWEAPT");
		string weaptstuff = Wads.ReadLump(weaptlump);
		Array<String> initialweaptstrings;
		weaptstuff.Split(initialweaptstrings,"#");
		for (int splitCounter = 0; splitCounter < initialweaptstrings.Size(); splitCounter++)
		{
			string blk = initialweaptstrings[splitCounter];
			blk.Replace("\r", "");
			while (blk.Length() > 0 && (blk.ByteAt(0) == 10 || blk.ByteAt(0) == 13))
				blk = blk.Mid(1, blk.Length() - 1);
			if (blk.Length() < 1)
				continue;

			Array<String> fields;
			blk.Split(fields, "$");
			if (fields.Size() < 3)
				continue;

			string PDAWeaponHeader = fields[0];
			string PDAWeaponText = fields[1];
			string PDAWeapClassName = fields[2];
			PDAWeaponHeader.Replace("\n", "");
			PDAWeapClassName.Replace("\n", "");
			PDAWeapClassName.Replace(" ", "");

			string PDAWeapExtraText = fields[3];
			for (int fi = 4; fi < fields.Size(); fi++)
				PDAWeapExtraText = PDAWeapExtraText .. "\n" .. fields[fi];

			PDAWeaponHeaders.Push(PDAWeaponHeader);
			PDAWeaponTexts.Push(PDAWeaponText);
			PDAWeaponExtraTexts.Push(PDAWeapExtraText);
			EventHandler.SendNetworkEvent("addweaponclass:" .. PDAWeapClassName);

			let pdaTextContainer = new("PB_PDAWeapTextContainer");
			pdaTextContainer.PDAWeaponExtraText = PDAWeapExtraText;
			pdaTextContainer.PDAWeaponText = PDAWeaponText;
			pdaTextContainer.PDAWeapClassName = PDAWeapClassName;
			pdaTextContainer.PDAWeaponHeader = PDAWeaponHeader;
			pdaTextContainer.found = false;
			pdaWeapTextArray.Push(pdaTextContainer);
		}
		if (pdaWeapTextArray.Size() > 0 && PDAWeaponStrings.Size() > 0
			&& pdaWeapTextArray.Size() != PDAWeaponStrings.Size())
		{
			Console.PrintF("[PDA] WARNING: PDAWEAP has %d labels but PDAWEAPT registered %d weapon rows.",
				PDAWeaponStrings.Size(), pdaWeapTextArray.Size());
		}
		int iii = 0;
		BrokenLines WeaponTextLines, WeaponExtraTextLines;
		string NewWeaponText;
		font breaklinefont = SmallFont;
		largestStringWidth = 0;
		string NewWeaponExtraText;
		for (iii = 0; iii < PDAWeaponTexts.Size(); iii++)
		{
			NewWeaponText = "";
			WeaponTextLines = breaklinefont.BreakLines(PDAWeaponTexts[iii], PB_PDA_DESC_BREAK_WIDTH);
			for (int linecounter = 0; linecounter < WeaponTextLines.Count(); ++linecounter)
			{
				string linestring = WeaponTextLines.StringAt(lineCounter);
				if (LargestStringWidth < SmallFont.StringWidth(WeaponTextLines.StringAt(lineCounter))*CleanYFac) largestStringWidth = WeaponTextLines.StringWidth(linecounter) * CleanXFac;
				linestring.AppendFormat("\n");
				NewWeaponText = NewWeaponText..Linestring;
			}
			PDAWeaponTexts[iii] = NewWeaponText;
			PDAWeaponTextVSize.Push(breaklinefont.GetHeight() * CleanYFac_1 * WeaponTextLines.Count());
			PDAWeaponTextHSize.Push(largestStringWidth * CleanXFac_1);
		}
		for (int extraindex = 0; extraindex < PDAWeaponExtraTexts.Size(); extraindex++)
		{
			NewWeaponExtraText = "";
			WeaponExtraTextLines = breaklinefont.BreakLines(PDAWeaponExtraTexts[extraindex], PB_PDA_DESC_BREAK_WIDTH);
			for (int linecounter = 0; linecounter < WeaponExtraTextLines.Count(); ++linecounter)
			{
				string linestring = WeaponExtraTextLines.StringAt(linecounter);
				if (largestStringWidth < SmallFont.StringWidth(linestring) * CleanYFac)
					largestStringWidth = SmallFont.StringWidth(linestring) * CleanXFac;
				linestring.AppendFormat("\n");
				NewWeaponExtraText = NewWeaponExtraText .. linestring;
			}
			PDAWeaponExtraTexts[extraindex] = NewWeaponExtraText;
		}

		ClearCodexEquipRegistry();
		PDAEquipStrings.Clear();
		PDAEquipTexts.Clear();
		PDAEquipHeaders.Clear();
		PDAEquipExtraTexts.Clear();
		PDAEquipIconClass.Clear();
		PDAEquipFound.Clear();
		pdaEquipTextArray.Clear();
		int lumpEq = Wads.FindLump("PDAEQUIP");
		if (lumpEq >= 0)
		{
			string eqstuff = Wads.ReadLump(lumpEq);
			eqstuff.Split(PDAEquipStrings, ",");
		}
		Array<String> eqBlocks;
		int lumpEqt = Wads.CheckNumForFullName("PDAEQUIPT");
		if (lumpEqt >= 0)
		{
			string eqtstuff = Wads.ReadLump(lumpEqt);
			eqtstuff.Split(eqBlocks, "#");
		}
		for (int ei = 0; ei < PDAEquipStrings.Size(); ei++)
		{
			string desc = "";
			string stats = "";
			string clsbundle = "";
			string firstCls = "";
			if (ei < eqBlocks.Size())
			{
				string blk = eqBlocks[ei];
				blk.Replace("\r", "");
				while (blk.length() > 0 && (blk.ByteAt(0) == 10 || blk.ByteAt(0) == 13))
					blk = blk.Mid(1, blk.length() - 1);
				Array<String> ef;
				blk.Split(ef, "$");
				if (ef.Size() >= 4)
				{
					desc = ef[1];
					clsbundle = ef[2];
					stats = ef[3];
				}
				else if (ef.Size() >= 3)
				{
					desc = ef[1];
					clsbundle = ef[2];
				}
			}
			if (desc == "")
				desc = "No dossier text available for this equipment entry.";
			string composed = PDAEquipStrings[ei] .. "\n\n" .. desc;
			if (stats != "")
				composed = composed .. "\n\n" .. stats;
			BrokenLines eqWrap = SmallFont.BreakLines(composed, PB_PDA_DESC_BREAK_WIDTH);
			string wrappedEq = "";
			for (int el = 0; el < eqWrap.Count(); el++)
			{
				if (el > 0) wrappedEq = wrappedEq .. "\n";
				wrappedEq = wrappedEq .. eqWrap.StringAt(el);
			}
			PDAEquipTexts.Push(wrappedEq);
			PDAEquipHeaders.Push(PDAEquipStrings[ei]);
			PDAEquipExtraTexts.Push(stats);
			if (clsbundle != "")
			{
				Array<String> clsParts;
				clsbundle.Split(clsParts, ",");
				for (int ci = 0; ci < clsParts.Size(); ci++)
				{
					string tok = clsParts[ci];
					tok.Replace("\n", "");
					tok.Replace(" ", "");
					if (tok.length() < 1) continue;
					if (firstCls == "") firstCls = tok;
					RegisterEquipmentCodexClass(tok, ei);
				}
			}
			PDAEquipIconClass.Push(firstCls);
			PDAEquipFound.Push(false);
			let eqRow = new("PB_PDAEquipTextContainer");
			eqRow.PDAEquipHeader = PDAEquipStrings[ei];
			eqRow.PDAEquipText = wrappedEq;
			eqRow.PDAEquipExtraText = stats;
			eqRow.PDAEquipClassName = firstCls;
			eqRow.found = false;
			pdaEquipTextArray.Push(eqRow);
		}
		if (PDA_CodexEquipClasses.Size() < 1 && PDAEquipStrings.Size() > 0)
		{
			Console.PrintF("[PDA] WARNING: equipment codex empty after init (PDAEQUIPT load failed?). Pickups will not unlock catalogue rows.");
		}
	}

	void SyncWeaponCodexFromOwner(PlayerPawn mo)
	{
		if (!mo)
			return;
		for (Inventory ch = mo.Inv; ch != null; ch = ch.Inv)
		{
			let wpn = Weapon(ch);
			if (!wpn)
				continue;
			String cn = wpn.GetClassName();
			bool already = false;
			for (int i = 0; i < pdaWeapTextArray.Size(); i++)
			{
				if (pdaWeapTextArray[i].PDAWeapClassName ~== cn && pdaWeapTextArray[i].found)
				{
					already = true;
					break;
				}
			}
			if (!already)
				EventHandler.SendNetworkEvent("Foundweapon:" .. cn);
		}
	}
}

class PB_PDAPreviewSequence
{
	Array<TextureID> frames;
	Array<int> ticsPerFrame;
	Array<int> segmentLabels;
}

class PB_PDAUi_Object
{
	TextureID DialogPicture;
	Vector2 ImagePos,ImageSize,InitialImagePos;
	bool ExitButtonTrue;
	bool BackButtonTrue;
	int descClipX,descClipY,descClipW,descClipH;
	bool MonsterMenuOnly;
	bool WeaponMenuOnly;
	bool EquipmentMenuOnly;
	bool NonMainMenuOnly;
	PB_PDAWeapTextContainer pdaWeapTextArray;
	PB_PDAEquipTextContainer pdaEquipRow;
	int fontcolor;
	int objecttype;
	int entrynumber;
	double globalAlphaValue;
	string toDraw;
	font usefont;
	bool notdrawn;
	bool objectHeldDown;
	bool unmovable;
	bool dontdraw;
	bool MouseOvered;
	bool Clicked;
	bool UnSelectable;
	bool MainHubBlockyExit;
	bool MainHubBlockySlot;
	bool MainHubBlockyAchievements;
	virtual string GetString()
	{
		Switch(objecttype)
		{
			case 0:
			Default:
				return "Exit";
				break;
			case 1:
				return "Monsters";
				break;
			case 2:
				return "Weapons";
				break;
			case 14:
				return "Equipment";
				break;
			case 16:
				return "Reward";
				break;
			case 17:
				return "Achievements";
				break;
		}
		return "Exit";
	}
	virtual bool ExitButton()
	{
		return ExitButtonTrue;
	}
	virtual void UiFunction()
	{
		if (!toDraw)
		{
			toDraw = GetString();
		}
	}
	void InitializeTexturedUiObject(TextureID tex)
	{
		let xy = TexMan.GetScaledSize(Tex);
		ImageSize = xy;
		DialogPicture = tex;
	}
	void InitializeUiObject(font touse = "SmallFont")
	{
		let dialog = self;
		dialog.usefont = touse;
		dialog.fontcolor = Font.CR_GREEN;
		double scale = clamp(Screen.GetHeight() / 240.0, 2.0, 6.0);
		dialog.ImageSize.X = usefont.StringWidth(dialog.toDraw) * scale;
		dialog.ImageSize.Y = usefont.GetHeight() * scale;
	}
}
