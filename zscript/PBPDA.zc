	clearscope static bool PB2022WeaponHudSkipWeapon(Name weaponClass)
	{
		// Corner weapon portrait (Icon / AltHUDIcon) — not the integrated HUD's AMMOIC* ammo-type glyph.
		// Bare hands: wheel uses MLDFA0; no meaningful weapon portrait in the PBX corner slot.
		return weaponClass == 'Melee_Attacks';
	}

	ui static bool PB2022_TexValid(TextureID t)
	{
		return t && t.IsValid();
	}

	// 4.5.0: TextureID() needs a tex name; default-local is the invalid sentinel.
	ui static TextureID PB2022_NoTex()
	{
		TextureID none;
		return none;
	}

	ui static TextureID PB2022_ModeHudWheel(String path)
	{
		TextureID t = TexMan.CheckForTexture(path, TexMan.Type_Any);
		return PB2022_TexValid(t) ? t : PB2022_NoTex();
	}

	ui static TextureID PB2022_ModeHudLump(String lump)
	{
		TextureID t = TexMan.CheckForTexture(lump, TexMan.Type_Any);
		return PB2022_TexValid(t) ? t : PB2022_NoTex();
	}

	ui static TextureID PB2022_ModeHudWheelOrLump(String wheelPath, String lumpFallback = "")
	{
		TextureID t = PB2022_ModeHudWheel(wheelPath);
		if (PB2022_TexValid(t))
			return t;
		if (lumpFallback.Length() > 0)
			return PB2022_ModeHudLump(lumpFallback);
		return PB2022_NoTex();
	}

	ui static bool PB2022_SpawnSpriteUnfitForWeaponHud(string tn)
	{
		if (tn.Length() < 4)
			return true;
		string p = tn.Mid(0, 4);
		return p ~== "PLAY" || p ~== "MARN" || p ~== "MARJ" || p ~== "PLA1"
			|| p ~== "STAN" || p ~== "STAL" || p ~== "PUNG" || p ~== "PUNS";
	}

	ui static TextureID PB2022_HudIconFromWeaponDefaults(Name weaponClass)
	{
		class<Weapon> wcls = (class<Weapon>)(weaponClass);
		if (!wcls)
			return PB2022_NoTex();
		readonly<Weapon> wdef = GetDefaultByType(wcls);
		if (!wdef)
			return PB2022_NoTex();
		if (wdef.Icon.IsValid())
			return wdef.Icon;
		if (wdef.AltHUDIcon.IsValid())
			return wdef.AltHUDIcon;
		return PB2022_NoTex();
	}

	ui static TextureID PB2022_FirstHudIconFromSpawn(Name cls)
	{
		class<Actor> acl = (class<Actor>)(cls);
		if (!acl)
			return PB2022_NoTex();
		readonly<Actor> adef = GetDefaultByType(acl);
		if (!adef)
			return PB2022_NoTex();
		State st = adef.SpawnState;
		for (int n = 0; n < 48 && st; n++)
		{
			TextureID sid = st.GetSpriteTexture(0);
			if (PB2022_TexValid(sid))
			{
				string tn = TexMan.GetName(sid);
				if (tn.Length() >= 4 && tn.Mid(0, 4) ~== "TNT1")
				{
					st = st.NextState;
					continue;
				}
				if (PB2022_SpawnSpriteUnfitForWeaponHud(tn))
				{
					st = st.NextState;
					continue;
				}
				return sid;
			}
			st = st.NextState;
		}
		return PB2022_NoTex();
	}

	ui static bool PB2022_WeaponHudIconExtremeAspect(TextureID tex)
	{
		if (!PB2022_TexValid(tex))
			return true;
		Vector2 ts = TexMan.GetScaledSize(tex);
		if (ts.X < 1.0 || ts.Y < 1.0)
			return true;
		double ar = ts.X / ts.Y;
		return ar < 0.55 || ar > 1.85;
	}

	ui static TextureID PB2022_ResolveWeaponPortraitIcon(Weapon weap, Name weaponClass)
	{
		TextureID wheel = TexMan.CheckForTexture(
			String.Format("graphics/pywheel/weapons/%s.png", weaponClass), TexMan.Type_Any);
		if (PB2022_TexValid(wheel))
			return wheel;

		TextureID iconID = PB2022_NoTex();
		if (weap)
		{
			if (weap.Icon.IsValid())
				iconID = weap.Icon;
			else if (weap.AltHUDIcon.IsValid())
				iconID = weap.AltHUDIcon;
		}
		if (!PB2022_TexValid(iconID))
			iconID = PB2022_HudIconFromWeaponDefaults(weaponClass);

		if (!PB2022_TexValid(iconID))
		{
			TextureID classIcon = TexMan.CheckForTexture(
				String.Format("%sICON", weaponClass), TexMan.Type_Any);
			if (PB2022_TexValid(classIcon))
				iconID = classIcon;
		}

		bool needsSpawnFallback = !PB2022_TexValid(iconID)
			|| (weaponClass == 'HASG' && PB2022_WeaponHudIconExtremeAspect(iconID));
		if (needsSpawnFallback)
		{
			TextureID spawn = PB2022_FirstHudIconFromSpawn(weaponClass);
			if (PB2022_TexValid(spawn))
				return spawn;
		}
		if (PB2022_TexValid(iconID))
			return iconID;
		if (weaponClass == 'HASG')
		{
			TextureID lump = PB2022_ModeHudLump("0ESGA0");
			if (PB2022_TexValid(lump))
				return lump;
		}
		return PB2022_NoTex();
	}

	ui void DrawPB2022WeaponPickupOverlay()
	{
		if (!playeringame[consoleplayer]) { return; }
		let p = players[consoleplayer];
		if (!p || !p.mo || !p.ReadyWeapon) { return; }
		let cvEnable = CVar.GetCVar("pb_weaponhud_enable", p);
		if (!cvEnable || !cvEnable.GetBool()) { return; }

		Weapon weap = p.ReadyWeapon;
		Name weaponClass = weap.GetClassName();

		if (PB2022WeaponHudSkipWeapon(weaponClass))
			return;

		TextureID iconID = PB2022_ResolveWeaponPortraitIcon(weap, weaponClass);
		if (!PB2022_TexValid(iconID)) { return; }

		let cvAlpha = CVar.GetCVar("pb_weaponhud_alpha", p);
		let cvScale = CVar.GetCVar("pb_weaponhud_scale", p);
		let cvOffX  = CVar.GetCVar("pb_weaponhud_x", p);
		let cvOffY  = CVar.GetCVar("pb_weaponhud_y", p);
		let cvMaxW  = CVar.GetCVar("pb_weaponhud_maxwidth", p);
		let cvMaxH  = CVar.GetCVar("pb_weaponhud_maxheight", p);
		double alpha = cvAlpha ? clamp(cvAlpha.GetFloat(), 0.0, 1.0) : 1.0;
		double userScale = cvScale ? max(0.1, cvScale.GetFloat()) : 1.0;
		int offX = cvOffX ? cvOffX.GetInt() : 0;
		int offY = cvOffY ? cvOffY.GetInt() : 0;
		double boxW = (cvMaxW ? max(16.0, cvMaxW.GetFloat()) : 96.0) * userScale;
		double boxH = (cvMaxH ? max(16.0, cvMaxH.GetFloat()) : 72.0) * userScale;
		// pb_weaponhud_x/y offset the box anchor from the screen bottom-right corner.
		double cx = double(Screen.GetWidth() + offX) - boxW * 0.5;
		double cy = double(Screen.GetHeight() + offY) - boxH * 0.5;

		DrawClipFittedTexture(iconID, cx, cy, boxW, boxH, alpha, false, false);
	}

	ui TextureID PB2022GetModeIcon(PlayerInfo p, Name weaponClass, out double localScale, out double localOffX, out double localOffY)
	{
		localScale = 1.0;
		localOffX = 0.0;
		localOffY = 0.0;
		if (!p || !p.mo)
			return PB2022_NoTex();

		TextureID modeIcon = PB2022_NoTex();
		Actor mo = p.mo;

		switch (weaponClass)
		{
			case 'PB_Shotgun':
				localScale = 0.9;
				if (mo.CountInv("SelectShotgun_Dragonsbreath") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_DB.png");
				else if (mo.CountInv("SelectShotgun_Slugshot") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_Slug.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_Buck.png");
				break;

			case 'PB_CSSG':
				localScale = 0.9;
				if (p.ReadyWeapon is "PB_CSSG")
				{
					int shellMode = PB_CSSG(p.ReadyWeapon).shellsmode + 1;
					if (shellMode == 9)
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Danmaku.png");
					else if (shellMode == 8)
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Doom.png");
					else if (shellMode == 7)
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_WPhosphorus.png");
					else if (shellMode == 6)
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Explosive.png");
					else if (shellMode == 5)
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_DB.png");
					else if (shellMode == 4)
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Flak.png");
					else if (shellMode == 3)
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Flechette.png");
					else if (shellMode == 2)
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Slug.png");
					else
						modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Buck.png");
				}
				break;

			case 'HASG':
				localScale = 0.9;
				if (mo.CountInv("HASG_Danmaku") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Danmaku.png");
				else if (mo.CountInv("HASG_WPhos") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_WPhosphorus.png");
				else if (mo.CountInv("HASG_Explosive") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Explosive.png");
				else if (mo.CountInv("HASG_DRBT") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_DB.png");
				else if (mo.CountInv("HASG_Flech") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Flechette.png");
				else if (mo.CountInv("HASG_Slug") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Slug.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/CSSG/SG_Buck.png");
				break;

			case 'PB_Carbine':
				localScale = 0.9;
				if (mo.CountInv("SelectCarbine_DualWield") >= 1 || mo.CountInv("DualWieldingCarbines") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Carbine_Dual.png");
				else if (mo.CountInv("SelectCarbine_FullAutoFire") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Carbine_Auto.png");
				else if (mo.CountInv("SelectCarbine_BurstFire") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Carbine_Burst.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Carbine_Semi.png");
				break;

			case 'PB_Minigun':
				localScale = 0.9;
				if (mo.CountInv("SelectMinigun_Triple") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Minigun_3.png");
				else if (mo.CountInv("SelectMinigun_Gatling") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Minigun_2.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Minigun_1.png");
				break;

			case 'PB_NeoHMG':
				localScale = 0.9;
				if (mo.CountInv("HMG_Select_Charged") >= 1 || mo.CountInv("HMGModeCharged") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_DB.png");
				else if (mo.CountInv("HMG_Select_Heated") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_Buck.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_Buck.png");
				break;

			case 'PB_M41A':
				localScale = 0.85;
				if (mo.CountInv("DualWieldingM41A") >= 1)
					modeIcon = PB2022_ModeHudWheelOrLump("graphics/pywheel/M41DW0.png", "graphics/pywheel/Carbine_Dual.png");
				else if (mo.CountInv("SelectM41A_30mmGrenade") >= 1 || mo.CountInv("M41ChangeCart") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/rocket_standard.png");
				else if (mo.CountInv("SelectM41A_12Gauge") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_Buck.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/rocket_standard.png");
				break;

			case 'PB_XM21':
				localScale = 0.85;
				if (mo.CountInv("XM21HasBallistics") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_DB.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/SG_Slug.png");
				break;

			case 'PB_Fusil':
				localScale = 0.9;
				modeIcon = PB2022_ModeHudLump("FUSIF0");
				break;

			case 'PB_SideFusil':
				localScale = 0.85;
				modeIcon = PB2022_ModeHudLump("ENTEJ0");
				break;

			case 'PB_Unmaker':
				localScale = 0.85;
				localOffY = -40.0;
				if (mo.CountInv("UnmakerFireSelected") >= 1)
					modeIcon = PB2022_ModeHudLump("AMMOIC6");
				else
					modeIcon = PB2022_ModeHudLump("AMMOIC7");
				break;

			case 'PB_Flamethrower':
				localScale = 0.9;
				localOffY = -40.0;
				if (mo.CountInv("FlamerNukageMode") >= 1)
					modeIcon = PB2022_ModeHudWheelOrLump("graphics/pywheel/grenade_cryo.png", "AMMOIC6");
				else
					modeIcon = PB2022_ModeHudWheelOrLump("graphics/pywheel/SG_DB.png", "AMMOIC6");
				break;

			case 'BioAcidLauncher':
				localScale = 0.85;
				localOffY = -40.0;
				modeIcon = PB2022_ModeHudLump("AMMOIC7");
				if (!PB2022_TexValid(modeIcon))
					modeIcon = PB2022_ModeHudLump("AMMOIC5");
				break;

			case 'BHGen':
				localScale = 0.85;
				localOffY = -40.0;
				modeIcon = PB2022_ModeHudLump("PRDCZ0");
				if (!PB2022_TexValid(modeIcon))
					modeIcon = PB2022_ModeHudLump("AMMOIC5");
				break;

			case 'PB_CryoElectroRifle':
				localScale = 0.9;
				localOffY = -40.0;
				if (mo.CountInv("PB_CryoElectroRifle_ElectricMode") >= 1)
				{
					modeIcon = PB2022_ModeHudLump("ZAP6A1");
					if (!PB2022_TexValid(modeIcon))
						modeIcon = PB2022_ModeHudLump("CELLA0");
				}
				else
				{
					modeIcon = PB2022_ModeHudLump("BXPLA0");
					if (!PB2022_TexValid(modeIcon))
						modeIcon = PB2022_ModeHudWheel("graphics/pywheel/grenade_cryo.png");
				}
				break;

			case 'PB_SMG':
				localScale = 0.85;
				localOffY = -40.0;
				if (mo.CountInv("DualWieldingSMGs") >= 1)
					modeIcon = PB2022_ModeHudWheelOrLump("graphics/pywheel/SMG/SMG_DUAL.png", "graphics/pywheel/Carbine_Dual.png");
				else if (mo.CountInv("LaserSightActivated") >= 1)
					modeIcon = PB2022_ModeHudWheelOrLump("graphics/pywheel/SMG/SMG_LASER.png", "graphics/pywheel/SG_Slug.png");
				else
					modeIcon = PB2022_ModeHudLump("ATFLA0");
				break;

			case 'PB_QuadSG':
				localScale = 0.85;
				if (mo.CountInv("QuadAkimboMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Quad_Dual.png");
				else if (mo.CountInv("FullBlastMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Quad_Full.png");
				else if (mo.CountInv("BreathMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Quad_Demonic.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Quad_Shells.png");
				break;

			case 'Rifle':
				localScale = 0.85;
				if (mo.CountInv("DualWieldingDMRs") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/hdmr_dual.png");
				else if (mo.CountInv("HDMRGrenadeMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/hdmr_grenade_on.png");
				else if (mo.CountInv("HDMRSniperMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/hdmr_sniper.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/hdmr_normal.png");
				break;

			case 'PB_MetalSniper':
				localScale = 0.85;
				if (p.ReadyWeapon is "PB_MetalSniper")
				{
					let ms = PB_MetalSniper(p.ReadyWeapon);
					if (ms.AltMode == 1)
						modeIcon = PB2022_ModeHudWheel("graphics/pywheel/rocket_standard.png");
					else if (ms.resonanceAmmoLoaded)
						modeIcon = PB2022_ModeHudWheel("graphics/pywheel/ResonanceRounds.png");
					else
						modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Normalrounds.png");
				}
				break;

			case 'LeverAction':
				localScale = 0.85;
				if (mo.CountInv("LeverActionHellMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Minigun_2.png");
				else if (mo.CountInv("Select_LeverAction_Marlin") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Marlin.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Magnum.png");
				break;

			case 'HellPistoler':
				localScale = 0.85;
				if (mo.CountInv("HellPistolerBeamMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Minigun_1.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Minigun_2.png");
				break;

			case 'PB_SuperGL':
				localScale = 0.85;
				if (mo.CountInv("GrenadeTypeAcid") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/grenade_acid.png");
				else if (mo.CountInv("GrenadeTypeCryo") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/grenade_cryo.png");
				else if (mo.CountInv("GrenadeTypeIncendiary") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/grenade_incendiary.png");
				else if (mo.CountInv("GrenadeTypeSticky") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/grenade_sticky.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/grenade_impact.png");
				break;

			case 'PB_Excavator':
				localScale = 0.85;
				if (mo.CountInv("EX_Select_DrillMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Excavator/DrillAlt.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Excavator/DropAlt.png");
				break;

			case 'PB_RocketLauncher':
				localScale = 0.85;
				if (mo.CountInv("RocketLauncher_Homing") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/rocket_homing.png");
				else if (mo.CountInv("RocketLauncher_Laser") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/rocket_laser.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/rocket_standard.png");
				break;

			case 'PB_M1Plasma':
				localScale = 0.85;
				if (mo.CountInv("PB_M1Plasma") >= 2)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Quad_Dual.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Quad_Single.png");
				break;

			case 'PB_DarkMatterRifle':
				localScale = 0.9;
				localOffY = -40.0;
				if (mo.CountInv("PB_DMR_GravityAltMode") >= 1)
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/rocket_standard.png");
				else
					modeIcon = PB2022_ModeHudWheel("graphics/pywheel/Minigun_2.png");
				break;

			case 'ProSurv_Ballista':
				localScale = 0.85;
				if (mo.CountInv("BallistaDemonicMode") >= 1)
					modeIcon = PB2022_ModeHudWheelOrLump("graphics/pywheel/Minigun_2.png", "CRBAB0");
				else
					modeIcon = PB2022_ModeHudWheelOrLump("graphics/pywheel/Carbine_Semi.png", "CBOWS0");
				break;

			case 'PB_Pistol':
				localScale = 0.85;
				if (mo.CountInv("PistolShieldLoadout") >= 1)
					modeIcon = PB2022_ModeHudLump("5L1DI0");
				break;

			case 'PB_Axe':
				localScale = 0.85;
				if (mo.CountInv("AxeShieldLoadout") >= 1)
					modeIcon = PB2022_ModeHudLump("5L1DI0");
				break;

			default:
				break;
		}

		return modeIcon;
	}
	ui void DrawPB2022WeaponModeOverlay()
	{
		if (!playeringame[consoleplayer]) { return; }
		let p = players[consoleplayer];
		if (!p || !p.mo || !p.ReadyWeapon) { return; }
		let cvPortrait = CVar.GetCVar("pb_weaponhud_enable", p);
		let cvModeOnly = CVar.GetCVar("pb_weaponmodehud_enable", p);
		bool portraitOn = cvPortrait && cvPortrait.GetBool();
		bool modeOnlyOn = cvModeOnly && cvModeOnly.GetBool();
		if (!portraitOn && !modeOnlyOn) { return; }

		Weapon weap = p.ReadyWeapon;
		Name weaponClass = weap.GetClassName();

		double modeScaleAdjust, modeOffX, modeOffY;
		TextureID modeIcon = PB2022GetModeIcon(p, weaponClass, modeScaleAdjust, modeOffX, modeOffY);
		if (!PB2022_TexValid(modeIcon)) { return; }

		let cvAlpha = CVar.GetCVar("pb_weaponmodehud_alpha", p);
		let cvScale = CVar.GetCVar("pb_weaponmodehud_scale", p);
		let cvOffX  = CVar.GetCVar("pb_weaponmodehud_x", p);
		let cvOffY  = CVar.GetCVar("pb_weaponmodehud_y", p);
		let cvMaxW  = CVar.GetCVar("pb_weaponmodehud_maxwidth", p);
		let cvMaxH  = CVar.GetCVar("pb_weaponmodehud_maxheight", p);
		double alpha = cvAlpha ? clamp(cvAlpha.GetFloat(), 0.0, 1.0) : 1.0;
		double userScale = (cvScale ? max(0.1, cvScale.GetFloat()) : 1.0) * modeScaleAdjust;
		int offX = (cvOffX ? cvOffX.GetInt() : 0) + int(modeOffX);
		int offY = (cvOffY ? cvOffY.GetInt() : 0) + int(modeOffY);
		double boxW = (cvMaxW ? max(12.0, cvMaxW.GetFloat()) : 56.0) * userScale;
		double boxH = (cvMaxH ? max(12.0, cvMaxH.GetFloat()) : 56.0) * userScale;
		double cx = double(Screen.GetWidth() + offX) - boxW * 0.5;
		double cy = double(Screen.GetHeight() + offY) - boxH * 0.5;

		DrawClipFittedTexture(modeIcon, cx, cy, boxW, boxH, alpha, false, false);
	}

	clearscope static string PB_PDA_NormClassStr(string cn)
	{
		cn.Replace("\r", "");
		cn.Replace("\n", "");
		cn.Replace("\t", "");
		while (cn.Length() > 0 && cn.ByteAt(0) <= 32)
			cn = cn.Mid(1, cn.Length() - 1);
		while (cn.Length() > 0 && cn.ByteAt(cn.Length() - 1) <= 32)
			cn = cn.Mid(0, cn.Length() - 1);
		return cn;
	}

	clearscope static int PB_PDA_ParseUInt(string s)
	{
		if (s.length() < 1) return -1;
		int n = 0;
		for (uint i = 0; i < s.length(); i++)
		{
			int code = int(s.ByteAt(i));
			if (code < 48 || code > 57) return -1;
			n = n * 10 + (code - 48);
		}
		return n;
	}

	clearscope static PlayerPawn PB_PDA_ResolvePlayer(Actor a)
	{
		for (int i = 0; a && i < 10; i++)
		{
			if (a is "PlayerPawn" && PlayerPawn(a).player) return PlayerPawn(a);
			Actor next = a.target != null ? a.target : (a.master != null ? a.master : a.tracer);
			if (!next || next == a) break;
			a = next;
		}
		return null;
	}

	clearscope static PlayerPawn PB_PDA_ResolveKiller(WorldEvent e)
	{
		if (!e) return null;
		PlayerPawn p = PB_PDA_ResolvePlayer(e.Inflictor);
		if (p) return p;
		p = PB_PDA_ResolvePlayer(e.DamageSource);
		if (p) return p;
		if (e.Thing) return PB_PDA_ResolvePlayer(e.Thing.target);
		return null;
	}

	clearscope static bool PB_XP_RewardsOn()
	{
		let cv = CVar.FindCVar("pb_xp_rewards");
		return cv && cv.GetBool();
	}

	void InvalidatePDAAchievementCache()
	{
		pdaAchBrowseInvalidateGen++;
	}

	void RequestPDAAchievementScrollReset()
	{
		pdaAchBrowseScrollResetGen++;
	}

	ui void PDA_SyncAchievementBrowseState()
	{
		if (pdaAchBrowseScrollResetAppliedGen != pdaAchBrowseScrollResetGen)
		{
			pdaAchBrowseScrollResetAppliedGen = pdaAchBrowseScrollResetGen;
			pdaAchBrowseScroll = 0;
		}
		if (pdaAchBrowseInvalidateAppliedGen == pdaAchBrowseInvalidateGen)
			return;
		pdaAchBrowseInvalidateAppliedGen = pdaAchBrowseInvalidateGen;
		pdaAchBrowseCacheValid = false;
		pdaAchBrowseRowKind.Clear();
		pdaAchBrowseRowAch.Clear();
		pdaAchBrowseRowLabel.Clear();
	}

	const PDA_ACH_ROW_HEADER = 1;
	const PDA_ACH_ROW_CATEGORY = 2;
	const PDA_ACH_ROW_ACHIEVEMENT = 3;
	const PB_PDA_ACH_BROWSE_SCROLL_LINES = 4;
	const PB_PDA_ACH_BROWSE_TEXT_SCALE_MUL = 0.66;
	const PB_PDA_ACH_BROWSE_ICON_TEXT_GAP = 14;
	// Defer heavy PDA UI object build off the first RenderOverlay frames (Windows busy-cursor / mouse jitter).
	const PB_PDA_UI_INIT_MIN_GAMETIC = 35;

	ui double PDA_AchievementBrowseTextScale()
	{
		return clamp(Screen.GetHeight() / 240.0, 2.0, 6.0) * PB_PDA_ACH_BROWSE_TEXT_SCALE_MUL;
	}

	ui int PDA_AchievementBrowseCenteredX(String text, double textScale, int listLeft, int listRight)
	{
		double w = SmallFont.StringWidth(text) * textScale;
		return int((listLeft + listRight) * 0.5 - w * 0.5);
	}

	ui void PDA_AchievementBrowseDrawCenteredLine(int color, int y, String text,
		double textScale, int listLeft, int listRight, double alpha, bool untranslated = false)
	{
		int drawColor = untranslated ? Font.CR_UNTRANSLATED : color;
		int drawX = PDA_AchievementBrowseCenteredX(text, textScale, listLeft, listRight);
		Screen.DrawText(SmallFont, drawColor, drawX, y, text,
			DTA_ScaleX, textScale, DTA_ScaleY, textScale,
			DTA_ClipLeft, listLeft, DTA_ClipRight, listRight,
			DTA_Alpha, alpha);
	}

	ui bool PDA_TryEnsureUiObjects(bool force = false)
	{
		if (uiObjects.Size() >= 1)
			return true;
		if (gamestate == GS_TITLELEVEL)
			return false;
		if (!force)
		{
			if (gametic < PB_PDA_UI_INIT_MIN_GAMETIC)
				return false;
			if (!PDAMode && !KatanaDualChoiceMode)
				return false;
		}
		return InitializeUiObjects();
	}

	ui void PDA_AchievementBrowseListMetrics(out int listLeft, out int listTop,
		out int listRight, out int listBottom)
	{
		int sw = Screen.GetWidth();
		int sh = Screen.GetHeight();
		listTop = int(sh * 0.14);
		listBottom = sh - int(sh * 0.12);
		int sideMargin = max(24, sw / 40);
		listLeft = sideMargin;
		listRight = sw - sideMargin;
	}

	ui int PDA_AchievementBrowseScrollStepPx(int direction, double textScale)
	{
		int lineH = max(1, int(SmallFont.GetHeight() * textScale));
		int targetPx = lineH * PB_PDA_ACH_BROWSE_SCROLL_LINES;
		int n = pdaAchBrowseRowKind.Size();
		if (n < 1)
			return targetPx;

		int scroll = pdaAchBrowseScroll;
		int y = 0;
		int anchor = 0;

		if (direction > 0)
		{
			for (int i = 0; i < n; i++)
			{
				int rh = PDA_AchievementRowPixelHeight(pdaAchBrowseRowKind[i], textScale);
				if (y + rh > scroll + 1)
				{
					anchor = i;
					break;
				}
				y += rh;
				anchor = i + 1;
			}
			int step = 0;
			for (int i = anchor; i < n && step < targetPx; i++)
				step += PDA_AchievementRowPixelHeight(pdaAchBrowseRowKind[i], textScale);
			return max(lineH, step);
		}

		for (int i = 0; i < n; i++)
		{
			int rh = PDA_AchievementRowPixelHeight(pdaAchBrowseRowKind[i], textScale);
			if (y + rh > scroll + 1)
			{
				anchor = i;
				break;
			}
			y += rh;
		}
		int stepUp = 0;
		for (int i = anchor - 1; i >= 0 && stepUp < targetPx; i--)
			stepUp += PDA_AchievementRowPixelHeight(pdaAchBrowseRowKind[i], textScale);
		return max(lineH, stepUp);
	}

	ui void PDA_AchievementBrowseColorCodes(PlayerInfo p, out String ccUnlocked,
		out String ccLocked, out String ccTitle, out String ccDesc, out String ccProgress)
	{
		ccUnlocked = VUAS_RenderSettings.GetColorCode(
			VUAS_AchievementHandler.GetCVarInt('ach_color_unlocked', p, 3));
		ccLocked = VUAS_RenderSettings.GetColorCode(
			VUAS_AchievementHandler.GetCVarInt('ach_color_locked', p, 20));
		ccTitle = VUAS_RenderSettings.GetColorCode(
			VUAS_AchievementHandler.GetCVarInt('ach_color_title', p, 10));
		ccDesc = VUAS_RenderSettings.GetColorCode(
			VUAS_AchievementHandler.GetCVarInt('ach_color_description', p, 2));
		ccProgress = VUAS_RenderSettings.GetColorCode(
			VUAS_AchievementHandler.GetCVarInt('ach_color_progress', p, 10));
	}

	ui String PDA_AchievementBrowseTitleLine(VUAS_AchievementData ach)
	{
		let p = players[consoleplayer];
		String ccUnlocked, ccLocked, ccTitle, ccDesc, ccProgress;
		PDA_AchievementBrowseColorCodes(p, ccUnlocked, ccLocked, ccTitle, ccDesc, ccProgress);

		String achTitle = StringTable.Localize(ach.title, false);

		if (ach.isHidden && !ach.isUnlocked)
			return String.Format("%s[LOCKED]\c- %s??? - Hidden Achievement\c-", ccLocked, ccTitle);

		if (ach.isUnlocked)
		{
			String timeStr = "";
			if (ach.unlockTime > 0)
				timeStr = String.Format(" %s(%s)\c-", ccDesc, SystemTime.Format("%d %b %Y", ach.unlockTime));
			return String.Format("%s[UNLOCKED]\c- %s%s\c-%s", ccUnlocked, ccTitle, achTitle, timeStr);
		}

		String progressStr = "";
		if (ach.targetCount > 1)
			progressStr = String.Format(" %s[%d/%d]\c-", ccProgress, ach.currentCount, ach.targetCount);
		return String.Format("%s[LOCKED]\c- %s%s\c-%s", ccLocked, ccTitle, achTitle, progressStr);
	}

	ui String PDA_AchievementBrowseDescLine(VUAS_AchievementData ach)
	{
		if (ach.isHidden && !ach.isUnlocked)
			return "";

		let p = players[consoleplayer];
		String ccUnlocked, ccLocked, ccTitle, ccDesc, ccProgress;
		PDA_AchievementBrowseColorCodes(p, ccUnlocked, ccLocked, ccTitle, ccDesc, ccProgress);

		String achDesc = StringTable.Localize(ach.description, false);
		if (achDesc.Length() < 1)
			return "";
		return String.Format("%s%s\c-", ccDesc, achDesc);
	}

	ui int PDA_AchievementRowPixelHeight(int rowKind, double textScale)
	{
		int lineH = max(1, int(SmallFont.GetHeight() * textScale));
		if (rowKind == PDA_ACH_ROW_HEADER) return lineH * 2;
		if (rowKind == PDA_ACH_ROW_CATEGORY) return int(lineH * 1.35);
		return int(lineH * 3.85);
	}

	ui int PDA_AchievementBrowseContentHeight(double textScale)
	{
		int h = 0;
		for (int i = 0; i < pdaAchBrowseRowKind.Size(); i++)
			h += PDA_AchievementRowPixelHeight(pdaAchBrowseRowKind[i], textScale);
		return h;
	}

	ui bool PDA_AchievementPassesBrowseFilter(VUAS_AchievementData ach, bool showHidden, int menuFilter)
	{
		if (ach.isHidden && !ach.isUnlocked && !showHidden)
			return false;
		if (menuFilter == 1 && !ach.isUnlocked)
			return false;
		if (menuFilter == 2 && ach.isUnlocked)
			return false;
		return true;
	}

	ui void RebuildPDAAchievementBrowseCache()
	{
		pdaAchBrowseRowKind.Clear();
		pdaAchBrowseRowAch.Clear();
		pdaAchBrowseRowLabel.Clear();

		let handler = VUAS_AchievementHandler.GetHandler();
		if (!handler || handler.achievements.Size() == 0)
		{
			pdaAchBrowseCacheValid = true;
			return;
		}

		bool showHidden = VUAS_AchievementHandler.GetCVarBool('ach_show_hidden', players[consoleplayer], false);
		int menuFilter = VUAS_AchievementHandler.GetCVarInt('ach_menu_filter', players[consoleplayer], 0);
		int totalCount = handler.achievements.Size();

		pdaAchBrowseRowKind.Push(PDA_ACH_ROW_HEADER);
		pdaAchBrowseRowAch.Push(-1);
		pdaAchBrowseRowLabel.Push("");

		Array<String> categories;
		for (int i = 0; i < totalCount; i++)
		{
			let ach = handler.achievements[i];
			bool found = false;
			for (int c = 0; c < categories.Size(); c++)
			{
				if (categories[c] ~== ach.category)
				{
					found = true;
					break;
				}
			}
			if (!found)
				categories.Push(ach.category);
		}

		for (int pass = 0; pass < 2; pass++)
		{
			bool wantUnlocked = (pass == 0);
			for (int c = 0; c < categories.Size(); c++)
			{
				String cat = categories[c];
				bool pushedCat = false;
				for (int i = 0; i < totalCount; i++)
				{
					let ach = handler.achievements[i];
					if (!(ach.category ~== cat))
						continue;
					if (ach.isUnlocked != wantUnlocked)
						continue;
					if (!PDA_AchievementPassesBrowseFilter(ach, showHidden, menuFilter))
						continue;

					if (!pushedCat)
					{
						String catHeader = "";
						for (int ch = 0; ch < cat.Length(); ch++)
						{
							int byte = cat.ByteAt(ch);
							if (ch == 0 && byte >= 97 && byte <= 122)
								catHeader.AppendFormat("%c", byte - 32);
							else
								catHeader.AppendFormat("%c", byte);
						}
						pdaAchBrowseRowKind.Push(PDA_ACH_ROW_CATEGORY);
						pdaAchBrowseRowAch.Push(-1);
						pdaAchBrowseRowLabel.Push(String.Format("--- %s ---", catHeader));
						pushedCat = true;
					}

					pdaAchBrowseRowKind.Push(PDA_ACH_ROW_ACHIEVEMENT);
					pdaAchBrowseRowAch.Push(i);
					pdaAchBrowseRowLabel.Push("");
				}
			}
		}

		pdaAchBrowseCacheValid = true;
	}

	ui void DrawPDAAchievementBrowse(double alpha)
	{
		if (alpha <= 0) return;
		PDA_SyncAchievementBrowseState();
		if (!pdaAchBrowseCacheValid)
			RebuildPDAAchievementBrowseCache();

		let handler = VUAS_AchievementHandler.GetHandler();
		int listLeft, listTop, listRight, listBottom;
		PDA_AchievementBrowseListMetrics(listLeft, listTop, listRight, listBottom);
		double textScale = PDA_AchievementBrowseTextScale();

		if (!handler)
		{
			PDA_AchievementBrowseDrawCenteredLine(Font.CR_GREEN, listTop,
				"No achievements defined.", textScale, listLeft, listRight, alpha);
			return;
		}

		int totalRows = pdaAchBrowseRowKind.Size();
		if (totalRows < 1)
		{
			PDA_AchievementBrowseDrawCenteredLine(Font.CR_GREEN, listTop,
				"No achievements match the current filter.", textScale, listLeft, listRight, alpha);
			return;
		}

		int viewH = listBottom - listTop;
		int contentH = PDA_AchievementBrowseContentHeight(textScale);
		int maxScroll = max(0, contentH - viewH);
		if (pdaAchBrowseScroll < 0)
			pdaAchBrowseScroll = 0;
		else if (pdaAchBrowseScroll > maxScroll)
			pdaAchBrowseScroll = maxScroll;
		int scrollY = pdaAchBrowseScroll;

		int y = listTop - scrollY;
		Screen.SetClipRect(listLeft, listTop, listRight - listLeft, viewH);

		for (int rowIdx = 0; rowIdx < totalRows; rowIdx++)
		{
			int kind = pdaAchBrowseRowKind[rowIdx];
			int rowH = PDA_AchievementRowPixelHeight(kind, textScale);
			int achIdx = pdaAchBrowseRowAch[rowIdx];

			if (y + rowH > listTop && y < listBottom)
			{
				if (kind == PDA_ACH_ROW_HEADER)
				{
					int unlocked = 0;
					for (int u = 0; u < handler.achievements.Size(); u++)
					{
						if (handler.achievements[u].isUnlocked)
							unlocked++;
					}
					int menuFilter = VUAS_AchievementHandler.GetCVarInt('ach_menu_filter', players[consoleplayer], 0);
					String filterLabel = "";
					if (menuFilter == 1) filterLabel = " (Unlocked Only)";
					else if (menuFilter == 2) filterLabel = " (Locked Only)";
					String header = String.Format("Achievements: %d / %d%s",
						unlocked, handler.achievements.Size(), filterLabel);
					PDA_AchievementBrowseDrawCenteredLine(Font.CR_YELLOW, y, header,
						textScale, listLeft, listRight, alpha);
				}
				else if (kind == PDA_ACH_ROW_CATEGORY)
				{
					String catLine = (rowIdx < pdaAchBrowseRowLabel.Size())
						? pdaAchBrowseRowLabel[rowIdx] : "--- ---";
					PDA_AchievementBrowseDrawCenteredLine(Font.CR_GOLD, y, catLine,
						textScale, listLeft, listRight, alpha);
				}
				else if (kind == PDA_ACH_ROW_ACHIEVEMENT && achIdx >= 0 && achIdx < handler.achievements.Size())
				{
					let ach = handler.achievements[achIdx];
					String titleLine = PDA_AchievementBrowseTitleLine(ach);
					String descLine = PDA_AchievementBrowseDescLine(ach);
					int lineH = int(SmallFont.GetHeight() * textScale);
					int iconSize = lineH * 2;
					int titleY = y + int(lineH * 0.08);
					int descY = y + lineH + int(lineH * 0.22);
					double titleW = SmallFont.StringWidth(titleLine) * textScale;
					double descW = descLine.Length() > 0
						? SmallFont.StringWidth(descLine) * textScale : 0.0;
					double textW = max(titleW, descW);
					int blockW = iconSize + PB_PDA_ACH_BROWSE_ICON_TEXT_GAP + int(textW + 0.5);
					int blockLeft = int((listLeft + listRight) * 0.5 - blockW * 0.5);
					if (blockLeft < listLeft)
						blockLeft = listLeft;
					int textX = blockLeft + iconSize + PB_PDA_ACH_BROWSE_ICON_TEXT_GAP;
					int iconX = blockLeft;

					TextureID iconTex = TexMan.CheckForTexture(ach.icon, TexMan.Type_Any);
					if (!(ach.isHidden && !ach.isUnlocked) && iconTex.IsValid())
					{
						if (ach.isUnlocked)
						{
							Screen.DrawTexture(iconTex, true, iconX, y,
								DTA_DestWidth, iconSize, DTA_DestHeight, iconSize,
								DTA_Alpha, alpha);
						}
						else
						{
							Screen.DrawTexture(iconTex, true, iconX, y,
								DTA_DestWidth, iconSize, DTA_DestHeight, iconSize,
								DTA_AlphaChannel, true, DTA_FillColor, 0xBBBBCC,
								DTA_Alpha, alpha);
						}
					}

					Screen.DrawText(SmallFont, Font.CR_UNTRANSLATED, textX, titleY, titleLine,
						DTA_ScaleX, textScale, DTA_ScaleY, textScale,
						DTA_ClipLeft, listLeft, DTA_ClipRight, listRight,
						DTA_Alpha, alpha);
					if (descLine.Length() > 0)
					{
						Screen.DrawText(SmallFont, Font.CR_UNTRANSLATED, textX, descY, descLine,
							DTA_ScaleX, textScale, DTA_ScaleY, textScale,
							DTA_ClipLeft, listLeft, DTA_ClipRight, listRight,
							DTA_Alpha, alpha);
					}
				}
			}

			y += rowH;
		}

		Screen.ClearClipRect();

		if (scrollY > 0 || contentH > viewH)
		{
			double hintSc = textScale * 0.85;
			int hintY = listBottom - int(SmallFont.GetHeight() * hintSc);
			PDA_AchievementBrowseDrawCenteredLine(Font.CR_GRAY, hintY,
				"Use page arrows or BACK / PDA key.", hintSc, listLeft, listRight, alpha * 0.9);
		}
	}

	ui void ScrollPDAAchievementBrowse(int direction)
	{
		PDA_SyncAchievementBrowseState();
		if (!pdaAchBrowseCacheValid)
			RebuildPDAAchievementBrowseCache();

		double textScale = PDA_AchievementBrowseTextScale();
		int listLeft, listTop, listRight, listBottom;
		PDA_AchievementBrowseListMetrics(listLeft, listTop, listRight, listBottom);
		int viewH = listBottom - listTop;
		int contentH = PDA_AchievementBrowseContentHeight(textScale);
		int maxScroll = max(0, contentH - viewH);
		if (maxScroll < 1)
			return;

		int step = PDA_AchievementBrowseScrollStepPx(direction, textScale);
		if (direction < 0)
			pdaAchBrowseScroll -= step;
		else if (direction > 0)
			pdaAchBrowseScroll += step;
		pdaAchBrowseScroll = clamp(pdaAchBrowseScroll, 0, maxScroll);
	}

	clearscope static bool PB_AchievementsOn()
	{
		if (netgame)
			return false;
		let cv = CVar.FindCVar("pb_achievements");
		return !cv || cv.GetBool();
	}

	override void WorldThingDamaged(WorldEvent e)
	{
		if (!e) return;
		Actor t = e.Thing;
		if (!t) return;
		if (t is "DoomImp" 
		&& t.target
		&& t.bCOUNTKILL
		&& t.bISMONSTER
		&& e.DamageType == "Melee"
		&& !t.target.player)
		{
			t.A_TakeInventory("SKImp",1);
			t.A_TakeInventory("SKImp2",1); 
			t.A_TakeInventory("SKImp3",1); 
			t.A_TakeInventory("SKDarkImpNami",1);
			t.A_TakeInventory("SKDarkImpNether",1);
			t.A_TakeInventory("SKDarkImpST",1);
			t.A_TakeInventory("SKDarkImpVoid",1);
		}
	}
	override void WorldThingDied(WorldEvent e)
	{
		if (!e) return;
		Actor t = e.Thing;
		bool dbg = PB_PDAWeaponContainer.PDA_DebugOn();
		if (!t)
		{
			if (dbg) Console.PrintF("[PDA-DBG] WorldThingDied: e.Thing null");
			return;
		}
		string tname = "" .. t.GetClassName();
		if (!t.bIsMonster || t is "PlayerPawn")
		{
			if (dbg)
			{
				int isMon = t.bIsMonster ? 1 : 0;
				int isPP = (t is "PlayerPawn") ? 1 : 0;
				Console.PrintF("[PDA-DBG] WorldThingDied skip cls=" .. tname .. " bIsMonster=" .. isMon .. " isPP=" .. isPP);
			}
			return;
		}
		PlayerPawn killer = PB_PDA_ResolveKiller(e);
		if (!killer || !killer.player)
		{
			if (dbg) Console.PrintF("[PDA-DBG] WorldThingDied no killer for cls=" .. tname);
			return;
		}
		let pda = PB_PDAWeaponContainer(killer.FindInventory("PB_PDAWeaponContainer", true));
		if (!pda)
		{
			if (dbg) Console.PrintF("[PDA-DBG] WorldThingDied no PB_PDAWeaponContainer on killer");
			return;
		}
		pda.ApplyMonsterCodexKill(t);
	}
	ui void UpdateDesc()
	{
		if (EquipmentMenuOpened && currentEquipmentIndex >= 0 && currentEquipmentIndex < PDAEquipTexts.Size())
		{
			if (WeaponTextMode == 1 && currentEquipmentIndex < PDAEquipExtraTexts.Size())
				descriptiondialog.todraw = PDAEquipExtraTexts[currentEquipmentIndex];
			else
				descriptiondialog.todraw = PDAEquipTexts[currentEquipmentIndex];
			return;
		}
		if (WeaponTextMode == 1) descriptiondialog.todraw = PDAWeaponExtraTexts[currentindex];
		else descriptiondialog.todraw = PDAWeaponTexts[currentindex];
	}
	ui bool CheckBaseWeapon(string weapname)
	{
		if (!playeringame[consoleplayer]) { return false; }
		let pmo = PlayerPawnBase(players[consoleplayer].mo);
		if (!pmo) { return false; }
		for (uint i = 0; i < pmo.baseWeapons.Size(); i++)
		{
			if (weapname == pmo.baseWeapons[i])
			{
				return true;
			}
		}
		return false;
	}
	override void UiTick()
	{
		if (gamestate == GS_TITLELEVEL) return;
		globalPDAAlpha = clamp(globalPDAAlpha,0.,1.0);
		if (netgame == true)
		{
			SendNetworkEvent("NetgameTrue");
		}
		if (weaponFound == true)
		{
			PDA_TryEnsureUiObjects(true);
			for (int foundWeapIndex = 0; foundWeapIndex < WeaponFoundName.size(); foundWeapIndex++)
			for (int weapIndex = 0; weapIndex < pdaWeapTextArray.size(); weapIndex++)
			{
				for (int i = 0;i < uiObjects.Size();i++)
				{
					if (uiObjects[i]
					&& WeaponFoundName[foundWeapIndex] == pdaWeapTextArray[weapIndex].PDAWeapClassName
					&& uiObjects[i].pdaWeapTextArray
					&& uiObjects[i].pdaWeapTextArray.PDAWeapClassName == pdaWeapTextArray[weapIndex].PDAWeapClassName
					&& uiObjects[i].dontdraw == true)
					{
						if (!uiObjects[i].pdaWeapTextArray.found)
						{
							S_StartSound("PDAOPEN",CHAN_AUTO,CHANF_DEFAULT,2);
							Console.PrintF("New PDA Entry:"..uiObjects[i].pdaWeapTextArray.PDAWeaponHeader);
							uiObjects[i].pdaWeapTextArray.found = true;
						}
						uiObjects[i].dontdraw = false;
					}
				}
			}		
			SendNetworkEvent("ResetWeaponName");
		}
		if (monsterFound == true)
		{
			PDA_TryEnsureUiObjects(true);
			for (int mfi = 0; mfi < monsterFoundSlots.Size(); mfi++)
			{
				int mslot = monsterFoundSlots[mfi];
				if (mslot < 0 || mslot >= PDAMonsterStrings.Size()) continue;
				for (int i = 0; i < uiObjects.Size(); i++)
				{
					if (uiObjects[i]
						&& uiObjects[i].objecttype == 6
						&& uiObjects[i].entrynumber == mslot
						&& uiObjects[i].dontdraw == true)
					{
						S_StartSound("PDAOPEN",CHAN_AUTO,CHANF_DEFAULT,2);
						Console.PrintF("New PDA Entry:" .. PDAMonsterStrings[mslot]);
						uiObjects[i].dontdraw = false;
					}
				}
			}
			SendNetworkEvent("ResetMonsterFound");
		}
		if (equipmentFound == true)
		{
			PDA_TryEnsureUiObjects(true);
			for (int efi = 0; efi < equipmentFoundSlots.Size(); efi++)
			{
				int eslot = equipmentFoundSlots[efi];
				if (eslot < 0 || eslot >= PDAEquipStrings.Size()) continue;
				for (int i = 0; i < uiObjects.Size(); i++)
				{
					if (uiObjects[i]
						&& uiObjects[i].objecttype == 7
						&& uiObjects[i].entrynumber == eslot
						&& uiObjects[i].dontdraw == true)
					{
						S_StartSound("PDAOPEN",CHAN_AUTO,CHANF_DEFAULT,2);
						Console.PrintF("New PDA Entry:" .. PDAEquipStrings[eslot]);
						uiObjects[i].dontdraw = false;
					}
				}
			}
			SendNetworkEvent("ResetEquipmentFound");
		}
		if (PDAMode && uiObjects.Size() >= 1)
		{
			double pdaArrowScale = clamp(Screen.GetHeight() / 240.0, 2.0, 6.0);
			SyncBlockyPageArrowHitboxes(pdaArrowScale);
			if (BlockyEnabled() && NonMainMenu && (WeaponMenuOpened || MonsterMenuOpened || EquipmentMenuOpened))
			{
				string nk = "";
				if (WeaponMenuOpened && currentindex >= 0 && currentindex < pdaWeapTextArray.Size())
					nk = "W:" .. BlockyNormalizeClassString(pdaWeapTextArray[currentindex].PDAWeapClassName);
				else if (MonsterMenuOpened && currentMonsterIndex >= 0 && currentMonsterIndex < PDAMonsterIconClass.Size())
					nk = "M:" .. BlockyNormalizeClassString(PDAMonsterIconClass[currentMonsterIndex]);
				else if (EquipmentMenuOpened && currentEquipmentIndex >= 0 && currentEquipmentIndex < pdaEquipTextArray.Size()
					&& pdaEquipTextArray[currentEquipmentIndex].PDAEquipClassName.length() > 0)
					nk = "E:" .. BlockyNormalizeClassString(pdaEquipTextArray[currentEquipmentIndex].PDAEquipClassName);
				if (nk != "" && nk != pdaPrevUILastQueuedKey)
				{
					pdaPrevUILastQueuedKey = nk;
					SendNetworkEvent("pdaprevq#" .. nk);
				}
			}
			else
				pdaPrevUILastQueuedKey = "";
		}
		if (KatanaDualChoiceMode)
		{
			if (MouseClicked && !MouseHeldDown)
			{
				int lx, ly, lw, lh, rx, ry, rw, rh;
				PB_KatanaDualChoiceGetTileLayout(lx, ly, lw, lh, rx, ry, rw, rh);
				bool hitL = MouseX >= lx && MouseX < lx + lw && MouseY >= ly && MouseY < ly + lh;
				bool hitR = MouseX >= rx && MouseX < rx + rw && MouseY >= ry && MouseY < ry + rh;
				if (hitL || hitR)
				{
					bool leftPickSith = (KatanaDualVariant == 0) ? hitL : hitR;
					if (leftPickSith)
						SendNetworkEvent("katanachoice_pick_sith");
					else
						SendNetworkEvent("katanachoice_pick_jedi");
				}
				SendNetworkEvent("releasemouse");
			}
		}
		for (int i = 0;i < uiObjects.Size();i++)
		{
			if (MouseX >= uiObjects[i].ImagePos.x
				&& MouseX <= (uiObjects[i].ImageSize.x + uiObjects[i].ImagePos.x)
				&& MouseY >= uiObjects[i].ImagePos.y
				&& MouseY <= (uiObjects[i].ImagePos.y + uiObjects[i].ImageSize.y)
				&& (!uiObjects[i].UnSelectable == true) && !uiObjects[i].notdrawn)
			{	
				if (MouseClicked == true && MouseHeldDown != true)
				{
					if (uiObjects[i].ExitButton() == true)
					{
						SendNetworkEvent("exitPDA");
						globalPDAAlpha = 0;
						descriptiondialog.todraw = "Select a entry to \nview its description";
						descriptiondialog.ImagePos = descriptiondialog.InitialImagePos;
						WeaponTextMode = 0;
					}
					else
					{
						switch(uiObjects[i].objecttype)
						{
						Default:
							break;
						case 1:
							globalPDAAlpha = 0;
							SendNetworkEvent("OpenMonsterMenu");
							break;
						case 2:
							globalPDAAlpha = 0;
							SendNetworkEvent("OpenWeaponMenu");
							break;
						case 14:
							globalPDAAlpha = 0;
							SendNetworkEvent("OpenEquipmentMenu");
							break;
						case 3:
							for (int counter = 0; counter < PDAWeaponHeaders.Size(); ++counter)
							{
								if (uiObjects[i].entrynumber == counter)
								{
									currentindex = uiObjects[i].entrynumber;
									if (WeaponTextMode == 1) descriptiondialog.todraw = PDAWeaponExtraTexts[counter];
									else descriptiondialog.todraw = PDAWeaponTexts[counter];
								}
							}
							break;
						case 6:
							for (int counter = 0; counter < PDAMonsterStrings.Size(); ++counter)
							{
								if (uiObjects[i].entrynumber == counter)
								{
									currentMonsterIndex = uiObjects[i].entrynumber;
									descriptiondialog.todraw = PDAMonsterTexts[counter];
								}
							}
							break;
						case 7:
							for (int counter = 0; counter < PDAEquipTexts.Size(); ++counter)
							{
								if (uiObjects[i].entrynumber == counter)
								{
									currentEquipmentIndex = uiObjects[i].entrynumber;
									if (WeaponTextMode == 1 && counter < PDAEquipExtraTexts.Size())
										descriptiondialog.todraw = PDAEquipExtraTexts[counter];
									else
										descriptiondialog.todraw = PDAEquipTexts[counter];
								}
							}
							break;
						case 4:
							if (AchievementsMenuOpened)
								ScrollPDAAchievementBrowse(-1);
							else if (BlockyEnabled())
							{
								if (MonsterMenuOpened)
									pdaBlockyMonsterPage = max(0, pdaBlockyMonsterPage - 1);
								else if (WeaponMenuOpened)
									pdaBlockyWeapPage = max(0, pdaBlockyWeapPage - 1);
								else if (EquipmentMenuOpened)
									pdaBlockyEquipPage = max(0, pdaBlockyEquipPage - 1);
								ApplyBlockyLayout();
							}
							break;
						case 5:
							if (AchievementsMenuOpened)
								ScrollPDAAchievementBrowse(1);
							else if (BlockyEnabled())
							{
								if (MonsterMenuOpened) pdaBlockyMonsterPage++;
								else if (WeaponMenuOpened) pdaBlockyWeapPage++;
								else if (EquipmentMenuOpened) pdaBlockyEquipPage++;
								ApplyBlockyLayout();
							}
							break;
						case 13:
							WeaponTextMode = 1;
							UpdateDesc();
							break;
						case 12:
							WeaponTextMode = 0;
							UpdateDesc();
							break;
						case 16:
							if (!BlockyEnabled() || !PB_EventHandler.PB_XP_RewardsOn() || NonMainMenu || netgame)
								break;
							SendNetworkEvent("pb_xp_spin");
							break;
						case 17:
							if (!BlockyEnabled() || !PB_EventHandler.PB_AchievementsOn() || NonMainMenu)
								break;
							SendNetworkEvent("pb_pda_open_achievements");
							break;
						}
					}
					if (uiObjects[i].BackButtonTrue)
					{
						if (AchievementsMenuOpened)
							SendNetworkEvent("closepdaachievements");
						else
							SendNetworkEvent("closemonstermenu");
						globalPDAAlpha = 0;
						descriptiondialog.todraw = "Select a entry to \nview its description";
						descriptiondialog.ImagePos = descriptiondialog.InitialImagePos;
						WeaponTextMode = 0;
					}
					else if (MouseHeldDown != true)
					{
						uiObjects[i].UiFunction();
						uiObjects[i].Clicked = true;
					}
				}
				if (uiObjects[i].usefont != NULL)
				{
					if (MouseHeldDown == true)
					{
						uiObjects[i].fontcolor = Font.CR_OLIVE;
						if (uiObjects[i].objecttype == 4) DescriptionDialog.ImagePos.y -= -5;
						else if (uiObjects[i].objecttype == 5) DescriptionDialog.ImagePos.y += -5;
					}
					else
					{
						uiObjects[i].fontcolor = Font.CR_GREEN;
					}
				}
				if (!uiObjects[i].MouseOvered)
				{
					uiObjects[i].MouseOvered = true;
					S_StartSound("PDAMOUSEOVER",CHAN_AUTO);
				}
			}
			else 
			{
				uiObjects[i].MouseOvered = false;
				uiObjects[i].fontcolor = Font.CR_GREEN;
			}
			
		}
		if (dashAlpha > 0)
		{
			dashAlpha = max(0, dashAlpha - 0.2);
			dashScale += 0.05;
		}
	}
	override void NewGame()
	{
		NewGameStarted = true;
	}

	void PDA_Play_ClearPreview()
	{
		pdaPrevFrames.Clear();
		pdaPrevFrameTics.Clear();
		pdaPrevSegIdx.Clear();
		pdaPrevBuiltKey = "";
		pdaPrevCurFrame = 0;
		pdaPrevTicsRemain = 0;
		pdaPrevLastAdvGametic = 0;
	}

	void PDA_Play_ResetAnim()
	{
		if (pdaPrevFrames.Size() < 1)
		{
			pdaPrevCurFrame = 0;
			pdaPrevTicsRemain = 0;
			return;
		}
		pdaPrevCurFrame = 0;
		pdaPrevTicsRemain = pdaPrevFrameTics[0];
		pdaPrevLastAdvGametic = gametic;
	}

	void PDA_Play_AdvancePreviewAnim()
	{
		if (!PDAMode || pdaPrevFrames.Size() < 1)
			return;
		PlayerInfo plr = players[consoleplayer];
		bool blockyOn = true;
		if (plr)
		{
			let cvB = CVar.GetCVar("pb_pda_blocky", plr);
			if (cvB)
				blockyOn = cvB.GetBool();
		}
		if (!blockyOn || !NonMainMenu || !(WeaponMenuOpened || MonsterMenuOpened || EquipmentMenuOpened))
			return;
		while (gametic >= pdaPrevLastAdvGametic + pdaPrevTicsRemain)
		{
			pdaPrevLastAdvGametic += pdaPrevTicsRemain;
			pdaPrevCurFrame++;
			if (pdaPrevCurFrame >= pdaPrevFrames.Size())
				pdaPrevCurFrame = 0;
			pdaPrevTicsRemain = pdaPrevFrameTics[pdaPrevCurFrame];
		}
	}

	clearscope bool PDA_ShouldSuppressWeaponPlayerSideArt(string tn) const
	{
		if (tn.Length() < 3)
			return false;
		string p3 = tn.Mid(0, 3);
		if (p3 ~== "TH3")
			return true;
		if (p3 ~== "EXE")
			return true;
		if (tn.Length() >= 4)
		{
			string p4 = tn.Mid(0, 4);
			if (p4 ~== "PLAY" || p4 ~== "STAN" || p4 ~== "STAL" || p4 ~== "LEGS" || p4 ~== "LEGE"
				|| p4 ~== "LEGZ"
				|| p4 ~== "PUNG" || p4 ~== "PUNS"
				|| p4 ~== "MARN" || p4 ~== "MARJ" || p4 ~== "MARI" || p4 ~== "PLA1"
				|| p4 ~== "DOOM"
				|| p4 ~== "ARMZ"
				|| p4 ~== "MISG"
				|| p4 ~== "KIC1"
				|| p4 ~== "MC3S"
				|| p4 ~== "PMAR"
				|| p4 ~== "MFST" || p4 ~== "FFST"
				|| p4 ~== "THRF"
				|| p4 ~== "FATF" || p4 ~== "KOKO"
				|| p4 ~== "SLDK" || p4 ~== "AKCK"
				|| p4 ~== "D3MI" || p4 ~== "D3ML"
				|| p4 ~== "P1N0" || p4 ~== "P1NK" || p4 ~== "P2NK" || p4 ~== "P3NK" || p4 ~== "P4NK"
				|| p4 ~== "P1R2" || p4 ~== "P3R0"
				|| p4 ~== "P1NS" || p4 ~== "P2NS" || p4 ~== "P3NS" || p4 ~== "P4NS"
				|| p4 ~== "FLK1" || p4 ~== "FLK2"
				|| p4 ~== "HND1"
				|| p4 ~== "SHIE"
				|| p4 ~== "SAWG"
				|| p4 ~== "XPFF" || p4 ~== "XPFS" || p4 ~== "XHFF"
				|| p4 ~== "POSM" || p4 ~== "POSA"
				|| p4 ~== "FOS1" || p4 ~== "FOS2" || p4 ~== "FOS3" || p4 ~== "FOS4"
				|| p4 ~== "NZ0D" || p4 ~== "NATT" || p4 ~== "NZFT" || p4 ~== "NFTY"
				|| p4 ~== "ESCR" || p4 ~== "SOBO"
				|| p4 ~== "YUTI" || p4 ~== "49AN"
				|| p4 ~== "HUF1" || p4 ~== "HUF2" || p4 ~== "HUF3" || p4 ~== "HEDF"
				|| p4 ~== "SAPO"
				|| p4 ~== "CPUI" || p4 ~== "BOTU"
				|| p4 ~== "PPLJ" || p4 ~== "TOPI"
				|| p4 ~== "SATZ"
				|| p4 ~== "HDF1" || p4 ~== "UH0D" || p4 ~== "H0HE" || p4 ~== "HS0D" || p4 ~== "H0PF" || p4 ~== "HDF0"
				|| p4 ~== "LSLS"
				|| p4 ~== "MHML" || p4 ~== "ARF2")
				return true;
		}
		return false;
	}

	clearscope bool PDA_ShouldSuppressWeaponStripArt(readonly<Actor> def, string tn) const
	{
		if (def && tn.Length() >= 4)
		{
			string p4 = tn.Mid(0, 4);
			if (def is "Melee_Attacks" && (p4 ~== "PUNG" || p4 ~== "PUNS"))
				return false;
		}
		return PDA_ShouldSuppressWeaponPlayerSideArt(tn);
	}

	bool PDA_FireWalk_InNamedSequence(readonly<Actor> def, State nx, string lab)
	{
		State r = def.FindStateByString(lab, true);
		return r && def.InStateSequence(nx, r);
	}

	bool PDA_FireWalk_NextIsLabelEntry(readonly<Actor> def, State nx, string lab)
	{
		State r = def.FindStateByString(lab, true);
		return r && nx == r;
	}

	bool PDA_Main_FireWalk_ShouldStopBeforeState(readonly<Actor> def, State nx)
	{
		if (!def || !nx)
			return false;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashPunching")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashPunchingDW")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "DualFlashPunching")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashPunchingStop")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashKicking")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashKickingDW")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "DualFlashKicking")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashKickingCombo")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashAirKicking")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashSlideKicking")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashSlideKickingStop")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashBarrelKicking")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashBarrelAirKicking")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashBarrelSlideKicking")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashBarrelSlideKickingStop")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FlashBarrelPunching")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "Select")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "SelectContinue")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "SelectAnimation")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "GoingToReady")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "GoingToReady2")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "SelectingAnimation")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "TryToSelectDrum")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "SelectFirstPersonLegs")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FirstPersonLegsStand")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FirstPersonLegsKickRight")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FirstPersonLegsKickLeft")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FirstPersonLegsWalk1")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FirstPersonLegsWalk2")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FirstPersonLegsJump")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FirstPersonLegsCrouch")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "FirstPersonLegsHide")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "KickHandler_Overlay")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "Melee_Equipment_Handler_Overlay")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "Equipment_Toggle_Handler_Overlay")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "QuickMelee")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "GoMeleeInstead")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "GoMeleePunchSetup")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "UseEquipment")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "BloodPunch")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "DoKick")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "SlideKick")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "AirKick")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "ThrowShieldSaw")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "GrabEnemy")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "GrabBarrel")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "PermormGloryKill")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "DoingFatality")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "GloryMelee")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "TossGrenade")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "ThrowMine")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "DoFatality")) return true;
		if (PDA_FireWalk_NextIsLabelEntry(def, nx, "Steady")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_Zombieman1_Overlay1")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_Zombieman1")) return true;
		if (PDA_FireWalk_InNamedSequence(def, nx, "Execution_Zombieman2_Overlay1")) return true;
