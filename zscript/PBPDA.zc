				fireTicCap, flashTics, flashSeek);
			pdaHeavyBossCodexTail = true;
		}
		else if (nm == 'PB_Excavator')
		{
			PDA_WeaponStrip_AppendPB_ExcavatorPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			pdaHeavyBossCodexTail = true;
		}
		else if (nm == 'VorpalBlade')
		{
			PDA_WeaponStrip_AppendVorpalBladePreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			pdaHeavyBossCodexTail = true;
		}
		if (pdaHeavyBossCodexTail)
		{
			PDA_WeaponStrip_AppendFireLike(nm, "Hold", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
				outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
			PDA_WeaponStrip_AppendFireLike(nm, "HoldShrink", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
				outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
			if (includeOverlays)
			{
				PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Smoke", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
				PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Heat", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
				PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Brass", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
				PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Shells", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
				PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Charge", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
				PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Off", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
				PDA_WeaponStrip_AppendOverlayIfPresent(nm, "OffhandFire", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
				PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Pump", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
			}
			return;
		}
		if (nm == 'PB_Pistol')
		{
			PDA_WeaponStrip_AppendPB_PistolPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'PB_Revolver')
		{
			PDA_WeaponStrip_AppendPB_RevolverPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'PB_SMG')
		{
			PDA_WeaponStrip_AppendPB_SMGPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'PB_MP40')
		{
			PDA_WeaponStrip_AppendPB_MP40Preview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'Paingiver')
		{
			PDA_WeaponStrip_AppendPaingiverPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
			return;
		}
		if (nm == 'PB_SuperGL')
			PDA_WeaponStrip_AppendFireLike(nm, "PDA_Preview_SGL_OpenShot", PB_PDA_WEAPON_PREVIEW_SEG_FIRE, true,
				outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendPrimaryFireWithDispatchFallbacks(nm,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "Hold", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		PDA_WeaponStrip_AppendFireLike(nm, "HoldShrink", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
			outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		if (includeOverlays)
		{
			PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Smoke", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
			PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Heat", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
			PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Brass", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
			PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Shells", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
			PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Charge", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
			PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Off", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
			PDA_WeaponStrip_AppendOverlayIfPresent(nm, "OffhandFire", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
			PDA_WeaponStrip_AppendOverlayIfPresent(nm, "Pump", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_WEAPON_PREVIEW_SEG_OVERLAY, overlayMaxSteps, overlayTicCap);
		}
		if (nm == 'PB_ObsidianDragonSlayer')
			PDA_WeaponStrip_AppendDragonSlayerPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
		if (nm == 'PB_Axe')
		{
			PDA_WeaponStrip_AppendFireLike(nm, "PDA_Preview_AxeThrow", PB_PDA_WEAPON_PREVIEW_SEG_HOLD, false,
				outFr, outTi, outSeg, useSeg, hardCap, fireTicCap, flashTics, flashSeek, PB_PDA_WEAPON_PREVIEW_SEG_FLASH);
		}
		if (nm == 'Melee_Attacks')
		{
			PDA_WeaponStrip_AppendMelee_AttacksPreview(nm, outFr, outTi, outSeg, useSeg, hardCap,
				fireTicCap, flashTics, flashSeek);
		}
	}

	bool PDA_Equip_XDeathDiffersFromDeath(readonly<Actor> def)
	{
		if (!def)
			return false;
		State d = def.FindStateByString("Death", true);
		State x = def.FindStateByString("XDeath", true);
		if (!d || !x)
			return false;
		TextureID td = d.GetSpriteTexture(0);
		TextureID tx = x.GetSpriteTexture(0);
		if (td.IsValid() && tx.IsValid() && td == tx)
			return false;
		return true;
	}

	void PDA_EquipStrip_LookupPrimaryBurst(Name pickupNm, out Name primary, out Name burst)
	{
		primary = '';
		burst = '';
		String s = pickupNm;
		if (s ~== "HandGrenadeAmmo")            { primary = 'ThrownGrenade1';          burst = ''; return; }
		if (s ~== "MineAmmo")                  { primary = 'ThrownProxMine';         burst = 'GroundProxMine'; return; }
		if (s ~== "StunGrenadeAmmo")           { primary = 'ThrownStunGrenade';      burst = 'StunGrenadeExplosion'; return; }
		if (s ~== "ShieldGrenadeAmmo")         { primary = 'ThrownShieldGrenade';    burst = 'ShieldSpawnerPlacedCover'; return; }
		if (s ~== "VoidGrenadeAmmo")           { primary = 'ThrownVoidGrenade';      burst = ''; return; }
		if (s ~== "HandMolotovAmmo")           { primary = 'ThrownMolotov';          burst = 'MolotovFireParticles'; return; }
		if (s ~== "HasLeech")                  { primary = '';                     burst = 'SiphonPuff'; return; }
		if (s ~== "PB_DTech")                  { primary = '';                     burst = 'SiphonPuff'; return; }
		if (s ~== "MiniHellRocketAmmo")        { primary = 'DoomerRevenantSeeker2';  burst = ''; return; }
		if (s ~== "HookAmmo")                 { primary = 'HookShot';               burst = ''; return; }
		if (s ~== "PB_HookToken")             { primary = 'HookShot';               burst = ''; return; }
		if (s ~== "AlreadyHaveMeatHook")       { primary = 'HookShot';               burst = ''; return; }
		if (s ~== "FreezenadeAmmo")            { primary = 'Freezenade';             burst = 'FreezenadeExplosion'; return; }
		if (s ~== "PB_CF_FreezeBotDeployAmmo")  { primary = 'PBCF_CF_FreezeBotTurret'; burst = 'PBCF_IceOrbCryo'; return; }
		if (s ~== "PB_CF_IceWallGenAmmo")      { primary = 'PBCF_CF_IceWallSegment'; burst = ''; return; }
		if (s ~== "PB_CF_HoloDecoyAmmo")       { primary = 'PBCF_CF_HoloDecoy';      burst = ''; return; }
		if (s ~== "PB_CF_TeslaTurretAmmo")     { primary = 'PBCF_CF_TeslaTurret';    burst = 'MineElectricity'; return; }
		if (s ~== "PB_CF_FlameTurretAmmo")     { primary = 'PBCF_CF_FlameTurret';    burst = 'FlyingBurningFuelSmall'; return; }
		if (s ~== "PB_CF_FreezeMineAmmo")      { primary = 'PBCF_CF_FreezeMine';     burst = 'PBCF_CryoWind'; return; }
		if (s ~== "PB_CF_SnowCasterAmmo")      { primary = '';                     burst = 'PBCF_SnowParticle'; return; }
	}

	void PDA_EquipStrip_AppendOutcomeLabelPass(Name nm, string label, bool mainTile,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (!def || !def.FindStateByString(label, true))
			return;
		int mx = mainTile ? PB_PDA_EQUIP_OUTCOME_MAIN_PUSH : PB_PDA_EQUIP_OUTCOME_DOSSIER_PUSH;
		PDA_EquipStrip_AppendLabelWalk(nm, label, outFr, outTi, outSeg, useSeg, hardCap,
			PB_PDA_EQUIP_PREVIEW_SEG_FOLLOW, mx, PB_PDA_EQUIP_FOLLOW_MAX_STEPS, PB_PDA_EQUIP_FOLLOW_TIC_CAP, true);
	}

	void PDA_EquipStrip_AppendPrimaryOutcomeLabels(Name nm, bool mainTile,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap)
	{
		PDA_EquipStrip_AppendOutcomeLabelPass(nm, "Explode", mainTile, outFr, outTi, outSeg, useSeg, hardCap);
		PDA_EquipStrip_AppendOutcomeLabelPass(nm, "Detonate", mainTile, outFr, outTi, outSeg, useSeg, hardCap);
		PDA_EquipStrip_AppendOutcomeLabelPass(nm, "RealDeath", mainTile, outFr, outTi, outSeg, useSeg, hardCap);
		PDA_EquipStrip_AppendOutcomeLabelPass(nm, "Crash", mainTile, outFr, outTi, outSeg, useSeg, hardCap);
		PDA_EquipStrip_AppendOutcomeLabelPass(nm, "Fly", mainTile, outFr, outTi, outSeg, useSeg, hardCap);
	}

	void PDA_EquipStrip_AppendFollowBurstActor(Name nm, bool mainTile,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (!def)
			return;
		int sp = mainTile ? PB_PDA_EQUIP_FOLLOW_MAIN_SPAWN_PUSH : PB_PDA_EQUIP_FOLLOW_DOSSIER_SPAWN_PUSH;
		int dt = mainTile ? PB_PDA_EQUIP_FOLLOW_MAIN_DEATH_PUSH : PB_PDA_EQUIP_FOLLOW_DOSSIER_DEATH_PUSH;
		if (nm == 'SiphonPuff')
		{
			PDA_EquipStrip_AppendLabelWalk(nm, "Death", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_EQUIP_PREVIEW_SEG_FOLLOW, dt, PB_PDA_EQUIP_FOLLOW_MAX_STEPS, PB_PDA_EQUIP_FOLLOW_TIC_CAP, true);
			return;
		}
		if (nm == 'PBCF_CryoWind')
		{
			PDA_EquipStrip_AppendLabelWalk(nm, "See", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_EQUIP_PREVIEW_SEG_FOLLOW, dt, PB_PDA_EQUIP_FOLLOW_MAX_STEPS, PB_PDA_EQUIP_FOLLOW_TIC_CAP, true);
			return;
		}
		if (nm == 'PBCF_IceOrbCryo')
		{
			if (def.FindStateByString("Fly", true))
				PDA_EquipStrip_AppendLabelWalk(nm, "Fly", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_EQUIP_PREVIEW_SEG_FOLLOW, sp, PB_PDA_EQUIP_FOLLOW_MAX_STEPS, PB_PDA_EQUIP_FOLLOW_TIC_CAP, true);
			if (def.FindStateByString("Death", true))
				PDA_EquipStrip_AppendLabelWalk(nm, "Death", outFr, outTi, outSeg, useSeg, hardCap,
					PB_PDA_EQUIP_PREVIEW_SEG_FOLLOW, dt, PB_PDA_EQUIP_FOLLOW_MAX_STEPS, PB_PDA_EQUIP_FOLLOW_TIC_CAP, true);
			return;
		}
		if (def.FindStateByString("Spawn", true))
			PDA_EquipStrip_AppendLabelWalk(nm, "Spawn", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_EQUIP_PREVIEW_SEG_FOLLOW, sp, PB_PDA_EQUIP_FOLLOW_MAX_STEPS, PB_PDA_EQUIP_FOLLOW_TIC_CAP, true);
		if (def.FindStateByString("Death", true))
			PDA_EquipStrip_AppendLabelWalk(nm, "Death", outFr, outTi, outSeg, useSeg, hardCap,
				PB_PDA_EQUIP_PREVIEW_SEG_FOLLOW, dt, PB_PDA_EQUIP_FOLLOW_MAX_STEPS, PB_PDA_EQUIP_FOLLOW_TIC_CAP, true);
	}

	void PDA_EquipStrip_AppendLabelWalk(Name nm, string label,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int segIdx,
		int maxPushes, int maxSteps, int authoredTicCap, bool enforceBoundary)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (!def)
			return;
		State st = def.FindStateByString(label, true);
		if (!st)
			return;
		int pushed = 0;
		int steps = 0;
		while (st && pushed < maxPushes && steps < maxSteps && outFr.Size() < hardCap)
		{
			if (PDA_WeaponStrip_TryPushFrame(st, def, outFr, outTi, outSeg, useSeg, segIdx,
				-1, true, authoredTicCap, hardCap))
				pushed++;
			State nx = st.NextState;
			if (!nx || nx == st)
				break;
			if (enforceBoundary && PDA_Main_FireWalk_ShouldStopBeforeState(def, nx))
				break;
			st = nx;
			steps++;
		}
	}

	void PDA_EquipStrip_AppendPickup(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int pickupTics)
	{
		PDA_WeaponStrip_AppendPickup(nm, outFr, outTi, outSeg, useSeg, hardCap, pickupTics,
			PB_PDA_WEAPON_PREVIEW_SPAWN_SEEK, PB_PDA_EQUIP_PREVIEW_SEG_PICKUP);
	}

	void PDA_EquipStrip_AppendCompanionThrow(Name compNm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		int maxThrowFrames, int throwTicCap)
	{
		PDA_EquipStrip_AppendLabelWalk(compNm, "Spawn", outFr, outTi, outSeg, useSeg, hardCap,
			PB_PDA_EQUIP_PREVIEW_SEG_THROW, maxThrowFrames, PB_PDA_EQUIP_THROW_MAX_STEPS, throwTicCap, true);
	}

	bool PDA_EquipStrip_AppendActiveOneLabel(Name nm, string label,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		int maxActiveFrames, int fixedTic)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(nm));
		if (!def)
			return false;
		State st = def.FindStateByString(label, true);
		if (!st)
			return false;
		int pushed = 0;
		int steps = 0;
		while (st && pushed < maxActiveFrames && steps < PB_PDA_EQUIP_ACTIVE_MAX_STEPS && outFr.Size() < hardCap)
		{
			if (PDA_WeaponStrip_TryPushFrame(st, def, outFr, outTi, outSeg, useSeg, PB_PDA_EQUIP_PREVIEW_SEG_ACTIVE,
				fixedTic, true, PB_PDA_EQUIP_DOSSIER_ACTIVE_TICS, hardCap))
				pushed++;
			State nx = st.NextState;
			if (!nx || nx == st)
				break;
			if (PDA_Main_FireWalk_ShouldStopBeforeState(def, nx))
				break;
			st = nx;
			steps++;
		}
		return pushed > 0;
	}

	void PDA_EquipStrip_AppendCompanionActiveMulti(Name compNm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		int maxFrames, int fixedTic)
	{
		if (PDA_EquipStrip_AppendActiveOneLabel(compNm, "Idle", outFr, outTi, outSeg, useSeg, hardCap, maxFrames, fixedTic))
			return;
		if (PDA_EquipStrip_AppendActiveOneLabel(compNm, "Active", outFr, outTi, outSeg, useSeg, hardCap, maxFrames, fixedTic))
			return;
		if (PDA_EquipStrip_AppendActiveOneLabel(compNm, "Hover", outFr, outTi, outSeg, useSeg, hardCap, maxFrames, fixedTic))
			return;
		if (PDA_EquipStrip_AppendActiveOneLabel(compNm, "See", outFr, outTi, outSeg, useSeg, hardCap, maxFrames, fixedTic))
			return;
		PDA_EquipStrip_AppendActiveOneLabel(compNm, "Chase", outFr, outTi, outSeg, useSeg, hardCap, maxFrames, fixedTic);
	}

	void PDA_EquipStrip_AppendCompanionDeath(Name compNm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int deathTicCap)
	{
		PDA_EquipStrip_AppendLabelWalk(compNm, "Death", outFr, outTi, outSeg, useSeg, hardCap,
			PB_PDA_EQUIP_PREVIEW_SEG_DEATH, PB_PDA_EQUIP_DEATH_MAX_PUSHES, PB_PDA_EQUIP_DEATH_MAX_STEPS, deathTicCap, true);
	}

	void PDA_EquipStrip_AppendCompanionXDeath(Name compNm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, int xdeathTicCap, bool allow)
	{
		if (!allow)
			return;
		readonly<Actor> def = GetDefaultByType((class<Actor>)(compNm));
		if (!def || !PDA_Equip_XDeathDiffersFromDeath(def))
			return;
		PDA_EquipStrip_AppendLabelWalk(compNm, "XDeath", outFr, outTi, outSeg, useSeg, hardCap,
			PB_PDA_EQUIP_PREVIEW_SEG_XDEATH, PB_PDA_EQUIP_DEATH_MAX_PUSHES, PB_PDA_EQUIP_DEATH_MAX_STEPS, xdeathTicCap, true);
	}

	void PDA_EquipStrip_AppendOneCompanion(Name compNm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		bool mainTile)
	{
		int tf = mainTile ? PB_PDA_EQUIP_MAIN_THROW_FRAMES : PB_PDA_EQUIP_DOSSIER_THROW_FRAMES;
		int tt = mainTile ? PB_PDA_EQUIP_MAIN_THROW_TIC_CAP : PB_PDA_EQUIP_DOSSIER_THROW_TIC_CAP;
		PDA_EquipStrip_AppendCompanionThrow(compNm, outFr, outTi, outSeg, useSeg, hardCap, tf, tt);

		int af = mainTile ? PB_PDA_EQUIP_MAIN_ACTIVE_MAX_FRAMES : PB_PDA_EQUIP_DOSSIER_ACTIVE_MAX_FRAMES;
		int at = mainTile ? PB_PDA_EQUIP_MAIN_ACTIVE_TICS : PB_PDA_EQUIP_DOSSIER_ACTIVE_TICS;
		PDA_EquipStrip_AppendCompanionActiveMulti(compNm, outFr, outTi, outSeg, useSeg, hardCap, af, at);

		int dc = mainTile ? PB_PDA_EQUIP_MAIN_DEATH_TIC_CAP : PB_PDA_EQUIP_DOSSIER_DEATH_TIC_CAP;
		PDA_EquipStrip_AppendCompanionDeath(compNm, outFr, outTi, outSeg, useSeg, hardCap, dc);

		PDA_EquipStrip_AppendCompanionXDeath(compNm, outFr, outTi, outSeg, useSeg, hardCap,
			PB_PDA_EQUIP_DOSSIER_XDEATH_TIC_CAP, !mainTile);
	}

	void PDA_EquipStrip_AppendFallbackInventory(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap, bool mainTile)
	{
		int apushes = mainTile ? 2 : 4;
		int upushes = mainTile ? 2 : 3;
		int atic = mainTile ? PB_PDA_EQUIP_MAIN_ACTIVE_TICS : 5;
		int utic = mainTile ? 3 : 4;
		PDA_EquipStrip_AppendLabelWalk(nm, "Active", outFr, outTi, outSeg, useSeg, hardCap,
			PB_PDA_EQUIP_PREVIEW_SEG_ACTIVE, apushes, 16, atic, true);
		PDA_EquipStrip_AppendLabelWalk(nm, "Use", outFr, outTi, outSeg, useSeg, hardCap,
			PB_PDA_EQUIP_PREVIEW_SEG_ACTIVE, upushes, 12, utic, true);
	}

	void PDA_EquipStrip_AppendFullCatalogEntry(Name nm,
		Array<TextureID> outFr, Array<int> outTi, Array<int> outSeg,
		bool useSeg, int hardCap,
		bool mainTile)
	{
		readonly<Inventory> ichk = GetDefaultByType((class<Inventory>)(nm));
		if (!ichk)
			return;
		int pickupTics = mainTile ? PB_PDA_MAIN_WEAPON_PICKUP_TICS : PB_PDA_WEAPON_PREVIEW_PICKUP_TICS;
		Name pickupStripNm = nm;
		if (nm == 'HasLeech')
			pickupStripNm = 'LeechGrenade';
		else if (nm == 'PB_CF_SnowCasterAmmo')
			pickupStripNm = 'PB_CF_SnowCasterPickup';
		PDA_EquipStrip_AppendPickup(pickupStripNm, outFr, outTi, outSeg, useSeg, hardCap, pickupTics);

		Name prim, burst;
		PDA_EquipStrip_LookupPrimaryBurst(nm, prim, burst);
		if (prim != '')
		{
			PDA_EquipStrip_AppendOneCompanion(prim, outFr, outTi, outSeg, useSeg, hardCap, mainTile);
			PDA_EquipStrip_AppendPrimaryOutcomeLabels(prim, mainTile, outFr, outTi, outSeg, useSeg, hardCap);
		}
		else if (burst == '')
			PDA_EquipStrip_AppendFallbackInventory(nm, outFr, outTi, outSeg, useSeg, hardCap, mainTile);
		if (burst != '')
			PDA_EquipStrip_AppendFollowBurstActor(burst, mainTile, outFr, outTi, outSeg, useSeg, hardCap);
	}

	void PDA_Play_AppendChain(Name actorClass, String label, int segIdx, int maxSteps, bool isMonster = false, bool filterPlayerBody = false)
	{
		readonly<Actor> def = GetDefaultByType((class<Actor>)(actorClass));
		if (!def)
			return;
		State st = def.FindStateByString(label, true);
		if (!st)
			return;
		int steps = 0;
		while (st && steps < maxSteps && pdaPrevFrames.Size() < PB_PDA_PREVIEW_TOTAL_FRAMES)
		{
			TextureID tid = st.GetSpriteTexture(0);
			bool ok = PDA_WeaponStrip_TextureRenderable(tid);
			if (ok)
			{
				string tn = TexMan.GetName(tid);
				if (tn.Length() >= 4 && tn.Mid(0, 4) ~== "TNT1")
					ok = false;
				else if (isMonster && tn.Length() >= 4 && tn.Mid(0, 4) ~== "PLAY")
					ok = false;
				else if (filterPlayerBody && PDA_ShouldSuppressWeaponStripArt(def, tn))
					ok = false;
			}
			if (ok)
			{
				int tic = st.tics;
				if (tic < 1)
					tic = 1;
				tic = max(PB_PDA_PREVIEW_MIN_TICS, tic);
				pdaPrevFrames.Push(tid);
				pdaPrevFrameTics.Push(tic);
				pdaPrevSegIdx.Push(segIdx);
			}
			State nx = st.NextState;
			if (!nx || nx == st)
				break;
			if (filterPlayerBody && PDA_Play_UseFireLikeWalkBreak(label)
				&& PDA_Main_FireWalk_ShouldStopBeforeState(def, nx))
				break;
			st = nx;
			steps++;
		}
	}

	void PDA_Play_BuildWeapon(string cn)
	{
		Name nm = cn;
		readonly<Weapon> wchk = GetDefaultByType((class<Weapon>)(nm));
		if (!wchk)
			return;
		PDA_WeaponStrip_AppendFullWeapon(nm, pdaPrevFrames, pdaPrevFrameTics, pdaPrevSegIdx, true,
			PB_PDA_WEAPON_PREVIEW_STRIP_MAX,
			PB_PDA_WEAPON_PREVIEW_PICKUP_TICS, PB_PDA_WEAPON_PREVIEW_SPAWN_SEEK,
			PB_PDA_WEAPON_PREVIEW_READY_MAX, PB_PDA_WEAPON_PREVIEW_READY_SEEK,
			PB_PDA_WEAPON_PREVIEW_READY_TICS, PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP,
			PB_PDA_WEAPON_PREVIEW_BODY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_FLASH_TICS, PB_PDA_WEAPON_PREVIEW_FLASH_SEEK,
			true, PB_PDA_WEAPON_PREVIEW_OVERLAY_TIC_CAP, PB_PDA_WEAPON_PREVIEW_OVERLAY_MAX_STEPS);
	}

	void PDA_Play_BuildMonster(string cn)
	{
		Name nm = cn;
		readonly<Actor> achk = GetDefaultByType((class<Actor>)(nm));
		if (!achk)
			return;
		int sz;
		PDA_Play_AppendChain(nm, "Spawn", 0, PB_PDA_PREVIEW_SEG_FRAMES, true);
		sz = pdaPrevFrames.Size();
		PDA_Play_AppendChain(nm, "See", 1, PB_PDA_PREVIEW_SEG_FRAMES, true);
		if (pdaPrevFrames.Size() == sz)
			PDA_Play_AppendChain(nm, "Chase", 1, PB_PDA_PREVIEW_SEG_FRAMES, true);
		sz = pdaPrevFrames.Size();
		PDA_Play_AppendChain(nm, "Missile", 2, PB_PDA_PREVIEW_SEG_FRAMES, true);
		if (pdaPrevFrames.Size() == sz)
			PDA_Play_AppendChain(nm, "Attack", 2, PB_PDA_PREVIEW_SEG_FRAMES, true);
		if (pdaPrevFrames.Size() == sz)
			PDA_Play_AppendChain(nm, "Charge", 2, PB_PDA_PREVIEW_SEG_FRAMES, true);
		if (pdaPrevFrames.Size() == sz)
			PDA_Play_AppendChain(nm, "Shoot", 2, PB_PDA_PREVIEW_SEG_FRAMES, true);
		sz = pdaPrevFrames.Size();
		PDA_Play_AppendChain(nm, "Melee", 3, PB_PDA_PREVIEW_SEG_FRAMES, true);
		if (pdaPrevFrames.Size() == sz)
			PDA_Play_AppendChain(nm, "Bite", 3, PB_PDA_PREVIEW_SEG_FRAMES, true);
		PDA_Play_AppendChain(nm, "Pain", 4, PB_PDA_PREVIEW_SEG_FRAMES, true);
		PDA_Play_AppendChain(nm, "Death", 5, PB_PDA_PREVIEW_SEG_FRAMES, true);
	}

	void PDA_Play_BuildEquipment(string cn)
	{
		Name nm = cn;
		PDA_EquipStrip_AppendFullCatalogEntry(nm, pdaPrevFrames, pdaPrevFrameTics, pdaPrevSegIdx, true,
			PB_PDA_EQUIP_PREVIEW_STRIP_MAX, false);
	}

	void PDA_Play_BuildFromKey(string key)
	{
		PDA_Play_ClearPreview();
		if (key.Length() < 3)
			return;
		string prefix = key.Mid(0, 2);
		string body = key.Mid(2, key.Length() - 2);
		body = PB_PDA_NormClassStr(body);
		if (body.Length() < 1)
			return;
		if (prefix == "W:")
			PDA_Play_BuildWeapon(body);
		else if (prefix == "M:")
			PDA_Play_BuildMonster(body);
		else if (prefix == "E:")
			PDA_Play_BuildEquipment(body);
		else
			return;
		pdaPrevBuiltKey = key;
	}

	void PDA_Main_ClearAnimChains()
	{
		pdaMainWeapFrames.Clear();
		pdaMainWeapTics.Clear();
		pdaMainAnimSegScratch.Clear();
		pdaMainMonFrames.Clear();
		pdaMainMonTics.Clear();
		pdaMainEquipFrames.Clear();
		pdaMainEquipTics.Clear();
		pdaMainWeapCur = 0;
		pdaMainMonCur = 0;
		pdaMainEquipCur = 0;
		pdaMainWeapTicsRem = 0;
		pdaMainMonTicsRem = 0;
		pdaMainEquipTicsRem = 0;
	}

	const PB_PDA_MAIN_TARGET_WEAP = 0;
	const PB_PDA_MAIN_TARGET_MON = 1;
	const PB_PDA_MAIN_TARGET_EQUIP = 2;

	void PDA_GetEquipActiveCompanions(Name pickupCls, out Name out1, out Name out2)
	{
		out1 = '';
		out2 = '';
		String s = pickupCls;
		if (s ~== "HandMolotovAmmo")           { out1 = 'ThrownMolotov';       out2 = 'MolotovExplosion'; return; }
		if (s ~== "HandGrenadeAmmo")           { out1 = 'HandGrenadeExplosion'; out2 = 'ThrownGrenade1'; return; }
		if (s ~== "MineAmmo")                 { out1 = 'ThrownProxMine';      out2 = 'GroundProxMine'; return; }
		if (s ~== "StunGrenadeAmmo")          { out1 = 'ThrownStunGrenade';   out2 = ''; return; }
		if (s ~== "ShieldGrenadeAmmo")         { out1 = 'ThrownShieldGrenade'; out2 = ''; return; }
		if (s ~== "VoidGrenadeAmmo")          { out1 = 'ThrownVoidGrenade';   out2 = ''; return; }
		if (s ~== "MiniHellRocketAmmo")       { out1 = 'DoomerRevenantSeeker2'; out2 = 'DoomerRevenantSeeker3'; return; }
		if (s ~== "PB_DTech")                 { out1 = 'SiphonPuff';          out2 = ''; return; }
		if (s ~== "HasLeech")                { out1 = 'SiphonPuff';          out2 = ''; return; }
		if (s ~== "HookAmmo")                { out1 = 'HookShot';            out2 = ''; return; }
		if (s ~== "PB_HookToken")            { out1 = 'HookShot';            out2 = ''; return; }
		if (s ~== "AlreadyHaveMeatHook")      { out1 = 'HookShot';            out2 = ''; return; }
		if (s ~== "FreezenadeAmmo")           { out1 = 'Freezenade';          out2 = 'FreezenadeExplosion'; return; }
		if (s ~== "PB_CF_FreezeBotDeployAmmo") { out1 = 'PBCF_CF_FreezeBotTurret'; out2 = ''; return; }
		if (s ~== "PB_CF_IceWallGenAmmo")    { out1 = 'PBCF_CF_IceWallSegment'; out2 = ''; return; }
		if (s ~== "PB_CF_HoloDecoyAmmo")      { out1 = 'PBCF_CF_HoloDecoy';   out2 = ''; return; }
		if (s ~== "PB_CF_TeslaTurretAmmo")    { out1 = 'PBCF_CF_TeslaTurret'; out2 = 'MineElectricity'; return; }
		if (s ~== "PB_CF_FlameTurretAmmo")    { out1 = 'PBCF_CF_FlameTurret'; out2 = ''; return; }
		if (s ~== "PB_CF_FreezeMineAmmo")     { out1 = 'PBCF_CF_FreezeMine';  out2 = ''; return; }
		if (s ~== "PB_CF_SnowCasterAmmo")     { out1 = 'PBCF_CF_SnowCasterEmitter'; out2 = ''; return; }
		if (s ~== "FlameBelchSelected")       { out1 = 'GloryFireMissile';    out2 = ''; return; }
		if (s ~== "IceBombSelected")          { out1 = 'SC_CryoGrenade';      out2 = ''; return; }
		if (s ~== "GK_FlamebelchSelected")    { out1 = 'GloryFireMissile';    out2 = ''; return; }
		if (s ~== "GK_IcebombSelected")       { out1 = 'SC_CryoGrenade';      out2 = ''; return; }
	}

	void PDA_Main_PushTo(int target, Name actorClass, string label,
		int maxSteps, bool filterPlay, int hardCap, int minTic = 2)
	{
		if (actorClass == 'None')
			return;
		class<Actor> ac = (class<Actor>)(actorClass);
		if (!ac)
			return;
		readonly<Actor> def = GetDefaultByType(ac);
		if (!def)
			return;
		State st = def.FindStateByString(label, true);
		if (!st)
			return;
		int curSize;
		switch (target)
		{
			case PB_PDA_MAIN_TARGET_WEAP:  curSize = pdaMainWeapFrames.Size(); break;
			case PB_PDA_MAIN_TARGET_MON:   curSize = pdaMainMonFrames.Size(); break;
			case PB_PDA_MAIN_TARGET_EQUIP: curSize = pdaMainEquipFrames.Size(); break;
			default: return;
		}
		int hopLimit = maxSteps;
		if (target == PB_PDA_MAIN_TARGET_WEAP && label ~== "Fire")
			hopLimit = min(maxSteps, PB_PDA_MAIN_FIRE_MAX_HOPS);
		int steps = 0;
		while (st && steps < hopLimit && curSize < hardCap)
		{
			TextureID tid = st.GetSpriteTexture(0);
			bool ok = PDA_WeaponStrip_TextureRenderable(tid);
			if (ok)
			{
				string tn = TexMan.GetName(tid);
				if (tn.Length() >= 4 && tn.Mid(0, 4) ~== "TNT1")
					ok = false;
				else if (filterPlay)
				{
					if (target == PB_PDA_MAIN_TARGET_MON)
					{
						if (tn.Length() >= 4 && tn.Mid(0, 4) ~== "PLAY")
							ok = false;
					}
					else if (PDA_ShouldSuppressWeaponPlayerSideArt(tn))
						ok = false;
				}
			}
			if (ok)
			{
				int tic = st.tics;
				if (tic < 1)
					tic = 1;
				tic = clamp(tic, minTic, 10);
				switch (target)
				{
					case PB_PDA_MAIN_TARGET_WEAP:
						pdaMainWeapFrames.Push(tid);
						pdaMainWeapTics.Push(tic);
						curSize = pdaMainWeapFrames.Size();
						break;
					case PB_PDA_MAIN_TARGET_MON:
						pdaMainMonFrames.Push(tid);
						pdaMainMonTics.Push(tic);
						curSize = pdaMainMonFrames.Size();
						break;
					case PB_PDA_MAIN_TARGET_EQUIP:
						pdaMainEquipFrames.Push(tid);
						pdaMainEquipTics.Push(tic);
						curSize = pdaMainEquipFrames.Size();
						break;
				}
			}
			State nx = st.NextState;
			if (!nx || nx == st)
				break;
			if (target == PB_PDA_MAIN_TARGET_WEAP && filterPlay && label ~== "Fire"
				&& PDA_Main_FireWalk_ShouldStopBeforeState(def, nx))
				break;
			st = nx;
			steps++;
		}
	}

	void PDA_Main_RebuildChains()
	{
		PDA_Main_ClearAnimChains();
		if (!playeringame[consoleplayer])
			return;
		Actor mo = players[consoleplayer].mo;
		if (!mo)
			return;
		let wc = PB_PDAWeaponContainer(mo.FindInventory("PB_PDAWeaponContainer", true));
		if (wc)
		{
			for (int i = 0; i < wc.pdaWeapTextArray.Size(); i++)
			{
				if (pdaMainWeapFrames.Size() >= PB_PDA_MAIN_WEAPON_STRIP_CHAIN_CAP)
					break;
				string sc = PB_PDA_NormClassStr(wc.pdaWeapTextArray[i].PDAWeapClassName);
				if (sc.length() < 1)
					continue;
				Name nm = sc;
				readonly<Weapon> wchk = GetDefaultByType((class<Weapon>)(nm));
				if (!wchk)
					continue;
				int weapEntryStart = pdaMainWeapFrames.Size();
				int weapEntryCap = min(PB_PDA_MAIN_WEAPON_STRIP_CHAIN_CAP,
					weapEntryStart + PB_PDA_MAIN_WEAPON_ENTRY_CAP);
				PDA_WeaponStrip_AppendFullWeapon(nm, pdaMainWeapFrames, pdaMainWeapTics, pdaMainAnimSegScratch, false,
					weapEntryCap,
					PB_PDA_MAIN_WEAPON_PICKUP_TICS, PB_PDA_WEAPON_PREVIEW_SPAWN_SEEK,
					PB_PDA_WEAPON_PREVIEW_READY_MAX, PB_PDA_WEAPON_PREVIEW_READY_SEEK,
					PB_PDA_MAIN_WEAPON_READY_TICS, 0,
					PB_PDA_MAIN_WEAPON_FIRE_TIC_CAP, PB_PDA_MAIN_WEAPON_FLASH_TICS, PB_PDA_WEAPON_PREVIEW_FLASH_SEEK,
					false, 0, 0);
			}
			for (int mi = 0; mi < wc.PDA_CodexMonsterClasses.Size(); mi++)
			{
				if (pdaMainMonFrames.Size() >= PB_PDA_MAIN_TILE_CAP)
					break;
				int sl = wc.PDA_CodexMonsterSlots[mi];
				if (sl < 0 || sl >= wc.PDAMonsterFound.Size() || !wc.PDAMonsterFound[sl])
					continue;
				if (wc.PDA_CodexMonsterClasses[mi] == null)
					continue;
				Name monNm = wc.PDA_CodexMonsterClassNames[mi];
				int n0m = pdaMainMonFrames.Size();
				PDA_Main_PushTo(PB_PDA_MAIN_TARGET_MON, monNm, "Death",   PB_PDA_MAIN_MON_STEPS, true, PB_PDA_MAIN_TILE_CAP);
				if (pdaMainMonFrames.Size() == n0m)
					PDA_Main_PushTo(PB_PDA_MAIN_TARGET_MON, monNm, "Missile", PB_PDA_MAIN_MON_STEPS, true, PB_PDA_MAIN_TILE_CAP);
				if (pdaMainMonFrames.Size() == n0m)
					PDA_Main_PushTo(PB_PDA_MAIN_TARGET_MON, monNm, "Pain",    PB_PDA_MAIN_MON_STEPS, true, PB_PDA_MAIN_TILE_CAP);
				if (pdaMainMonFrames.Size() == n0m)
					PDA_Main_PushTo(PB_PDA_MAIN_TARGET_MON, monNm, "See",     12, true, PB_PDA_MAIN_TILE_CAP);
			}
			for (int ei = 0; ei < wc.PDA_CodexEquipClasses.Size(); ei++)
			{
				if (pdaMainEquipFrames.Size() >= PB_PDA_MAIN_EQUIP_CHAIN_CAP)
					break;
				if (wc.PDA_CodexEquipClasses[ei] == null)
					continue;
				string esc = PB_PDA_NormClassStr(wc.PDA_CodexEquipClassNames[ei]);
				if (esc.length() < 1)
					continue;
				Name eqNm = esc;
				int entryStart = pdaMainEquipFrames.Size();
				int entryCap = min(PB_PDA_MAIN_EQUIP_CHAIN_CAP, entryStart + PB_PDA_MAIN_EQUIP_ENTRY_CAP);
				PDA_EquipStrip_AppendFullCatalogEntry(eqNm, pdaMainEquipFrames, pdaMainEquipTics, pdaMainAnimSegScratch,
					false, entryCap, true);
			}
		}
		if (pdaMainMonFrames.Size() == 0)
			PDA_Main_PushTo(PB_PDA_MAIN_TARGET_MON, 'Doomer', "FatalitySpiderMastermind", PB_PDA_MAIN_MON_STEPS, false, 1200);
		pdaMainWeapLastGt = pdaMainMonLastGt = pdaMainEquipLastGt = gametic;
		if (pdaMainWeapFrames.Size() > 0)
		{
			pdaMainWeapCur = 0;
			pdaMainWeapTicsRem = pdaMainWeapTics[0];
		}
		if (pdaMainMonFrames.Size() > 0)
		{
			pdaMainMonCur = 0;
			pdaMainMonTicsRem = pdaMainMonTics[0];
		}
		if (pdaMainEquipFrames.Size() > 0)
		{
			pdaMainEquipCur = 0;
			pdaMainEquipTicsRem = pdaMainEquipTics[0];
		}
	}

	void PDA_Main_AdvanceAnims()
	{
		if (!PDAMode || NonMainMenu)
			return;
		PlayerInfo plr = players[consoleplayer];
		bool blockyOn = true;
		if (plr)
		{
			let cvB = CVar.GetCVar("pb_pda_blocky", plr);
			if (cvB)
				blockyOn = cvB.GetBool();
		}
		if (!blockyOn)
			return;
		while (pdaMainWeapFrames.Size() > 0 && gametic >= pdaMainWeapLastGt + pdaMainWeapTicsRem)
		{
			pdaMainWeapLastGt += pdaMainWeapTicsRem;
			pdaMainWeapCur++;
			if (pdaMainWeapCur >= pdaMainWeapFrames.Size())
				pdaMainWeapCur = 0;
			pdaMainWeapTicsRem = pdaMainWeapTics[pdaMainWeapCur];
		}
		while (pdaMainMonFrames.Size() > 0 && gametic >= pdaMainMonLastGt + pdaMainMonTicsRem)
		{
			pdaMainMonLastGt += pdaMainMonTicsRem;
			pdaMainMonCur++;
			if (pdaMainMonCur >= pdaMainMonFrames.Size())
				pdaMainMonCur = 0;
			pdaMainMonTicsRem = pdaMainMonTics[pdaMainMonCur];
		}
		while (pdaMainEquipFrames.Size() > 0 && gametic >= pdaMainEquipLastGt + pdaMainEquipTicsRem)
		{
			pdaMainEquipLastGt += pdaMainEquipTicsRem;
			pdaMainEquipCur++;
			if (pdaMainEquipCur >= pdaMainEquipFrames.Size())
				pdaMainEquipCur = 0;
			pdaMainEquipTicsRem = pdaMainEquipTics[pdaMainEquipCur];
		}
	}

	override void PlayerEntered(PlayerEvent e)
	{
		if (!e) return;
		if (e.PlayerNumber < 0 || e.PlayerNumber >= MAXPLAYERS) return;
		if (!playeringame[e.PlayerNumber]) return;
		let pmo = players[e.PlayerNumber].mo;
		if (!pmo) return;
		let ppb = PlayerPawnBase(pmo);
		if (ppb) { ppb.baseweaponpda = false; }
		pmo.A_SetBlend("black",1.0,35);
	}
	override void WorldTick()
	{
		if (gamestate == GS_TITLELEVEL) return;
		for (int i = 0; i < taunttimer.Size(); i++)
		{
			if (taunttimer[i] > 0)
				taunttimer[i]--;
		}
		if (MouseClicked == false)
		{
			MouseHeldDown = false;
		}
		if (!DontTick) uiTics++;
		if (pdaPrevNeedsBuild)
		{
			pdaPrevNeedsBuild = false;
			PDA_Play_BuildFromKey(pdaPrevPendingKey);
			PDA_Play_ResetAnim();
		}
		PDA_Play_AdvancePreviewAnim();
		if (KatanaDualChoiceMode)
			PB_KatanaDualAdvancePreviewAnims();
		if (pdaMainAnimDirty && PDAMode && !NonMainMenu)
		{
			pdaMainAnimDirty = false;
			PDA_Main_RebuildChains();
		}
		PDA_Main_AdvanceAnims();
		ThinkerIterator ti = ThinkerIterator.Create("PlayerPawn");
		PlayerPawn a;
		bool eqSweep = level.maptime >= PB_PDA_UI_INIT_MIN_GAMETIC && (level.time % 14) == 0;
		while (a = PlayerPawn(ti.Next()))
		{
			if (a.player && a.player.morphTics <= 5)
			{
				let amo = a.player.mo;
				if (!amo) { continue; }
				switch(amo.GetClassName())
				{
					case 'RevenantPlayer': amo.ACS_NamedExecuteAlways("RevenantMorphModeDisable");break;
					case 'BaronPlayer': amo.ACS_NamedExecuteAlways("BaronMorphModeDisable");break;
				}
			}
			if (eqSweep && a.player)
			{
				let pda = PB_PDAWeaponContainer(a.FindInventory("PB_PDAWeaponContainer", true));
				if (pda)
					pda.SweepEquipmentCodexFromPawn(a);
			}
		}
	}
	bool PB_WeaponReadyForTaunt(Weapon wpn, PlayerInfo plr)
	{
		if (!plr)
			return false;
		if (!wpn)
			return true;
		let pbw = PB_WeaponBase(wpn);
		if (!pbw)
			return true;
		let psp = plr.GetPSprite(PSP_WEAPON);
		if (!psp || !psp.Curstate)
			return false;
		if (pbw.InStateSequence(psp.Curstate, pbw.ResolveState("Ready"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("ReallyReady"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("ReadyToFire"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("Ready2"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("Ready3"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("Ready4"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("Ready5"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("ReadyToFire2"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("ReadyDualUnloaded"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("Ready_ADS"))
			|| pbw.InStateSequence(psp.Curstate, pbw.ResolveState("JavelinReady3")))
			return true;
		return false;
	}

	void PB_TryRequestTaunt(int pnum)
	{
		if (pnum < 0 || pnum >= MAXPLAYERS)
			return;
		if (taunttimer[pnum] > 0)
			return;
		let pm = players[pnum].mo;
		if (!pm || !pm.player)
			return;
		if (PDAMode || pm.CountInv("GoFatality") > 0 || pm.CountInv("CantFire") > 0)
			return;
		if (pm.player.ReadyWeapon && pm.player.ReadyWeapon is "PB_TauntWeapon")
			return;
		if (!PB_WeaponReadyForTaunt(pm.player.ReadyWeapon, pm.player))
			return;
		taunttimer[pnum] = tauntCooldownTics;
		pm.GiveInventory("PB_TauntWeapon", 1);
		let wp = PB_TauntWeapon(pm.FindInventory("PB_TauntWeapon"));
		if (!wp)
			return;
		if (pm.player.ReadyWeapon && !(pm.player.ReadyWeapon is "PB_TauntWeapon"))
			wp.PrevWeapon = Weapon(pm.player.ReadyWeapon);
		pm.player.ReadyWeapon = wp;
		pm.player.SetPSprite(PSP_WEAPON, wp.FindState("Ready"));
	}

	override void NetworkProcess(ConsoleEvent e)
	{
		if (!e) return;
		if (gamestate == GS_TITLELEVEL) return;
		if (HeldDownTics <= 0) mouseclicked = false;
		if (e.Name ~== "RequestTaunt")
		{
			PB_TryRequestTaunt(e.Player);
			return;
		}
		if (e.Name ~== "netgametrue")
		{
			isnetgame = true;
		}
		if (e.Name ~== "releasemouse")
		{
			self.MouseHeldDown = false;
			self.MouseClicked = false;
		}
		if (e.Name ~== "openmonstermenu")
		{
			AchievementsMenuOpened = false;
			RequestPDAAchievementScrollReset();
			InvalidatePDAAchievementCache();
			MonsterMenuOpened = true;
			WeaponMenuOpened = false;
			EquipmentMenuOpened = false;
			NonMainMenu = true;
			S_StartSound("PDAOPEN",CHAN_AUTO);
		}
		if (e.Name ~== "closemonstermenu")
		{
			MonsterMenuOpened = false;
			WeaponMenuOpened = false;
			EquipmentMenuOpened = false;
			AchievementsMenuOpened = false;
			NonMainMenu = false;
			InvalidatePDAAchievementCache();
			RequestPDAAchievementScrollReset();
			S_StartSound("PDABACK",CHAN_AUTO);
			PDA_Play_ClearPreview();
			pdaPrevPendingKey = "";
			pdaPrevNeedsBuild = false;
			pdaMainAnimDirty = true;
		}
		if (e.Name ~== "closepdaachievements")
		{
			if (!AchievementsMenuOpened)
				return;
			AchievementsMenuOpened = false;
			NonMainMenu = false;
			InvalidatePDAAchievementCache();
			RequestPDAAchievementScrollReset();
			S_StartSound("PDABACK", CHAN_AUTO);
			pdaMainAnimDirty = true;
		}
		if (e.Name ~== "openweaponmenu")
		{
			AchievementsMenuOpened = false;
			RequestPDAAchievementScrollReset();
			InvalidatePDAAchievementCache();
			WeaponMenuOpened = true;
			MonsterMenuOpened = false;
			EquipmentMenuOpened = false;
			NonMainMenu = true;
			S_StartSound("PDAOPEN",CHAN_AUTO);
		}
		if (e.Name ~== "openequipmentmenu")
		{
			AchievementsMenuOpened = false;
			RequestPDAAchievementScrollReset();
			InvalidatePDAAchievementCache();
			EquipmentMenuOpened = true;
			MonsterMenuOpened = false;
			WeaponMenuOpened = false;
			NonMainMenu = true;
			S_StartSound("PDAOPEN",CHAN_AUTO);
		}
		if (e.Name ~== "resetweaponname")
		{
			self.WeaponFound = false;
			self.WeaponFoundName.Clear();
		}
		if (e.Name ~== "resetmonsterfound")
		{
			self.MonsterFound = false;
			self.MonsterFoundSlots.Clear();
		}
		if (e.Name ~== "resetequipmentfound")
		{
			self.equipmentFound = false;
			self.equipmentFoundSlots.Clear();
		}
		if (e.Name ~== "weaponname")
		{
			self.WeaponFound = true;
		}
		if (MouseHeldDown == false && MouseClicked == true && !(HeldDownTics <= 0) ) HeldDownTics--;
		if (e.Name ~== "input")
		{
			if (PDAMode || KatanaDualChoiceMode)
			{
				DeltaMouseX = e.Args[0] / 2;
				DeltaMouseY = e.Args[1];
				MouseX += DeltaMouseX;
				MouseY -= DeltaMouseY;
				MouseX = clamp(MouseX, 0, Screen.GetWidth());
				MouseY = clamp(MouseY, 0, Screen.GetHeight());
				MousePositionSet = true;
				if (e.Args[2] == 1 && !MouseClicked)
				{
					MouseClicked = true;
					MouseHeldDown = false;
					HeldDownTics = 5;
				}
				else if (e.Args[2] == 2)
				{
					MouseClicked = false;
					MouseHeldDown = false;
					HeldDownTics = 0;
				}
			}
		}
		if (e.Name ~== "exitpda")
		{
			SetPlayerProperty(1,0,4);
			players[consoleplayer].timefreezer &= ~(1 << consoleplayer);
			Level.SetFrozen(false);
			S_StartSound("PDABACK",CHAN_AUTO);
			PDAMode = false;
			MouseX = 1;
			MouseY = 1;
			MousePositionSet = false;
			MouseClicked = false;
			MonsterMenuOpened = false;
			WeaponMenuOpened = False;
			EquipmentMenuOpened = false;
			AchievementsMenuOpened = false;
			NonMainMenu = false;
			InvalidatePDAAchievementCache();
			RequestPDAAchievementScrollReset();
			LastPDAToggleTic = gametic;
			PDA_Play_ClearPreview();
			pdaPrevPendingKey = "";
			pdaPrevNeedsBuild = false;
			PDA_Main_ClearAnimChains();
			pdaMainAnimDirty = false;
		}
		if (e.Name ~== "pb_pda_open_achievements")
		{
			if (!PB_AchievementsOn() || isnetgame || !PDAMode)
				return;
			MonsterMenuOpened = false;
			WeaponMenuOpened = false;
			EquipmentMenuOpened = false;
			NonMainMenu = true;
			AchievementsMenuOpened = true;
			RequestPDAAchievementScrollReset();
			InvalidatePDAAchievementCache();
			S_StartSound("PDAOPEN", CHAN_AUTO);
		}
		if (e.Name ~== "openpda")
		{
			if (KatanaDualChoiceMode)
				return;
			if (isnetgame) return;
			if (e.Player < 0 || e.Player >= MAXPLAYERS) return;
			if (!playeringame[e.Player]) return;
			if (gametic - LastPDAToggleTic < 6) return;
			LastPDAToggleTic = gametic;
			if (AchievementsMenuOpened)
			{
				SendNetworkEvent("closepdaachievements");
				return;
			}
			if (PDAMode)
			{
				SetPlayerProperty(1,0,4);
				players[e.Player].timefreezer &= ~(1 << e.Player);
				Level.SetFrozen(false);
				S_StartSound("PDABACK",CHAN_AUTO);
				PDAMode = false;
				MouseX = 1;
				MouseY = 1;
				MousePositionSet = false;
				MouseClicked = false;
				MouseHeldDown = false;
				HeldDownTics = 0;
				MonsterMenuOpened = false;
				WeaponMenuOpened = false;
				EquipmentMenuOpened = false;
				AchievementsMenuOpened = false;
				NonMainMenu = false;
				InvalidatePDAAchievementCache();
				RequestPDAAchievementScrollReset();
				PDA_Play_ClearPreview();
				pdaPrevPendingKey = "";
				pdaPrevNeedsBuild = false;
				PDA_Main_ClearAnimChains();
				pdaMainAnimDirty = false;
			}
			else
			{
				SetPlayerProperty(1,1,4);
				int freezemask = 1 << e.Player;
				players[e.Player].timefreezer |= freezemask;
				Level.SetFrozen(true);
				S_StartSound("PDAOPEN",CHAN_AUTO);
				PDAMode = true;
				pdaMainAnimDirty = true;
				if (playeringame[e.Player] && players[e.Player].mo)
				{
					let pda = PB_PDAWeaponContainer(players[e.Player].mo.FindInventory("PB_PDAWeaponContainer"));
					if (pda)
						pda.SyncWeaponCodexFromOwner(PlayerPawn(players[e.Player].mo));
				}
			}
		}
		if (e.Name ~== "modifymousepos")
		{
			MouseX = e.Args[0];
			MouseY = e.Args[1];
			MousePositionSet = true;
		}
		if (e.Name ~== "katanachoice_open0")
		{
			if (e.Player < 0 || e.Player >= MAXPLAYERS || !playeringame[e.Player])
				return;
			if (PDAMode)
			{
				PB_KatanaDualChoiceApplyPick(true, e.Player);
				return;
			}
			if (isnetgame)
			{
				PB_KatanaDualChoiceApplyPick(true, e.Player);
				return;
			}
			KatanaDualChoiceMode = 1;
			KatanaDualVariant = 0;
			KatanaDualFrozenPlr = e.Player;
			SetPlayerProperty(1, 1, 4);
			players[e.Player].timefreezer |= (1 << e.Player);
			Level.SetFrozen(true);
			MouseX = 1;
			MouseY = 1;
			MousePositionSet = false;
			MouseClicked = false;
			MouseHeldDown = false;
			HeldDownTics = 0;
			PB_KatanaDualChoiceBuildPreviews(0);
			PB_KatanaDualChoiceResetPreviewAnims();
			return;
		}
		if (e.Name ~== "katanachoice_open1")
		{
			if (e.Player < 0 || e.Player >= MAXPLAYERS || !playeringame[e.Player])
				return;
			if (PDAMode)
			{
				PB_KatanaDualChoiceApplyPick(false, e.Player);
				return;
			}
			if (isnetgame)
			{
				PB_KatanaDualChoiceApplyPick(false, e.Player);
				return;
			}
			KatanaDualChoiceMode = 1;
			KatanaDualVariant = 1;
			KatanaDualFrozenPlr = e.Player;
			SetPlayerProperty(1, 1, 4);
			players[e.Player].timefreezer |= (1 << e.Player);
			Level.SetFrozen(true);
			MouseX = 1;
			MouseY = 1;
			MousePositionSet = false;
			MouseClicked = false;
			MouseHeldDown = false;
			HeldDownTics = 0;
			PB_KatanaDualChoiceBuildPreviews(1);
			PB_KatanaDualChoiceResetPreviewAnims();
			return;
		}
		if (e.Name ~== "katanachoice_pick_sith")
		{
			if (!KatanaDualChoiceMode)
				return;
			PB_KatanaDualChoiceApplyPick(true, e.Player);
			return;
		}
		if (e.Name ~== "katanachoice_pick_jedi")
		{
			if (!KatanaDualChoiceMode)
				return;
			PB_KatanaDualChoiceApplyPick(false, e.Player);
			return;
		}
		if (e.Name ~== "pdaprevclear")
		{
			PDA_Play_ClearPreview();
			pdaPrevPendingKey = "";
			pdaPrevNeedsBuild = false;
		}
		if (e.Name.Length() > 9 && e.Name.Left(9) ~== "pdaprevq#")
		{
			pdaPrevPendingKey = e.Name.Mid(9, e.Name.Length() - 9);
			pdaPrevNeedsBuild = true;
		}
		if (e.Name ~== "foundweapon")
		{
			weaponFound = true;
		}
		if (e.Name ~== "addbaseweapons")
		{
			weaponFoundName.push("Rifle");
			weaponFoundName.push("PB_Pistol");
			weaponFoundName.push("Melee_Attacks");
		}
		Array<String> splittedStrings;
		e.Name.Split(splittedStrings,":");
		if (splittedStrings.Size() == 0) return;
		if (splittedStrings[0] == "addweaponclass")
		{
			PBWeapons.Push(splittedStrings[1]);
		}
		if (splittedStrings[0] ~== "foundweapon")
		{
			weaponFound = true;
			weaponFoundName.push(splittedStrings[1]);
			PB_Achievements.OnPDAWeaponFound();
		}
		if (splittedStrings.Size() >= 2 && splittedStrings[0] ~== "foundmonster")
		{
			int ms = PB_PDA_ParseUInt(splittedStrings[1]);
			if (ms >= 0)
			{
				monsterFound = true;
				monsterFoundSlots.Push(ms);
				PB_Achievements.OnPDAMonsterFound();
			}
		}
		if (splittedStrings.Size() >= 2 && splittedStrings[0] ~== "foundequip")
		{
			int es = PB_PDA_ParseUInt(splittedStrings[1]);
			if (es >= 0)
			{
				equipmentFound = true;
				equipmentFoundSlots.Push(es);
				PB_Achievements.OnPDAEquipFound();
			}
		}
	}
	override void WorldLoaded(WorldEvent e)
	{
		PB_KatanaDualChoiceClose();
	}
	override void OnRegister()
	{
		MouseX = 1;
		MouseY = 1;
		PDAMode = false;
		AchievementsMenuOpened = false;
		RequestPDAAchievementScrollReset();
		InvalidatePDAAchievementCache();
		KatanaDualChoiceMode = 0;
		KatanaDualVariant = 0;
		KatanaDualFrozenPlr = -1;
	}
	override void InterfaceProcess(ConsoleEvent e)
	{
		if (!e) return;
		if (e.Name ~== "PB_DashWhatchamacallit")
		{
			dashAlpha = 1.0;
			dashScale = 1.0;
		}
	}
	clearscope Vector2 GetTextureCenterPosition(TextureID tex)
	{
		if (!tex) return (0,0);
		return TexMan.GetScaledSize(tex) / 2;
	}

