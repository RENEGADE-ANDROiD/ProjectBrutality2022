// Cat's Frozen equipment deployables (Slice 4). Credits: addon lineage Cat's Frozen V2.6.x (SchrodingCat et al.).

class PBCF_CF_SnowCasterEmitter : Actor
{
	PlayerPawn plr;
	int ttl;

	override void PostBeginPlay()
	{
		Super.PostBeginPlay();
		plr = PlayerPawn(master ? master : target);
		ttl = 35 * 14;
	}

	override void Tick()
	{
		Super.Tick();
		if (!plr || plr.health <= 0)
		{
			Destroy();
			return;
		}
		SetOrigin(plr.pos + (0, 0, plr.viewheight * 0.42), true);
		angle = plr.angle;
		pitch = plr.pitch;
		if ((level.maptime & 7) == 0)
		{
			for (int i = -2; i <= 2; i++)
			{
				double a = angle + i * 9.;
				double ox = cos(a) * 28.;
				double oy = sin(a) * 28.;
				Actor c = Spawn("PBCF_SlowingCloud", (pos.x + ox, pos.y + oy, pos.z + 12.), NO_REPLACE);
				if (c)
				{
					c.target = plr;
					c.angle = a;
					c.VelFromAngle(13., a);
					c.vel.z = -sin(pitch) * 13.;
				}
				double sx = cos(a) * 18.;
				double sy = sin(a) * 18.;
				Actor s = Spawn("PBCF_SnowParticle", (pos.x + sx, pos.y + sy, pos.z + 10.), NO_REPLACE);
				if (s)
				{
					s.target = plr;
					s.VelFromAngle(9., a);
				}
			}
			A_RadiusGive("PBCF_CryocubusSlowdown", 168., RGF_MONSTERS, 12);
		}
		if (--ttl <= 0)
			Destroy();
	}

	Default
	{
		+NOINTERACTION
		+NOBLOCKMAP
	}
}

class PBCF_CF_FreezeBotTurret : PBCF_FriendlyDeployableBase
{
	int ttl;
	int firewait;

	override void PostBeginPlay()
	{
		Super.PostBeginPlay();
		ttl = 35 * 55;
		firewait = 0;
		bFriendly = true;
	}

	Actor PickEnemy(double rad)
	{
		Actor best = null;
		double bd = 1e18;
		let it = BlockThingsIterator.Create(self, rad);
		while (it.Next())
		{
			Actor mo = it.thing;
			if (mo == self || mo == master)
				continue;
			if (!mo.bShootable || mo.health <= 0 || !mo.bIsMonster)
				continue;
			if (!CheckSight(mo))
				continue;
			double d = Distance2D(mo);
			if (d < bd)
			{
				best = mo;
				bd = d;
			}
		}
		return best;
	}

	override void Tick()
	{
		Super.Tick();
		if (health <= 0)
			return;
		if (--ttl <= 0)
		{
			Destroy();
			return;
		}
		if (firewait-- > 0)
			return;
		let tgt = PickEnemy(1728.);
		if (!tgt)
			return;
		target = tgt;
		A_Face(tgt);
		A_SpawnProjectile("PBCF_IceOrbCryo", height * 0.58, 10, 0, CMF_AIMOFFSET);
		firewait = 17;
	}

	Default
	{
		Health 240;
		Radius 18;
		Height 44;
		Mass 140;
		+FRIENDLY
		+SOLID
		+SHOOTABLE
		+STANDSTILL
		Speed 0;
	}

	States
	{
	Spawn:
			FZB1 A 1 Bright;
			Loop;
	Death:
			TNT1 A 0 A_NoBlocking;
			TNT1 AAA 0 A_SpawnItemEx("IceShard1", 0, 0, 18, random(4, 14), random(-10, 10), random(4, 14), random(0, 359), SXF_NOCHECKPOSITION);
			TNT1 A 0 A_SpawnItemEx("CryoSmoke3", 0, 0, 10, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
			Stop;
	}
}

