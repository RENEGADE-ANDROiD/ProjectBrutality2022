class PBCF_CF_IceWallSegment : Actor
{
	int ttl;

	override void PostBeginPlay()
	{
		Super.PostBeginPlay();
		ttl = 35 * 22;
	}

	override void Tick()
	{
		Super.Tick();
		if (health <= 0)
			return;
		if (--ttl <= 0)
		{
			A_NoBlocking();
			A_SpawnItemEx("CryoSmoke3", 0, 0, 8, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
			Destroy();
		}
	}

	Default
	{
		Health 280;
		Radius 24;
		Height 96;
		Mass 400;
		+SOLID
		+SHOOTABLE
		DamageType "Ice";
		Scale 1.2;
	}

	States
	{
	Spawn:
			BXPL A -1;
			Stop;
	Death:
			TNT1 A 0 A_NoBlocking;
			TNT1 AAA 0 A_SpawnItemEx("IceShard1", 0, 0, 24, random(6, 18), random(-12, 12), random(6, 18), random(0, 359), SXF_NOCHECKPOSITION);
			TNT1 A 0 A_SpawnItemEx("CryoSmoke3", 0, 0, 12, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
			Stop;
	}
}

class PBCF_CF_HoloDecoy : PBCF_FriendlyDeployableBase
{
	int ttl;

	override void PostBeginPlay()
	{
		Super.PostBeginPlay();
		ttl = 35 * 24;
		bFriendly = true;
	}

	override void Tick()
	{
		Super.Tick();
		if (--ttl <= 0)
		{
			Destroy();
			return;
		}
		if ((level.maptime & 15) != 0)
			return;
		let it = BlockThingsIterator.Create(self, 1536.);
		while (it.Next())
		{
			Actor mo = it.thing;
			if (!mo || mo == self)
				continue;
			if (!mo.bIsMonster || mo.health <= 0 || mo.player)
				continue;
			if (!mo.bShootable)
				continue;
			mo.target = self;
		}
	}

	Default
	{
		Radius 16;
		Height 56;
		+FRIENDLY
		+SOLID
		RenderStyle "Translucent";
		Alpha 0.65;
	}

	States
	{
	Spawn:
			PLAY E -1;
			Stop;
	Death:
			TNT1 A 0 A_NoBlocking;
			TNT1 A 0 A_SpawnItemEx("CryoSmoke3", 0, 0, 28, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
			Stop;
	}
}

class PBCF_CF_FreezeMine : Actor
{
	bool armed;

	override void PostBeginPlay()
	{
		Super.PostBeginPlay();
		armed = true;
	}

	void DoDetonate()
	{
		if (!armed)
			return;
		armed = false;
		A_PlaySound("FRZFIRE2", CHAN_BODY);
		A_SpawnItemEx("PBCF_CryoWind", 0, 0, 10, 0, 0, 4, random(0, 359), SXF_NOCHECKPOSITION);
		A_RadiusGive("PBCF_CryocubusSlowdown", 216., RGF_MONSTERS, 40);
		// Rocket Jump integration: when pb_rocketjump is enabled, freeze-mine
		// detonation kicks any nearby player + grants PBBlastMomentum (matches
		// PB_PlayerHandGrenadeExplosion / PB_PlayerStickyExplosion behaviour).
		// Triggers from monster-step, shooting the mine (Die() -> DoDetonate),
		// or any other detonation path.
		let cvRJ = CVar.FindCVar("pb_rocketjump");
		if (cvRJ && cvRJ.GetInt())
		{
			A_RadiusThrust(900, 280, RTF_AFFECTSOURCE | RTF_THRUSTZ | RTF_NOIMPACTDAMAGE);
			A_RadiusGive("PBBlastMomentum", 280, RGF_PLAYERS | RGF_CUBE, 30);
		}
		A_SpawnItemEx("CryoSmoke3", 0, 0, 4, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		A_NoBlocking();
		Destroy();
	}

	override void Tick()
	{
		Super.Tick();
		if (!armed || health <= 0)
			return;
		let it = BlockThingsIterator.Create(self, 72.);
		while (it.Next())
		{
			Actor mo = it.thing;
			if (!mo || mo == master)
				continue;
			if (mo.player)
				continue;
			if (!mo.bShootable || mo.health <= 0)
				continue;
			DoDetonate();
			return;
		}
	}

	override void Die(Actor source, Actor inflictor, int dmgflags)
	{
		if (armed)
			DoDetonate();
		else
			Super.Die(source, inflictor, dmgflags);
	}

	Default
	{
		Radius 12;
		Height 10;
		Health 14;
		Mass 60;
		+SOLID
		+SHOOTABLE
		DamageType "Ice";
	}

	States
	{
	Spawn:
			FZBL A -1;
			Stop;
	Death:
			TNT1 A 0;
			Stop;
	}
}
