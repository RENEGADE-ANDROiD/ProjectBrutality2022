//===========================================================================
//
// Tilt++.pk3
//
// Unified player camera tilting for strafing, moving, swimming and death
//
// Written by Nash Muhandes
//
// Feel free to use this in your mods. No need to ask for my permission!
//
//===========================================================================

class TiltPlusPlusHandler : EventHandler
{
	override void PlayerEntered(PlayerEvent e)
	{
		if (!e) return;
		int pn = e.PlayerNumber;
		if (pn < 0 || pn >= MAXPLAYERS || !playeringame[pn]) return;
		let pmo = players[pn].mo;
		if (!pmo) return;
		pmo.A_GiveInventory("Z_TiltMe", 1);
	}
}

class Z_TiltMe : CustomInventory
{
	Default
	{
		Inventory.MaxAmount 1;
		+INVENTORY.UNDROPPABLE
		+INVENTORY.UNTOSSABLE
		+INVENTORY.AUTOACTIVATE
	}

	double strafeInput;
	double moveTiltOsc, underwaterTiltOsc;
	double deathTiltOsc;
	double deathTiltAngle;
	double lastRoll;
	double dashRollMul;

	override void BeginPlay()
	{
		Super.BeginPlay();
		dashRollMul = 1.;
	}

	//===========================================================================
	//
	//
	//
	//===========================================================================

	bool bIsOnFloor (void)
	{
		if (!Owner) return false;
		let pp = PlayerPawn(Owner);
		if (pp && pp.player)
			return pp.player.OnGround || Owner.bOnMObj;
		return (Owner.Pos.Z <= Owner.FloorZ + 0.5) || Owner.bOnMObj;
	}

	bool bIsCrouching (void)
	{
		return Owner && Owner.player && Owner.player.mo
			&& Owner.GetCameraHeight() <= (Owner.player.mo.ViewHeight / 2);
	}

	double GetVelocity (void)
	{
		return Owner ? Owner.Vel.Length() : 0.;
	}

	int GetWaterLevel (void)
	{
		return Owner ? Owner.WaterLevel : 0;
	}

	bool bIsPlayerAlive (void)
	{
		return Owner && Owner.Health > 0;
	}

	//===========================================================================
	//
	//
	//
	//===========================================================================
	void Tilt_CalcViewRoll (void)
	{
		if (!Owner || !Owner.player)
			return;
		// CVARS ///////////////////////////////////////////////////////////////
		bool strafeTiltEnabled = sv_strafetilt;
		bool moveTiltEnabled = sv_movetilt;
		bool turnTiltEnabled = sv_turntilt;
		bool underwaterTiltEnabled = sv_underwatertilt;
		bool deathTiltEnabled = sv_deathtilt;

		double strafeTiltSpeed = sv_strafetiltspeed;
		double strafeTiltAngle = sv_strafetiltangle;
		bool strafeTiltReversed = sv_strafetiltinvert;

		double moveTiltScalar = sv_movetiltscalar;
		double moveTiltAngle = sv_movetiltangle;
		double moveTiltSpeed = sv_movetiltspeed;

		double turnTiltScalar = sv_turntiltscalar;
		bool turnTiltReversed = sv_turntiltinvert;

		double underwaterTiltSpeed = sv_underwatertiltspeed;
		double underwaterTiltAngle = sv_underwatertiltangle;
		double underwaterTiltScalar = sv_underwatertiltscalar;

		//===========================================================================
		//
		// Strafe Tilting
		//
		//===========================================================================

		// normalized strafe input (lerp toward target to avoid view-roll steps on direction change)
		double targetStrafe = 0.;
		if (strafeTiltEnabled && bIsOnFloor() && bIsPlayerAlive())
		{
			int dir;
			if (strafeTiltReversed) dir = -1;
			else dir = 1;
			targetStrafe = strafeTiltSpeed * (Owner.GetPlayerInput(MODINPUT_SIDEMOVE) / 10240.0);
			targetStrafe *= strafeTiltAngle;
			targetStrafe *= dir;
		}
		strafeInput += (targetStrafe - strafeInput) * 0.22;

		if (Owner.CheckInventory("PlayerDashed", 1))
			dashRollMul += (5.0 - dashRollMul) * 0.20;
		else
			dashRollMul += (1.0 - dashRollMul) * 0.20;

		lastRoll += dashRollMul * strafeInput;

		//===========================================================================
		//
		// Movement Tilting
		//
		//===========================================================================

		double rollMove = 0.;
		if (moveTiltEnabled && bIsOnFloor() && bIsPlayerAlive())
		{
			double v = GetVelocity() * moveTiltScalar;

			moveTiltOsc += moveTiltSpeed;

			if (moveTiltOsc >= 360. || moveTiltOsc < 0.)
			{
				moveTiltOsc = 0.;
			}

			rollMove = Sin(moveTiltOsc);
			rollMove *= moveTiltAngle;
			rollMove *= v;
		}

		lastRoll += rollMove;

		//===========================================================================
		//
		// Turn Tilting
		//
		//===========================================================================

		double rollTurn = 0.;
		if (turnTiltEnabled && bIsPlayerAlive() && !Owner.CheckInventory("PlayerWheelOpen", 1))
		{
			double xinput = PlayerPawn(Owner).GetPlayerInput(MODINPUT_YAW) * (turnTiltReversed ? -1 : 1);
			xinput = turnTiltScalar * xinput / 32767.0;
			rollTurn = xinput;
		}

		lastRoll += rollTurn;

		//===========================================================================
		//
		// Underwater Tilting
		//
		//===========================================================================

		double rollUnderwater = 0.;
		if (GetWaterLevel() >= 3 && underwaterTiltEnabled)
		{
			double v = 15. * underwaterTiltScalar;

			underwaterTiltOsc += underwaterTiltSpeed;

			if (underwaterTiltOsc >= 360. || underwaterTiltOsc < 0.)
			{
				underwaterTiltOsc = 0.;
			}

			rollUnderwater = Sin(underwaterTiltOsc);
			rollUnderwater *= underwaterTiltAngle;
			rollUnderwater *= v;
		}

		lastRoll += rollUnderwater;

		//===========================================================================
		//
		// Death Tilting
		//
		//===========================================================================

		double rollDeath = 0.;
		if (!bIsPlayerAlive() && deathTiltEnabled)
		{
			double deathTiltSpeed = 1.0;

			if (deathTiltAngle == 0)
			{
				deathTiltAngle = -90.f;
				deathTiltAngle += FRandom(-45.f, 45.f);
				deathTiltAngle *= RandomPick(-1, 1);
			}

			if (deathTiltOsc < 22.5)
			{
				deathTiltOsc += deathTiltSpeed;
			}

			rollDeath = Sin(deathTiltOsc);
			rollDeath *= deathTiltAngle;
		}
	//		deathTiltOsc = 0;
	//		deathTiltAngle = 0;

		lastRoll += rollDeath;

		//===========================================================================
		//
		// Tilt Post Processing
		//
		//===========================================================================

		if (abs(lastRoll) > 0.000001)
		{
			// Stabilize tilt
			lastRoll *= 0.75;
		}

		// Tactical lean is the base (PB_WeaponTilterInventory.leanRoll); Tilt++ stacks lastRoll on top.
		double leanBase = 0.;
		let tacInv = Owner.FindInventory("PB_WeaponTilterInventory");
		if (tacInv)
		{
			let tac = PB_WeaponTilterInventory(tacInv);
			if (tac) leanBase = tac.leanRoll;
		}
		Owner.A_SetRoll(leanBase + lastRoll, SPF_INTERPOLATE);
	}

	override void Tick(void)
	{
		if (Owner && Owner is "PlayerPawn") //&& !Owner.CheckInventory("PB_LockScreenTilt",1)) always do viewroll stuff
		{
			Tilt_CalcViewRoll();
		}

		Super.Tick();
	}

	//===========================================================================
	//
	//
	//
	//===========================================================================
	States
	{
	Use:
		TNT1 A 0;
		Fail;
	Pickup:
		TNT1 A 0
		{
			return true;
		}
		Stop;
	}
}
