//===========================================================================
// SNDINFO.MonsterPack
// Merged from Monster Pack Add-On/SNDINFO.txt.
// GZDoom auto-loads every `SNDINFO*` lump; no include line needed.
// The following four logical names collided with identical definitions in
// SNDINFO.PBMonsters and have been commented out here to keep one authority:
//   aracnorb/sight, aracnorb/death, aracnorb/melee, monster/heltel.
// NOTE: the original MP add-on file redefines ZPTank/{see,pain,death,Run,explode}
// twice within itself (once for Zombieplasmatank, once for Zombietankelite).
// That behavior is preserved as-is; GZDoom will silently accept the second
// binding as the winning one — identical to external-load behavior.
//===========================================================================
//Horrorspawn

$random Horrorspawn/Step { Horrorspawn/Step1 Horrorspawn/Step2 Horrorspawn/Step3 Horrorspawn/Step4 Horrorspawn/Step5 Horrorspawn/Step6 Horrorspawn/Step7 Horrorspawn/Step8 Horrorspawn/Step9 }
Horrorspawn/Step1 "Sounds/Monsters/Horrorspawn/HorrorspawnStep1"
Horrorspawn/Step2 "Sounds/Monsters/Horrorspawn/HorrorspawnStep2"
Horrorspawn/Step3 "Sounds/Monsters/Horrorspawn/HorrorspawnStep3"
Horrorspawn/Step4 "Sounds/Monsters/Horrorspawn/HorrorspawnStep4"
Horrorspawn/Step5 "Sounds/Monsters/Horrorspawn/HorrorspawnStep5"
Horrorspawn/Step6 "Sounds/Monsters/Horrorspawn/HorrorspawnStep6"
Horrorspawn/Step7 "Sounds/Monsters/Horrorspawn/HorrorspawnStep7"
Horrorspawn/Step8 "Sounds/Monsters/Horrorspawn/HorrorspawnStep8"
Horrorspawn/Step9 "Sounds/Monsters/Horrorspawn/HorrorspawnStep9"

$rolloff Horrorspawn/Step 100 800

$volume Horrorspawn/Step 0.6

$random ZombieFodder/Sight { FODDSEE1 FODDSEE2 FODDSEE3 FODDSEE4 FODDSEE5 FODDSEE6 FODDSEE7 }
FODDSEE1 FODDSEE1
FODDSEE2 FODDSEE2
FODDSEE3 FODDSEE4
FODDSEE4 FODDSEE4
FODDSEE5 FODDSEE5
FODDSEE6 FODDSEE6
FODDSEE7 FODDSEE7

$random ZombieFodder/Roar { FODDSEE3 FODDSEE4 FODDSEE5 FODDSEE6 FODDSEE7 }

$random ZombieFodder/Active { FODDERACT1 FODDERACT2 }
FODDERACT1	FODDACT1
FODDERACT2	FODDACT2

ZombieFodder/Pain	FODDPAIN

$random ZombieFodder/Death { FODDERDIE1 FODDERDIE2 }
FODDERDIE1	FODDDIE1
FODDERDIE2	FODDDIE2

ZombieFodder/Melee DSCLAW
ZFODDGIB ZFODDGIB

$volume ZombieFodder/Sight 0.8
$volume ZombieFodder/Active 0.7
$volume ZombieFodder/Pain 0.8
$volume ZombieFodder/Death 0.6

//Hunger
$random Hunger/Sight { HUNSEE1 HUNSEE2 }
HUNSEE1	HUNSEE1
HUNSEE2	HUNSEE2
HUNSEE3 HUNSEE3
HUNSEE4 HUNSEE4
HUNSEE5 HUNSEE5
HUNSEE6 HUNSEE6
HUNHOW HUNHOW
$volume Hunger/Sight 0.5

$random Hunger/Spawn { HUNSPA1 HUNSPA2 HUNSPA3 HUNSPA4 }
HUNSPA1 HUNSPA2
HUNSPA2 HUNSPA2
HUNSPA3 HUNSPA3
HUNSPA4 HUNSPA4
$volume Hunger/spawn 0.5

$random Hunger/roar { HUNHOW1 HUNHOW2 HUNHOW3 HUNHOW4 }
HUNHOW1 HUNHOW1
HUNHOW2 HUNHOW2
HUNHOW3 HUNHOW3 
HUNHOW4 HUNHOW4
$volume Hunger/roar 0.5

$random Hunger/Active { HUNACT1 HUNACT2 HUNACT3 HUNACT4 HUNACT5 HUNACT6 HUNSEE1 HUNSEE2 }
HUNACT1	HUNACT1
HUNACT2	HUNACT2
HUNACT3	HUNACT3
HUNACT4	HUNACT4
HUNACT5	HUNACT5
HUNACT6	HUNACT6
HUNSEE1	HUNSEE1
HUNSEE2	HUNSEE2
$volume Hunger/Active 0.5

$random Hunger/Pain	{ HUNPAI1 HUNPAI2 HUNPAI3 HUNPAI4 HUNPAI5 }
HUNPAI1	HUNPAI1
HUNPAI2 HUNPAI2
HUNPAI3 HUNPAI3
HUNPAI4 HUNPAI4
HUNPAI5 HUNPAI5

$volume HUNPAI5 0.3

$random Hunger/Death { HUNDIE1 HUNDIE2 HUNDIE3 }
HUNDIE1	HUNDIE1
HUNDIE2	HUNDIE2
HUNDIE3 HUNDIE3

$volume Hunger/Death 1
$volume HUNDIE3 0.15

$random Hunger/Idle { HUNIDL1 HUNIDL2 HUNIDL3 HUNIDL4  }
HUNIDL1 HUNIDL1 
HUNIDL2 HUNIDL2
HUNIDL3 HUNIDL3
HUNIDL4 HUNIDL4
$volume Hunger/Idle 0.3

Flying/Fly FLYING

//Fresh Horrorspawn
$random FOD2ACT { FOD2ACT1 FOD2ACT2 FOD2ACT3 FOD2ACT4 }
FOD2ACT1 FOD2ACT1
FOD2ACT2 FOD2ACT2
FOD2ACT3 FOD2ACT3
FOD2ACT4 FOD2ACT4

FOD2SEE FOD2SEE

FOD2PAI FOD2PAI

