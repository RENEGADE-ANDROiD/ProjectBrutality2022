ACTOR PB_CF_SnowCasterAmmo : Ammo
{
	Inventory.Amount 1
	Inventory.MaxAmount 6
	Ammo.BackpackAmount 2
	Ammo.BackpackMaxAmount 8
	Inventory.Icon "BXPLA0"
	Inventory.PickupMessage ""
	+INVENTORY.IGNORESKILL
}

