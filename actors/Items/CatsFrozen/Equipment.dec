ACTOR PB_CF_SnowCasterPickup : PB_CF_SnowCasterAmmo
{
	//$Category Ammunition
	Inventory.PickupMessage "$PB_PICKUP_PB_CF_SNOWCASTER"
	Inventory.PickUpSound "BACKPACK"
	Scale 0.55
	States
	{
	Spawn:
		TNT1 A 0 A_SpawnItem("BlueFlareMedium", -1, 1)
		BXPL A -1 Bright
		Stop
	Pickup:
		TNT1 A 0 A_GiveInventory("PB_CF_SnowCasterAmmo", 1)
		Stop
	}
}

ACTOR PB_CF_FreezeBotDeployPickup : PB_CF_FreezeBotDeployAmmo
{
	//$Category Ammunition
	Inventory.PickupMessage "$PB_PICKUP_PB_CF_FREEZEBOT"
	Inventory.PickUpSound "Ammocase/Open"
	Scale 0.45
	States
	{
	Spawn:
		FZBL A 1 A_SpawnItem("BlueFlareMedium", -1, 1)
		Loop
	Pickup:
		TNT1 A 0 A_GiveInventory("PB_CF_FreezeBotDeployAmmo", 1)
		Stop
	}
}

