ACTOR CrueltyBonushealth_ : Health Replaces CrueltyBonushealth
{
	Game Doom
	SpawnID 152
	-COUNTITEM
	+BOUNCEONWALLS
	+BOUNCEONCEILINGS
	+BOUNCEONFLOORS
	+FORCEXYBILLBOARD
	+THRUACTORS
	Radius 5
	Scale 0.75
	+INVENTORY.ALWAYSPICKUP
	Inventory.Amount 1
	Inventory.MaxAmount 9999
	Inventory.PickupMessage "*** Brutality Bonus awarded! +1 health ***"
	States
	{
	Spawn:
		TNT1 A 0
		TNT1 A 0 A_ChangeFlag("THRUACTORS", 0)
	Fade:
		1BON A 3
		1BON A 3 Bright A_FadeOut(0.01)
		Loop
	}
}

ACTOR CrueltyBonusArmor_ : BasicArmorBonus
{
	Game Doom
	SpawnID 152
	-COUNTITEM
	+BOUNCEONWALLS
	+BOUNCEONCEILINGS
	+BOUNCEONFLOORS
	+FORCEXYBILLBOARD
	+THRUACTORS
	Radius 5
	Scale 0.75
	+INVENTORY.ALWAYSPICKUP
	Inventory.Icon "BON2A0"
	Armor.Savepercent 33.335
	Armor.Saveamount 1
	Armor.Maxsaveamount 9999
	Inventory.PickupMessage "*** Brutality Bonus awarded! +1 Armor ***"
	States
	{
	Spawn:
		TNT1 A 0
		TNT1 A 0 A_ChangeVelocity(frandom(-3, 3), frandom(-3, 3), frandom(5, 15))
		TNT1 A 0 A_ChangeFlag("THRUACTORS", 0)
	Fade:
		1BON B 3
		1BON B 3 Bright A_FadeOut(0.01)
		Loop
	}
}
