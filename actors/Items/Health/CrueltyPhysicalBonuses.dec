// PB_PhysicalBonuses — bouncy 1BON shards for Cruelty bonus drops (replaces abstract pickups in GenericHealth.dec)

ACTOR TauntSnd : SwitchableDecoration
{
	-SOLID
	+NOINTERACTION
	+THRUACTORS
	+THRUSPECIES
	Radius 220
	States
	{
	Spawn:
		TNT1 A 0
		TNT1 A 0 A_PlaySound("TAUNT0", 0)
		TNT1 A 50
		Stop
	}
}

ACTOR CrueltyBonus1HealthSpawner : SwitchableDecoration REPLACES CrueltyBonus1health
{
	-SOLID
	+NOINTERACTION
	+THRUACTORS
	+THRUSPECIES
	Radius 1
	States
	{
	Spawn:
		TNT1 A 0
		TNT1 A 0 A_SpawnItemEx("CrueltyBonushealth_",0,0,0,frandom(-3,3),frandom(-3,3),frandom(15,25),random(0,360),SXF_NOCHECKPOSITION)
		Stop
	}
}

