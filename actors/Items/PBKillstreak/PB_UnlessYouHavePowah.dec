// Legacy Familiar fire projectile -- left in place for back-compat / save-game
// references. The active drone-summon helper now fires FriendlyDroneShot below.
ACTOR FamiliarFireball
{
	Speed 15
	FastSpeed 20
	Radius 10
	Height 6
	Mass 5
	Damage 15
	DamageType "Fire"
	Projectile
	RenderStyle Add
	Decal "FireDemonScorch"
	SeeSound "familiar/attack"
	DeathSound "familiar/hit"
	States
	{
	Spawn:
		FAMB A 5 Bright
		Loop
	Death:
		FAMB BCDE 5 Bright
		Stop
	}
}

// Drone-themed plasma fired by the friendly Familiar/Drone helper. Visual is
// Shadesmaster's DROS plasma (same lump set used by Realm667_DroneShot), but
// the damage is the original Familiar's 15 so combat utility is preserved.
// MTHRUSPECIES + Species "FriendlyDrone" lets multiple deployed drones share
// a fire arc without shooting each other.
ACTOR FriendlyDroneShot
{
	Speed 18
	FastSpeed 24
	Radius 6
	Height 6
	Mass 5
	Damage 15
	Projectile
	+RANDOMIZE
	+MTHRUSPECIES
	Species "FriendlyDrone"
	RenderStyle Add
	Scale 0.5
	SeeSound "drone/fire"
	States
	{
	Spawn:
		DROS ABAB 3 Bright
		Loop
	Death:
		DROS CDEFGH 4 Bright
		Stop
	}
}

// Drone summon orb -- kept as class name "FamiliarSummon" so kill-streak pool,
// menu / cvar plumbing, and existing saves all keep working unchanged. The orb
// pickup uses the legacy FAMS sphere art (the magic catalyst); using it deploys
// a friendly Drone that fights alongside the player.
Actor FamiliarSummon : CustomInventory
{
	//$Title "Drone Summon Sphere"
	//$Category Powerups
	Radius 12
	Height 20
	+INVENTORY.INVBAR
	+INVENTORY.FANCYPICKUPSOUND
	+COUNTITEM
	+INVENTORY.AUTOACTIVATE
	+INVENTORY.ALWAYSPICKUP
	Inventory.MaxAmount 5
	Inventory.InterHubAmount 5
	Inventory.Icon "FAMSZ0"
	Inventory.PickupMessage "Drone Summon Sphere"
	Inventory.PickupSound "misc/p_pkup"
	states
	{
	Spawn:
		FAMS ABCDCB 4 bright
		loop
	Use:
		TNT1 A 0 A_SpawnItemEx("FamiliarSummonThrown", 0, 0, 32, 20, 0, 0, 0, SXF_NOCHECKPOSITION) 
		TNT1 A 0 A_PlaySound("familiar/throw")
    Stop
 	}
}

//this is the projectile that "spawns" the familiar when it lands
Actor FamiliarSummonThrown
{
	Speed 20
	+NOBLOCKMAP
	+DROPOFF
	+MISSILE
	+NOTELEPORT
	+MTHRUSPECIES
	SeeSound "familiar/throw"
	DeathSound "familiar/spawn"
	States
	{
	Spawn:
		FAMS ABCDCB 4 bright
		Loop
	Death:
		FAMS AA 4 bright
	SpawnCheck:
		FAMS A 4 bright
		TNT1 A 0 A_JumpIfCloser(40, "SpawnCheck")
		// Spawn the drone 24 mu above the orb's landing position so it doesn't
		// start with its bottom flush against the floor (FAMS orb arcs down due
		// to gravity and usually dies right at floor level). The remaining lift
		// to player chest height is handled by the velZ pulse in Familiar.Spawn
		// below -- combined, the drone hovers at ~64 mu above floor before
		// +FLOAT/A_Chase takes over and pulls it to the player's z.
		TNT1 A 0 A_SpawnItemEx("Familiar", 0, 0, 24, 0, 0, 0, 0, SXF_NOCHECKPOSITION)
		TNT1 A 0 A_SpawnItemEx("FamiliarSmoke", 0, 0, 0, 0, 0, 0, 0, SXF_NOCHECKPOSITION)
		Stop
  }
}

ACTOR FamiliarSmoke
{
  +NOBLOCKMAP
  +NOGRAVITY
  +NOTELEPORT
  RenderStyle Translucent
  Alpha 0.6
  Scale 0.5
  States
  {
  Spawn:
    FASM ABCDEFGHIJKLMNOPQ 3
    Stop
  }
}
