actor KSFreeze : PowerupGiver
{
	//$Title Haste Sphere
	//$Category Powerups
	//$Sprite HASTA0
	Game Doom
	SpawnID 7210
	inventory.pickupmessage "Killstreak Acquired:  You move faster!"
	inventory.maxamount 0
	powerup.duration -5
	powerup.color "FF FF 00", 0.012
	powerup.type Speed
	-COUNTITEM
	+FloatBob
	+INVENTORY.AUTOACTIVATE
	+INVENTORY.ALWAYSPICKUP
	Inventory.PickupSound "DEM"
	States
	{
	Spawn:
	
	TNT1 AA 0
    HAST AAABBBCCC 2 A_SpawnItem("YellowFlareMedium",0,30)
    Goto Spawn+2
	
	
	
	Pickup:
        TNT1 AAAAAAAAAAAAA 0 A_CustomMissile ("ShinnySmoke", 0, 0, random (0, 360), 2, random (0, 360))
		TNT1 A 0 A_Print ("You got the Haste Sphere. Your body trembles with energy...")
		Stop
	}
}

ACTOR CoffeeTime : PowerupGiver
{
	//$Category Powerups
	//$Sprite PINVA0
	//$Title "Invulnerability sphere"
	Game Doom
	SpawnID 133
	Scale 0.9
	-COUNTITEM
	+INVENTORY.AUTOACTIVATE
	+INVENTORY.ALWAYSPICKUP
	+INVENTORY.BIGPOWERUP
	+FORCEXYBILLBOARD
	Inventory.MaxAmount 0
	Powerup.Type PowerSpeed
	Powerup.Color Gold, 0.03
	Inventory.PickupMessage "I think it's kickin' in !"
	Tag "Coffee Time !"
	States
	{
	Spawn:
		C0FF A -1
		stop
	}
}

Actor TFST : PowerupGiver
{
    -CountItem
    +NoGravity
    +Inventory.AutoActivate
    +Inventory.AlwaysPickup
	+FLOATBOB
	+FORCEXYBILLBOARD
    Inventory.MaxAmount 0
    Powerup.Type "PB_PowerTimeSlow"
    Powerup.Color GoldMap, 0.12
    Inventory.PickupMessage "Time freeze!"
    States
    {
    Spawn:
        TIME ABCD 6 Bright
        Loop
    }
}

