/////////////////////////////Execution Zombie Fresh////////////////////////////////////////////////////

ACTOR PB_Fresh_Execution_1 //Dairo helping To you :)
{
  Scale 1.0
  +FORCEXYBILLBOARD
  +Clientsideonly
  +FLOORCLIP
  +FLOORHUGGER
  -SOLID
  +THRUACTORS
  States
	{
	Spawn:	
		
		// Frame 1: 12 Ticks
		000E A 3 A_FaceMaster
		000E BBC 2 ThrustThingZ(0,50,1,0)
		
		// Frame 2: 8 ticks
		TNT1 A 0 {
		A_ChangeFlag("FLATSPRITE", true);
		}
		000E D 2
		000E DDD 4 
		
		// Frame 3: 8
		000E DDDDD 1
		TNT1 A 0 {
		A_SpawnProjectile ("Teeth", 3, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("Teeth", 3, 0, random (145, 205), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("Teeth", 3, 0, random (145, 205), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("XDeath1", 4, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnItem("BloodSplasher2");
		}
		000E E 3
			
		// Frame 4: 6
		000E E 1
		000E F 5
		
		// Frame 5: 13
		000E G 4 {
		A_StartSound("FOD2PAI", CHAN_BODY);
		A_SpawnProjectile ("Teeth", 3, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("Teeth", 3, 0, random (145, 205), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("Teeth", 3, 0, random (145, 205), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("Teeth", 3, 0, random (145, 205), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("Teeth", 3, 0, random (145, 205), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("PB_BloodMistLarge", 4, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (20, 90));
		A_SpawnProjectile ("XDeath1", 4, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("XDeath1", 4, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnProjectile ("XDeath1", 4, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		A_SpawnItem("BloodSplasher2");
		}
		000E GGGHHHIII 1
		
		// Frame 6: 13
		000E HHHIIIHHH 1
		TNT1 A 0 {
		A_StopSound(CHAN_BODY);
		A_SpawnProjectile ("ImpHeadExplode", 3, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
		}
		000E JJJJJJ 1
		
		// Frame 7: 14
		000E J 16
		TNT1 A 0 A_SpawnItemEx("GlorySawPinataPretty",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360))
		//TNT1 A 0 A_SpawnItem ("CrueltyBonus5Health")
		TNT1 A 0 A_SpawnItem("DeadExecutionFresh")
	Stop
		}
 }
 
ACTOR PB_Fresh_Execution_2 //Dairo helping To you :)
{
  Scale 1.0
  +FORCEXYBILLBOARD
  +Clientsideonly
  +FLOORCLIP
  +FLOORHUGGER
  -SOLID
  +THRUACTORS
  States
	{
	Spawn:
		000E L 14 A_FaceMaster
		TNT1 AA 0 A_CustomMissile ("Brutal_Blood", 25, 0, random (140, 230), 2, random (30, 60))
		TNT1 AA 0 A_CustomMissile ("BloodmistBig", 30, 0, random (0, 360), 2, random (30, 150))
		TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBlood", 50, 0, random (160, 200), 2, random (0, 50))
		ZFO1 H 15 A_FaceMaster
		TNT1 AA 0 A_CustomMissile ("Brutal_Blood", 25, 0, random (140, 230), 2, random (30, 60))
		TNT1 AA 0 A_CustomMissile ("BloodmistBig", 30, 0, random (0, 360), 2, random (30, 150))
		TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBlood", 50, 0, random (160, 200), 2, random (0, 50))
		ZFO1 BBBB 3 A_FaceMaster
		ZFO1 BBB 1 A_FaceMaster
		ZFOB BBB 1 A_FaceMaster
		ZFOB BB 1 A_FaceMaster
		TNT1 A 0 A_PlaySound("player/cyborg/fist", 3)
		NULL A 0 A_PlaySound("misc/xdeath2")
		TNT1 A 0 A_CustomMissile("XDeathPB_FreshHorrorspawnHead", 50, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("Brutal_Blood", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("BloodmistBig", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
		XXXX A 0 A_CustomMissile ("ShakeYourAssMinor", 1, 0, random (360, 360), 2, random (0, 160))
		ZFOB AAA 1 
		ZFOB AAAAAAAA 1
		TNT1 A 0 A_SpawnItemEx("GlorySawPinataPretty",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360))
		XXXX A 0 A_CustomMissile ("ShakeShakeShake", 1, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("PlayerFlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("PB_SmallGib", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("Instestin", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("XDeath1", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("XDeathHorrorArm", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("Xdeath3", 16, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("NashGoreBloodSpurt", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("PB_SuperWallRedBlood", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("BloodMistBig", 40, 0, random (170, 190), 2, random (0, 40))
		//TNT1 A 0 A_SpawnItem ("CrueltyBonus5Health")
	Stop
		}
 }
 
ACTOR PB_Fresh_Execution_3
{
  Scale 1.0
  +NOINTERACTION
  +FORCEXYBILLBOARD
  +Clientsideonly
  Radius 12
  States
    {
	Spawn:
	
		// Frame 1: 12 Ticks
		000E A 4 A_FaceMaster
		TNT1 A 0 A_StartSound("FOD2PAI", CHAN_BODY )
		000E BM 3  
		TNT1 A 0 A_ChangeFlag("NOINTERACTION", False)
		000E PPP 1 A_Recoil(-15)
		
