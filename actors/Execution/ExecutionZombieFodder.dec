	Stop
		}
 }
 
/////////////////////////////////Execution Zombie Fodder/////////////////////////////////////////

ACTOR PB_Fodder_Execution_1 : PB_Fresh_Execution_1
{
  States
	{
	Spawn:	
		
		// Frame 1: 12 Ticks
		ZFOD A 3 A_FaceMaster
		000E QQR 2 ThrustThingZ(0,50,1,0)
		
		// Frame 2: 8 ticks
		TNT1 A 0 {
		A_ChangeFlag("FLATSPRITE", true);
		}
		000E S 2
		000E SSS 4 
		
		// Frame 3: 8
		000E SSSSS 1
		TNT1 A 0 {
		A_SpawnProjectile ("Teeth", 3, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
