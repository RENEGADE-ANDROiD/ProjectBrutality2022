		TNT1 AAAAA 0 A_SpawnProjectile ("PB_BloodMistBig", 40, 0, random (0, 360), 2, random (30, 90))
		TNT1 AA 0 A_SpawnProjectile ("MuchBlood", 50, 0, random (0, 360), 2, random (0, 160))


		TNT1 AAAA 0 A_SpawnProjectile("RahovartExPart1", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 AA 0 A_SpawnProjectile("RahovartExPart2", 32, 0, random (0, 360), 2, random (0, 160))
