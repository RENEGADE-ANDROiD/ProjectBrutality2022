		TNT1 A 0 A_SpawnProjectile("RahovartExPart5", 32, 0, random (0, 360), 2, random (0, 160))
		//TNT1 A 0 A_SpawnProjectile("RahovartExPart6", 32, 0, random (0, 360), 2, random (0, 160))

		EXPL A 0 A_SpawnItemEx("ExplosionParticleSpawner", 0, 0, 0, 0, 0, 0, 0, 128)
		EXPL AAAAAAAAAAAAAAAAA 0 A_SpawnProjectile("FireBallExplosion", 6, 0, random (0, 360), 2, random (0, 360))

		TNT1 A 0 A_SpawnProjectile("ExplosionSmoke", 1, 0, random (0, 360), 2, random (70, 110))
