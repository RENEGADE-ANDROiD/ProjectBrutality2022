					return state(0);
				}
			}
			return state(0);
		}
		Goto See
	Stagger:
		CYUS J 0 
		{
			if(getcvar(be_ExecutionHighlight)==1)
			{	return state("PrepareStaggerHighlight");}
			else
			{	return state("StagLooper");	}
		}
		Goto StagLooper
	PrepareStaggerHighlight:
		CYGS J 0
