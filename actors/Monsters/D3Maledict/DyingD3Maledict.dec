Actor Gib_WingD3Maledict: LimbBase
{
  damagefactor "Kick", 9.0
  damagefactor "Melee", 9.0
  damagefactor "SuperPunch", 9.0
  -CLIENTSIDEONLY
  Radius 10
  Mass 10
  Health 60
  Scale 1.0
  States
	{
	Spawn:
		TNT1 A 0
		D3MI F -1
	Loop

	Pain:
		TNT1 A 0 A_Changeflag ("ROLLSPRITE", 1)
		TNT1 A 0 ThrustThingZ(0,20,0,1)
		D3MI E 6 {A_SetRoll(random(0,360));}
		TNT1 A 0 A_Changeflag ("ROLLSPRITE", 0)
	Goto Spawn

	XDeath:
	Death:
	Death.fire:
	Death.burn:
	Death.flames:
	Death.Plasma:
	Death.Incinerate:
	Death.SuperPlasma:
	Death.Desintegrate:
	Death.Crush:
		TNT1 AAAAAAAA 0 A_CustomMissile ("Brutal_FlyingBloodTrail5", 0, 0, random (0, 360), 2, random (60, 140))
		TNT1 A 0 A_PlaySound("misc/xdeath4")
		CRS1 A 5
		CRS1 A 9009
	Stop

	Death.Melee:
	Death.SuperPunch:
	Death.Kick:
		D3MI F 1 A_FaceTarget
		TNT1 A 0 A_PlaySound("player/cyborg/fist", 3)
	Death.ExplosiveImpact:
		TNT1 A 0 A_Changeflag ("ROLLSPRITE", 1)
		TNT1 A 0 A_ChangeFlag("NOBLOCKMAP", 0)
		TNT1 A 0 ThrustThingZ(0,50,0,1)
		D3MI E 6 {A_SetRoll(random(0,360));}
		D3MI E 3 A_CheckFloor("Landz")
	Goto Landz

	Landz:
		TNT1 A 0 A_Changeflag ("ROLLSPRITE", 0)
		TNT1 A 0 A_SpawnItem("Gib_WingD3Maledict")
	Stop

	Death.Trample:
	Death.Stomp:
		TNT1 A 0 A_GiveToTarget("BootsSmearedWithRedBlood", 6)
	Goto Death

	Death.plasma:
	Death.Burn:
	Death.Flames:
