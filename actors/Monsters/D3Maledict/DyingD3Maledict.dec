ACTOR LilD3Maledict
{
  Radius 3
  Height 3
  Speed 2
  Health 5
  Scale 0.2
  DamageFactor "Kick", 6.0
  DamageFactor "Shrink", 0.0
  DamageFactor "bloodsplasher", 0.0    DamageFactor "tinybloodsplasher", 0.0    DamageFactor "superbloodsplasher", 0.0    DamageFactor "smallbloodsplasher", 0.0
  DamageFactor "BlueBloodSplasher", 0.0
  DamageFactor "BlueSuperBloodSplasher", 0.0
  PainChance "Kick", 255
  PainChance "SuperKick", 255
  DamageFactor "trample", 2.0
  DamageFactor "Avoid", 0.0
  damagefactor "killme", 0.0
  +SHOOTABLE
  +FLOORCLIP
  +LOOKALLAROUND
  +FRIGHTENED
  +SOLID
  States
	{
	Spawn:
		D3MA A 1 A_Look
	See:
		D3MA AABBCCDD 2 A_Wander
	Loop
			
	Death:
	XDeath:
		TNT1 A 0 A_Playsound("misc/xdeath3", 2)
		TNT1 A 0 A_CustomMissile ("Brutal_LiquidBlood2", 2, 0, random (0, 360), 2, random (60, 120))
		TNT1 AA 0 A_CustomMissile ("MuchBlood2", 3, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_SpawnItem ("XDeath2", 1, 3)
		TNT1 A 0 A_SpawnItem ("GrowingBloodPool", 1)
	Stop
		}
 }