Actor DeadD3Maledict
{
  damagefactor "Blood", 0.0
  damagefactor "Trample", 0.0
  damagefactor "Melee", 10.0
  damagefactor "Fatality", 10.0
  damagefactor "Kick", 10.0
  +CORPSE
  +SHOOTABLE
  +SOLID
  +THRUACTORS
  Scale 1.0
  Radius 40
  Height 22
  Health 500
  States
	{
	Spawn:
		TNT1 A 0
		D3MF W -1
	Stop

	Death:
	XDeath:
	Death.Disintegrate:
	Death.Stomp:
	Death.CrushedBodies:
	Death.Crush:
	Crush:
	Death.Fatality:
	Death.Melee:
	Death.Kick:
	Death.Extremepunches:
		TNT1 AAAAAAAAAA 0 A_SpawnItemEX("NashgoreGibs", 0, 0, 0, random (4, 12), 0, random (4, 12), random(0, 360))
		TNT1 A 0 A_CustomMissile ("XDeathHeadD3Maledict", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 AA 0 A_CustomMissile ("XDeathWingD3Maledict", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 AA 0 A_CustomMissile ("XDeathFeetD3Maledict", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("XDeathTailD3Maledict", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("XDeathHumpD3Maledict", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 AAAA 0 A_CustomMissile ("PB_SmallGib", 32, 0, random(0,360), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("MeatDeath", 0, 0, random (0, 360), 2, random (0, 160))
		TNT1 AA 0 A_CustomMissile ("MeatDeathsmall", 0, 0, random (0, 360), 2, random (0, 160))
		TNT1 AAA 0 A_CustomMissile ("Instestin", 32, 0, random(0,360), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("XDeath1", 42, 0, random(0,360), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("Xdeath3", 26, 0, random(0,360), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("NashGoreBloodSpurt", 32, 0, random(0,360), 2, random (0, 40))
	Stop

	Death.Plasma: Death.Plasma2:
	Death.Flames:
	Death.Burn:
		TNT1 AAAAAA 0 A_SpawnItemEx("TinyBurningPiece2", random (-15, 15), random (-15, 15))
		TNT1 AAAAAA 0 A_SpawnItemEx("TinyBurningPiece3", random (-15, 15), random (-15, 15))
		TNT1 AAAAAA 0 A_CustomMissile ("Brutal_FlyingBlood", 50, 0, random (0, 360), 2, random (0, 160))
		TNT1 AA 0 A_SpawnProjectile ("XDeathBurnedMeat", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 AA 0 A_SpawnProjectile ("XDeathBurnedMeat2", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 AA 0 A_SpawnProjectile ("XDeathBurnedMeat3", 32, 0, random (0, 360), 2, random (0, 160))
		TNT1 AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA 6 A_CustomMissile ("PlasmaSmoke", 16, 0, random (0, 180), 2, random (0, 180))
	Stop

	Death.TeleportRemover:
	Death.GibRemoving:
		TNT1 A 0
		TNT1 A 0 A_Scream
		TNT1 A 0 A_NoBlocking
		TNT1 A 0 A_ChangeFlag("NOCLIP", 1)
		TNT1 A 0 A_ChangeFlag("SHOOTABLE", 0)
		TNT1 A 0 A_ChangeFlag("NOBLOCKMAP", 1)
	Stop	

	}
}




//HalfUpperbody
//Horizontal saw
Actor RipHalfD3MaledictUpper: DeadD3Maledict
{
  Radius 8
  Height 8
  Speed 7
  Mass 8
  BounceFActor 0.2
  +DOOMBOUNCE
  +NOBLOCKMAP
  +MISSILE
  +NOTELEPORT
  +DONTSPLASH
  +MOVEWITHSECTOR
  DeathSound "misc/xdeath1"
  Decal BrutalBloodSplat
  Scale 1.0
  States
	{
	Spawn:
		TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
		TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
		D3ML GH 12 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
	Loop
		
	Death:
		TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
		TNT1 A 0 A_SpawnItem("RipHalfD3MaledictUpperGib")
	Stop
	}
}

Actor RipHalfD3MaledictUpperGib: DeadD3Maledict
{
  Scale 1.0
  -CORPSE
  States
	{
	Spawn:
		TNT1 A 0
		D3ML I 1 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
		D3ML I -1
	Stop

	Death:
	XDeath:
	Death.Fatality:
	Death.Melee:
	Death.Kick:
	Death.Extremepunches:
