ACTOR FrozenEnemyBase
{
	DamageFactor "IceBeam", 0.0
	Health 1000
	Mass 2000
	+SOLID
	+SHOOTABLE
	+NOBLOOD
	States
	{
	Spawn:
		TNT1 A -1
		Wait
	}
}

Actor XDeathHeadD3Maledict: XDeathBullArm1
{
  -CLIENTSIDEONLY
  +ROLLSPRITE
  Radius 20
  Scale 1.0
  States
	{
	Spawn:
		TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
		TNT1 A 0 A_JumpIf(momz == 0, "Death")
		D3MI AAAAAAA 3 A_SetRoll(roll-25)
	Loop

	Death:
		TNT1 A 0 A_ChangeFlag("ROLLSPRITE", 0)
		TNT1 A 0 A_SpawnItem("HeadD3Maledict",0,0,0,1)
	Stop
	}
}

Actor HeadD3Maledict: LimbBase
{
  damagefactor "Kick", 9.0
  damagefactor "Melee", 9.0
  damagefactor "SuperPunch", 9.0
  -CLIENTSIDEONLY
  Radius 20
  Mass 10
  Health 60
  Scale 1.0
  States
	{
	Spawn:
		TNT1 A 0 
		D3MI B 1 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
		D3MI B -1
	Stop

	Death.Trample:
	Death.Stomp:
		TNT1 A 0
		TNT1 A 0 A_GiveToTarget("BootsSmearedWithRedBlood", 6)
	Goto Death

	Death:
		TNT1 A 0
		TNT1 A 0 A_SpawnItem("HorrorHeadExplode")
	Stop

	Crush:
		TNT1 A 0
		TNT1 AAAAAAAA 0 A_CustomMissile ("Brutal_FlyingBloodTrail5", 0, 0, random (0, 360), 2, random (60, 140))
		TNT1 A 0 A_PlaySound("misc/xdeath4")
		CRS1 B 5
		CRS1 B 9009
	Stop

	Death.plasma:
		TNT1 A 0
		TNT1 A 0 A_SpawnItemEx("TinyBurningPiece2", random (-15, 15), random (-15, 15))
		TNT1 A 0 A_SpawnItemEx("TinyBurningPiece3", random (-15, 15), random (-15, 15))
		EXPL A 0 A_CustomMissile ("ExplosionSmoke", 32, 0, random (0, 360), 2, random (0, 360))
		TNT1 A 0
	Stop

	Death.Melee:
	Death.SuperPunch:
	Death.Kick:
		TNT1 A 0
		D3MI AA 1 A_FaceTarget
		TNT1 AAAA 0 A_SpawnItemEx("Blood", 0, 0, 10)
		TNT1 A 0 A_CustomMissile ("XDeathHeadD3Maledict", 5, 0, random (170, 190), 2, random (20, 40))
		TNT1 A 0 A_PlaySound("misc/xdeath4", 1)
		TNT1 A 0 A_PlaySound("player/cyborg/fist", 3)
		TNT1 A 20
	Stop
	
	Pain:
		TNT1 A 0
		TNT1 A 0 ThrustThingZ(0,50,0,1)
		D3MI AAAAA 3 A_SetRoll(roll-25)
	Goto Spawn
	
	Death.ExplosiveImpact:
		TNT1 A 0
		TNT1 A 0 A_ChangeFlag("NOBLOCKMAP", 0)
		TNT1 A 0 ThrustThingZ(0,50,0,1)
		D3MI AAAAA 3 A_SetRoll(roll-25)
		TNT1 A 0 A_SpawnItem("HeadD3Maledict")
	Stop
	}
}


