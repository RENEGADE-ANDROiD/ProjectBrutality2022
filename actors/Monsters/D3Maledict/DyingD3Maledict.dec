Actor PlasmaDyingD3Maledict2
{
  -CLIENTSIDEONLY
  -SOLID
  Scale 1.0
  Translation "0:255=%[0,0,0]:[0.2,0.2,0.2]"
  States
	{
	Spawn:
		TNT1 A 0
		D3MF QR 7
		D3MF STUV 6
		D3MF V 1 A_CheckFloor("SpawnCorpse")
	Loop

	SpawnCorpse:
		TNT1 A 0 A_StartSound("Corpse/Fall",CHAN_6)
		TNT1 A 0 A_SpawnItem ("GrowingBloodPool")
		TNT1 A 0 A_SpawnItem("PlasmaDeadD3Maledict")
	Stop
	}
}


