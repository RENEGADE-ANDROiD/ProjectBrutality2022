		TNT1 AAAAAAAAAAAAAAA 0 A_CustomMissile ("IceBlood", random (5, 35), random (20, -20), random (0, 360), 2, random (0, 160), SXF_NOCHECKPOSITION)
		TNT1 AAAAAAAAAAAAAAAAAA 0 A_CustomMissile ("IceDust", random (5, 35), random (20, -20), random (0, 360), 2, random (0, 160), SXF_NOCHECKPOSITION)
		TNT1 A 0 A_SpawnItem("BloodSplasher3")
		TNT1 AAAAAAAAAAAAAA 0 A_SpawnProjectile ("BloodMistXXBig", 30, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_SAVEPITCH, -random (70, 90))
