		D3MA C 2 A_Wander
		TNT1 A 0 {A_CustomMissile("BurnParticlesNoDamage", random(30,80), 0, random (0, 360), 2, random (50, 130)); A_CustomMissile("FireballExplosionFlamesBig", random(30,80), 0, random (0, 360), 2, random (50, 130)); A_CustomMissile("ExplosionParticleVerySlow", random(30,80), 0, random (0, 360), 2, random (50, 130));}
		TNT1 A 0 A_StartSound("D3Maledict/StepLight", CHAN_BODY, CHANF_OVERLAP)
		D3MA CC 4 A_Wander
		D3MA C 2 A_Wander
		TNT1 A 0 {A_CustomMissile("BurnParticlesNoDamage", random(30,80), 0, random (0, 360), 2, random (50, 130)); A_CustomMissile("FireballExplosionFlamesBig", random(30,80), 0, random (0, 360), 2, random (50, 130)); A_CustomMissile("ExplosionParticleVerySlow", random(30,80), 0, random (0, 360), 2, random (50, 130));}
		D3MA DDD 4 A_Wander
		TNT1 A 0 A_JumpIfInventory("PoorGuyBurningLife", 15, "Death")
		TNT1 A 0 A_GiveInventory("PoorGuyBurningLife", 1)
	Loop

    Death:
