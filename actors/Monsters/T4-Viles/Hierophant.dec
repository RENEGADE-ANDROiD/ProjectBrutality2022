   }
}

Actor HierospawnHead
{

	Radius 8
    Height 15
	Speed 5
	Scale 0.65
	Gravity 0.5
	Mass 4
	BounceFactor 0.5
	wallbouncefactor 0.5
	BounceCount 2
	BounceType Doom
	BounceSound "Gore/HeadBounce"
	seesound "bloood"
    deathsound "bloood"
	+MISSILE
    +MOVEWITHSECTOR
    +CLIENTSIDEONLY
    +NOBLOCKMAP
    +NOTELEPORT
	+THRUACTORS
	States
	{
	Spawn:
		HDTH ABCD 2 A_SpawnItemEx("Brutal_BloodSpot")
	Loop
	Bounce:
		TNT1 A 0 A_SpawnItemEx("Brutal_BloodSpot")
		TNT1 A 0 A_SpawnItemEx("Brutal_BloodSpot")
		Goto Spawn
	Death:
		TNT1 A 0 A_PlaySound("Gore/HeadBounce",CHAN_6)
		TNT1 A 0 A_SpawnItemEx("Brutal_BloodSpot")
		TNT1 A 0 A_SpawnItemEx("Brutal_BloodSpot")
		TNT1 A 0 A_SpawnItemEx("Brutal_BloodSpot")
		TNT1 A 0 A_NoBlocking
		TNT1 A 0 A_QueueCorpse
        HDTH E -1
		Stop
	}
}

ACTOR XDeathHieroArm
{
    Scale 0.65
    Speed 8
	Gravity 0.4
	BounceFactor 0.4
	seesound "bloood"
    deathsound "bloood"
    States
    {
    Spawn:
        TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
