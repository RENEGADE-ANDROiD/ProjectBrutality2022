Actor HieroBall2 : BishopFX
{
    Speed 25
	Scale 0.3
    Damage 8
    DamageType "Normal"
    Seesound "weapons/firmfi"
    DeathSound "weapons/firex5"
    Decal "PLASMAScorch"
    +ThruGhost
    +ForceXYBillBoard

    States
    {
    Spawn:
        HIB2 ABCD 1 Bright A_Weave(3, 3, 1.0, 1.0)
        HIB2 A 0 Bright A_SeekerMissile(5, 6)
        Loop

    Death:
        HIB2 E 0 Bright A_SetTranslucent(0.90, 1)
        HIB2 EFGHIJKLMNO 3 Bright
        Stop
    }
}

