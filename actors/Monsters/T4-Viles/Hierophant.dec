}

ACTOR Shadowskullball
{
   Radius 8
   Height 8
   Speed 25
   Damage 15
   DamageType "Fire"
   PainType "Explosion"
   DeathType "Explosion"
   Decal "RedScorch"
   Scale 1.0
   BounceType "Hexen"
   BounceFactor 1
   WallBounceFactor 1
   BounceCount 4
   ReactionTime 500
   PROJECTILE
   RENDERSTYLE ADD
   ALPHA 0.95
   +NOTIMEFREEZE
   +THRUGHOST
   +EXPLODEONWATER
   +BLOODSPLATTER
   +SEEKERMISSILE
   +NOTIMEFREEZE
   +MTHRUSPECIES
   SeeSound "monster/curse1"
   DeathSound "monster/curse2"
   
   
  
   States
   {
   Spawn: 
      TNT1 A 0 A_Countdown
      TNT1 A 0 A_SeekerMissile (5,5, SMF_CURSPEED)
      IFX1 A 4 Bright A_SpawnItem("ShadowskullballTrail",0,0)
      TNT1 A 0 A_SeekerMissile (5,5, SMF_CURSPEED)
      IFX1 B 4 Bright A_SpawnItem("ShadowskullballTrail",0,0)
      loop
   Death:
      BAL3 C 5 Bright A_Explode (16, 96)
      BAL3 DEFGH 5 Bright
      stop
   }
}

