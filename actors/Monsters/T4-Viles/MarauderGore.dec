//==============================================================================
// Marauder / Peacekeeper SSG addon (PB3.0 port)
// Original addon: ikdfa (Marauder addon for PB)
// Sprites: Craneo (Marauder), TypicalSF (Doom Eternal SSG), PB Team (doomguy/chaingunguy sprites)
// Reload / fatality / death / gore sprites + code + revenge idea: DarthSeeth
// Additional code: Dox, Headshot_Ev (Glory-kill addon / Brutal Doom BE)
// PB3.0 build update: Jeniffer / Jenny (2023-05-14)
// Ported into Project Brutality 2022 tree on 2026-04-20.
//==============================================================================

// --- Dead / brutalized / fatalized Marauder cadavers (first cluster) ---
Actor DeadMarauderMSSDD0: CurbstompedMarine
{
    States
    {
    Spawn:
MSSD D -1
Stop
Death:
	TNT1 A 0 A_SpawnItem("GibsZ")
	TNT1 AA 0 A_CustomMissile ("XDeath1", 45, 0, random (0, 360), 2, random (0, 160))
	TNT1 A 0 A_CustomMissile ("XDeath2", 45, 0, random (0, 360), 2, random (0, 160))
	TNT1 A 0 A_CustomMissile ("XDeath3", 45, 0, random (0, 360), 2, random (0, 160))
	TNT1 AA 0 A_CustomMissile ("XDeathMarauderLeg", 5, 0, random (0, 360), 2, random (0, 160))
    Stop
   }
}

Actor BrutalizedMarauder1
{
	Game Doom
	Radius 16
	Height 50
	Health 50
	damagefactor "Blood", 0.0 damagefactor "BlueBlood", 0.0 damagefactor "GreenBlood", 0.0
    damagefactor "Avoid", 0.0
	damagefactor "Shrapnel", 0.0
	damagefactor "KillMe", 0.0
	PainSound "MRDPN"
	Mass 999999
	-SOLID
	+SHOOTABLE
	+FLOORCLIP
	+DONTSPLASH
	-COUNTKILL
	Scale 1.0
	States
	{
	Spawn:
		//M4UD JJJJJJJJJJ 10 A_SpawnItem ("DripingBlood", 0, 23)
		M4UD JJTTJJTTJJ 10 A_SpawnItem ("DripingBlood", 0, 23)
		M4UD K 6
		TNT1 A 0 A_SpawnItem ("BrutalizedDeadMarauder")
		Stop
	
	Pain:
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		M4UD J 1
		Goto Spawn

	Death:
		TNT1 A 0 A_CustomMissile ("MuchBlood", 1, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("XDeathMarauderArm2", 45, 0, random (0, 360), 1, random (0, 160))
		TNT1 A 0 A_CustomMissile ("XDeath1", 45, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_PlaySound("Marauderguy/death")
		TNT1 A 0 A_SpawnItem ("BrutalizedMarauder2")
		Stop
	}
}

Actor BrutalizedMarauder2: BrutalizedMarauder1
{
	States
	{
	Spawn:
		//M4UD MMM 10 A_SpawnItem ("DripingBlood", 0, 23)
		M4UD MMN 10 A_SpawnItem ("DripingBlood", 0, 23)
		//M4UD NNNNN 10 A_SpawnItem ("DripingBlood", 0, 23)
		M4UD NMMNN 10 A_SpawnItem ("DripingBlood", 0, 23)
		M4UD O 5
		TNT1 A 0 A_SpawnItem ("BrutalizedDeadMarauder")
		Stop
	
	Pain:
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		M4UD M 5
		Goto Spawn

	Death:
		TNT1 AAAA 0 A_CustomMissile ("Brains1", 50, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("Brains3", 50, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("Brains6", 50, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("Brains7", 50, 0, random (0, 360), 2, random (0, 160))
        TNT1 AAAAAA 0 A_CustomMissile ("BrainBlood", 50, 0, random (0, 360), 2, random (0, 160))
		TNT1 AAAA 0 A_CustomMissile ("SmallBrainPiece", random (45, 55), random (5, -5), random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("SmallBrainPiece", 50, 0, random (0, 360), 2, random (0, 160))
		TNT1 AA 0 A_CustomMissile ("SuperWallRedBlood", 46, 0, random (170, 190), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("XDeath1", 45, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_SpawnItem ("BrutalizedMarauder3")
		Stop
	}
}

Actor BrutalizedMarauder3: BrutalizedMarauder1
{
	States
	{
	Spawn:
		M4UD P 5
		M4UD QQQQQQQQQQ 10 A_SpawnItem ("Blood", 0, 43)
		M4UD R 5
		TNT1 A 0 A_SpawnItem ("SuperBrutalizedDeadMarauder")
		Stop
	
	Pain:
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		M4UD P 5
		Goto Spawn

	Death:
		TNT1 AAA 0 bright A_CustomMissile ("SuperGoreSpawner", 35, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAAA 0 A_CustomMissile ("PB_XDeath1", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("PB_XDeath2", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("PB_XDeath3", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("PB_XDeath4", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("NashgoreBlood", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("PB_Intestine", 32, 0, random (0, 360), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("PB_SuperWallRedBlood", 32, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAA 0 A_CustomMissile ("PB_SuperWallRedBlood", 46, 0, random (170, 190), 2, random (0, 40))
		TNT1 AAAAAAAA 0 A_CustomMissile ("BloodMistBig", 40, 0, random (0, 360), 2, random (30, 90))
		TNT1 A 0 A_SpawnItem ("CrueltyBonus5Health")

		TNT1 A 0 A_CustomMissile ("PB_SquirtingBloodTrail", 44, 0, random (0, 60), 2, random (30, 60))
		M4UD S 5 A_CustomMissile ("PB_SquirtingBloodTrail", 30, 0, random (0, 360), 2, random (0, 40))
		TNT1 A 0 A_SpawnItem ("BrutalizedMarauderLegs")
		Stop
	}
}

Actor BrutalizedMarauderBlasted: BrutalizedMarauder3
{
	+NOPAIN
	States
	{
	Spawn:
		M4BM AAAA 6 A_CustomMissile ("Brutal_LiquidBlood2", 64, 0, random (0, 360), 2, random (30, 60))
		M4BM BBBBCCCC 2 A_CustomMissile ("Brutal_LiquidBlood2", 34, 0, random (0, 60), 2, random (30, 60))
		TNT1 A 0 A_SpawnItem ("GrowingBloodPool")
		M4BM DDDDDDDDDDDDDDDDDDDDD 6 A_CustomMissile ("Brutal_LiquidBlood2", 16, 0, random (0, 60), 2, random (30, 60))
        TNT1 A 0 A_SpawnItem("DeadMarauderMPSDD")
		TNT1 A 0 A_Noblocking
		TNT1 A -1
        Stop
	Death:
		TNT1 A 0 A_SpawnItem ("CrueltyBonus5Health")
		TNT1 AA 0 A_CustomMissile ("XDeath1", 45, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("XDeath2", 45, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("XDeath3", 45, 0, random (0, 360), 2, random (0, 160))
		//M4UD S 1
		TNT1 A 0 A_SpawnItem ("BrutalizedMarauderLegs")
		Stop		
	}
}

Actor BrutalizedMarauderLostHead: BrutalizedMarauder1
{
	+NOPAIN
	hEALTH 100
	States
	{
	Spawn:
		M4HS BBB 2 A_CustomMissile ("Brutal_LiquidBlood2", 50, 0, random (0, 360), 2, random (60, 120))
		TNT1 A 0 A_XScream
		M4HS CCCCCCCCCCCCCCC 2 A_CustomMissile ("Brutal_LiquidBlood2", 40, 0, random (0, 360), 2, random (60, 120))
		TNT1 A 0 A_NoBlocking
		M4HS DDDEEE 2 A_CustomMissile ("Brutal_LiquidBlood2", 30, 0, random (0, 360), 2, random (60, 120))
		TNT1 A 0 A_SpawnItem ("GrowingBloodPool")
		M4HS FFFFFFFFFFFFFFF 2 A_CustomMissile ("Brutal_LiquidBlood2", 5, 0, random (0, 360), 2, random (10, 40))
 		TNT1 A 1 A_SpawnItem ("DeadMarauder_NoHeadExploded", 3)
        Stop
	Death:
		TNT1 A 0 A_CustomMissile ("XDeath2", 32, 0, random (0, 360), 2, random (0, 90))
		TNT1 A 0 A_CustomMissile ("XDeath3", 32, 0, random (0, 360), 2, random (0, 90))
		TNT1 AAA 0 A_CustomMissile ("Brutal_FlyingBlood", 32, 0, random (0, 360), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 32, 0, random (0, 360), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 32, 0, random (0, 360), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("Instestin", 32, 0, random (0, 360), 2, random (0, 40))
		TNT1 AAA 0 A_CustomMissile ("BloodMistBig", 40, 0, random (0, 360), 2, random (0, 90))
		TNT1 A 0 A_CustomMissile ("XDeathMarauderArm2", 62, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_NoBlocking
        TNT1 A 0 A_SpawnItem("BrutalizedMarauderBlasted")
		TNT1 A -1
        Stop
		
	}
}

