//==============================================================================
// Marauder / Peacekeeper SSG addon (PB3.0 port)
// Original addon: ikdfa (Marauder addon for PB)
// Sprites: Craneo (Marauder), TypicalSF (Doom Eternal SSG), PB Team (doomguy/chaingunguy sprites)
// Reload / fatality / death / gore sprites + code + revenge idea: DarthSeeth
// Additional code: Dox, Headshot_Ev (Glory-kill addon / Brutal Doom BE)
// PB3.0 build update: Jeniffer / Jenny (2023-05-14)
// Ported into Project Brutality 2022 tree on 2026-04-20.
//==============================================================================

// --- Marauder-scope inventory tokens ---
Actor CanBeStunned : Inventory {
Inventory.MaxAmount 180 }
Actor CantUseAxe : Inventory {
Inventory.MaxAmount 150 }
Actor CantUseShotgun : Inventory {
Inventory.MaxAmount 55 }
Actor MarauderDied : Inventory {
Inventory.MaxAmount 1 }
Actor IsMarauder : Inventory {
Inventory.MaxAmount 1 }
Actor ShieldUp : Inventory {
Inventory.MaxAmount 210 }

Actor FireAcidAvoid : Inventory {
Inventory.MaxAmount 1 }

Actor FatalityHited : Inventory {
Inventory.MaxAmount 1 }

Actor SKMarauder: 				Inventory {Inventory.MaxAmount 1} //Needed for StealthKill
Actor MarauderFatality:			Inventory {Inventory.MaxAmount 1} //Needed for Fatality
Actor DontMeleeAgain: 			Inventory {Inventory.MaxAmount 1}
Actor MarauderAxeThrown: 		Inventory {Inventory.MaxAmount 1}
Actor MarauderVulnerability:	Inventory {Inventory.MaxAmount 1}
Actor MarauderSummonWolf: 		Inventory {Inventory.MaxAmount 1}
Actor MarauderTeleport: 		Inventory {Inventory.MaxAmount 1}
Actor MarauderTaunted: 			Inventory {Inventory.MaxAmount 1}
Actor MarauderAvoiding: 		Inventory {Inventory.MaxAmount 1}

// --- Attack projectiles / axe / chunks / wolf summon / monster body ---
Actor MarauderMeleeAttack: BaronBall
{
	Radius 10
	Height 18
	DamageType Cut
	Projectile 
	+RANDOMIZE
    Damage 16
	+FORCEXYBILLBOARD
    +THRUGHOST
    +BLOODSPLATTER 
	RenderStyle Add
	Alpha 0.6
	HitObituary "Marauder finally got the slayer!"
	Obituary "Marauder finally got the slayer!"
	+DONTHURTSPECIES

	SeeSound "None"
	DeathSound "none"
	Decal "none"
    Speed 20
	States
	{
	Spawn:
		TNT1 A 4
		Stop
	Death:
        TNT1 A 0 A_PlaySound("Machete/Yum")
		TNT1 A 1
		Stop
	}
}

Actor MarauderAxeSwingAttack: BaronBall
{
	Radius 10
	Height 18
	DamageType Cut
	Projectile 
	+RANDOMIZE
    Damage 12
	+FORCEXYBILLBOARD
    +THRUGHOST
    +BLOODSPLATTER 
	RenderStyle Add
	Alpha 0.6
	HitObituary "Marauder finally helped slayer open his eyes"
	Obituary "Marauder finally helped slayer open his eyes"
	+DONTHURTSPECIES
	SeeSound "None"
	DeathSound "none"
	Decal "none"
    Speed 20
	States
	{
	Spawn:
		TNT1 A 4 BRIGHT
		Stop
	Death:
        TNT1 A 0 A_PlaySound("Machete/Yum")
		TNT1 A 0 BRIGHT
		Stop
	}
}

//Vertical slice
Actor MarauderAxe : FastProjectile
	{
	Game Doom
	DamageType Cut
	Radius 4
	Height 8
	Speed 70
	Damage (random(20,25))
	PROJECTILE
    +THRUGHOST
	RenderStyle Add
	Alpha 1
  //SeeSound "ImpFire"
	DeathSound "weapons/StachanovHit"
	Decal "BFGLightning"
	Decal "BigScorch"
	Scale 2
	MissileType "MarauderAxetrail"
	HitObituary "Marauder finally got the slayer!"
	Obituary "Marauder finally got the slayer!"
	States
	{
	Spawn:
	TNT1 A 0
	TNT1 A 0 A_PlaySound("Weapons/StachanovFly",6,1.0,1)
	Fly:
	TNT1 A 6 
	Loop
  Death:
    TNT1 A 0 A_StopSound(6)
    TNT1 A 0 A_PlaySound("Weapons/YamatoExp",3)
    TNT1 A 0 A_Explode(random(10,13),8,0,0)
    TNT1 AAAA 0 A_SpawnItemEx("ObeliskTrailSpark", random(19,-19), random(19,-19), random(19,-19), 0, 0, 0, 0, 128, 0)
    TNT1 BCD 4
    Stop			
		
	}
}

Actor MarauderAxetrail: RevanentBeamTrail
{
  RenderStyle Add
  Scale 0.04
  Alpha 1
  +NOINTERACTION
  +NOGRAVITY
  +CLIENTSIDEONLY
  States
  {
  Spawn:
    TNT1 A 0
    TNT1 A 0 A_SetScale(ScaleX+0.004, ScaleY+0.16)
    YAE4 A 1 bright //A_SpawnItemEx("ObeliskTrailSpark", random(4,-4), random(4,-4), random(4,-4), 0, 0, 0, 0, 128, 0)
  Trolololo:
    YAE4 A 0 A_SetScale(ScaleX-0.001, ScaleY -0.04)
    YAE4 A 1 bright A_FadeOut(0.2)
    Loop
  }
}


//Horizontal slice
