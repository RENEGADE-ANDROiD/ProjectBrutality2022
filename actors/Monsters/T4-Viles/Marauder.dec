		Pain:
		ShieldBlock:
			TNT1 A 0 A_ChangeFlag("NOPAIN", 1)
			TNT1 A 0 A_ChangeFlag("FRIGHTENED", 1)
			TNT1 A 0 A_ChangeFlag("DONTRIP", 1)
			TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 0)	
			TNT1 A 0 A_Stop
			TNT1 A 0 A_JumpIfInventory("CanBeStunned", 1, "Stun")
			TNT1 A 0 A_PlaySound("SHIELDWA")
			TNT1 A 0 A_ChangeFlag("MISSILEMORE", 1)
			TNT1 A 0 A_SetInvulnerable
			
			MASH A 0 A_SpawnItem("HeadshotTarget6", 0, 45,0)
			MASH AABBCCDD 6 A_FaceTarget 
			TNT1 A 0 A_ChangeFlag("NOPAIN", 0)
			TNT1 A 0 A_ChangeFlag("FRIGHTENED", 0)
			TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
			TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 1)	

			Goto Summon
			BlockEnd:
			Goto Pain.Avoid			

		Stun:
			TNT1 A 0 A_ChangeFlag("NOPAIN", 1)
			TNT1 A 0 A_ChangeFlag("FRIGHTENED", 1)
			TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
			TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 0)	
			TNT1 A 0 A_PlaySound("MRDPN", 1)
			TNT1 A 0 A_UnSetInvulnerable
			TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
			MAUD G 8
			TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
			MAUD G 8
			TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
			MAUD G 8
			TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
			MAUD G 8
			TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
			MAUD G 8
			TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
			TNT1 A 0 A_PlaySound("MRDPN", 1)
			MAUD G 8
			TNT1 A 0 A_TakeInventory("CanBeStunned", 1000)	
			Goto Pain.Avoid	


	Summon:
		WOLF A 0 A_JumpIfInventory("MarauderSummonWolf",1,"BlockEnd")
		WOLF A 0 A_PlaySound("WOLFSPN")
		MAUD AAAAUUUUVVV 1 Bright A_ChangeFlag("NOBLOCKMONST", 1)
		MAUD V 1 Bright
		{	
			A_SpawnItemEx("ObeliskExplode",1,1,15,5,1,1,1);
			A_FaceTarget;
			A_SpawnItemEx("MarauderWolfSummon",1,1,1,5,1,1,1,SXF_SETMASTER);
			A_GiveInventory("MarauderSummonWolf",1);
		}
		TNT1 A 0 A_ChangeFlag("NOBLOCKMONST", 0)
		Goto BlockEnd

    Death:
		TNT1 AAA 0 A_SpawnItem("Blood", 0, 40)
		TNT1 A 0 A_Jump(64,"Death.Arm")
		M4OD A 8 A_Scream
		MAUD H 6 A_NoBlocking
		MAUD IJKLM 5
        TNT1 A 0 
		TNT1 A 0 A_SpawnItem ("GrowingBloodPool")
        TNT1 A 1 A_SpawnItem ("DeadMarauder", 3)
		Stop
		
	XDeath:
		TNT1 A 0 A_NoBlocking
		TNT1 A 0 A_FaceTarget
        TNT1 A 0 A_CustomMissile ("MarauderXDeath", 0, 0, random (0, 360), 2, random (0, 160))
		Stop		
		
		
	Death.Shrapnel:
		TNT1 A 0
		TNT1 A 0 A_JumpIfHealthLower(-50, 4)
		TNT1 A 0 A_SpawnItem("MuchBlood", 0, 32)
		TNT1 A 0 ThrustThingZ(0, 30, 0, 0)
		TNT1 A 0 A_Jump(128, "Death.Head")
		Goto Death
		TNT1 AA 0
		TNT1 A 0 A_Jump(255, "Death.ExplosiveImpact", "Death.Leg")
		Goto Death
		
