Actor MarauderWolfSummon
{
	Health 50
	Speed 10
	Radius 20
	Height 32
	RenderStyle Add
	Monster
	Species "Marauder"
	Tag "Phantom Wolf"
	PainChance "Kick", 255
	DamageFactor "Kick", 50.0
	+FLOORCLIP
	+NOBLOOD
	+THRUSPECIES
	+DONTHARMSPECIES
	SeeSound "WOLFSEE"
	DeathSound "WOLFDED"
	Obituary "%o was chewed by the Marauder's Wolf."
	States
	{
		Spawn:
			WOLF AB 10 A_Look
			Loop
		See:
			TNT1 A 0 A_PlaySound("WOLFSTP",3)
			WOLF B 1 Bright {A_Chase;A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF BBB 1 Bright {A_Chase("","");A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF B 1 Bright {A_Chase;A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF BBB 1 Bright {A_Chase("","");A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			TNT1 A 0 A_PlaySound("WOLFSTP",3)
			WOLF C 1 Bright {A_Chase;A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF CCC 1 Bright {A_Chase("","");A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF C 1 Bright {A_Chase;A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF CCC 1 Bright {A_Chase("","");A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			TNT1 A 0 A_PlaySound("WOLFSTP",3)
			WOLF D 1 Bright {A_Chase;A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF DDD 1 Bright {A_Chase("","");A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF D 1 Bright {A_Chase;A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF DDD 1 Bright {A_Chase("","");A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			TNT1 A 0 A_PlaySound("WOLFSTP",3)
			WOLF A 1 Bright {A_Chase;A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF AAA 1 Bright {A_Chase("","");A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF A 1 Bright {A_Chase;A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			WOLF AAA 1 Bright {A_Chase("","");A_SpawnItemEx("WolfAfterimage",0,0,0,0,0,0,0,SXF_TRANSFERSPRITEFRAME);}
			Loop
		Melee:
			TNT1 A 0 A_Playsound("caco/melee")
			WOLF EF 4 Bright A_FaceTarget
			WOLF G 4 Bright A_CustomMeleeAttack(10,"Wolf/attack","Wolf/attack")
		Goto See
	Death.Ice:
	Death.IceBeam:
	Death.Freeze:
	Death.Frost:
		Death:
			WOLF E 1 Bright
			WOLF E 1 Bright A_Scream
			WOLF EEEEE 1 Bright
			{
			A_Fadeout(0.2);
			A_SpawnParticle("Yellow",SPF_FULLBRIGHT|SPF_RELATIVE,10,5,0,0,0,20,random(-3,3),random(-3,3),random(-3,3));
			A_SpawnParticle("Orange",SPF_FULLBRIGHT|SPF_RELATIVE,10,5,0,0,0,20,random(-3,3),random(-3,3),random(-3,3));
			A_SpawnParticle("White",SPF_FULLBRIGHT|SPF_RELATIVE,10,5,0,0,0,20,random(-3,3),random(-3,3),random(-3,3));
			A_TakeInventory("MarauderSummonWolf",0,0,AAPTR_MASTER);
			}
			Stop
	}
}

Actor WolfAfterimage
{
	Radius 5
	Height 1
	Renderstyle Add
	+NOGRAVITY
	+NOBLOCKMAP
	States
	{
		Spawn:
			"####" "#####" 1 Bright A_Fadeout(0.2)
			Stop
	}
}


Actor PB_Marauder: PB_Monster
 {
	Health 800
	Speed 12
	MeleeRange 150
	Height 70
	Radius 22
	+FLOORCLIP
	+DONTHARMSPECIES
	Monster
	Species "Marauder"
	Tag "Marauder"
	PainChance 255
	DamageFactor "Crush", 10.0

	DamageFactor "TeleportRemover", 0.0
	DamageFactor "GibRemoving", 0.0
	DamageFactor "CauseObjectsToSplash", 0.0
	DamageFactor "Head", 1.0
	DamageFactor "MinorHead", 1.0

	DamageFactor "SSG", 1.0
	DamageFactor "Avoid", 0.0
	DamageFactor "killme", 0.0

	PainChance "Blood", 0
	SeeSound "MARTNT"
	ActiveSound "MARTNT"
	PainSound "MRDPN"
	DamageFactor "Fatality", 0.8

	DamageFactor "Burn", 0.35
	DamageFactor "Flame", 0.35
	DamageFactor "Fire", 0.35
	DamageFactor "Acid", 0.35
	DamageFactor "Disintegrate", 0.25
	DamageFactor "Bullet", 0.5
	DamageFactor "Railgun", 1.0
	DamageFactor "CutLess", 0.25
	DamageFactor "Explosive", 0.6
	DamageFactor "SuperKick", 0.6
	DamageFactor "ExplosiveImpact", 0.8
	DamageFactor "Shotgun", 0.8
	DamageFactor "Freeze", 0.6
	DamageFactor "Nailgun", 0.8
	DamageFactor "GibRemoving", 0.0
	DamageFactor "Crucible", 1.0
	DamageFactor "GloryFire", 0.6
	DamageFactor "BloodPunch", 0.8
	PainChance "CallingTheBaronAFaggot", 255
	
	DeathSound "MARDED"
	DropItem "MarauderSSG"
	DropItem "MSSGUpgrade", 80
	
  PainChance "Stun", 255
  PainChance "Taunt", 255
  PainChance "Fatality", 200
  PainChance "GloryKill", 200
  PainChance "Kick", 200
  PainChance "Melee", 200
  PainChance "ExtremePunches", 200
  PainChance "Head", 255
  PainChance "SSG", 255
  PainChance "Railgun", 255
  PainChance "Explosive", 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 25
  DropItem "Crucible" 15
  WoundHealth 140
  Mass 100000
	States {
	
	Wound:
		"####" "#" 1
		{
			if(GetCvar("be_ExecutionsON"))
			{	
				if(countinv("FinisherToken")==0) //if it isnt healing already
				{								//will heal and give the token that indicates it's executable
					A_SpawnItemEx("BaronHighlight",0,0,0,0,0,0,0,SXF_SETMASTER|SXF_NOCHECKPOSITION); //to highlight if ON, and to remove the token after the monster heals
					A_GiveInventory("FinisherToken",1);	//token to allow melee attack to execute
					A_GiveToTarget("BloodPunchKilled",1); // Check BloodPunch
				}
				
				if(GetCvar(be_MonsterStagger)==1) //will the monsters stagger at all?
				{
					return state("Stagger");	//stays there for a few seconds
				}
				else
				{
					return state(0);
				}
			}
			return state(0);
		}
		Goto SeeRealNoShield
		
	Stagger:
		MAUD B 0
		{
			if(getcvar(be_ExecutionHighlight)==1)
			{	return state("PrepareStaggerHighlight");}
			else
			{	return state("StagLooper");	}
		}
		Goto StagLooper
	PrepareStaggerHighlight:
		MAUK G 4
		Goto StagLooper
	
	StagLooper:
		"####" "#" 4
		{
			if(!countinv("FinisherToken"))
			{
				return state("SeeRealNoShield");
			}
			if(getcvar(be_NoisyStagger) && countinv("PainSoundToken"))
			{ 
				A_PlaySound("MRDPN", 1); 
				A_TakeInventory("PainSoundToken");
			}
			return state(0);
		}
		"####" "#" 0 A_SpawnItem("HeadshotTarget4", 0, 44,0)
		"####" "#" 0
		Loop		
	
	StopCooldown:
		TNT1 A 1
		Stop
	Spawn:
		MAUD A 15
		TNT1 A 0 ACS_ExecuteAlways(1346)
		MAUD A 0 A_GiveInventory("SKMarauder", 1)
		TNT1 A 0 A_ChangeFlag("NOPAIN", 0)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 0)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 1)
		Goto Stand
		Stand:
			MAUD AA 10 A_Look
		Loop
		See:
			TNT1 A 0 A_TakeInventory("EnemyMemory", 15)
			TNT1 A 0 A_TakeInventory("SKMarauder", 1000)
			TNT1 A 0 A_CheckSight("SeeNeverSeen")
		Goto SeeRealNoShield

/*
		SeeReal:
			MASH A 0 A_JumpIfInventory("ShieldUp", 1, 2)
			MAUD A 0
			"####" A 0 A_SpawnItem("HeadshotTarget2", 0, 45,0)
			"####" A 0 A_PlaySound("metalboot/steps",4)
			"####" AABBCCDD 2 A_Chase
			Loop
	*/
	
	SeeRealNoShield:
		TNT1 A 0 A_ChangeFlag("NOPAIN", 0)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 0)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 1)
		
		TNT1 A 0 A_TakeInventory("MarauderAvoiding", 250)
		
		TNT1 A 0 A_TakeInventory("FireAcidAvoid", 250)
		
		
		TNT1 A 0 A_JumpIfInventory("EnemyMemory", 12, "SearchForPlayer")
		TNT1 A 0 A_GiveInventory("EnemyMemory", 1)
		
		MAUD AA 2 A_Chase

		TNT1 A 0 { if(GetCvar("bd_MonsterFootsteps") == 1) { A_PlaySound("floorhardZombie",3); } }
		MAUD AA 2 A_Chase

		MAUD BB 2 A_Chase

		MAUD BB 2 A_Chase

		MAUD CC 2 A_Chase

		MAUD CC 2 A_Chase
		TNT1 A 0 { if(GetCvar("bd_MonsterFootsteps") == 1) { A_PlaySound("floorhardZombie",3); } }

		MAUD DD 2 A_Chase

		MAUD DD 2 A_Chase
		Goto SeeContinue

	SeeNeverSeen:
		TNT1 A 0 A_ChangeFlag("NOPAIN", 0)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 0)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 1)		
		TNT1 A 0 A_TakeInventory("MarauderAvoiding", 250)
        TNT1 A 0 A_PlaySound("metalboot/steps",3)
		TNT1 A 0 A_TakeInventory("SKMarauder", 1000)		
		MAUD AA 2 A_Chase
		TNT1 A 0 { if(GetCvar("bd_MonsterFootsteps") == 1) { A_PlaySound("floorhardZombie",3); } }
		MAUD AA 2 A_Chase
		MAUD BB 2 A_Chase
		MAUD BB 2 A_Chase
		MAUD CC 2 A_Chase
		MAUD CC 2 A_Chase
		TNT1 A 0 { if(GetCvar("bd_MonsterFootsteps") == 1) { A_PlaySound("floorhardZombie",3); } }
		MAUD DD 2 A_Chase
		MAUD DD 2 A_Chase
		Goto SeeRealNoShield

	SeeContinue:
		TNT1 A 0 A_CheckSight("SeeNeverSeen")
		TNT1 A 0 A_JumpIfInventory("EnemyMemory", 12, "SearchForPlayer")

SeeContinuePart36Continue:
		TNT1 A 0 A_GiveInventory("EnemyMemory", 1)
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		MAUD AAA 2 A_Chase

		TNT1 A 0 A_JumpIf(GetCvar("bd_RollingZombies")==1, 2)
		TNT1 A 0 A_Jump(16, "Pain.Avoid")
		TNT1 A 0

		TNT1 A 0 A_Jump(64, 2)
		MAUD A 0 A_FaceTarget
		MAUD A 0 A_JumpIfCloser(100,"Melee") //A_JumpIfCloser(200,"AxeSwingAttack")
		MAUD BBB 2 A_Chase

		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		TNT1 A 0 A_Jump(128, 2)
		MAUD A 0 A_FaceTarget
		MAUD A 0 A_JumpIfCloser(200,"AxeSwingAttack")
		MAUD CCC 2 A_Chase

		TNT1 A 0 A_Jump(64, 2)
		MAUD A 0 A_FaceTarget
		MAUD A 0 A_JumpIfCloser(200,"AxeSwingAttack")
		MAUD DDD 2 A_Chase

		TNT1 A 0 A_Jump(96, 2)
		MAUD A 0 A_FaceTarget
		TNT1 A 0 A_JumpIfCloser(140, "FallBack")
		TNT1 A 0 A_JumpIfInTargetInventory("IsInvisible", 1, "Idle")
		Loop

	Idle:
	SearchForPlayer:
		TNT1 A 0 A_ChangeFlag("NOPAIN", 0)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 0)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 1)
		TNT1 A 0 A_ClearTarget
		TNT1 A 0 A_TakeInventory("EnemyMemory", 30)
		TNT1 A 0 A_GiveInventory("SKMarauder", 1)
		MAUD A 10 A_Look
		MAUD A 10 A_Look
		
		MAUD A 10 A_Look

		TNT1 A 0 A_SetAngle(angle - 40)
		
		MAUD A 10 A_Look
		
		TNT1 A 0 A_SetAngle(angle + 40)
		MAUD A 10 A_Look
		
		MAUD A 10 A_Look

		
		TNT1 A 0 A_Wander
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		MAUD A 4 A_Look
		
		TNT1 A 0 A_Wander

		MAUD B 4 A_Look
		
		TNT1 A 0 A_Wander
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		MAUD C 4 A_Look
		
		TNT1 A 0 A_Wander

		MAUD D 4 A_Look
		TNT1 A 0 A_jump(128, "SearchForPlayer")
		
		TNT1 A 0 A_Wander
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		MAUD A 4 A_Look
		
		TNT1 A 0 A_Wander

		MAUD B 4 A_Look
		
		TNT1 A 0 A_Wander
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		MAUD C 4 A_Look

		TNT1 A 0 A_Wander

		MAUD D 4 A_Look
		Goto SearchForPlayer

		Missile:
			TNT1 AAAA 0 A_JumpIfInventory("CantUseShotgun", 1, "ThrowAxeVertical")
			TNT1 A 0 A_JumpIfCloser(250, "SSGMissile")
		ThrowAxeVertical:
			TNT1 A 0
			TNT1 A 0 A_Jump(128, "ThrowAxeHorizontal")
			TNT1 A 0 A_PlaySound("MARSMAR", 1)
			TNT1 A 0 A_FaceTarget
			MAUD U 16
			TNT1 A 0 A_CustomMissile("MarauderAxe",23,0,0,1)
			MAUD W 16
			TNT1 A 0 A_Jump(256, "ThrowEnd")	
		ThrowAxeHorizontal:
			TNT1 A 0 A_PlaySound("MARSMAR", 1)
			TNT1 A 0 A_FaceTarget
			MAUD W 16
			TNT1 A 0 A_CustomMissile("MarauderAxe2",23,0,0,1)
			MAUD U 16		
		ThrowEnd:
			TNT1 AAAA 0 A_TakeInventory("CantUseShotgun", 150)
			Goto SeeRealNoShield
		GetOut:
			TNT1 A 0 A_FaceTarget
			TNT1 A 0 A_TakeInventory("CantUseAxe", 150 )
			TNT1 A 0 A_TakeInventory("CantUseShotgun", 150)
			Goto Pain.Avoid
			
		Melee:
			TNT1 A 0 A_JumpIfInventory("CantUseAxe", 1, "GetOut")
			TNT1 A 0  A_JumpIfCloser(100,"MeleeToStun")
		AxeSwingAttack: //MELEE
			TNT1 A 0 A_JumpIfInventory("CantUseAxe", 1, "GetOut")
			TNT1 A 0 A_GiveInventory("CanBeStunned", 100)
			TNT1 A 0 A_UnSetInvulnerable
			TNT1 A 0  A_FaceTarget	
			TNT1 A 0  A_GiveInventory("CantUseAxe", 150 )
			TNT1 A 0  A_PlaySound("MSWING")
			TNT1 A 0  A_FaceTarget
			TNT1 W 0 ThrustThingZ(0, 20, 0, 0)
			TNT1 A 0  A_Recoil(-10)
			MAAT AAAAAAAAAAAA 1 //A_SpawnItemEx("MarauderDashTrail",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)		
			TNT1 A 0 A_SpawnItem("HeadshotTarget4", 0, 44,0)
			MAAT A 4  A_FaceTarget
			TNT1 A 0  A_Recoil(-5)
			MAAT A 4  A_FaceTarget			
			TNT1 A 0 A_JumpIf(GetCvar("bd_RollingZombies")==1, 2)	
			TNT1 A 0 A_CustomMissile("MarauderAxeSwingAttack",10,0,0,0)
			TNT1 A 0 A_TakeInventory("CanBeStunned", 1000 )
			TNT1 A 0 A_TakeInventory("CantUseShotgun", 150)
			TNT1 A 0 A_Jump(96, "Pain.Avoid")	
			Goto SeeRealNoShield

		MeleeToStun:
			TNT1 A 0 A_UnSetInvulnerable
			TNT1 A 0 A_GiveInventory("CantUseAxe", 150 )
			TNT1 A 0 A_FaceTarget
			TNT1 A 0 A_GiveInventory("CanBeStunned", 100)
			TNT1 A 0 A_PlaySound("MSWING")
			TNT1 A 0 A_Recoil(-10)
			TNT1 A 0 { if(GetCvar("bd_MonsterFootsteps") == 1) { A_PlaySound("floorhardZombie",3); } }
			TNT1 A 0 A_SpawnItem("HeadshotTarget4", 0, 44,0)
			MAAT BC 4
			TNT1 A 0 A_Recoil(-10)
			TNT1 A 0 { if(GetCvar("bd_MonsterFootsteps") == 1) { A_PlaySound("floorhardZombie",3); } }
			TNT1 A 0 A_SpawnItem("HeadshotTarget4", 0, 44,0)				
			MAAT DE 4
			TNT1 A 0 A_Recoil(-10)
			TNT1 A 0 { if(GetCvar("bd_MonsterFootsteps") == 1) { A_PlaySound("floorhardZombie",3); } }
			TNT1 A 0 A_SpawnItem("HeadshotTarget4", 0, 44,0)				
			M44T FG 4
			TNT1 A 0 A_CustomMissile("MarauderMeleeAttack",10,0,0,0)
			TNT1 A 0 { if(GetCvar("bd_MonsterFootsteps") == 1) { A_PlaySound("floorhardZombie",3); } }
			TNT1 A 0 A_SpawnItem("HeadshotTarget4", 0, 44,0)					
			M44T HI 4
			TNT1 A 0 A_TakeInventory("CanBeStunned", 1000 )
			TNT1 A 0 A_TakeInventory("CantUseShotgun", 150)
			Goto SeeRealNoShield

		SSGMissile: //SSG attack
			TNT1 A 0 A_JumpIfInventory("CantUseShotgun", 1, "Missile")
		SSGMissileStill:
			M4RL A 0 A_JumpIfInventory("SergeantAmmo",2,"Reload")
			TNT1 A 0 A_TakeInventory("SergeantAmmo",100)
			TNT1 A 0 A_GiveInventory("SergeantAmmo",2)
			TNT1 A 0 A_JumpIfInventory("MarauderTaunted", 1, "SSGDragonBreathMissile")
			TNT1 A 0 A_FaceTarget
			MAUD E 6
			/*
			TNT1 A 0 {
			
			A_CustomBulletAttack(0, 0, 1, 5, "shotpuff", 0, 220);
			A_CustomBulletAttack (12, 6, 4, 2, "ShotgunPuff");
			
			A_CustomMissile("GunFireSmokE", 0, 0, 2, 0, 0, 0);
			A_CustomMissile("GunFireSmoke", 0, 0, -2, 0, 0, 0);
			A_PlaySound("MSSFR");
			A_GiveInventory("CantUseShotgun", 100);
			}
			*/
			TNT1 A 0 A_FaceTarget
			TNT1 AAAA 0 A_PlaySound("MSSFR")
			TNT1 AAAA 0 A_CustomMissile("GunFireSmokE", 0, 0, 2, 0, 0, 0)
			TNT1 AAAA 0 A_CustomMissile("GunFireSmoke", 0, 0, -2, 0, 0, 0)
			TNT1 AAAAAAAAAAAAAAAAAAAAA 0 A_CustomMissile("QuadTracer", random(40, 64), random(-25, 25), random(-20, 20), 0,random(-22, 22))
			MAUD F 4
			MAUD E 8
			TNT1 AAAA 0 A_GiveInventory("CantUseShotgun", 150)
			TNT1 A 0 A_Jump(100, "Reload")
			Goto SeeRealNoShield

		SSGDragonBreathMissile:
			MAUD E 6
			TNT1 A 0 A_FaceTarget
			TNT1 A 0 A_TakeInventory("MarauderTaunted", 25)
			TNT1 AAAA 0 A_CustomMissile("GunFireSmoke", 0, 0, 2, 0, 0, 0)
			TNT1 AAAA 0 A_CustomMissile("GunFireSmoke", 0, 0, -2, 0, 0, 0)
			TNT1 AAAAAAAAAA 0 A_CustomMissile("MarauderChunk1",35,5, 0, 0, 0)
			TNT1 AAAAAAAAAA 0 A_CustomMissile("MarauderChunk2",35,5, random(-15, 15), 0, 0)
			TNT1 AAAAAAAAAA 0 A_CustomMissile("MarauderChunk3",35,5, random(-25, 25), 0, 0)

			TNT1 AAAA 0 A_PlaySound("FLAKFIRE")
			MAUD F 4
			MAUD E 8
			TNT1 AAAA 0 A_GiveInventory("CantUseShotgun", 150)
			TNT1 A 0 A_JumpIfCloser(200,"AxeSwingAttack")
			TNT1 A 0 A_Jump(100, "Reload")
			Goto SeeRealNoShield

	Reload:
		M4RL A 5
		M4RL B 3
		TNT1 A 0 A_PlaySound("weapons/sshotc")
		TNT1 A 0 A_TakeInventory("SergeantAmmo",2)
		TNT1 A 0 A_CustomMissile("ShotCaseSpawn",32,-4,1)
		TNT1 A 0 A_CustomMissile("ShotCaseSpawn",32,-8,1)
		M4RL BB 3
		M4RL C 7
		M4RL DD 5//D 7
		TNT1 A 0 A_Playsound("weapons/sshotl")
		M4RL CCAA 4//EF 5
		TNT1 A 0 A_PlaySound("weapons/sshotc")
		MAUD A 5
		TNT1 A 0 A_CheckSight("SeeRealNoShield")
		TNT1 A 0 A_Jump(64,"Missile")
		Goto SeeRealNoShield
		
	Pain.Avoid:
		TNT1 A 0 A_ChangeFlag("NOPAIN", 0)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 0)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 1)

	    TNT1 A 0
		TNT1 A 0 A_JumpIf(GetCvar("bd_RollingZombies")==1, "Missile")
	    TNT1 A 0 A_Jump(256, "AvoidLeft","AvoidJumpLeft", "AvoidRight","AvoidJumpRight","HopNRollLeft", "HopNRollRight")
        Goto AvoidLeft
	  
	HopNRollRight:
	    MAUD A 3 A_FaceTarget
		MAUD V 3 A_FaceTarget
		TNT1 A 0 ThrustThingZ(0, 20, 0, 0)
	    TNT1 A 0 ThrustThing(angle*256/360+64, 5, 0, 0)
		MAU4 AB 6 
		
	LeftHopNRollloop:
		MAU4 B 1 A_CheckFloor("AvoidRightShort")
		TNT1 A 0 A_CheckCeiling("AvoidRightShort")
        Goto leftHopNRollloop
		
	HopNRollLeft:
	    MAUD A 3 A_FaceTarget
		MAUD V 3 A_FaceTarget
		TNT1 A 0 ThrustThingZ(0, 20, 0, 0)
	    MAUD A 0 ThrustThing(angle*256/360+192, 5, 0, 0)
		MAU4 AH 6
	
	RightHopNRollloop:
		MAU4 H 1 A_CheckFloor("AvoidLeftShort")
		TNT1 A 0 A_CheckCeiling("AvoidLeftShort")
        Goto RightHopNRollloop
		
	AvoidLeftShort:
		TNT1 A 0 ThrustThing(angle*256/360+192, 9, 0, 0)
		MAU4 GFEDCBA 2 A_FaceTarget
		TNT1 A 0 A_CheckSight("SeeRealNoShield")
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		Goto SeeRealNoShield
		
	AvoidRightShort:
		TNT1 A 0 ThrustThing(angle*256/360+64, 9, 0, 0)
		MAU4 CDEFGHA 2 A_FaceTarget
		TNT1 A 0 A_CheckSight("SeeRealNoShield")
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		Goto SeeRealNoShield
				
   AvoidJumpLeft:
		TNT1 A 0 A_PlaySound("MARAUDJ", 1)
	    MAUD A 3 A_FaceTarget
		MAUD V 3 A_FaceTarget
		TNT1 A 0 ThrustThingZ(0, 20, 0, 0)
	    MAUD A 0 ThrustThing(angle*256/360+192, 5, 0, 0)
		leftjumploop:
		MAU4 A 1 A_FaceTarget
		MAU4 A 1 A_CheckFloor("missile")
		TNT1 A 0 A_CheckCeiling("missile") //For corruption cards
        Goto leftjumploop

	AvoidJumpRight:
		TNT1 A 0 A_PlaySound("MARAUDJ", 1)
	    MAUD A 3 A_FaceTarget
		MAUD V 3 A_FaceTarget
		TNT1 A 0 ThrustThingZ(0, 20, 0, 0)
	    TNT1 A 0 ThrustThing(angle*256/360+64, 5, 0, 0)
		rightjumploop:
        MAU4 A 1 A_FaceTarget
		MAU4 A 1 A_CheckFloor("missile")
		TNT1 A 0 A_CheckCeiling("missile") //For corruption cards
        Goto rightjumploop  
	  
	AvoidLeft:
		MAUD A 1 A_FaceTarget
		TNT1 A 0 ThrustThing(angle*256/360+192, 12, 0, 0)
		MAU4 HGFEDCBA 2 A_FaceTarget
		TNT1 A 0 A_CheckSight("SeeRealNoShield")
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		Goto SeeRealNoShield
		
	AvoidRight:
		MAUD A 1 A_FaceTarget
		TNT1 A 0 ThrustThing(angle*256/360+64, 12, 0, 0)
		MAU4 ABCDEFGH 2 A_FaceTarget
		TNT1 A 0 A_CheckSight("SeeRealNoShield")
		TNT1 A 0 A_PlaySound("metalboot/steps",3)
		Goto SeeRealNoShield

	Pain.LowKick:
	Pain.Kick:
		TNT1 A 0 A_ChangeFlag("NOPAIN", 1)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 1)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 0)
		TNT1 A 0 A_UnSetInvulnerable

		TNT1 AAAA 0 A_TakeInventory("CantUseShotgun", 100)
		TNT1 A 0 A_GiveInventory("MarauderTaunted")
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		TNT1 A 0 A_TakeInventory("IsFiring", 1)
		TNT1 A 0 A_TakeInventory("SKMarauder", 1)
		TNT1 A 0
		TNT1 A 0 ThrustThingZ(0,15,0,1)
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Recoil (3)
		MAUD G 2
		M4BK ABC 2
		MAUD A 0 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		M4BK C 8
		MAUD A 0 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		M4BK D 8 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		MAUD A 0 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		M4BK C 8
		M4BK D 8 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		MAUD A 0 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		M4BK C 8
		M4BK D 8 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		MAUD A 0 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		M4BK C 8
		M4BK D 8 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		MAUD A 0 A_SpawnItem("HeadshotTarget8", 0, 44,0)
		M4BK BA 4
		MAUD G 4
		TNT1 A 0 A_Jump(128,"SeeRealNoShield")
		TNT1 A 0 A_JumpIfInventory("SergeantAmmo",2,"Reload")
		Goto SeeRealNoShield

	Pain.Stun:
		TNT1 A 0 A_ChangeFlag("NOPAIN", 1)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 1)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 0)	
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		TNT1 A 0 A_UnSetInvulnerable
		TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
		MAUD G 7 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
		TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
		MAUD G 7 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
		TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
		MAUD G 7 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
		TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
		MAUD G 7 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
		TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
		MAUD G 7 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
		TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 45,0)
		MAUD G 7 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
		TNT1 A 0 A_TakeInventory("CanBeStunned", 1000)	
		Goto Pain.Avoid	

    Pain.Taunt:
		TNT1 A 0 A_StopSound(6)
        TNT1 A 0 A_PlaySound ("MARTNT",6)
		TNT1 A 0 A_TakeInventory("SKMarauder", 1)
        Goto SeeRealNoShield

	   Pain.Melee:
		MAUD G 2
		TNT1 A 0 A_JumpIfInventory ("SKMarauder", 1, "Death.StealthKill")
	   	TNT1 A 0 A_ChangeFlag("NOPAIN", 1)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 1)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 0)
        Goto ShieldBlock
		
	   Pain.Disintegrate:
	   Pain.Fire:
	   Pain.Flames:
	   Pain.Burn:
	   Pain.GloryFire:
		TNT1 A 0 A_JumpIfInventory("FireAcidAvoid", 1, 5)
		TNT1 A 0 A_GiveInventory("FireAcidAvoid", 1)
		TNT1 A 0 A_ChangeFlag("NOPAIN", 0)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 0)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 1)
		MAU4 A 1
		TNT1 A 0 A_ChangeFlag("NOPAIN", 1)
		TNT1 A 0 A_ChangeFlag("FRIGHTENED", 1)
		TNT1 A 0 A_ChangeFlag("DONTRIP", 0)
		TNT1 A 0 A_ChangeFlag("ALLOWPAIN", 0)
		
		TNT1 A 0 A_Jump(256, "returnfire1", "returnfire1","jumpout")
		returnfire1:
		TNT1 A 0 A_PlaySound("MARAUDJ", 1)
		MAUD W 7 ThrustThing((Random (0, 360)), 20, 0, 0)
		TNT1 A 0 A_PlaySound("MARSMAR", 1)
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_CustomMissile("MarauderAxe",23,0,0,1)
		MAUD U 7 ThrustThing((Random (0, 360)), 20, 0, 0)
		TNT1 A 0 A_Jump(256, "returnfire2", "AvoidLeft","AvoidJumpLeft", "AvoidRight","AvoidJumpRight","HopNRollLeft", "HopNRollRight")
		returnfire2:
		TNT1 A 0 A_PlaySound("MARAUDJ", 1)
		MAUD U 7 ThrustThing((Random (0, 360)), 20, 0, 0)
		TNT1 A 0 A_PlaySound("MARSMAR", 1)
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_CustomMissile("MarauderAxe2",23,0,0,1)
		MAUD W 7 ThrustThing((Random (0, 360)), 20, 0, 0)
		jumpout:
		TNT1 A 0 A_Jump(256, "AvoidLeft","AvoidJumpLeft", "AvoidRight","AvoidJumpRight","HopNRollLeft", "HopNRollRight")		
        Goto Pain.Avoid

	Pain.Siphon:
		TNT1 AAA 0 A_SpawnItemEx ("RedLightning_Small", random (-12, 12), random (-12, 12), random (16, 52), 0, 0)
		MAUD G 1 
		{
			A_FaceTarget;
			A_GiveToTarget("HealthBonus",4);
		}
		MAUD G 5 A_FaceTarget 
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		Goto Pain

	Pain.BloodPunch:
		TNT1 A 0 A_GiveToTarget("BloodPunchKilled",1)
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0	A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		Pain.Bullet:	
		Pain.Freeze:
		Pain.Saw:
		Pain.Cut:
		Pain.Tear:
