	}
}

Actor MarauderAxe2trail: RevanentBeamTrail
{
  RenderStyle Add
  Scale 0.04
  Alpha 1
  +NOINTERACTION
  +NOGRAVITY
    +CLIENTSIDEONLY
  States
  {
  Spawn:
    TNT1 A 0
    TNT1 A 0 A_SetScale(ScaleX+0.32, ScaleY+0.04)
