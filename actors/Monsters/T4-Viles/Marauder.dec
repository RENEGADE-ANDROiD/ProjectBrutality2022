    Death.Fatality:

		TNT1 A 0 A_JumpIfIntargetInventory("FistsSelected", 1, 1)
		Goto Death.ExplosiveImpact
		NULL A 0 A_GiveToTarget("GoFatality", 1)
		NULL A 0 A_GiveToTarget("BF_SetInvulnerablityFix", 1)
		StartFatality:
		TNT1 A 0 A_JumpIfIntargetInventory("FistsSelected", 1, "FatalityContinue1")
		TNT1 A 0 A_TakeInventory("FatalityHited", 100)
		TNT1 A 0 A_Jump (256, "FatalityContinue2")
		FatalityContinue1:
		TNT1 A 0 A_GiveInventory("FatalityHited", 1)
		FatalityContinue2:
		TNT1 A 0		
		NULL A 0 A_ChangeFlag("NOTHRUST", 1)
        NULL A 0 SetPlayerProperty(0,1,0)
		NULL A 0 SetPlayerProperty(0,5,1)
        NULL A 0 ACS_ExecuteAlways(477, 0, 0, 0, 0)//Start Camera
		NULL A 0 ACS_Execute(acsFatality, 0)
	    TNT1 A 0 A_PlaySound("MRDPN", 1)
        TNT1 A 0 A_NoBlocking		
		TNT1 A 0 A_PlaySound("MRDPN", 1)
		TNT1 A 0 A_SpawnItemEx("GloryHightPinataSpawn2",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360))

		NULL A 0
		{
			if(GetCvar(be_HealthBonus)==1)
			{
				if(GetCvar(be_OnlyBerserk)==1)
				{
					if(CountInv("FatalityHited") == 1)
					{
						A_GiveToTarget("HealthBonus",50);
					}
				}
				else
				{
					A_GiveToTarget("HealthBonus",50);
				}
			}
		}
		TNT1 A 0 A_TakeInventory("FatalityHited", 100)
		TNT1 A 0 A_Jump (128, "FatalityMarauder2")
        //////////////////////////////////////////////////////
		TNT1 A 0 A_PlaySound("MSWING")
        MAFA ABC 6 A_SetTics(6 / GetCVar("cl_fatalityspeed"))
        MAFA DE 4 A_SetTics(4 / GetCVar("cl_fatalityspeed"))
		TNT1 A 0 A_PlaySound("weapons/fistwhoosh",1)
		MAFA E 2 A_SetTics(2 / GetCVar("cl_fatalityspeed"))
        MAFA FFF 5 A_SetTics(5 / GetCVar("cl_fatalityspeed"))
		MAFA GG 4 A_SetTics(2 / GetCVar("cl_fatalityspeed"))
		MAFA HI 4 A_SetTics(4 / GetCVar("cl_fatalityspeed"))
		TNT1 A 0 A_PlaySound("MARTNT", 6)
		MAFA IIIIII 6 A_SetTics(6 / GetCVar("cl_fatalityspeed"))
		TNT1 A 0 A_StopSound(6)
		TNT1 A 0 A_CustomMissile ("ShakeShakeShake", 1, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_PlaySound("misc/xdeath4")
        TNT1 A 0 A_PlaySound("gore/headshot",2)
        TNT1 AA 0 A_CustomMissile ("Brains2", 62, -8, random (0, 360), 2, random (0, 160))
        TNT1 AAAA 0 A_CustomMissile ("BloodMistSmall", 58, 0, random (0, 360), 2, random (0, 160))
        TNT1 AAAA 0 A_CustomMissile ("XDeath1", 60, 0, random (0, 360), 2, random (0, 160))
		TNT1 AAAAAAAAA 0 A_CustomMissile ("Teeth", 55, -5, random (0, 360), 2, random (0, 160))
        TNT1 AAAA 0 A_CustomMissile ("SmallLSPart1", 55, 0, random (0, 360), 2, random (0, 360))
		TNT1 AAAA 0 A_CustomMissile ("SmallLSPart3", 57, 0, random (0, 360), 2, random (0, 360))
		TNT1 AAAA 0 A_CustomMissile ("Brutal_LiquidBlood2", 60, -10, random (0, 360), 2, random (60, 120))
		TNT1 A 0 A_CustomMissile ("ShakeShakeShake", 1, 0, random (0, 360), 2, random (0, 160))
		TNT1 A 0 A_CustomMissile ("Brutal_LiquidBlood2", 57, -10, random (0, 360), 2, random (60, 120))
		TNT1 A 0 ACS_Execute(580, 0, 0, 0, 0)
        TNT1 A 0 ACS_Execute(581, 0, 0, 0, 0)
		TNT1 A 0 ACS_Execute(583, 0, 0, 0, 0)
        TNT1 A 0 ACS_Execute(584, 0, 0, 0, 0)
        MAFA JKLM 6 A_SetTics(6 / GetCVar("cl_fatalityspeed"))
