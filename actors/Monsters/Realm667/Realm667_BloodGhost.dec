ACTOR GhostHealthBonus : Health
{
    +COUNTITEM
    +INVENTORY.ALWAYSPICKUP
    Inventory.Amount 1
    Inventory.MaxAmount 200
    Inventory.PickupMessage "$PB_PICKUP_GhostHealthBonus"
    Inventory.PickupSound "Health_Small"
    States
    {
    Spawn:
        GHPK ABCDCB 6 Bright
        Loop
    }
}
