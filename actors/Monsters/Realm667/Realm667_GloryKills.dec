		Stop
	VGF3:
		TNT1 A 0 A_GiveToTarget("ImpFatality6",1)
		Stop
	}
}

ACTOR PB_Realm667_BehemothGK : PB_Realm667_Behemoth Replaces PB_Realm667_Behemoth
{
	WoundHealth 400
	States
	{
	Wound:
		"####" "#" 1
		{
