ACTOR PB_Realm667_BlotGK : PB_Realm667_Blot Replaces PB_Realm667_Blot
{
	WoundHealth 6
	States
	{
	Wound:
		"####" "#" 1
		{
			if(GetCvar("be_ExecutionsON"))
			{
				if(countinv("FinisherToken") == 0)
				{
					A_SpawnItemEx("ImpHighlight",0,0,0,0,0,0,0,SXF_SETMASTER|SXF_NOCHECKPOSITION);
					A_GiveInventory("FinisherToken",1);
					A_GiveToTarget("BloodPunchKilled",1);
				}
				if(GetCvar("be_MonsterStagger")==1)
				{
					return state("Stagger");
				}
				else
				{
					return state(0);
				}
			}
			return state(0);
		}
		Goto See
	Stagger:
		EYES A 0
		{ return state("StagLooper"); }
		Goto StagLooper
	StagLooper:
		"####" "#" 4
		{
			if(!countinv("FinisherToken"))
			{
				return state("See");
			}
			return state(0);
		}
		"####" "#" 0
		Loop
	Death.GloryKill:
		TNT1 A 0 A_GiveToTarget("BPtoken",1)
		Goto Death.Fatality
	Death.Fatality:
		TNT1 A 0 A_Pain
		TNT1 A 0 A_NoBlocking
		TNT1 A 0 A_SpawnItemEx("GloryLowPinataSpawn",0,0,4,random(0,8),0,random(0,8),random(0,360))
		TNT1 A 0 A_GiveToTarget("GoFatality",1)
		// Blot is a tiny eye-blob (EYES sprites). Realm667_FatalityFP1/FP2 play
		// NATT/NZ0D zombieman strips, which look completely wrong as the in-hand
		// victim. No shipped first-person finisher matches an eye-blob shape, so
		// only grant GoFatality (pinata/kill credit) and let the player's
		// FatalityChecker fall through to See -- no humanoid animation.
		Stop
	}
}

