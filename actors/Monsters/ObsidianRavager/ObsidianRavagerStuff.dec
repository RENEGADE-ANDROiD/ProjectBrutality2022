Actor ChaosBarrage : ChaosBall
{
  Radius 2
  Height 2
  Damage (random(10,12) * 2)
  Scale 0.05
  Decal "Scorch"
  Missiletype "ChaosBarrageTrail"
  States
	{
	Spawn:
		TNT1 A 6
		TNT1 A 0 BRIGHT A_NoGravity
		TNT1 A 0 BRIGHT A_SeekerMissile(1, 2)
		loop
	
	Death:
		TNT1 A 0 A_SpawnItem("HellRifle_Puff",0)
		TNT1 A 0 A_SpawnItem("RedFlare",0)
		TNT1 AAA 0 A_SpawnItemEx("ExplosionParticleVerySlow", random(-8, 8), random(-8, 8), random(-2,2), 0, 0, 0, 0, 128, 0)
		TNT1 AAA 0 A_SpawnItemEx("ObeliskTrailSpark", random(-8, 8), random(-8, 8), random(-2,2), 0, 0, 0, 0, 128, 0)
		TNT1 A 4
		TNT2 AAA 3 A_SpawnProjectile ("PlasmaSmoke", 1, 0, random (0, 360), 2, random (0, 160))
		Stop
		}
 }

Actor ChaosBarrageNoGrav : ChaosBarrage
{
  +NOGRAVITY
}

Actor ChaosBarrageDGrav : ChaosBarrage
{
  Gravity 1.3
}


Actor ChaosBallTrail
{
  RenderStyle Add
  Alpha 1
  Scale 0.6
  +NOGRAVITY
  +RANDOMIZE
  +ROLLSPRITE
  States
	{
	Spawn:
		DB60 E 1 BRIGHT 
	Trolololo:
		TNT1 A 0 A_SetScale(ScaleX -0.1, ScaleY -0.1)
		TNT1 A 0 A_SetRoll(random(0,360))
		DB60 F 1 bright //A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.1, ScaleY -0.1)
		TNT1 A 0 A_SetRoll(random(0,360))
		DB60 G 1 bright //A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.1, ScaleY -0.1)
		TNT1 A 0 A_SetRoll(random(0,360))
		DB60 H 1 bright //A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.1, ScaleY -0.1)
		TNT1 A 0 A_SetRoll(random(0,360))
		DB60 I 1 bright //A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.1, ScaleY -0.1)
		TNT1 A 0 A_SetRoll(random(0,360))
		DB60 J 1 bright //A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.1, ScaleY -0.1)
		TNT1 A 0 A_SetRoll(random(0,360))
		DB60 K 1 bright //A_FadeOut(0.1)
		Stop
		}
 }

Actor ChaosBarrageTrail : ChaosBallTrail
{
  Scale 0.06
  States
	{
	Spawn:
		PBAL HI 1 BRIGHT 
	Trolololo:
		TNT1 A 0 A_SetScale(ScaleX -0.01, ScaleY -0.01)
		PBAL I 1 bright A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.01, ScaleY -0.01)
		PBAL I 1 bright A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.01, ScaleY -0.01)
		PBAL I 1 bright A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.01, ScaleY -0.01)
		PBAL I 1 bright A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.01, ScaleY -0.01)
		PBAL I 1 bright A_FadeOut(0.1)
		TNT1 A 0 A_SetScale(ScaleX -0.01, ScaleY -0.01)
		PBAL I 1 bright A_FadeOut(0.1)
		Stop
		}
 }

ACTOR ObsidianChunk
{
    Radius 8
    Height 8
	Mass 1
    Scale 0.3
	Speed 7
	Gravity 0.5
	BounceFactor 0.4
	+DOOMBOUNCE
	+MISSILE
    +MOVEWITHSECTOR
    +CLIENTSIDEONLY
    +NOBLOCKMAP
    +NOTELEPORT
	+THRUACTORS
    States
    {
    Spawn:
		TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
		VOBC ABCDEFGH 4
        Loop

	Death:
        VOBC H 200
        Stop
    }
}


Actor ObsidianTrap1
{
  Scale 0.4
  Radius 4.5
  Height 26
  DeathSound "Obsidian/TrapDeath"
  Health 30
  +NOTELEPORT
  +SOLID
  +SHOOTABLE
  +DONTTHRUST
  +NOBLOODDECALS +NOBLOOD
  //BloodType "ObsidianChunk"
  Species "ObsidianRavager"
  States
	{
	Spawn:
		VOT1 ABC 2
		Goto See
	See:
		VOT1 DDDD 32
		Goto Death
	Death:
		TNT1 AAA 0 A_SpawnProjectile ("ObsidianChunk", 5, 0, random (0, 360), 2, random (0, 160),SXF_NOCHECKPOSITION)
		VOT1 C 3 A_Scream
		VOT1 BA 3
		stop
		}
 }
 
Actor ObsidianTrap2 : ObsidianTrap1
{
  States
	{
	Spawn:
		VOT2 ABC 2
		Goto See
	See:
		VOT2 DDDD 32
		Goto Death
	Death:
		VOT2 C 3 A_Scream
		VOT2 BA 3
		TNT1 A 0
		stop
		}
 }
 
Actor ObsidianTrap3 : ObsidianTrap1
{
  States
	{
	Spawn:
		VOT3 ABC 2
		Goto See
	See:
		VOT3 DDDD 32
		Goto Death
	Death:
		VOT3 C 3 A_Scream
		VOT3 BA 3
		TNT1 A 0
		stop
		}
 }
 
Actor ObsidianTrap4 : ObsidianTrap1
