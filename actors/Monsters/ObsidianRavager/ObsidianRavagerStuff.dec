ACTOR CrystalSlowCurse : PowerSpeed
{
  Speed 0.5
}

actor ObsidianCrystalSlowBonus : PowerupGiver
{
  Game Doom
  inventory.pickupmessage "It became very difficult for you to move ..."
  inventory.maxamount 0
  powerup.duration -1
  powerup.type "CrystalSlowCurse"
  -COUNTITEM
  +INVENTORY.AUTOACTIVATE
  +INVENTORY.ALWAYSPICKUP
}


ACTOR ObsidianCrystalA01
{
  Tag "Infernal Crystal"
  Radius 13
  Height 45
  Speed 0
  Health 50
  MeleeRange 200
  Scale 0.5
  Mass 100000
  MONSTER
  +THRUACTORS
  +NOINFIGHTING
  +NOTARGET
  +NOICEDEATH
  +MISSILEEVENMORE
  +THRUSPECIES
  +MTHRUSPECIES
  +DONTHURTSPECIES
  +DONTHARMSPECIES
  -BOSS
  -BOSSDEATH
  +NOFEAR
  +NOPAIN
  -DONTRIP
  +NOBLOODDECALS
  +NOBLOOD
  +MISSILEMORE
  +LOOKALLAROUND
  -Countkill
  Species "ObsidianRavager"
  Obituary "%o was too close to the infernal crystal"
  states
    {
	Spawn:
		TNT1 A 5
		TNT1 A 0 A_ScaleVelocity(0)
		TNT1 A 0 A_ClearTarget
		TNT1 A 0 A_ChangeFlag("THRUACTORS", 0)
	Goto RealSpawn

	RealSpawn:
		TNT1 A 0 A_ChangeFlag("NORADIUSDMG", 1)
		TNT1 A 0 A_Explode(6,90,0)
		TNT1 A 0 A_Playsound("Obsidian/TrapSpawn", 1)
		TNT1 A 0 Radius_Quake (2, 24, 0, 15, 0)  
		TNT1 AAAAA 0 A_SpawnProjectile ("ExplosionSmokeFast22", 0, 0, random (0, 360), 2, random (0, 360))
		TNT1 AAAAA 0 A_SpawnProjectile ("ChaosBallSuperPlasmaFire", 0, 0, random (0, 360), 2, random (0, 360))
		TNT1 AAAA 0 A_SpawnProjectile ("ChaosBallPlasmaFireSmall2", 0, 0, random (0, 360), 2, random (0, 360))
		TNT1 A 0 A_SpawnItem("RedFlare" ,0)
		TNT1 A 0 Light("Shadowball")
		V02A ABC 1 Bright
		TNT1 A 0 A_ChangeFlag("NORADIUSDMG", 0)
	SpawnReal:
		TNT1 A 0
		V02A D 5 Bright Light("Shadowball") A_Look
		Loop

	See:
		TNT1 A 0
		V02A D 5 Bright Light("Shadowball")
		{
		A_Chase;
		}
		TNT1 A 0 A_StopSound(7)
		loop
		
	Melee:
		V02A D 5 Bright Light("Shadowball")
		{
		A_FaceTarget;
		A_PlaySound("LGLoop", 7, 1, 1);
		A_SpawnItemEx("HSTracer", 0, random(-20,20), random(15,45));
		A_GiveToTarget ("ObsidianCrystalSlowBonus", 1);
		}
		Goto See

	Death.Crucible:
		TNT1 A 0 A_SpawnItemEx("GlorySawPinataPretty",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360))
		Goto Death	
		
	Death.GloryFire:
		TNT1 A 0 A_SpawnItemEx("FlamePinataSpawn",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360))
		Goto Death
   
	Death.BloodPunch:
		TNT1 A 0 A_GiveToTarget("BloodPunchKilled",1)
		TNT1 A 0 A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0 A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0 A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0 A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0 A_SpawnItemEx("GlorySawPinataPretty",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360))
		Goto Death
   
	Pain.GloryFire:
		TNT1 A 0 A_Jump(192, "See")
		TNT1 A 0 A_SpawnItemEx("FlamePinataSpawn",0,0,Height / 2,random(0,8),0,random(0,8),random(0,360))
		Goto See  
		
	Pain.BloodPunch:
		TNT1 A 0 A_GiveToTarget("BloodPunchKilled",1)
		TNT1 A 0 A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0 A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0 A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		TNT1 A 0 A_SpawnItemEx("BloodpunchWave", 0, 0, Height / 2, 0, 0, 0, 0, SXF_CLIENTSIDE|SXF_TRANSFERPITCH)
		Goto See

	Death:
		TNT1 A 0 A_NoBlocking
		TNT1 A 0 A_PlaySound ("IceBreakSmall")
		TNT1 A 0 A_SpawnProjectile ("ObsidianCrystalsRedBlackDustMed", 5, 0, random (0, 360), 2, random (0, 160), SXF_NOCHECKPOSITION)
		Stop
		}
 }

