 }
 
ACTOR ChaosBallBig
{
  Radius 5
  Height 5
  Speed 22
  Damage (random(10,12) * 3)
  Scale 0.4
  Projectile
  Gravity 0.2
  Renderstyle Add
  -NOGRAVITY
  +SEEKERMISSILE
  +RANDOMIZE
  +ROLLSPRITE
  DeathSound "Obsidian/Impact"
  Decal "Scorch"
  Scale 0.5
  States
	{
	Spawn:
		PBAL HIHIHI 1 BRIGHT light("Shadowball")
		{
		A_SpawnItem ("ChaosBallTrail", 0, random( -2, 2));
		A_SpawnItem("RedFlare22", 15);
		A_SpawnItem("HSTracer", 25);
		A_SpawnItemEx("ChaosBallTrail", 0, 0, 0, 0, 0, 0, 0, SXF_TRANSFERTRANSLATION|SXF_TRANSFERPOINTERS);
		A_SeekerMissile(1, 2);
		}
		TNT1 A 0 A_NoGravity
		Loop
		
	Death:
		TNT1 A 0 A_ChangeFlag("SHOOTABLE", 0)
		TNT1 A 0 A_StopSound(1)
		TNT1 A 0  {
		A_SpawnItemEx ("ChaosBallBigExplosion",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);
		A_StopSound(CHAN_BODY);
		A_StartSound("FAREXPL", CHAN_AUTO|CHANF_OVERLAP);
		Radius_Quake (3, 8, 0, 15, 0);
		A_SpawnItemEx ("DetectFloorCrater",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);
		A_SpawnItemEx ("DetectCeilCrater",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);
		A_SpawnItemEx ("ExplosionRedFlareSpawner",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);
		A_SpawnItemEx ("LiquidExplosionEffectSpawner",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0);
		A_SpawnProjectile ("ExplosionSmokeFast22", 0, 0, random (0, 360), 2, random (0, 360));
		A_SpawnProjectile ("ExplosionSmokeFast22", 0, 0, random (0, 360), 2, random (0, 360));
		A_SpawnProjectile ("ExplosionSmokeFast22", 0, 0, random (0, 360), 2, random (0, 360));
		A_SpawnProjectile ("MediumExplosionRedFlames", 0, 0, random (0, 360), 2, random (0, 360));
		A_SpawnProjectile ("MediumExplosionRedFlames", 0, 0, random (0, 360), 2, random (0, 360));
		A_SpawnProjectile ("MediumExplosionRedFlames", 0, 0, random (0, 360), 2, random (0, 360));
		A_SpawnProjectile ("PBExplosionparticles", 0, 0, random (0, 360), 2, random (40, 90));
		A_SpawnProjectile ("PBExplosionparticles", 0, 0, random (0, 360), 2, random (40, 90));
		A_SpawnProjectile ("PBExplosionparticles2", 0, 0, random (0, 360), 2, random (40, 90));
		A_SpawnProjectile ("PBExplosionparticles2", 0, 0, random (0, 360), 2, random (40, 90));
		A_SpawnProjectile ("PBExplosionparticles3", 10, 0, random (0, 360), 2, random (40, 90));
		A_SpawnItemEx("ChaosBallBigBlastWave", 0, 0, 1, 0, 0, 0, 0, SXF_NOCHECKPOSITION);
		}
		EXPL AAAAA 0 A_SpawnProjectile ("ExplosionSmokeFast22", 0, 0, random (0, 360), 2, random (0, 360))
		TNT1 AAAAA 0 A_SpawnProjectile ("ChaosBallSuperPlasmaFire", 0, 0, random (0, 360), 2, random (0, 360))
		TNT1 AAAA 0 A_SpawnProjectile ("ChaosBallPlasmaFireSmall2", 0, 0, random (0, 360), 2, random (0, 360))
		TNT1 AAAAAAAAAAAAAAAAA 0 A_SpawnProjectile ("ChaosBallPlasmaParticle", 0, 0, random (0, 360), 2, random (0, 360))
		TNT1 AAAAA 0 BRIGHT A_SpawnItem("RedFlare22" ,0)
		TNT1 A 1 Light("Shadowball")
		TNT1 A 25
		Stop
		}
 }

