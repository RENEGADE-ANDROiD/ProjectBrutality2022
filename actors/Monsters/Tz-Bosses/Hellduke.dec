//==============================================================================
//=================================HELLDUKE=====================================

ACTOR Hellduke : Cyberdemon
{

  Health 5000
  Tag "Hellduke"
  SeeSound "Monsters/DKSEE"
  PainSound "TYRPAI"
  DeathSound "Monsters/DKDIE"
  ActiveSound "TYRACT"
  Obituary "%o was blasted away by the Hellduke."
  var float user_LaunchAngle;
  MeleeRange 64
  Painchance 10
  Mass 2000
  damagefactor "BFG", 0.38
  DamageFactor "Plasma", 0.75
  DamageFactor "Desintegrate", 0.38
  DamageFactor "GreenFire", 0.38
