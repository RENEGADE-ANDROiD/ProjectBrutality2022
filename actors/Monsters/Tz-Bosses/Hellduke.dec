Actor GrenadeBoom	//Smoke, which spawns the explosion FX; it has to be in this order to draw "explo" on top of the "smoke" in-game
{
	+NOINTERACTION
	+FORCEXYBILLBOARD
	+CLIENTSIDEONLY
	RenderStyle Translucent
	Scale 0.8
	Alpha 0.75
	Decal "burnScorch"
	States
	{
	Spawn:
		TNT1 A 0 Nodelay A_SpawnItemEx("RocketExplosionNew",0,0,0, 0,0,0,0, SXF_NOCHECKPOSITION)
		TNT1 A 0 A_SpawnItemEx("GrenadeLaunchShockwave",0,0,0, 0,0,0,0, SXF_NOCHECKPOSITION)
		TNT1 A 0 A_Jump(128,"Flip")
		Goto PlayOff
	Flip:
		TNT1 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	PlayOff:
		D4X4 ABCDEFGHIJKLMNOP 1 Bright
		D4X4 QRSTUVWXYZ 1 Bright A_FadeOut(0.075)
		Stop
	}
}

Actor GrenadeExploDebris 
{
	+NOINTERACTION
	+FORCEXYBILLBOARD
	+CLIENTSIDEONLY
	RenderStyle Add
	Scale 1.0
	Translation "0:255=%[0,0,0]:[1,1,2]"
	States
	{
	Spawn:
		TNT1 A 0 
		TNT1 A 100  A_Jump(255,"T1","T2","T3","T4","T5","T6","T7","T8")
		Goto PlayOff
	T1:	
		DFL1 A 0 
		Goto PlayOff
	T2:
		DFL2 A 0 
		Goto PlayOff
	T3:
		DFL3 A 0 
		Goto PlayOff
	T4:	
		DFL4 A 0 
		Goto PlayOff
	T5:	//Flipped X
		DFL1 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	T6:
		DFL2 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	T7:
		DFL3 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	T8:	
		DFL4 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	PlayOff:	//normal
		"####" BCEFGIJKLMNOPQRSTUVWXYZ 1 Bright
		Stop
	}
}

