}

Actor DukeGrenadelauncher
{
	var int user_timer;
	PROJECTILE
	+CANBOUNCEWATER
	-NOGRAVITY
	+FORCERADIUSDMG
	+EXTREMEDEATH
	+SEEKERMISSILE
	Radius 4
	Height 9
	Damage 0
	Speed 40
	Mass 0
	Gravity 0.10
	ReactionTime 1	//hard measure to make it explode
	BounceType "Hexen"
	SeeSound "weapon/grenade"
	Activesound "Activegren"
	BounceSound "weapon/grenade"
	DeathSound "Explosion"
	Decal "burnScorch"
	BounceFactor 0.35
	WallBounceFactor 0.35
	+USEBOUNCESTATE
	+MTHRUSPECIES
	Scale 0.5
	Translation "80:111=%[0,0,0]:[1,0.5,0]"
	States
	{
	Spawn:
		TNT1 A 0 NoDelay ThrustThingZ(0,7,0,1)
		GRNL A 1 Bright A_SpawnItemEx("GrenadeTrail",0,0,0, 0,0,0, 0, SXF_NOCHECKPOSITION)
		Wait
		
		Bounce:	//once it bounces, it starts the fuse that lasts very little
			GRNL A 0 A_ChangeFlag("USEBOUNCESTATE",0)
			GRNL A 0 A_SpawnItemEx("GrenadeTrail",0,0,0, 0,0,0, 0, SXF_NOCHECKPOSITION)
			GRNL A 1 
			Goto Counter
	Counter:
		GRNL A 0 A_JumpIf(user_timer>=20,"TimedOut")
		GRNL A 0 A_SetUserVar(user_timer,user_timer+1)
		GRNL A 1 A_SpawnItemEx("GrenadeTrail",0,0,0, 0,0,0, 0, SXF_NOCHECKPOSITION)
		Loop
		
	TimedOut:
		TNT1 A 0 A_Stop
		TNT1 A 0 A_StopSound(6) //stops the "arm" sound
		TNT1 A 0 A_ChangeFlag("NOINTERACTION",1)
		TNT1 AA 0 A_CountDown //reactiontime is 1, so it dies fast
		TNT1 A 1 A_CountDown  //but added a few for netgame rando-bugs prevention
		Wait
		
	Death:
		TNT1 A 0 A_SeekerMissile(0,0,SMF_LOOK|SMF_CURSPEED,256)
		TNT1 A 0 A_JumpIfTargetInLOS("XDeath",360,JLOSF_PROJECTILE,170)
		TNT1 A 100 A_Jump(256,"DeathCont") //for virtual jump to inherited versions
		Goto DeathCont
		
	Xdeath:	//Direct hit
		TNT1 A 100 A_Jump(256,"DeathCont") //for virtual jump to inherited versions
		Goto DeathCont
		
	DeathCont:
		TNT1 A 0 A_Quake(2,27,0,512)
		TNT1 A 0 A_Explode(80,128,1)
		TNT1 A 0 A_Explode(11*random(4,8),32,0,0,32) //this replaces projectile damage, no self harm, always deals it to monsters
		TNT1 A 0 A_SpawnItemEx("RocketExplosionNew",0,0,0, 0,0,0,0, SXF_NOCHECKPOSITION)
		TNT1 A 0 A_SpawnItemEx("GrenadeBoom",0,0,0, 0,0,0,0, SXF_NOCHECKPOSITION)
		TNT1 A 10
		Stop
	}
}

