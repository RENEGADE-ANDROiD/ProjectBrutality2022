  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  States
  {
  Spawn:
    DUKE A 0 
    DUKE A 1 A_SetInventory("HelldukeArmor",1) //gives 2000 armor.
    DUKE AB 10 A_Look
    Goto Spawn+2
  See:
    TNT1 A 0 A_PlaySound("TYRHOOF",CHAN_5)
    DUKE A 3 A_Hoof
	DUKE ABB 3 A_Chase
	TNT1 A 0 A_PlaySound("TYRHOOF",CHAN_5)
	DUKE C 3 A_Hoof
    DUKE CDD 3 A_Chase
    Loop
  Missile:
    TNT1 A 0 A_Jump(256,"Missile1","Missile2","Missile4","Missile5","DodgeLeft","DodgeRight")
	DodgeLeft:
	TNT1 A 0 A_ChangeFlag("NODROPOFF",true)
	DUKE E 1 A_FaceTarget
	TNT1 A 0 A_PlaySound("DUKESLIDER",CHAN_6)
	DUKE E 0 ThrustThing (angle*256/360+192, 20,0,0)
	DUKE EEEEEEEEEEEEEEEEEE 1
	{
	A_SpawnItemEx("OrangeFlareSmall",0,40,5,random(-5,5),random(-5,5),random(1,8),0,SXF_NOCHECKPOSITION);
	A_SpawnItemEx("OrangeFlareSmall",0,-40,5,random(-5,5),random(-5,5),random(1,8),0,SXF_NOCHECKPOSITION);
	}
	DUKE EE 2 A_FaceTarget
	TNT1 A 0 A_ChangeFlag("NODROPOFF",false)
	Goto Missile1
	DodgeRight:
    TNT1 A 0 A_ChangeFlag("NODROPOFF",true)
	DUKE E 1 A_FaceTarget
    TNT1 A 0 A_PlaySound("DUKESLIDER",CHAN_6)
	DUKE E 0 ThrustThing (angle*256/360+64, 20,0,0)
