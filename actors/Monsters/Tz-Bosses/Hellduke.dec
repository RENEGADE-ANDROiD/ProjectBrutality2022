	TNT1 AAA 0 A_CustomMissile ("ExplosionSpawner", 10, 0, random (0, 360), 2, random (0, 360))
    TNT1 AAA 0 A_CustomMissile ("UltraGoreSPawner", 80, 0, random (0, 360), 2, random (0, 180))
    TNT1 AAA 0 A_CustomMissile ("BloodMistXXBig", 90, 0, random (0, 360), 2, random (70, 90))
	TNT1 AAAAAA 0 A_CustomMissile ("PB_SmallGib", 32, 0, random (150, 210), 2, random (0, 40))
	TNT1 AAA 0 A_SpawnItemEx("NewExplosionFlare")
	TNT1 AAA 0 A_SpawnItemEx("DragonsBreathFlare")
	TNT1 AAA 0 A_SpawnItemEx("OrangeExplosionFlare")
	TNT1 AAA 0 A_SpawnItemEx("IncendiaryGrenadeExplosion")
