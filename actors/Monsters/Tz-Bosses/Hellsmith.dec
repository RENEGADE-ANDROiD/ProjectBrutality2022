// Explosion actors
//-------------------------------------------------
// Implode effect
Actor SupershotImploder
{
    Damage 0
	+NOINTERACTION
	+CLIENTSIDEONLY
	+NONETID
	+FORCEXYBILLBOARD
	RenderStyle Add
	Alpha 1
	scale 1.5
	Translation "0:255=%[0.08,0.2,0.08]:[0.0,1.8,0.0]"
	States
	{
	Spawn:
		TNT1 A 0 NODELAY A_Jump(256,"T1","T2")
	T1:
		DB45 A 0
		Goto EndAnim
	T2:
		DB46 A 0
		Goto EndAnim
	EndAnim:
		"####" AC 1 Bright Light("GreenBigPoint2")
		"####" EG 1 Bright Light("GreenMediumPoint1")
		"####" IK 1 Bright Light("GreenMediumPoint2")
		"####" MO 1 Bright Light("GreenMediumPoint3")
		"####" QS 1 Bright Light("GreenSmallPoint1")
		"####" UW 1 Bright Light("GreenSmallPoint2")
		"####" Y 1 Bright Light("GreenSmallPoint3")
		//ACEGIKMOQSUWY
		Stop
	}
}
// explosion shockwave
Actor SupershotExploRing
{
    Damage 0
	+NOINTERACTION
	+CLIENTSIDEONLY
	+FORCEXYBILLBOARD
	RenderStyle Add
	Alpha 1.0
	scale 3.5
	Translation "0:255=%[0,0,0]:[0.0,1.8,0.0]"
	States
	{
