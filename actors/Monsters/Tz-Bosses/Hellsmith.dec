Actor SupershotfogLightning 
{
    Damage 0
	+NOINTERACTION
	+CLIENTSIDEONLY
	var int user_counter;
	RenderStyle Add
	Alpha 0.99
	scale 0.65
	States
	{
	Spawn:
		TNT1 A 0 NODELAY A_Jump(200,2,3,4,5,6,7,8)	//for sliiiigh randomization of when it spawns
		TNT1 AAAAAAAAAA 1
		TNT1 A 0 A_Jump(256,"T1","T2","T3","T4","T5")
		
		T1:	DLI1 A 0 
			Goto PlayOff
		T2:	DLI2 A 0 
			Goto PlayOff
		T3:	DLI3 A 0 
			Goto PlayOff
		T4:	DLI4 A 0 
			Goto PlayOff
		T5:	DLI5 A 0 
			Goto PlayOff
		
	PlayOff:
		"####" A 0 A_Jump(128,"FromL")
		
		FromA:
			"####" ABCDE 1 Bright
			"####" FGHIJK 1 Bright
			Goto Repeater
		FromL:
			"####" LMNOP 1 Bright
			"####" QRSTUV 1 Bright
			Goto Repeater
		
	Repeater:
		TNT1 A 0 A_JumpIf(user_counter>=2,"Destroy")
		TNT1 A 0 A_SetUserVar(user_counter,user_counter+1)
		Goto Spawn
		
	Destroy:
		TNT1 A 5
		Stop
		
	}
}

Actor Argentsuperball
{
    Speed 40
	Scale 0.6
	Projectile 
    Damage (100)
    DamageType "Desintegrate"
    Seesound "HELLSSFIRE"
    DeathSound "HELLSSIMPA"
    Decal "BiggerPLASMAScorch"
	+FORCERADIUSDMG
	+THRUSPECIES
	+MTHRUSPECIES
	+DONTHURTSPECIES
	+DONTHARMSPECIES
    +ThruGhost
    +ForceXYBillBoard
    +Bright
    States
    {
	  DM:
		TNT1 A 0
		TNT1 A 0 A_ChangeFLag("THRUSPECIES", 0)
		TNT1 A 0 A_ChangeFLag("MTHRUSPECIES", 0)
		Goto Spawn
	
    Spawn:
	    TNT1 A 0
		TNT1 A 0 A_Playsound("ASBFLY",6 ,1,1)
        HFR1 ABCDEFGHIJKLMNOPQR 1 Bright A_SetTranslucent(0.90, 1)
        HFR1 A 0 Bright 
		NULL AAAAA 0 A_SpawnItemEx("ArgentParticleShort", 0,0,6, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
        Loop

    Death:
        NULL A 0 A_SpawnItem("ArgentsuperballImpact")
		NULL AAAAAAAAAAAA 0 A_SpawnItemEx("ArgensuperballParticle", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
	    NULL AAAAAAAAAAAA 0 A_SpawnItemEx("ArgensuperballParticle", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
	    NULL AAAAAAAAAAAA 0 A_SpawnItemEx("ArgensuperballParticle", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
	    NULL AAAAAAAAAAAA 0 A_SpawnItemEx("ArgensuperballParticle", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
		TNT1 A 0 A_Quake(5, 40, 0, 512)
		stop
	}
}

