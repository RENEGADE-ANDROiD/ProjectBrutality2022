		TNT1 A 0 A_SpawnItemEx("SupershotExploRing",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		TNT1 A 0 A_SpawnItemEx("SupershotClassicExplo",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		TNT1 A 0 A_SpawnItemEx("BFGDecalSprayer",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		NULL AAAAAAAAAAAA 0 A_SpawnItemEx("SupershotParticle", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
	    NULL AAAAAAAAAAAA 0 A_SpawnItemEx("SupershotParticle", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
	    NULL AAAAAAAAAAAA 0 A_SpawnItemEx("SupershotParticle", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
	    NULL AAAAAAAAAAAA 0 A_SpawnItemEx("SupershotParticle", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION)
		TNT1 A 0 A_Explode(2,3,0,0,true)
		TNT1 A 0 A_BFGSpray("SupershotfogLightning",40,10)
		TNT1 A 2
		TNT1 AAA 1 A_SpawnItemEx("SupershotExploLightning",0,0,0,0,0,0,0,32)
		Stop
	}
}

