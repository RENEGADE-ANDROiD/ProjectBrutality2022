Actor Argentplasmablast
{
  Radius 16
  Height 8
  Speed 40
  Damage (80)
  Projectile
  +RANDOMIZE
  +ForceXYBillboard
  +FORCERADIUSDMG
  +CLIENTSIDEONLY
  +THRUGHOST
  +THRUSPECIES
  +MTHRUSPECIES
  +DONTHURTSPECIES
  +DONTHARMSPECIES
  +FULLVOLDEATH
  +FULLVOLACTIVE
  RenderStyle Add
  Alpha 0.95
  scale 0.09
  ActiveSound "DSAPBFLY"
  SeeSound "APBLASTFIR"
  DeathSound "APBLASTIMP"
  DamageType "SuperPlasma"
  Decal "BigPLASMAScorch"
  States
  {
  DM:
	TNT1 A 0
	TNT1 A 0 A_ChangeFLag("THRUSPECIES", 0)
	TNT1 A 0 A_ChangeFLag("MTHRUSPECIES", 0)
	Goto Spawn
  
  Spawn:
    APLB ABCDEF 1 bright {
		A_SpawnItemEx("ArgentParticleShort", 0,0,0, (Random(-5,5)), (Random(-5,5)), (Random(-5,5)), 0, SXF_ABSOLUTEMOMENTUM|SXF_NOCHECKPOSITION);
		A_SpawnItemEx("ArgentPlasmaBlastTrail", (-2/10), 0, 0, 0, 0, 0, 0, 160);
