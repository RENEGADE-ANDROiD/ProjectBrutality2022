    RenderStyle NONE
	Alpha 0.85
	PROJECTILE
    +FLOORHUGGER
    +NOCLIP
	states
	{
	Spawn:
           TNT1 A 1
           TNT1 A 0 A_CustomMissile("PentaLine2",0,0,-198,2)
           TNT1 A 0 A_CustomMissile("PentaLine2",0,0,198,2)
	   stop
	}
}

