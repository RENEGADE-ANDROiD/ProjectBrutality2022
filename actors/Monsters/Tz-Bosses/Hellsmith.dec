ACTOR HSPentagramSpawner : PentagramSpawner
{
	Game Doom
    +NOBLOCKMAP
    +NOTELEPORT
    +DONTSPLASH
	+FORCEXYBILLBOARD
    +CLIENTSIDEONLY
    +NOCLIP
	-NOGRAVITY
	+FLOORHUGGER
	+Bright
	RenderStyle Add
    XScale 0.5
	YScale 0.05
	Alpha 0.75
	Gravity 1
	Radius 1
	Height 1
	States
	{
    Spawn:
        TNT1 A 1
		TNT1 AAAAA 2 A_SpawnItem("BurningHSPentagram")
		TNT1 A 10
		TNT1 A 1 A_SpawnItem("HSPentagramOff")
		TNT1 A 1
        Stop
	}
}

