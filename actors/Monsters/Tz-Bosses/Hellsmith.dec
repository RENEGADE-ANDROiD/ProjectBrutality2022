Actor RocketTrailSmoke	//centered smoke
{
	+CLIENTSIDEONLY
	+NONETID
	+NOINTERACTION
	+FORCEXYBILLBOARD
	RenderStyle Translucent
	Alpha 0.2
	Scale 0.2
	States
	{
	Spawn:
		TNT1 A 0 NoDelay A_Jump(256,1,2,3,4)
		X037 A 0 A_SetScale(frandom(0,0.2)) Goto Missile
		X037 B 0 A_SetScale(frandom(0,0.2)) Goto Missile
		X037 C 0 A_SetScale(frandom(0,0.2)) Goto Missile
		X037 D 0 A_SetScale(frandom(0,0.2)) Goto Missile
	Missile:
		"####" "#" 1 A_SetScale(ScaleX+0.03)	"####" "#" 0 A_FadeIn(0.02)
		"####" "#" 1 A_SetScale(ScaleX+0.03)	"####" "#" 0 A_FadeIn(0.02)
		"####" "#" 1 A_SetScale(ScaleX+0.03)	"####" "#" 0 A_FadeIn(0.02)
		"####" "#" 1 A_SetScale(ScaleX+0.03)	"####" "#" 0 A_FadeIn(0.02)
		"####" "#" 1 A_SetScale(ScaleX+0.03)	"####" "#" 0 A_FadeIn(0.02)
		"####" "#" 1 A_SetScale(ScaleX+0.03)	"####" "#" 0 A_FadeIn(0.02)
		"####" "#" 1 A_SetScale(ScaleX+0.03)	"####" "#" 0 A_FadeIn(0.02)
		"####" "#" 1 A_SetScale(ScaleX+0.03)	"####" "#" 0 A_FadeIn(0.02)
		Goto Continue
	Continue:
		"####" "#" 1 A_FadeOut(0.018)
		"####" "#" 1 A_SetScale(ScaleX+0.02)
		Loop
	}
}

ACTOR HellsmithHeavyRocket
{
	Radius 8
	Height 8
	Scale 0.9
	Damage (50)
	Speed 40
	Projectile 
	Decal "burnScorch"
	+BRIGHT 
	+RANDOMIZE
	+DONTHURTSPECIES
	+DONTHARMSPECIES
	RenderStyle Normal
	SeeSound "TYRFIR"
	DeathSound "TYMEXP"
	DamageType "ExplosiveImpact"
	
	States
	{
	Spawn:
		TYM1 AAABBB 1 Light(YellowMediumPoint2) Bright A_SpawnItemEx("RocketTrailFire",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		TYM1 AAABBB 1  Light(YellowMediumPoint2) Bright A_SpawnItemEx("RocketTrailFire",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		TYM1 AAABBB 1  Light(YellowMediumPoint2) Bright A_SpawnItemEx("RocketTrailFire",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		TYM1 AAABBB 0 A_SpawnItemEx("RocketTrailSmoke",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		Goto Spawn+1
		
	Death:
		TNT1 A 0 
		{
		A_Explode(20,200);
		Radius_Quake (2, 54, 0, 25, 0);
		}
		TNT1 A 0 A_SpawnItemEx("RockExplShockwave",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		TNT1 A 0 A_SpawnItemEx("RocketExploDebris",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
		TNT1 A 0 A_SpawnItemEx("RocketExplosionNew",0,0,0, 0,0,0,0, SXF_NOCHECKPOSITION)
		TNT1 AAA 0 A_CustomMissile ("FlyingBurningFuel", 24, 0, random (150, 210), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("FlyingBurningFuel2", 24, 0, random (150, 210), 2, random (0, 40))
		TNT1 AA 0 A_CustomMissile ("FlyingBurningFuel3", 24, 0, random (150, 210), 2, random (0, 40))
		TNT1 A 10 
        TNT1 A 0 A_Jump(256, "RocketExploFXSpawner")
        stop
	   }
}

