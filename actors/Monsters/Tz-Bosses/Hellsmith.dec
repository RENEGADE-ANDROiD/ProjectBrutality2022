{
	States
	{
    Spawn:
        TNT1 A 0
		HSPG AAAAAAAAAAAAAAAAAAAAAAA 1 A_FadeIn(0.02)
		HSPG AAAAAAAAAAAAAAAAAAAAAAA 1 A_FadeOut(0.02)
        Stop
	}
}

