//==============================================================================
//================================HELLSMITH=====================================

ACTOR Hellsmith : Cyberdemon
{
  Health 8000
  Height 170
  Radius 72
  Speed 25
  PainChance 16  
  Damage 50
  MeleeRange 110
  MaxStepHeight 56
  MaxDropOffHeight 56
  Mass 4000
  Tag "The Hellsmith"
  SeeSound "hellsmith/sight"
  ActiveSound "hellsmith/active"
  PainSound "hellsmith/pain"
  DeathSound "hellsmith/death"  
  Obituary "%o was no match for the Hellsmith."
  Hitobituary "%o was crushed by the Hellsmith." 
  damagefactor "BFG", 0.38
  DamageFactor "Avoid", 0.0
  DamageFactor "Plasma", 0.75
  DamageFactor "Desintegrate", 0.38
  damagefactor "killme", 0.0
  damagefactor "GibRemoving", 0.0
  damagefactor "TeleportRemover", 0.0
  DamageFactor "CauseObjectsToSplash", 0.0
  damagefactor "Stomp", 0.0
  damagefactor "Trample", 0.0
  DamageFactor "Freeze", 0.25
  DamageFactor "Ice", 0.25
  DamageFactor "Frost", 0.25
  damagefactor "Explosive", 1.1
  DamageFactor "GreenFire", 0.38
  damagefactor "HKFT", 0.05
  DamageFactor "SSG", 0.75
  DamageFactor "Blast", 0.75
  DamageFactor "Cut", 0.75
  damagefactor "Decaptate", 0.95
  damagefactor "Crush", 10.0
  DamageFactor "Blackhole", 0.75
  damagefactor "Blood", 0.0 damagefactor "BlueBlood", 0.0 damagefactor "GreenBlood", 0.0
  BloodType "CyberDemon_Blood", "SawBlood", "SawBlood"
  DropItem "DemonStrengthRune" 50
  DropItem "Doublesphere" 25
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  +NOTARGET
  +MISSILEEVENMORE
  +MISSILEMORE
  +NOINFIGHTING
  +THRUSPECIES
  +MTHRUSPECIES
  +DONTHURTSPECIES
  +DONTHARMSPECIES
  +NOICEDEATH
  +BOSS
  +NOFEAR
  +DONTRIP
  +THRUGHOST
  +FULLVOLDEATH
  +FULLVOLACTIVE
  
  States
  {
  Spawn:
    HSMI A 0 
    HSMI A 1 A_SetInventory("HellsmithArmor",1) //gives 3000 armor.
    HSMI AB 10 A_Look
    Goto Spawn+2
  See:
    HSMI A 0 A_UnsetInvulnerable
    HSMI A 3 A_Hoof
	HSMI ABB 3 A_Chase
	HSMI C 3 A_Hoof
    HSMI CDD 3 A_Chase
    Loop
  Missile:
    HSMI A 0 A_UnsetInvulnerable
	HSMI A 0 A_JumpIfCloser(200,"Missile3",1)
    HSMI A 0 A_Jump(128,"Missile2","Missile4","Missile5")
	HSMI A 0 A_JumpIf(health <= 4000,"Missile6")
  Missile1: //Super Rocket and SupershotBFG
    HSMI I 6 A_FaceTarget
    HSMI J 12 Bright A_CustomMissile("HellsmithHeavyRocket",90,-28)
	HSMI K 6 A_FaceTarget
    HSMI I 6 A_FaceTarget
    HSMI J 12 Bright A_CustomMissile("HellsmithHeavyRocket",90,-28)
	HSMI K 6 A_FaceTarget
	HSMI I 6 A_FaceTarget
    HSMI J 12 Bright A_CustomMissile("HellsmithHeavyRocket",90,-28)
	HSMI K 6 A_FaceTarget
	HSMI I 6 A_FaceTarget
    HSMI J 12 Bright A_CustomMissile("Hellsmithsupershot",90,-28)
	HSMI K 6 A_FaceTarget
	HSMI A 0 A_Jump(64,"Missile3")
	HSMI A 0 A_Jump(128,"Missile4","Missile5","Missile2")
	HSMI A 0 A_JumpIf(health <= 4000,"Missile6")
    Goto See
  Missile2: //Stream rockets
    HSMI EEEEEEE 4 A_FaceTarget	
    HSMI F 4 bright
	{ 
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	}
	HSMI G 4 A_FaceTarget
    HSMI E 4 A_FaceTarget
    HSMI F 4 bright
	{ 
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	}
	HSMI G 4 A_FaceTarget
    HSMI E 4 A_FaceTarget
    HSMI F 4 bright
	{ 
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	}
	HSMI G 4 A_FaceTarget
	HSMI F 4 bright
	{ 
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	}
	HSMI G 4 A_FaceTarget
    HSMI E 4 A_FaceTarget
    HSMI F 4 bright
	{ 
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	}
	HSMI G 4 A_FaceTarget
    HSMI E 4 A_FaceTarget
    HSMI F 4 bright
	{ 
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,3),0,random(-3,3));
	A_CustomMissile("HellsmithStreamRocket",140,32,random(-3,3),0,random(-3,3));
	}
	HSMI G 4 A_FaceTarget
	HSMI G 0 A_Jump(128,"Missile2","Missile1")
	HSMI A 0 A_Jump(128,"Missile5","Missile4")
	HSMI A 0 A_JumpIf(health <= 4000,"Missile6")
    Goto See
  Missile3: //Pentagram Fire
    HSMI L 6 {A_PlaySound("hellsmith/melee", 1); A_FaceTarget;}
	HSMI M 6 A_FaceTarget
	HSMI N 12 bright
	{
	A_CustomMissile("PentagramSpawner",-32,0,0);
	A_CustomMissile("PentaLine1",0,0,-72,2);
    A_CustomMissile("PentaLine1",0,0,-144,2);
    A_CustomMissile("PentaLine1",0,0,-216,2);
    A_CustomMissile("PentaLine1",0,0,-288,2);
    A_CustomMissile("PentaLine1",0,0,0,2);
	}
    Goto See
		
  Missile4: //Charge
    HSMI G 35 {A_FaceTarget; A_SetInvulnerable; A_ChangeFlag("NOPAIN",1);}
	HSMI H 4 {A_PlaySound("hellsmith/charge", 1); A_SkullAttack(32); A_SpawnItemEx("HellsmithTrail",0,0,0,0,0,0);}
	HSMI HHHHHHHHHHH 4 {A_SkullAttack(32); A_SpawnItemEx("HellsmithTrail",0,0,0,0,0,0);}
	HSMI H 0 A_Stop
	HSMI A 2 {A_UnsetInvulnerable; A_ChangeFlag("NOPAIN",0);}
	Goto See
  Missile5: //Plasmablast and superplasmaball 
    HSMI I 6 A_FaceTarget
    HSMI J 12 Bright A_CustomMissile("Argentplasmablast",90,-28)
	HSMI K 6 A_FaceTarget
    HSMI I 6 A_FaceTarget
    HSMI J 12 Bright A_CustomMissile("Argentplasmablast",90,-28)
	HSMI K 6 A_FaceTarget
	HSMI I 6 A_FaceTarget
    HSMI J 12 Bright A_CustomMissile("Argentplasmablast",90,-28)
	HSMI K 6 A_FaceTarget
	HSMI I 6 A_FaceTarget
    HSMI J 12 Bright A_CustomMissile("Argentsuperball",90,-28)
	HSMI K 6 A_FaceTarget
	HSMI A 0 A_Jump(64,"Missile3")
	HSMI A 0 A_Jump(128,"Missile1","Missile4","Missile5")
	HSMI A 0 A_JumpIf(health <= 4000,"Missile6")
	Goto See
  Missile6: //Summon Hellspirit  
    HSMI L 8 {A_KillChildren; A_PlaySound("hellsmith/melee", 1); A_FaceTarget;}
	HSMI M 8 
	HSMI N 15
	{
	A_PlaySound("hellsmith/laugh4", 1);
	A_CustomMissile("HSPentagramSpawner",16,0,0);
	A_CustomMissile("ChargeLightning",16,0,0);
	A_CustomMissile("ChargeLightning",16,0,72);
	A_CustomMissile("ChargeLightning",16,0,-72);
	A_CustomMissile("ChargeLightning2",16,0,0);
	A_CustomMissile("ChargeLightning2",16,0,72);
	A_CustomMissile("ChargeLightning2",16,0,-72);
	A_SpawnItemEx("HSFireSpirit",144,0,16,0,0,0,0,SXF_SETMASTER);
	A_SpawnItemEx("HSSoulSpirit",-144,0,16,0,0,0,0,SXF_SETMASTER);
	A_SpawnItemEx("HSIronSpirit",0,144,16,0,0,0,0,SXF_SETMASTER);
	A_SpawnItemEx("HSBloodSpirit",0,-144,16,0,0,0,0,SXF_SETMASTER);
	}
	HSMI NNNNN 35 HealThing(600,600) //Regen Health.
	Goto See
  Melee:
    HSMI L 0 A_Jump(128,"Missile3")
    HSMI L 6 {A_FaceTarget; A_PlaySound("hellsmith/melee", 1);}
	HSMI M 6 A_FaceTarget
	HSMI N 12 A_CustomMeleeAttack(random(1,10)*50,"hellsmith/hit","hellsmith/miss","wepnormal",0)
	Goto See
  Pain:
    HSMI O 0 A_JumpIfHealthLower(4000,"Pain2")
    HSMI O 10 A_PlaySound("hellsmith/laugh", 1)
    Goto See
  Pain2:
    HSMI O 10 A_Pain	
    Goto See	  
  Death:
    HSMD A 10 Bright 
    HSMD B 10 Bright {A_Scream; A_SpawnItemEx("HSHammer",50,50,110,2,2,0,25);}
    HSMD C 10 Bright A_KillChildren
    HSMD D 10 Bright A_NoBlocking  
    HSMD EFGHIFGHIFGHIFGH 10 Bright
	EXPL A 0 Radius_Quake (6, 200, 0, 22, 0)
	TNT1 AAAAAA 0 A_CustomMissile ("ExplosionSpawner", 50, 0, random (0, 360), 2, random (0, 360))
    TNT1 AAAA 0 A_CustomMissile ("SuperGoreSPawner", 110, 0, random (0, 360), 2, random (0, 180))
    TNT1 AAAAAAA 0 A_CustomMissile ("BloodMistXXBig", 90, 0, random (0, 360), 2, random (70, 90))
	TNT1 AAAA 0 A_CustomMissile ("MuchMeatDeath", 0, 0, random (0, 360), 2, random (0, 160))
    TNT1 A 0 A_CustomMissile ("RidiculousExplosionSpawner", 30, 0, random (0, 360), 2, 90)
    TNT1 AAAAAAAAAAAA 0 A_CustomMissile ("PEPart2SuperFast", 32, 0, random (0, 360), 2, random (0, 160))
    TNT1 AAAA 0 A_CustomMissile ("UltraGoreSPawner", 30, 0, random (0, 360), 2, random (0, 180))
    TNT1 AAAAAA 0 A_CustomMissile ("UltraGoreSpawner", 30, 0, random (0, 360), 2, random (0, 180))
	TNT1 AAAAAAAAAAAAAA 0 A_CustomMissile ("BloodMistXXBig", 30, 0, random (0, 360), 2, random (70, 90))
	TNT1 AAAAAAAAAAAAAAAAAAAAAAAA 0 A_CustomMissile ("BloodMistXXBig", 100, 0, random (0, 360), 2, random (20, 90))
	TNT1 A 0 A_SpawnItem ("GrowingBloodPool")
	HSMD JKLMNOPQRS 1 
	HSMD T -1  A_BossDeath
    stop
  }
}

ACTOR HSFireSpirit : HellSmith
{
  BLOODTYPE CYANSMOKEBLOODTYPE
  BLOODCOLOR CYAN
  Health 1000
  PainChance 32  
  Tag "Fire Effigy"
  SeeSound "hellsmithspirit/sight"
  ActiveSound "hellsmithspirit/active"
  PainSound "hellsmithspirit/pain"
  DeathSound "hellsmith/laugh4"  
  Obituary "%o. was roasted by an Fire Effigy."  
  Hitobituary "%o was smashed by an Fire Effigy."
  DropItem "DemonStrengthRune" 25
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  Translation "0:255=%[0,0,0] : [1,0.5,0]"
  RenderStyle Translucent
  Alpha 0.75
  +NOTARGET  
  +MISSILEMORE  
  +BRIGHT  
  +DONTHURTSPECIES
  +DONTHARMSPECIES
  -BOSS
  -MISSILEEVENMORE
  +GHOST
  +THRUGHOST
  
  States
  {
  Spawn:
    HSMI A 0 
    HSMI A 1 A_SetInventory("HSAttackToken",5)
    HSMI AB 10 A_Look
    Loop
  See:
    HSMI A 3 A_Hoof
	HSMI ABB 3 A_Chase
	HSMI C 3 A_Hoof
    HSMI CDD 3 A_Chase
    Loop
  Missile: //Pentagram Fire
    HSMI L 6 {A_PlaySound("hellsmith/melee", 1); A_FaceTarget;}
	HSMI M 6 {A_FaceTarget; A_TakeInventory("HSAttackToken",1);}
	HSMI N 15
	{
	A_Playsound("weapons/firbfi",4);
	A_CustomMissile("PentagramSpawner",-32,0,0);
	A_CustomMissile("PentaLine1",0,0,-72,2);
    A_CustomMissile("PentaLine1",0,0,-144,2);
    A_CustomMissile("PentaLine1",0,0,-216,2);
    A_CustomMissile("PentaLine1",0,0,-288,2);
    A_CustomMissile("PentaLine1",0,0,0,2);
	}
	HSMI N 0
	{
		If (CountInv("HSAttackToken") <= 0)
		{
			A_Die;
		}		
	}
	Goto See
  Melee:
    HSMI L 6 {A_FaceTarget; A_PlaySound("hellsmith/melee", 1);}
	HSMI M 6 A_FaceTarget
	HSMI N 12 A_CustomMeleeAttack(random(1,10)*20,"hellsmith/hit","hellsmith/miss","wepnormal",0)
	Goto See
  Pain:
    HSMI O 10 A_Pain
    Goto See
  Death:
    HSMI O 3 {A_Scream; A_NoBlocking;}	
    HSMI OOOOOOOOOO 3 A_FadeOut(0.05)
    Stop
  }
}

ACTOR HSIronSpirit : HSFireSpirit
{ 
  BLOODTYPE CYANSMOKEBLOODTYPE
  BLOODCOLOR CYAN
  RenderStyle Translucent
  Alpha 0.75
  DamageType "ExplosiveImpact"
  DropItem "DemonStrengthRune" 25
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  Tag "Iron Effigy"
  Obituary "%o. was nailed by an Iron Effigy."  
  Hitobituary "%o was smashed by an Iron Effigy."
  Translation "0:255=%[0,0,0] : [0.5,0.5,1]"
  +GHOST
  +BRIGHT
  +NOINFIGHTING
  +THRUSPECIES
  +MTHRUSPECIES
  +DONTHURTSPECIES
  +DONTHARMSPECIES
  +THRUGHOST
  
  States
  {
  Spawn:
    HSMI A 0 
    HSMI A 1 A_SetInventory("HSAttackToken",35) 
    HSMI AB 10 A_Look
    Loop
  Missile: //Stream rockets
    HSMI E 2 A_FaceTarget
    HSMI F 4 bright
	{ 
	A_TakeInventory("HSAttackToken",1);
	A_CustomMissile("HellsmithStreamRocket",140,-32,0,0,random(-2,2));		
	A_CustomMissile("HellsmithStreamRocket",140,32,0,0,random(-2,2));
	A_CustomMissile("HellsmithStreamRocket",140,-32,random(-3,0),0,random(-3,3));		
	A_CustomMissile("HellsmithStreamRocket",140,32,random(0,3),0,random(-3,3));
	}		
	HSMI G 2 A_CPosRefire
	HSMI G 0
	{
		If (CountInv("HSAttackToken") <= 0)
		{
			A_Die;
		}		
	}
	Goto Missile  
  }
}

ACTOR HSBloodSpirit : HSFireSpirit
{ 
  BLOODTYPE CYANSMOKEBLOODTYPE
  BLOODCOLOR CYAN
  RenderStyle Translucent
  Alpha 0.75
  DropItem "DemonStrengthRune" 25
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  Tag "Blood Effigy"
  Obituary "%o. was blasted by an Blood Blood."  
  Hitobituary "%o was smashed by an Blood Blood."
  DamageType "SuperPlasma"
  Translation "0:255=%[0,0,0] : [1,0.25,0.25]"
  +GHOST
  +BRIGHT
  +NOINFIGHTING
  +THRUSPECIES
  +MTHRUSPECIES
  +DONTHURTSPECIES
  +DONTHARMSPECIES
  +THRUGHOST
  
  States
  {
  Spawn:
    HSMI A 0 
    HSMI A 1 A_SetInventory("HSAttackToken",5) 
    HSMI AB 10 A_Look
    Loop
  Missile: //Super Hellbolt
    HSMI I 6 A_FaceTarget
    HSMI J 12 Bright {A_CustomMissile("Argentplasmablast",90,-28); A_TakeInventory("HSAttackToken",1);}
	HSMI K 6 A_FaceTarget
	HSMI I 6 A_FaceTarget
    HSMI J 12 Bright {A_CustomMissile("Argentplasmablast",90,-28); A_TakeInventory("HSAttackToken",1);}
	HSMI K 6 A_FaceTarget
	HSMI I 6 A_FaceTarget
    HSMI J 12 Bright {A_CustomMissile("Argentplasmablast",90,-28); A_TakeInventory("HSAttackToken",1);}
	HSMI K 6 A_FaceTarget
	HSMI I 6 A_FaceTarget
    HSMI J 12 Bright {A_CustomMissile("Argentsuperball",90,-28); A_TakeInventory("HSAttackToken",1);}
	HSMI K 6 A_FaceTarget
	HSMI K 0
	{
		If (CountInv("HSAttackToken") <= 0)
		{
			A_Die;
		}		
	}
	Goto See  
  }
}

ACTOR HSSoulSpirit : HSFireSpirit
{ 
  BLOODTYPE CYANSMOKEBLOODTYPE
  BLOODCOLOR CYAN
  RenderStyle Translucent
  Alpha 0.75
  Damage 40
  DamageType "ExtremePunches"
  DropItem "DemonStrengthRune" 25
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  DropItem "Demonpickup2" 255
  Tag "Spirit Effigy"
  Obituary "%o. couldn't evade an Spectral Effigy."  
  Hitobituary "%o was smashed by an Spectral Effigy."
  Translation "0:255=%[0,0,0] : [1,1,1]"
  +GHOST
  +BRIGHT
  +NOINFIGHTING
  +THRUSPECIES
  +MTHRUSPECIES
  +DONTHURTSPECIES
  +DONTHARMSPECIES
  +THRUGHOST
  
  States
  {
  Spawn:
    HSMI A 0 
    HSMI A 1 A_SetInventory("HSAttackToken",6) 
    HSMI AB 10 A_Look
    Loop  
  Missile: //Charge
    HSMI G 35 {A_FaceTarget; A_TakeInventory("HSAttackToken",1);}
	HSMI H 4 {A_PlaySound("hellsmith/charge", 1); A_FaceTarget; A_SkullAttack(32); A_SpawnItemEx("HellsmithTrail2",0,0,0,0,0,0);}
	HSMI HHHHHHHHHHH 4 {A_SpawnItemEx("HellsmithTrail2",0,0,0,0,0,0);}	
	HSMI H 0
	{
		If (CountInv("HSAttackToken") <= 0)
		{
			A_Die;
		}		
	}
	HSMI H 0 A_Stop	
	HSMI A 2 
	Goto See
  }
}

ACTOR HellsmithTrail
{
   RenderStyle Translucent
   Alpha 0.5
   +FORCEXYBILLBOARD
   States
   {
   Spawn:
      TNT1 A 6
	  HSMI H 6 A_FadeOut(0.1)
	  goto Spawn+1
   Death:
      TNT1 A 1
      stop
   }
}

ACTOR HellsmithTrail2 : HellsmithTrail 
{
   RenderStyle Add
   Alpha 0.5
   Translation "0:255=%[0,0,0] : [1,1,1]"
   +FORCEXYBILLBOARD
   States
   {
   Spawn:
      TNT1 A 6
	  HSMI H 6 A_FadeOut(0.1)
	  goto Spawn+1
      Death:
      TNT1 A 1
      stop
   }
}

ACTOR HSHammer : CacodemonBall
{    
	Damage 10
	Speed 0
	Obituary "%o was comedicly crushed by the falling hammer of a dying Hellsmith."
	SeeSound ""
	DeathSound "hellsmith/miss"
	Renderstyle Normal
	+RIPPER
	-NOGRAVITY
	States
	{
	Spawn:
      HAMM ABCD 3 
      goto Spawn+3
	Death:
	Crash:
      HAMM EFG 3  
	  HAMM G -1 
	  stop
	}
}

ACTOR HSAttackToken: Inventory //used to limit atack number
{
     Inventory.Amount 1
     Inventory.MaxAmount 100
}

ACTOR HellsmithStreamRocket
{
	Radius 3
	Height 3
	Scale 0.6
	Damage (20)
	Speed 35
	Projectile
	Decal "HitScorchMediumSmall"
	+RANDOMIZE
	+THRUSPECIES
    +MTHRUSPECIES
	+DONTHURTSPECIES
	+DONTHARMSPECIES
	RenderStyle Normal
	SeeSound "TYSMFI"
	DeathSound "TYSMEX"
	DamageType "ExplosiveImpact"
	
	States
	{
	Spawn:
	  HSHR A 1 Light(YellowMediumPoint2) Bright A_SpawnItemEx("RocketTrailFire",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
	  HSHR A 1  Light(YellowMediumPoint2) Bright A_SpawnItemEx("RocketTrailFire",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
	  HSHR A 1  Light(YellowMediumPoint2) Bright A_SpawnItemEx("RocketTrailFire",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
	  TNT1 A 0 A_SpawnItemEx("RocketTrailSmoke",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
	  Goto Spawn+1
		
	Death:
	  TNT1 A 0 A_Quake(2,35,0,1024)
	  TNT1 A 0 A_Explode(96,128,1)
	  TNT1 A 0 A_Explode(32,160,0,0,128)
	  TNT1 A 0 A_SpawnItemEx("RockExplShockwave",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
	  TNT1 A 0 A_SpawnItemEx("RocketExploDebris",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION)
	  TNT1 A 0 A_SpawnItemEx("RocketExplosionNew",0,0,0, 0,0,0,0, SXF_NOCHECKPOSITION)
	  TNT1 A 10 
      TNT1 A 0 A_Jump(256, "RocketExploFXSpawner")
      stop
	   }
}	
		
Actor RocketExplosionNew
{
	+NOINTERACTION
	+FORCEXYBILLBOARD
	+CLIENTSIDEONLY
	Scale 0.133
	States
	{
	Spawn:
	  TNT1 A 0 NoDelay
	  TNT1 A 100 A_Jump(255,"T1",/*"T2","T3",*/"T4")
	  Goto PlayOff
	T1:	//flip x
	   TNT1 A 0 A_SetScale(scalex*-1,scaley)
	   D4X1 ABC 1 Bright Light("YellowMediumFlicker2") A_SetScale(scalex-0.133,scaley+0.133)
		Goto PlayOff
/*	T2:	//flip Y
	   TNT1 A 0 A_SetScale(scalex*1,scaley*-1)
	   D4X1 ABC 1 Bright Light("YellowMediumFlicker2") A_SetScale(scalex+0.133,scaley-0.133)
		Goto PlayOff*/
/*	T3:	//flip both
	   TNT1 A 0 A_SetScale(scalex*(-1),scaley*(-1))
	   D4X1 ABC 1 Bright Light("YellowMediumFlicker2") A_SetScale(scalex-0.133,scaley-0.133)
	   Goto PlayOff*/
	T4:	//normal
	   D4X1 ABC 1 Bright Light("YellowMediumFlicker2") A_SetScale(scalex+0.133,scaley+0.133)
	   Goto PlayOff
	PlayOff:	//normal
	   D4X1 DEF 1 Bright Light("YellowBigFlicker3")
	   D4X1 GHI 1 Bright Light("YellowMediumFlicker1")
	   D4X1 JKL 1 Bright Light("YellowMediumFlicker2")
	   D4X1 MNO 1 Bright Light("YellowMediumFlicker3") A_FadeOut(0.05)
	   D4X1 PQR 1 Bright Light("YellowSmallFlicker1") A_FadeOut(0.05)
	   D4X1 ST 1 Bright Light("YellowSmallFlicker2") A_FadeOut(0.05)
	   D4X1 UV 1 Bright Light("YellowSmallFlicker3") A_FadeOut(0.05)
	   D4X1 WXYZ 1 Bright A_FadeOut(0.05)
	   D4X2 ABCDE 1 Bright A_FadeOut(0.05)
	   Stop
	}
}

Actor RockExplShockwave
{
	+NOINTERACTION
	+FORCEXYBILLBOARD
	+CLIENTSIDEONLY
	RenderStyle Add
	Alpha 0.99
	Scale 0.7
	States
	{
	Spawn:
		D4X2 G 1 BRIGHT 
		D4X2 H 1 BRIGHT A_SetScale(scalex*1.25)
		TNT1 A 0 A_FadeOut(0.18)
		D4X2 I 1 BRIGHT A_SetScale(scalex*1.25)
		TNT1 A 0 A_FadeOut(0.18)
		D4X2 J 1 BRIGHT A_SetScale(scalex*1.25)
		TNT1 A 0 A_FadeOut(0.18)
		D4X2 J 1 BRIGHT A_SetScale(scalex*1.25)
		Stop
	}
}

Actor RocketExploDebris
{
	+NOINTERACTION
	+FORCEXYBILLBOARD
	+CLIENTSIDEONLY
	RenderStyle Add
	Scale 1.15
	Translation "0:255=%[0,0,0]:[2.0,1.1,0]"
	States
	{
	Spawn:
		TNT1 A 0 
		TNT1 A 100  A_Jump(255,"T1","T2","T3","T4","T5","T6","T7","T8")
		Goto PlayOff
	T1:	
		DFL1 A 0 
		Goto PlayOff
	T2:
		DFL2 A 0 
		Goto PlayOff
	T3:
		DFL3 A 0 
		Goto PlayOff
	T4:	
		DFL4 A 0 
		Goto PlayOff
	T5:	//Flipped X
		DFL1 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	T6:
		DFL2 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	T7:
		DFL3 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	T8:	
		DFL4 A 0 A_SetScale(scalex*-1,scaley)
		Goto PlayOff
	PlayOff:	//normal
		"####" BCEFGIJKLMNOPQRSTUVWXYZ 1 Bright
		Stop
	}
}

Actor RocketExploFXSpawner
{	+NOINTERACTION
	RenderStyle Add
	Alpha 0.99
	States
	{
	Spawn:
		TNT1 A 0 NoDelay A_PlaySound("Doom4/Weapon/RocketLauncher/Explosion",CHAN_AUTO,1.0,false,0.66)
		TNT1 A 0 A_SpawnItemEx("RocketExploLowQuality",-2,0,0,frandom(-0.1,-1),frandom(-1,1),frandom(-1,1),0,SXF_NOCHECKPOSITION|SXF_CLIENTSIDE)
		TNT1 A 0 A_SpawnItemEx("RocketExploLowQuality",-2,0,0,frandom(-0.1,-1),frandom(-1,1),frandom(-1,1),0,SXF_NOCHECKPOSITION|SXF_CLIENTSIDE)
		TNT1 A 0 A_SpawnItemEx("RocketExploLowQuality", 0,0,0,frandom( 0.1, 1),frandom(-1,1),frandom(-1,1),0,SXF_NOCHECKPOSITION|SXF_CLIENTSIDE)
		TNT1 A 0 A_SpawnItemEx("RocketLQSmoke",-1,0,0,frandom(-0.2,0.2),frandom(-0.2,0.2),frandom(-0.15,0.15),0,SXF_NOCHECKPOSITION|SXF_CLIENTSIDE)
		//Show Some light
		TNT1 A 2 Light("OrangeMediumPoint3")
		TNT1 A 2 Light("OrangeMediumPoint2")
		TNT1 AA 2 Light("OrangeMediumPoint1")
		TNT1 A 2 Light("OrangeMediumPoint2")
		TNT1 A 2 Light("OrangeMediumPoint3")
		TNT1 A 2 Light("OrangeSmallPoint1")
		TNT1 A 2 Light("OrangeSmallPoint2")
		TNT1 A 2 Light("OrangeSmallPoint3")
		Stop
	}
}

