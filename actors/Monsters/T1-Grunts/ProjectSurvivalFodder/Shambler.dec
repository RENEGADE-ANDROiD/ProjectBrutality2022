ACTOR XDeathFodder : XDeathGibBase {
	Radius 1
    Height 1
    Scale 0.8
	Speed 0
	Mass 1
	Decal BloodSuper
	BounceFactor 0.5
	+DOOMBOUNCE
	+MISSILE
    +NOBLOCKMAP
    +NOTELEPORT
    +MOVEWITHSECTOR
    +NOGRAVITY
    +NOCLIP
    +DONTSPLASH
		States {
			Spawn:
				TNT1 A 0 A_SpawnItem("BloodSplasher3")
				TNT1 AAAA 0 A_PBGibMissile ("SuperWallRedBlood", 40, 0, random (0, 360), 2, random (-15, 15))
				TNT1 AAAA 0 A_PBGibMissile ("CeilBloodLauncherLong", 0, 0, random (0, 360), 2, random (50, 130))
				TNT1 AA 0 A_PBGibMissile ("XDeathFodderArm", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_PBGibMissile ("XDeath1", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_PBGibMissile ("XDeathOrgan1", 24, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_PBGibMissile ("XDeathOrgan2", 24, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_PBGibMissile ("XDeath4", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_PBGibMissile ("XDeath4b", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 AAAAA 0 A_PBGibMissile ("Instestin", 24, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_PBGibMissile ("XDeathFodderLeg", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_SpawnItem ("BigBloodSpot")
				TNT1 A 1
				TNT1 A 0 ACS_NamedExecuteAlways("DetermineUserBloodAmount", 0, 0, 0, 0)//Check Blood density
				TNT1 A 2
				TNT1 AAAAA 0 A_CustomMissile ("BloodMistExtraBig", 30, 0, random (0, 360), 2, random (20, 90))
				Stop }}

ACTOR FodderHeadExplode: ZombieXDeath {
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 A_PlaySound("misc/xdeath4")
				TNT1 A 0 A_PlaySound("gore/headshot", 2)
				TNT1 AAAAA 0 A_CustomMissile ("BloodMistBig", 0, 0, random (0, 360), 2, random (30, 90))
				TNT1 AAAAA 0 A_CustomMissile ("Brutal_FlyingBlood", 0, 0, random (0, 360), 2, random (30, 90))
				TNT1 A 0 A_CustomMissile ("Brains3", 0, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("Brains6", 0, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("Brains7", 0, 0, random (0, 360), 2, random (0, 160))
				TNT1 AAA 0 A_CustomMissile ("SmallBrainPieceFast", random (45, 55), random (5, -5), random (170, 190), 2, random (-10, 10))
				TNT1 AAAAA 0 A_CustomMissile ("SmallBrainPiece", 0, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_CustomMissile ("SuperWallRedBlood", 6, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("Teeth", 0, 0, random (0, 360), 2, random (0, 160))
				TNT1 AAA 0 A_CustomMissile ("XDeath1", 0, 0, random (0, 360), 2, random (0, 160))
