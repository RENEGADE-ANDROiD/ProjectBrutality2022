Actor DeadShamblerPinned: ZombiemanTorso {
	+NOPAIN
	+NOGRAVITY
	Health 200
	DamageFactor "Head", 15.0
	Height 40
	Radius 6
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 A_PlaySound("Weapons/NailHitBleed")
				TNT1 A 0 A_Recoil(15)
				2SHA W 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_Recoil(10)
				2SHA W 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_JumpIf(momx < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momx > 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy > 0, "LayDown")
				2SHA W 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_Recoil(10)
				2SHA X 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_JumpIf(momx < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momx > 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy > 0, "LayDown")
				2SHA X 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_Recoil(10)
				2SHA X 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_JumpIf(momx < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momx > 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy > 0, "LayDown")
				2SHA X 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_Recoil(10)
				2SHA X 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_JumpIf(momx < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momx > 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy > 0, "LayDown")
				2SHA X 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_Recoil(10)
				2SHA X 4 A_CustomMissile ("Brutal_LiquidBlood3", 25, random(-2,2), random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_JumpIf(momx < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momx > 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy > 0, "LayDown")
				TNT1 A 0 A_Jump(36, "SlideDown")
			JustHangThere:
				TNT1 A 0 A_Recoil(6)
				2SHA X 6
				TNT1 A 0 A_JumpIf(momx < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momx > 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy > 0, "LayDown")
				2SHA X 16
				Loop
			SlideDown:
				TNT1 A 0 A_Recoil(6)
				TNT1 A 0 ThrustThingZ(0, 6, 1, 0)
				2SHA X 6
				TNT1 A 0 A_JumpIf(momz < 2, "SlumpSittingDown")
				TNT1 A 0 A_JumpIf(momx < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy < 0, "LayDown")
				TNT1 A 0 A_JumpIf(momx > 0, "LayDown")
				TNT1 A 0 A_JumpIf(momy > 0, "LayDown")
				2SHA X 12
				Loop
			SlumpSittingDown:
				TNT1 A 0 A_SpawnItemEx ("DeadShamblerSitting",10,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop	
			LayDown:
				TNT1 A 0 A_NoBlocking
				TNT1 A 0 A_SpawnItemEx ("DeadShamblerBasic",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}
				
ACTOR DeadShamblerRapidFire1 {
	Game Doom
	Radius 16
	Height 50
	Health 20
	PainSound "Shambler/Pain"
	PainChance 255
	Mass 999999
	+SHOOTABLE
    +FLOORCLIP
    +LOOKALLAROUND
	+FRIGHTENED
	+SOLID
	+DONTSPLASH
	MONSTER
	+FRIENDLY
	-COUNTKILL
	Scale 1.0
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 A_Recoil(2)
				TNT1 A 0 A_CustomMissile ("XDeathFodderArm", 35, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_CustomMissile ("PB_XDeath1", 40, 0, random (0, 360), 2, random (0, 160))
			Pain:
				4SHA A 30
				Goto DieNow
			DieNow:
				TNT1 A 0
				TNT1 A 0 A_SpawnItemEx ("DeadShamblerRapidFire1Stop",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop
			Death:
				TNT1 A 0
				TNT1 AA 0 A_CustomMissile ("PB_XDeath1", 40, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_SpawnItemEx ("DeadShamblerRapidFire2",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop
			Death.SSG:
			XDeath:
				TNT1 A 0 A_XScream
				TNT1 A 0 A_NoBlocking
				TNT1 A 0 A_CustomMissile ("XDeathFodder", 0, 0, random (0, 360), 2, random (0, 160))
				Stop }}

