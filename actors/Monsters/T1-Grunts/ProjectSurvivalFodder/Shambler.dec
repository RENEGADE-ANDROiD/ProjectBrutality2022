	+ACTIVATEMCROSS
	+ACTIVATEIMPACT
	+CANUSEWALLS
		States {
			Spawn:
				TNT1 A 0 A_ChangeFlag("NOCLIP", 1)
				FZAR A 2
				TNT1 A 0 A_ChangeFlag("NOCLIP", 0)
				TNT1 A 0
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
				FZAR ABCDEFGH 6 A_CustomMissile ("Brutal_FlyingBloodTrail", 0, 0, random (0, 360), 2, random (0, 360))
				Goto Spawn+3 }}
				
actor GibFodderLeg: LimbBase {
    Scale 1.2
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 
				FZLG A 1 A_SpawnItem ("Brutal_BloodSpot", 0, 1)
				TNT1 A 0 A_Jump(256, "Spawn1", "Spawn2")
				Spawn1:
				FZLG A -1
				Stop
			Spawn2:
				FZLG E -1
				Stop
			Death:    
				TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBloodTrail", 0, 0, random (0, 360), 2, random (0, 360))
				Stop
			Death.Kick:
			Death.Melee:
			Death.SuperPunch:
				FZLG AA 1 A_FaceTarget
				TNT1 A 0 A_CustomMissile ("XDeathFodderLegKicked", 5, 0, random (170, 190), 2, random (20, 40))
				Stop
			Pain:
				TNT1 A 0
				TNT1 A 0 ThrustThingZ(0,20,0,1)
				FZLG ABCDEFGH 3
				Goto Spawn
			Death.ExplosiveImpact:
				TNT1 A 0
				TNT1 A 0 A_ChangeFlag("NOBLOCKMAP", 0)
				TNT1 A 0 ThrustThingZ(0,50,0,1)
				FZLG A 6
				FZLG ABCDEFGH 3 A_CheckFloor("Landz")
				Goto Landz
			Landz:
				TNT1 A 0 A_SpawnItemEx ("GibFodderLeg",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}

ACTOR XDeathFodderLeg: XDeathArm1 {
		States {
			Spawn:
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
				FZLG ABCDEFGH 4 A_CustomMissile ("Brutal_FlyingBloodTrail5", 0, 0, random (0, 360), 2, random (0, 360))
				Loop
			Death:
				FZLG A 1
				TNT1 A 0 A_SpawnItemEx ("GibFodderLeg",0,0,0,1,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}

ACTOR XDeathFodderLegKicked: XDeathFodderLeg {
	+ACTIVATEMCROSS
	+ACTIVATEIMPACT
	+CANUSEWALLS
		States {
			Spawn:
				TNT1 A 0 A_ChangeFlag("NOCLIP", 1)
				FZLG A 2
				TNT1 A 0 A_ChangeFlag("NOCLIP", 0)
				TNT1 A 0
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
				FZLG ABCDEFGH 6 A_CustomMissile ("Brutal_FlyingBloodTrail", 0, 0, random (0, 360), 2, random (0, 360))
				Goto Spawn+3 }}
				
