ACTOR ZombieDropFire
{
   Radius 8
   Height 40
   PROJECTILE
   RENDERSTYLE ADD
   DamageType Fire
   ALPHA 1
   Scale 1.3
   -NOGRAVITY
   +LOWGRAVITY
   +NOEXPLODEFLOOR
   +NODAMAGETHRUST
   +THRUGHOST
   States
   {
   Spawn:
	  FRTF ABC 4 Bright
	  FRTF A 0 Bright A_Playsound("weapons/onfire",CHAN_5,1,1)
	  Go:
      FRTF A 0 Bright A_Explode(1,16,0)
      FRTF CDEFGEF 4 Bright A_Explode(1,16,0)
      FRTF A 0 A_Jump(65,1)
      loop
      NULL A 0
	  FRTF GHIJKLMNO 3 Bright
      goto death
   Death:
	  TNT1 A 0 A_StopSound(CHAN_5)
      NULL A 1 Bright
      stop
   }
}

