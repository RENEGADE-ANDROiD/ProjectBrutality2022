Actor CyberFodder : Shotgunguy
{
  Health 350
  Speed 5
  Painchance 40
  MaxStepHeight 40
  MaxDropOffHeight 40
  Height 44
  Scale 1.15
  +DONTHURTSPECIES
  +DONTHARMSPECIES
  +DONTHARMCLASS
  +THRUSPECIES
  +NOINFIGHTING
  +AVOIDMELEE
  +CANNOTPUSH
  -CANUSEWALLS
  -CANPUSHWALLS
  -ACTIVATEMCROSS
  -ACTIVATEPCROSS
  PainChance 0
	PainChance "Kick", 255
	PainChance "ExtremePunches", 255
	PainChance "Stun", 255
	damagefactor "Stun", 250
	PainChance "desintegrate", 200
	damagefactor "desintegrate", 2.0
	damagefactor "TeleportRemover", 0.0
    damagefactor "Shrapnel", 0.4
	DamageFactor "CauseObjectsToSplash", 0.0
	damagefactor "killme", 0.0
	+NOBLOOD
	PainChance "Fire", 12
	PainChance "Flames", 12
	PainChance "Burn", 12
	PainChance "FireExplosion", 12
	damagefactor "FireExplosion", 0.0
	damagefactor "Fire", 0.0
	damagefactor "Flames", 0.0
	damagefactor "Burn", 0.0
	PainChance "Ice", 200
	PainChance "Freeze", 200
	PainChance "IceExplosion", 200
	damagefactor "IceExplosion", 2.0
	damagefactor "Ice", 2.0
	damagefactor "Freeze", 2.0
	DropItem "MetalShard1"
	DropItem "NewCell" 128
	DropItem "NewClip" 128
	Tag "Cyber Fodder"
	Species "Fodder"
	BloodType "Brutal_Blood", "BloodSPlatterReplacer", "SawBlood"
	SeeSound "CyberZ/Sight"
	ActiveSound "CyberZ/Active"
	PainSound "CyberZ/Pain"
	DeathSound "ZombieFodder/death"
	Obituary "%o was Blazed by a CyberFodder"
		  States
			  {
			  Spawn:
				TNT1 A 1
			  RealSpawn:
				TNT1 A 0 A_SpawnItem ("HeadshotTarget4", 0, 40,0)
				CFOD A 4 A_Look
				Loop
			  See:
				CFO2 AABBBBAAAA 2 A_FaceTarget
			  SeeBegin:
				TNT1 A 0 A_StopSound(CHAN_5)
				TNT1 A 0 A_SetSpeed(4)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 40,0)
				CFOD AA 4 A_Chase
				TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 40,0)
				CFOD BB 4 A_Chase
				TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 40,0)
				CFOD CC 4 A_Chase
				TNT1 A 0 A_SpawnItem ("HeadshotTarget8", 0, 40,0)
				CFOD DD 4 A_Chase
				TNT1 A 0 A_Jump(40,"See2")
				Loop
			  See2:
				TNT1 A 0 A_SetSpeed(6)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget6", 0, 40,0)
				CFOD AB 3
				{
				A_Chase;
				A_Recoil(-1);
				}
				TNT1 A 0 A_SpawnItem ("HeadshotTarget6", 0, 40,0)
				CFOD CD 3
				{
				A_Chase;
				A_Recoil(-1);
				}
				TNT1 A 0 A_Jump(13,"See")
				Loop
			  Missile:
				TNT1 A 0 A_JumpIfCloser(230,"Flamer")
				TNT1 A 0 A_SpawnItem ("HeadshotTarget10", 0, 40,0)
				CFOD EE 5 A_FaceTarget
				TNT1 A 0 A_SpawnItem ("HeadshotTarget30", 0, 40,0)
				CFOD FFFFFFFFFF 3 Light("Shadowball")
				{
				A_FaceTarget;
				}
				TNT1 A 0 A_CustomMissile("CFodFlare",34,5)
				TNT1 A 0 A_PlaySound("BIOSHOOT", 1)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget6", 0, 40,0)
				CFOD G 3 Light("ShadowBall") A_CustomMissile("Demonicbullet",34,5)
				CFOD F 3 A_FaceTarget
				TNT1 A 0 A_CustomMissile("CFodFlare",34,5)
				TNT1 A 0 A_PlaySound("BIOSHOOT", 1)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget6", 0, 40,0)
				CFOD G 3 Light("ShadowBall") A_CustomMissile("Demonicbullet",34,5,random(7,-7),CMF_OFFSETPITCH,random(4,-4))
				CFOD F 3 A_FaceTarget 
				TNT1 A 0 A_CustomMissile("CFodFlare",34,5)
				TNT1 A 0 A_PlaySound("BIOSHOOT", 1)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget6", 0, 40,0)
				CFOD G 3 Light("ShadowBall") A_CustomMissile("Demonicbullet",34,5,random(7,-7),CMF_OFFSETPITCH,random(4,-4))
				CFOD F 3 A_FaceTarget 
				TNT1 A 0 A_CustomMissile("CFodFlare",34,5)
				TNT1 A 0 A_PlaySound("BIOSHOOT", 1)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget6", 0, 40,0)
				CFOD G 3 Light("ShadowBall") A_CustomMissile("Demonicbullet",34,5,random(7,-7),CMF_OFFSETPITCH,random(4,-4))
				CFOD F 3 A_FaceTarget
				TNT1 A 0 A_CustomMissile("CFodFlare",34,5)
				TNT1 A 0 A_PlaySound("BIOSHOOT", 1)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget6", 0, 40,0)
				CFOD G 3 Light("ShadowBall") A_CustomMissile("Demonicbullet",34,5,random(7,-7),CMF_OFFSETPITCH,random(4,-4))
				CFOD F 3 A_FaceTarget
				TNT1 A 0 A_CustomMissile("CFodFlare",34,5)
				TNT1 A 0 A_PlaySound("BIOSHOOT", 1)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget23", 0, 40,0)
				CFOD G 3 Light("ShadowBall") A_CustomMissile("Demonicbullet",34,5,random(7,-7),CMF_OFFSETPITCH,random(4,-4))
				TNT1 A 0 A_PlaySound("UCHAIN/Steam")
				CFOD FFFFFFFFFFFFFFEEEEEE 1
				{
				A_FaceTarget;
				}
				Goto See
			  Flamer:
				TNT1 A 0 A_SpawnItem ("HeadshotTarget10", 0, 40,0)
				CFOD EE 5 A_FaceTarget
				TNT1 A 0 A_PlaySound("FLMDRAW", 3)
				CFOD FFFFFFFFFFFFFFFFFFFFFFFF 1 
				{
				A_FaceTarget;
				}
				TNT1 A 0 A_SpawnItem ("HeadshotTarget30", 0, 40,0)
				CFOD GGGGGGGGGG 3 
				{
				A_FaceTarget(0.5,3,0,0);
				A_PlaySound("FLMRLOP");
				A_CustomMissile("EnemyFlamethrowerMissile",36,4,random(-1,1),CMF_AIMDIRECTION,pitch*-1);
				}
				TNT1 A 0 A_StopSound(CHAN_5)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget4", 0, 40,0)
				CFOD F 4
				TNT1 A 0 A_PlaySound("HRSteam", 3)
				Goto See2
			  Pain:
				TNT1 A 0 A_StopSound(CHAN_5)
				TNT1 A 0 A_SpawnItem ("HeadshotTarget6", 0, 40,0)
				CFOD H 3
				CFOD H 3 A_Pain
				Goto See
			Pain.Stun:
				TNT1 A 0
				Goto XDeath
			Death.Shotgun:
				Death.Shotgun:
				TNT1 A 0 A_JumpIfCloser(150, "Death.Splatter")
				TNT1 A 0 A_Jump(64, "Death.Splatter")
				TNT1 A 0 A_Jump(64, "Death.Head")
			Death:
				TNT1 AAAAAA 0 A_CustomMissile ("PB_SmallGib", 32, 0, random (150, 210), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("NashGoreBloodSpurt", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("PB_SuperWallRedBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("PB_BloodMistBig", 40, 0, random (0, 360), 2, random (30, 90))
				TNT1 A 0 A_CustomMissile ("MuchBlood", 50, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_CustomMissile ("MetalShard1", 50, 0, random (0, 360), 2, random (30, 160))
				TNT1 A 0 A_CustomMissile ("MetalShard2", 50, 0, random (0, 360), 2, random (30, 160))
				CFOD I 7 A_Scream
				CFOD J 5 
				CFOD K 5 A_NoBlocking
				TNT1 A 0 A_PlaySound("Corpse/Fall",CHAN_6)
				CFOD L 5
				TNT1 A 0 A_SpawnItemEx ("XDeathBodyCyber",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0) 
				Stop
			Death.Head:
				TNT1 A 0 A_JumpIfInTargetInventory("HitboxFireDamage",1,"ImmunityRecovery")
