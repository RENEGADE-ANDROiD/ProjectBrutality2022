				TNT1 A 0 A_SpawnItem("HeadshotTarget20", 1, 28,0)
				3SPI C 10
				3SPI D 5 A_PlaySound("Spiker/Pain")
				TNT1 A 0 A_SpawnItem("HeadshotTarget20", 1, 28,0)
				3SPI C 10
				TNT1 A 0 A_Jump(42,"DieNow")
				3SPI D 5 A_PlaySound("Spiker/Pain")
				TNT1 A 0 A_SpawnItem("HeadshotTarget20", 1, 28,0)
				3SPI C 10
				TNT1 A 0 A_Jump(42,"DieNow")
				3SPI D 5 A_PlaySound("Spiker/Pain")
				TNT1 A 0 A_SpawnItem("HeadshotTarget20", 1, 28,0)
				3SPI C 10
				TNT1 A 0 A_Jump(42,"DieNow")
				3SPI D 5 A_PlaySound("Spiker/Pain")
				TNT1 A 0 A_SpawnItem("HeadshotTarget20", 1, 28,0)
