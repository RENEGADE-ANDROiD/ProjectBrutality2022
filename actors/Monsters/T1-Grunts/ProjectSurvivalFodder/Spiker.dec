				TNT1 A 0 A_CustomMissile ("MuchBlood", 16, 0, random (0, 360), 2, random (0, 160))
				2SPI A 5 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
				TNT1 AAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("SuperWallRedBlood", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("MuchBlood", 16, 0, random (0, 360), 2, random (0, 160))
				2SPI A 5 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
				TNT1 AAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("SuperWallRedBlood", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("MuchBlood", 16, 0, random (0, 360), 2, random (0, 160))
				2SPI A 5 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
				TNT1 AAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("SuperWallRedBlood", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("MuchBlood", 16, 0, random (0, 360), 2, random (0, 160))
				2SPI BCD 3 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
			Death:
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_SpawnItemEx ("GibHalfSpikerLower",0,0,0,1,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}

actor GibHalfSpikerLower: ZombieXDeath {
	Scale 1.0
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 
				2SPI D 1 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				2SPI D -1
				Stop    }}
				
ACTOR HalfSpikerUpper {
    Radius 8
    Height 8
    Speed 7
	Mass 8
	BounceFactor 0.2
	+DOOMBOUNCE
    +NOBLOCKMAP
	+MISSILE
    +NOTELEPORT
    +DONTSPLASH
    +MOVEWITHSECTOR
    DeathSound "misc/xdeath1"
	Decal BrutalBloodSplat
	Scale 1.0
		States {
			Spawn:
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
				2SPI EEEFFFGGGH 12 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
			Death:
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_SpawnItemEx ("GibHalfSpikerUpper",0,0,0,1,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}

actor GibHalfSpikerUpper: ZombieXDeath  {
	Scale 1.0
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 
				2SPI H 1 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				2SPI H -1
