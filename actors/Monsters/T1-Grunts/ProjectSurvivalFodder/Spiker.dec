				TNT1 AAAA 0 A_CustomMissile ("PB_SuperWallRedBlood", 20, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("BloodMistBig", 20, 0, random (0, 360), 2, random (30, 90))
				3SPI KKKKKKKKKK 3 A_CustomMissile ("PB_SquirtingBloodTrail", 26, 0, random (0, 360), 2, random (30, 60))
