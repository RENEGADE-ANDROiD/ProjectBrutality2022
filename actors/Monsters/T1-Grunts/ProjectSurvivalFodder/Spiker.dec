				3SPI G 5
				3SPI G 5 A_NoBlocking
				3SPI G 5 
				TNT1 A 0 A_PlaySound("Corpse/Fall",CHAN_6)
				3SPI H 5 
				TNT1 A 0 A_SpawnItem ("CrueltyBonus5Health")
				TNT1 A 0 A_SpawnItemEx ("DeadSpikerNoHead",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0) 
				Stop
			Death.Shotgun:
