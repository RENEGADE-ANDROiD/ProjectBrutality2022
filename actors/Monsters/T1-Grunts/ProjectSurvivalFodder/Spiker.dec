					A_Pain;
					A_facetarget;
				}
				TNT1 A 0 A_GiveInventory("IsDown", 1)
				TNT1 A 0 {
					ThrustThingZ(0,30,0,1);
					ThrustThing(angle*256/360+128, 5, 0, 0);
				}
				2SPI W 3 A_SpawnProjectile ("PB_SquirtingBloodTrail", 15, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 40))
