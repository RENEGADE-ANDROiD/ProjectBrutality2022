			Pain.Kick:
			Pain.ExtremePunches:
			Pain.ExplosiveImpact:
			Pain.Explosive:
				TNT1 A 0
				TNT1 A 0 A_GiveInventory("IsDown", 1)
				2SPI W 1 A_Pain
				TNT1 A 0 ThrustThingZ(0,20,0,1)
				2SPI W 1 A_facetarget
				2SPI W 4 ThrustThing(angle*256/360+128, 5, 0, 0)
			FallDown:
				TNT1 A 0 A_GiveInventory("IsDown", 1)
				ZSPI T 2
				ZSPI U 4
				ZSPI V 4
				Goto FallingAfterImpact
			FallingAfterImpact:
				5SPI X 1 A_GiveInventory ("FallingHeight", 1)
				5SPI X 1 A_CheckFloor ("GetUp")
				TNT1 A 0 A_JumpIf (momz == 0, "GetUp")
				Loop
			GetUp:
				TNT1 A 0
				TNT1 A 0 A_ChangeFlag("GHOST", 1)
				TNT1 A 0 A_ChangeFlag("NOPAIN", 0)
				TNT1 A 0 A_ChangeFlag("SOLID", 0)
				TNT1 A 0 A_ChangeFlag("FORCEXYBILLBOARD", 1)
				TNT1 A 0 A_GiveInventory("ISDOWN", 1)
				TNT1 A 0 A_JumpIfInventory ("FallingHeight", 15, "FallingDie")
				ZSPI WWWWWWWW 5 A_JumpIf(momz < 0, "FallingAfterImpact")
				TNT1 A 0 A_ChangeFlag("SOLID", 1)
				TNT1 A 0 A_TakeInventory("ISDOWN", 1)
				TNT1 A 0 A_ChangeFlag("FORCEXYBILLBOARD", 0)
				TNT1 A 0 A_TakeInventory("FallingHeight", 100)
				TNT1 A 0 A_TakeInventory("IsDown", 1)
				TNT1 A 0 A_JumpIfInventory("ZombieSleeping", 1, "SeeSleeping2")
				ZSPI XZY 5
				Goto See
			Pain.IsDown:
				TNT1 A 0 A_JumpIfInventory("ZombieSleeping", 1, "SeeSleeping2")
				TNT1 A 0
				ZSPI M 1
				ZSPI M 5 A_Pain
				Goto GetUp
			FallingDie:
				TNT1 A 0
				TNT1 A 0 A_ChangeFlag("SHOOTABLE", 0)
				TNT1 A 0 A_ChangeFlag("COUNTKILL", 0)
				TNT1 A 0 A_JumpIfInventory ("FallingHeight", 20, "FallingSuperDeath")
				TNT1 A 0 A_JumpIfInventory ("FallingHeight", 6, "FallingDeath")
			FallingDeath:
			Death.IsDown:
			Death.FellFromALongFall:
				TNT1 A 0 
				ZSAH L 1
				TNT1 A 1 
				TNT1 A 0 A_Scream
				TNT1 A 0 A_NoBLocking
				TNT1 AAAA 0 A_CustomMissile ("XDeath1", 32, 0, random (0, 360), 2, random (50, 130))
