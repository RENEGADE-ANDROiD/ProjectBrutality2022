ACTOR DeadSpikerGuts {
	Game Doom
	Radius 12
	Height 28
	Health 50
	PainSound "Spiker/Pain"
	PainChance 255
	Mass 999999
	+SHOOTABLE
    +FLOORCLIP
    +LOOKALLAROUND
	+FRIGHTENED
	+SOLID
	+DONTSPLASH
