				TNT1 A 0 A_CustomMissile ("PukerHeadExplode", 20, 0, random (150, 210), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("XDeath3Green", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("NashgoreBlood", 20, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("Green_FlyingBlood", 20, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("Green_FlyingBlood", 20, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("SuperWallGreenBlood", 20, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("GreenBloodMistBig", 20, 0, random (0, 360), 2, random (30, 90))
				3PUK KKKKKKKKKK 3 A_CustomMissile ("Green_FlyingBloodTrail", 26, 0, random (0, 360), 2, random (30, 60))
				3PUK LLL 3 A_CustomMissile ("Green_FlyingBloodTrail", 20, 0, random (0, 360), 2, random (10, 40))
				3PUK MM 3 A_CustomMissile ("Green_FlyingBloodTrail", 6, 0, random (0, 360), 2, random (30, 60))
				TNT1 A 0 A_SpawnItem ("CrueltyBonus5Health")
				TNT1 A 0 A_SpawnItemEx ("DeadPukerNoArmOrHead",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0) 
