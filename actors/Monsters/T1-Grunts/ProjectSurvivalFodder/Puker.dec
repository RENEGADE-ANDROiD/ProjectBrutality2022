			FallingSuperDeath:
				TNT1 A 0
				TNT1 A 0 
				TNT1 A 0 
				TNT1 A 0 A_XScream
				TNT1 A 0 A_NoBLocking
				Goto Death.ExplosiveImpact
			Death.Kick:
			Death.Melee:
				TNT1 A 0
