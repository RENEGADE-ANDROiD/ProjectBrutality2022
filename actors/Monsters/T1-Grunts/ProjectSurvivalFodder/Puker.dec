				2PUK W 4 A_CustomMissile ("Green_LiquidBlood", 15, 0, random (0, 360), 2, random (0, 40))
				TNT1 A 0 A_JumpIf((MomY == 0), "PinToWall")
				2PUK W 4 A_CustomMissile ("Green_LiquidBlood", 15, 0, random (0, 360), 2, random (0, 40))
