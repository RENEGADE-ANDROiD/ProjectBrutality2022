actor DeadPukerSplattered: ZombieXDeath {
	Scale 1.0
	BloodType "MuchBloodGreen"
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 
				ZPUK S 1 A_SpawnItem("MuchBloodGreen",0,0,0,1)
				ZPUK S -1
				Stop
			Death:
			Death.Stomp:
				TNT1 A 0 A_NoBlocking
				TNT1 AA 0 A_CustomMissile ("XDeath1Green", 5, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("XDeath2Green", 5, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_CustomMissile ("Green_FlyingBlood", 5, 0, random (0, 360), 2, random (0, 160))
				TNT1 AAA 0 A_CustomMissile ("Green_LiquidBlood", 5, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_CustomMissile ("GreenSuperGoreSpawner", 10, 0, random (0, 360), 2, random (10, 170))
				Stop
            Death.plasma:
				TNT1 A 0
				TNT1 A 0 A_NoBlocking
				TNT1 A 0 A_XScream
				TNT1 A 0 A_NoBlocking
				TNT1 AA 0 A_CustomMissile ("Green_FlyingBlood", 50, 0, random (0, 360), 2, random (0, 160))
				EXPL AA 0 A_CustomMissile ("ExplosionSmoke", 32, 0, random (0, 360), 2, random (0, 360))
				TNT1 A 0
				Stop
			Death.TeleportRemover:
			Death.GibRemoving:
				TNT1 A 0
				TNT1 A 0 A_Scream
				TNT1 A 0 A_NoBlocking
				TNT1 A 0 A_ChangeFlag("NOCLIP", 1)
				TNT1 A 0 A_ChangeFlag("SHOOTABLE", 0)
				TNT1 A 0 A_ChangeFlag("NOBLOCKMAP", 1)
				Stop
			Death.CrushedBodies:
			Death.Crush:
			Crush:
				TNT1 A 0 A_NoBlocking
				TNT1 AA 0 A_SpawnItem("MeatDeathSmall")
				TNT1 A 0 A_SetAngle(0)
				TNT1 A 0 bright A_CustomMissile ("GreenSuperGoreSpawner", 1, -20, random (0, 360), 2, random (25, 45))
				TNT1 A 0 bright A_CustomMissile ("GreenSuperGoreSpawner", 1, 20, random (0, 360), 2, random (25, 45))
				TNT1 A 0 A_CustomMissile ("XDeath2Green", 1, random (-30, 30), random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("XDeath3Green", 1, random (-30, 30), random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("GreenBloodMistBig", 1, -20, random (0, 360), 2, random (30, 90))
				TNT1 A 0 A_SetAngle(90)
				TNT1 A 1
				TNT1 A 1 A_XScream
				Stop 
			Death.Desintegrate:
				TNT1 A 0
				TNT1 AA 0 A_CustomMissile ("Green_FlyingBlood", 0, 0, random (0, 360), 2, random (0, 90))
				TNT1 A 0 A_CustomMissile ("Green_FlyingBlood", 7, 0, random (0, 360), 2, random (30, 60))
				TNT1 A 0 A_CustomMissile ("GreenBloodMistBig", 7, 0, random (0, 360), 2, random (30, 60))
				TNT1 A 0 A_SpawnItem("Xdeath3Green")
				Stop }}
				
