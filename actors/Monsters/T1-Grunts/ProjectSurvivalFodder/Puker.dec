Actor Puker {
	Health 70
	WoundHealth 30
    GibHealth 20
    Radius 20
    Height 44
    Speed 4
    PainChance 200
	PainChance "Stun", 255
	PainChance "Avoid", 35
	PainChance "Head", 255
    PainChance "Taunt", 255
    PainChance "Kick", 255
    PainChance "ExtremePunches", 255
	PainChance "Melee", 255
	PainChance "desintegrate", 12
    damagefactor "desintegrate", 0.0
    PainChance "explosiveimpact", 12
    damagefactor "explosiveimpact", 3.0
    PainChance "Explosive", 200
    damagefactor "explosive", 3.0
    PainChance "LandMine", 200
    damagefactor "LandMine", 3.0
	MaxStepHeight 28
	MaxDropOffHeight 500
    SeeSound ""
    PainSound "Puker/Pain"
    DeathSound "Puker/Death"
    ActiveSound "Puker/Active"
    Obituary "%o was consumed by a Zombie."
	BloodType "MuchBloodGreen", "BloodSPlatterReplacer", "SawBlood"
	Species "Fodder"
	Friction 0.9
    Monster
	damagefactor "MinorHead", 1.1
	damagefactor "Head", 1.1
    +FLOORCLIP
	+NOINFIGHTING
	+THRUSPECIES
	+DONTHURTSPECIES
	+DONTHARMCLASS
	+DONTHARMSPECIES
	+CANNOTPUSH
	-CANUSEWALLS
	-CANPUSHWALLS
	-ACTIVATEMCROSS
	-ACTIVATEPCROSS
		States {
		
			Spawn:
				TNT1 A 0
				TNT1 A 0 A_Jump(76,"SpawnSleeping")
			Spawn2:
				TNT1 A 0 A_SpawnItem("HeadshotTarget4", 8, 40,0)
				ZPUK AB 4 A_Wander
				TNT1 A 0 A_Look
				TNT1 A 0 A_PlaySound("flesh/step", 4)
				TNT1 A 0 A_SpawnItem("HeadshotTarget4", 8, 40,0)
				ZPUK CD 4 A_Wander
				TNT1 A 0 A_Look
				TNT1 A 0 A_PlaySound("flesh/step", 4)
				TNT1 A 0 A_Jump(2,"Grumble")
				Loop
			SpawnSleeping:
				TNT1 A 0 A_ChangeFlag("LOOKALLAROUND", 1)
				TNT1 A 0 A_GiveInventory("ZombieSleeping",1)
				TNT1 A 0 A_GiveInventory("IsDown",1)
				5PUK A 2 A_Look
				Loop
			SeeSleeping:
				5PUK A 2
				TNT1 A 0 A_JumpIfCloser(250,1)
				Goto SpawnSleeping
			SeeSleeping2:
				TNT1 A 0 A_CheckSight("SeeSleeping")
				TNT1 A 0 A_ChangeFlag("LOOKALLAROUND", 0)
				TNT1 A 0 A_TakeInventory("ZombieSleeping",1)
				TNT1 A 0 A_TakeInventory("IsDown",1)
				TNT1 A 0 A_PlaySound("Puker/Sight")
				ZPUK XZYBAAAA 5
				Goto See
			Grumble:
				TNT1 A 0 A_PlaySound("Puker/Ramble")
				TNT1 A 0 A_SpawnItem("HeadshotTarget20", 8, 40,0)
				5PUK B 10
				5PUK C 10
				TNT1 A 0 A_SpawnItem("HeadshotTarget20", 8, 40,0)
				5PUK B 10
				5PUK C 10
				TNT1 A 0 A_SpawnItem("HeadshotTarget10", 8, 40,0)
				5PUK A 10
				Goto Spawn2
			See:
				TNT1 A 0 A_JumpIfInventory("ZombieSleeping",1,"SeeSleeping")
			See2:
				TNT1 A 0 A_JumpIf(momz > -3,1)
				Goto FallDown
				TNT1 A 0 A_SetSpeed(6)
				TNT1 A 0 A_SpawnItem("HeadshotTarget4", 8, 40,0)
				ZPUK AB 5 A_Chase
				TNT1 A 0 A_Recoil(frandom(-2.0,2.0))
				TNT1 A 0 A_PlaySound("flesh/step", 4)
				TNT1 A 0 A_SpawnItem("HeadshotTarget4", 8, 40,0)
				ZPUK CD 5 A_Chase
				TNT1 A 0 A_Recoil(frandom(-2.0,2.0))
				TNT1 A 0 ThrustThing(random(0,360),random(1,2))
				TNT1 A 0 A_PlaySound("flesh/step", 4)
				TNT1 A 0 A_Jump(2,"Grumble")
				TNT1 A 0 A_Jump(3,"Lunge")
				Loop
			Missile:
				TNT1 A 0 A_JumpIfCloser(180,1)
				Goto See
				TNT1 A 0 {
					A_PLAYSOUND("Puker/PrepPuke");
					A_ChangeFlag("NOPAIN",true);
				}
				5PUK BBBBBBBBBBBBBBBBBBBBBBBBB 1 A_FaceTarget
				5PUK C 6 A_FaceTarget
				TNT1 A 0 A_PlaySound("Puker/Puke")
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile2", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK D 1 A_CustomMissile("PukeStreamMissile", 40, 0, random(-5,5), 2, random(-5,5))
				5PUK C 15 A_ChangeFlag("NOPAIN",false)
				Goto See
			Lunge:
				TNT1 A 0 A_Recoil(-10)
				TNT1 A 0 ThrustThingZ(0,20,0,1)
				ZPUK E 5
				Goto See
			Melee:
				TNT1 A 0 A_SpawnItem("HeadshotTarget10", 8, 40,0)
				ZPUK EF 10 A_FaceTarget
				TNT1 A 0 A_SpawnItem("HeadshotTarget8", 8, 40,0)
				ZPUK G 8 A_CustomMissile("ImpAttack",10,0,0,0)
				ZPUK FE 10 A_FaceTarget
				Goto See
			Pain:
				TNT1 A 0 A_JumpIfInventory("ZombieSleeping", 1, "SeeSleeping2")
				TNT1 A 0 A_JumpIfInventory("IsDown", 1, "Pain.IsDown")
				TNT1 A 0 A_SpawnItem("HeadshotTarget8", 8, 40,0)
				ZPUK H 4
				ZPUK H 4 A_Pain
				Goto See
			Pain.Stun:
				TNT1 A 0
				TNT1 A 0 A_ChangeFlag("NOGRAVITY", 0)
				TNT1 A 0 A_ChangeFlag("THRUSPECIES", 0)
				TNT1 A 0 A_ChangeFlag("CEILINGHUGGER", 0)
				TNT1 A 0 A_SpawnItemEx ("StunElectrocute", random (-4, 4), random (-4, 4),  random (16, 32), 0, 0)
				ZPUK H 1 A_Pain
				ZPUK HHHHHHHHHH 3 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
				ZPUK H 1 A_Pain
				ZPUK HHHHHHHHHH 3 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
				ZPUK H 1 A_Pain
				ZPUK HHHHHHHHHH 3 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
				ZPUK H 1 A_Pain
				ZPUK HHHHHHHHHH 3 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
				ZPUK H 1 A_Pain
				ZPUK HHHHHHHHHH 3 A_SpawnItemEx ("StunElectrocute", random (-12, 12), random (-12, 12),  random (16, 52), 0, 0)
				ZPUK H 1 A_Pain
				TNT1 A 0 A_JumpIfInventory("ZombieSleeping", 1, "SeeSleeping2")
				Goto See
			Death.Shotgun:
				TNT1 A 0 A_JumpIfInventory("IsDown", 1, "Death.IsDownShotgun")
				TNT1 A 0 A_JumpIfCloser(50, "Death.ExtremePunches")
				TNT1 A 0 A_JumpIfCloser(100, "Death.Splatter")
				TNT1 A 0 A_Jump(72, "Death.Chunk")
				TNT1 A 0 A_Jump(72, "Death.Guts")
				TNT1 A 0 A_Jump(72, "Death.Kick")
				Goto Death.Splatter
			Death.SSG:
			Death.Railgun:
			Death.Blast:
				TNT1 A 0 A_JumpIfInventory("IsDown", 1, "Death.IsDownShotgun")
				TNT1 A 0 A_JumpIfCloser(100, "Death.ExtremePunches")
				TNT1 A 0 A_Jump(72, "Death.Splatter")
				TNT1 A 0 A_Jump(72, "Death.Guts")
				TNT1 A 0 A_Jump(72, "Death.ExtremePunches")
				Goto Death.Splatter
			Death:
				TNT1 A 0 A_JumpIfInventory("IsDown", 1, "Death.IsDown")
				TNT1 AAA 0 A_CustomMissile ("XDeath1Green", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("SuperWallGreenBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("GreenBloodMistBig", 40, 0, random (0, 360), 2, random (30, 90))
				TNT1 A 0 A_CustomMissile ("MuchBloodGreen", 40, 0, random (0, 360), 2, random (0, 160))
				ZPUK I 7 A_Scream
				ZPUK J 5 A_NoBlocking
				TNT1 A 0 A_PlaySound("Corpse/Fall",CHAN_6)
				ZPUK KL 5
				TNT1 A 0 A_SpawnItemEx ("DeadPukerBasic",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop
			Death.Head:
				TNT1 A 0 A_Stop
				TNT1 A 0 A_JumpIfInTargetInventory("HitboxFireDamage",1,"Death.Fire")
				TNT1 A 0 A_JumpIfInTargetInventory("HitboxIceDamage",1,"Death.Ice")
				TNT1 A 0 A_JumpIfInTargetInventory("HitboxAcidDamage",1,"Death.Desintegrate")
				TNT1 A 0 A_JumpIfInTargetInventory("HitboxDemonicDamage",1,"Death.Incinerate")
				TNT1 A 0 A_JumpIfInTargetInventory("HitboxPlasmaDamage",1,"Death.Plasma")
				TNT1 A 0 A_JumpIfInTargetInventory("HitboxBladedDamage",1,"Death.Decapitate")
				TNT1 A 0 A_JumpIfHealthLower(-150, "Death.Backflip")
				TNT1 A 0 A_JumpIfHealthLower(-90, "Death.HeadExplode")
				TNT1 A 0 A_JumpIfInTargetInventory("RandomHeadExploder", 1, "Death.HeadExplode")
				TNT1 A 0 A_Playsound("MinorHeadshot", 0)
				TNT1 AA 0 A_CustomMissile ("XDeath1Green", 40, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("XDeath3Green", 40, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("XDeath1Green", 40, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_CustomMissile ("XDeath3Green", random (40, 45), random (5, -5), random (170, 190), 2, random (-10, 10))
				TNT1 AA 0 A_CustomMissile ("XDeath1Green", 40, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("SuperWallGreenBlood", 40, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("Green_FlyingBlood", 40, 0, random (0, 360), 2, random (0, 160))
				3PUK N 9 A_NoBlocking
				3PUK O 9 A_Scream
				3PUK P 8
				3PUK Q 8 
				TNT1 A 0 A_SpawnItem ("DeadPukerCrackedHead")
				Stop	
			Death.headExplode:
				TNT1 A 0
				TNT1 A 0 A_SpawnItem("PukerHeadExplode", 0, 40)
				2PUK SSSS 2 A_CustomMissile ("Green_LiquidBlood", 40, 0, random (0, 360), 2, random (60, 120))
				TNT1 A 0 A_NoBlocking
				2PUK TTTT 2 A_CustomMissile ("Green_LiquidBlood", 35, 0, random (0, 360), 2, random (60, 120))
				TNT1 A 0 A_XScream
				2PUK UUUUUUUU 2 A_CustomMissile ("Green_LiquidBlood", 30, 0, random (0, 360), 2, random (60, 120))
				2PUK VVV 2 A_CustomMissile ("Green_LiquidBlood", 20, 0, random (0, 360), 2, random (60, 120)) 
				3PUK IIIIIIIIIIIIIIIIIIIIIIIII 2 A_CustomMissile ("Green_LiquidBlood", 15, 0, random (0, 360), 2, random (15, 40))
				TNT1 A 0 A_SpawnItem ("DeadPukerNoHead")
				Stop
			Death.Decapitate:
				TNT1 A 0 {
					A_Stop;
					A_FaceTarget;
					A_NoBlocking;
					A_CustomMissile("PukerHeadExplode", 32, 0, random (170, 190), 2, random (0, 40));
					A_SpawnProjectile ("MuchBloodGreen", 40, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (0, 160));
				}
				TNT1 A 0 A_StartSound("misc/XDeath2c")
				2PUK S 9 A_NoBlocking
				2PUK T 6
				2PUK U 9
				TNT1 A 0 A_SpawnItem ("DeadPukerNoHead")
				Stop	
			Death.Backflip:	
				TNT1 A 0 A_Jump(108,"Death.HeadExplode")
				TNT1 A 0 A_ClearTarget()
				2PUK S 2 {
					A_SpawnItem("PukerHeadExplode", 0, 40);
					A_StartSound("misc/XDeath4");
					A_FaceTarget;
					A_XScream;
					A_NoBlocking;
					ThrustThingZ(0,35,0,1);
					}
				5PUK Y 2 A_Recoil(10)
				5PUK Z 9
				ZPUK M 3
				2PUK QR 6
				TNT1 A 0 A_StartSound("BODYF",6)
				3PUK IIIIIIIIIIIIIIIIIII 4 A_SpawnProjectile ("Green_FlyingBloodTrail", 10, 0, random (0, 360), CMF_AIMDIRECTION|CMF_ABSOLUTEPITCH|CMF_OFFSETPITCH|CMF_BADPITCH|CMF_SAVEPITCH, random (10, 40))
				3PUK I 1 A_SpawnItem ("DeadPukerNoHead")
				Stop
			Death.Tear:
				TNT1 AAA 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (150, 210), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("Instestin", 32, 0, random (150, 210), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("XDeath1Green", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("SuperWallGreenBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("GreenBloodMistBig", 40, 0, random (0, 360), 2, random (30, 90))
				TNT1 A 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("GreenBloodMistBig", 40, 0, random (0, 360), 2, random (30, 90))
				TNT1 A 0 A_CustomMissile ("MuchBloodGreen", 50, 0, random (0, 360), 2, random (0, 160))
				ZPUK O 5 A_XScream
				ZPUK P 5 A_NoBlocking
				ZPUK Q 5 
				TNT1 A 0 A_PlaySound("Corpse/Fall",CHAN_6)
				ZPUK R 5 
				TNT1 A 0 A_SpawnItemEx ("DeadPukerSplattered",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0) 
				Stop
			Death.Chunk:
				TNT1 A 0 A_XScream
				3PUK J 6 A_Stop
				TNT1 AAA 0 A_CustomMissile ("PB_Intestine", 32, 0, random (150, 210), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("XDeath1Green", 32, 0, random (150, 210), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("XDeathFodderArm", 32, 0, random (150, 210), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("XDeathPukerHead", 32, 0, random (150, 210), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("XDeath3Green", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("NashgoreBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAAA 0 A_CustomMissile ("SuperWallGreenBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("GreenBloodMistBig", 40, 0, random (0, 360), 2, random (30, 90))
				3PUK KKKKKKKKKK 3 A_CustomMissile ("Green_FlyingBloodTrail", 26, 0, random (0, 360), 2, random (30, 60))
				3PUK LLL 3 A_CustomMissile ("Green_FlyingBloodTrail", 26, 0, random (0, 360), 2, random (10, 40))
				3PUK MM 3 A_CustomMissile ("Green_FlyingBloodTrail", 6, 0, random (0, 360), 2, random (30, 60))
				TNT1 A 0 A_SpawnItemEx ("DeadPukerNoArmOrHead",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0) 
				Stop
			Death.SuperPunch:
			Death.ExtremePunches:
				TNT1 A 0 A_JumpIfInventory("IsDown", 1, "Death.IsDownShotgun")
				TNT1 A 0 A_Jump(96, "DeathSplatter")
				ZFPD I 0 A_CustomMissile("XDeathPukerHead", 32, 0, random (170, 190), 2, random (0, 40))
				ZFPD II 0 A_CustomMissile("XDeathFodderArm", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_SpawnItem("BloodSplasher2")
				TNT1 A 0 bright A_CustomMissile ("SuperGoreSpawner", 35, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("XDeath1Green", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("XDeath2Green", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("XDeath3Green", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("Instestin", 32, 0, random (150, 210), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("Green_FlyingBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("SuperWallGreenBlood", 32, 0, random (170, 190), 2, random (0, 40))
				TNT1 AAA 0 A_CustomMissile ("SuperWallGreenBlood", 46, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("GreenBloodMistBig", 40, 0, random (0, 360), 2, random (30, 90))
				4PUK M 6
				4PUK NNN 2 A_SpawnItem ("Big_Blood", 0, 30)
				TNT1 A 0 A_PlaySound("Corpse/Fall",CHAN_6)
				4PUK OP 6 
				TNT1 A 0 A_SpawnItemEx ("GibHalfPukerLower",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop
			Death.Landmine:
				TNT1 A 0 A_SpawnItem("BloodSplasher3")
				TNT1 A 0 A_CustomMissile("XDeathPukerHead",50,0,random(-300,300))
				TNT1 AA 0 A_CustomMissile("XDeathFodderArm",50,0,random(-300,300))
				TNT1 AA 0 A_CustomMissile("XDeathFodderLeg",50,0,random(-300,300))
				TNT1 AAAA 0 A_CustomMissile ("SuperWallGreenBlood", 40, 0, random (0, 360), 2, random (-15, 15))
				TNT1 AAAA 0 A_CustomMissile ("CeilBloodLauncherLong", 0, 0, random (0, 360), 2, random (50, 130))
				TNT1 AA 0 A_CustomMissile ("XDeath1Green", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("XDeath2Green", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("XDeath3Green", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 AA 0 A_CustomMissile ("XDeath4Green", 32, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("XDeathOrgan1", 24, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_CustomMissile ("XDeathOrgan2", 24, 0, random (0, 360), 2, random (0, 160))
				TNT1 AAAA 0 A_CustomMissile ("Instestin", 24, 0, random (0, 360), 2, random (0, 160))
				TNT1 A 0 A_SpawnItem ("BigBloodSpot")
				TNT1 A 1
				TNT1 A 2
				Stop
			Death.cut:
			Death.Saw:
				TNT1 A 0
				TNT1 A 0 A_Jump(132, "DeathSplatter")
				TNT1 A 0 A_ChangeFlag("NOGRAVITY", 0)
				TNT1 A 0 A_ChangeFlag("THRUSPECIES", 0)
				TNT1 A 0 A_ChangeFlag("CEILINGHUGGER", 0)
				TNT1 O 0 A_NoBlocking
				TNT1 AAA 0 A_CustomMissile ("Instestin", 32, 0, random (150, 210), 2, random (0, 40))
