ACTOR XDeathScreamerHead: XDeathBullArm1 {
	-CLIENTSIDEONLY
	Radius 10
    Scale 1.0
		States {
			Spawn:
			Spawn1:
				TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
				TNT1 A 0 A_JumpIf(momz == 0, "Death")
				2SCR IJ 3
				TNT1 A 0 A_ChangeFlag("THRUSPECIES", 0)
				ZHSH KLMNOP 3
				Loop
			Death:
				ZHSH J 1
				TNT1 A 0 A_SpawnItemEx ("ScreamerHead",0,0,0,1,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}

actor ScreamerHead: LimbBase {
	damagefactor "Kick", 99.0
	damagefactor "Melee", 99.0
	damagefactor "SuperPunch", 99.0
	-CLIENTSIDEONLY
	+SHOOTABLE
	+THRUACTORS
	damagefactor "Crush", 50.0
    Radius 10 
	Mass 12
	Health 40
    Scale 1.0
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0
				TNT1 A 0 
				TNT1 A 0 A_Jump(256, "Spawn1", "Spawn2")
			Spawn1:
				ZHSH J 1
				ZHSH J -1
				Stop
			Spawn2:
				ZHSH N 1
				ZHSH N -1
				Stop
			Death.Trample:
			Death.Stomp:
				TNT1 A 0 A_GiveToTarget("BootsSmearedWithRedBlood", 6)
				Goto Death
			Death:
				TNT1 A 0
				TNT1 A 0 A_SpawnItemEx ("FodderHeadExplode",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop
			Crush:
				TNT1 AAAAAAAA 0 A_CustomMissile ("Brutal_FlyingBloodTrail5", 0, 0, random (0, 360), 2, random (60, 140))
				TNT1 A 0 A_PlaySound("misc/xdeath4")
				CRS1 B 5
				CRS1 B 9009
				Stop
			Death.plasma:
				TNT1 A 0
				TNT1 A 0 A_CustomMissile ("XDeathBurnedSkull", 32, 0, random (0, 360), 2, random (0, 160))
				EXPL A 0 A_CustomMissile ("ExplosionSmoke", 32, 0, random (0, 360), 2, random (0, 360))
				TNT1 A 0
				Stop
			Death.Melee:
			Death.SuperPunch:
			Death.Kick:
				ZHSH MM 1 A_FaceTarget
				TNT1 AAAA 0 A_SpawnItemEx("Blood", 0, 0, 10)
				TNT1 A 0 A_CustomMissile ("XDeathScreamerHeadKicked", 5, 0, random (170, 190), 2, random (20, 40))
				TNT1 A 0 A_PlaySound("misc/xdeath4", 1)
				TNT1 A 0 A_PlaySound("player/cyborg/fist", 3)
				TNT1 A 20
				Stop
			Pain:
				TNT1 A 0
				TNT1 A 0 ThrustThingZ(0,20,0,1)
				ZHSH IJKLMNOP 2
				Goto Spawn
			Death.ExplosiveImpact:
				TNT1 A 0
				TNT1 A 0 A_ChangeFlag("NOBLOCKMAP", 0)
				TNT1 A 0 ThrustThingZ(0,50,0,1)
				ZHSH IJKL 6
				TNT1 A 0 A_SpawnItemEx ("ScreamerHead",0,0,0,0,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}

