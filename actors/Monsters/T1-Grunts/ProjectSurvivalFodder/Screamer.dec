				TNT1 A 0 A_CustomMissile ("MuchBlood", 16, 0, random (0, 360), 2, random (0, 160))
				2SCR A 5 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
				TNT1 AAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("SuperWallRedBlood", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("MuchBlood", 16, 0, random (0, 360), 2, random (0, 160))
				2SCR A 5 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
				TNT1 AAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("SuperWallRedBlood", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("MuchBlood", 16, 0, random (0, 360), 2, random (0, 160))
				2SCR A 5 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
				TNT1 AAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("Brutal_FlyingBloodMuchFaster", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 AA 0 A_CustomMissile ("SuperWallRedBlood", 16, 0, random (170, 190), 2, random (0, 40))
				TNT1 A 0 A_CustomMissile ("MuchBlood", 16, 0, random (0, 360), 2, random (0, 160))
				2SCR BCD 3 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
			Death:
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_SpawnItemEx ("GibHalfScreamerLower",0,0,0,1,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}

actor GibHalfScreamerLower: ZombieXDeath {
	Scale 1.0
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 
				2SCR D 1 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				2SCR D -1
				Stop    }}
				
ACTOR HalfScreamerUpper {
    Radius 8
    Height 8
    Speed 7
	Mass 8
	BounceFactor 0.2
	+DOOMBOUNCE
    +NOBLOCKMAP
	+MISSILE
    +NOTELEPORT
    +DONTSPLASH
    +MOVEWITHSECTOR
    DeathSound "misc/xdeath1"
	Decal BrutalBloodSplat
	Scale 1.0
		States {
			Spawn:
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_JumpIf(waterlevel > 1, "Death")
				2SCR EEEFFFGGGH 12 A_CustomMissile("Brutal_FlyingBloodTrail",0,0,180,2)
			Death:
				TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				TNT1 A 0 A_SpawnItemEx ("GibHalfScreamerUpper",0,0,0,1,0,0,0,SXF_NOCHECKPOSITION,0)
				Stop }}

actor GibHalfScreamerUpper: ZombieXDeath  {
	Scale 1.0
		States {
			Spawn:
				TNT1 A 0
				TNT1 A 0 
				2SCR H 1 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
				2SCR H -1
				Stop    }}
				
//Projectile/////

Actor ZombiePassiveSpawner {
	Speed 100
	Radius 20
    Height 56
	Mass 40
	MaxStepHeight 150
	MaxDropOffHeight 28
	DeathSound "Shambler/Spawn"
	+THRUACTORS
	-COUNTKILL
	+Boss
	+DONTSPLASH
		States {
			Spawn:
				TNT1 A 0 A_ChangeFlag("FRIGHTENED",1)
				TNT1 AAAAAAAAAAAAAA 1 A_Chase
				TNT1 A 1 A_Chase
				TNT1 A 0 A_CheckSight ("Create")
				TNT1 A 1 A_Chase
				TNT1 A 0 A_CheckSight ("Create")
				TNT1 A 1 A_Chase
				TNT1 A 0 A_CheckSight ("Create")
				TNT1 A 1 A_Chase
				TNT1 A 0 A_CheckSight ("Create")
				TNT1 A 1 A_Chase
				TNT1 A 0 A_CheckSight ("Create")
				TNT1 A 1 A_Chase
				TNT1 A 0 A_CheckSight ("Create")
				TNT1 A 1 A_Chase
				TNT1 A 0 A_CheckSight ("Create")
				TNT1 A 1 A_Chase
				TNT1 A 0 A_CheckSight ("Create")
				TNT1 A 0 A_Jump(20,"Death")
				Loop
			Create:
				TNT1 A 0 A_SpawnItemEx ("ShamblerSummoned",0,0,0,0,0,0,random(0,360),SXF_NOCHECKPOSITION,0)
				TNT1 A 0 A_Scream
				Goto Death
			Death:
				TNT1 A 0 A_Scream
				Stop	}}