	Death.Ice:
	Death.IceExplosion:
	Death.Freeze:
	Death.Frost:
		TNT1 A 0 A_ChangeFlag("SHOOTABLE", 0)
		TNT1 A 0 A_ChangeFlag("SOLID", 0)
		TNT1 A 0 A_SpawnItem("FrozenHangman")
		Stop
   } 
}

Actor HangmanMissile : PukeStreamMissile { Speed 6 }
Actor HangmanMissile2 : HangmanMissile { Damage 0 }