Actor HorrorspawnHead
{

	Radius 8
    Height 16
	Speed 5
	Gravity 0.5
	Mass 4
	BounceFactor 0.5
	wallbouncefactor 0.5
	BounceCount 2
	BounceType Doom
	BounceSound "Gore/HeadBounce"
	+MISSILE
    +MOVEWITHSECTOR
    +CLIENTSIDEONLY
    +NOBLOCKMAP
    +NOTELEPORT
	+THRUACTORS
	States
	{
	Spawn:
		ZFOH ABCD 2 A_SpawnItemEx("BloodSplasher3")
	Loop
	Bounce:
		TNT1 A 0 A_SpawnItemEx("BloodSplasher3")
		TNT1 A 0 A_SpawnItemEx("BloodSplasher3")
		Goto Spawn
	Death:
		TNT1 A 0 A_PlaySound("Gore/HeadBounce",CHAN_6)
		TNT1 A 0 A_SpawnItemEx("BloodSplasher3")
		TNT1 A 0 A_SpawnItemEx("BloodSplasher3")
		TNT1 A 0 A_SpawnItemEx("BloodSplasher3")
		TNT1 A 0 A_NoBlocking
		TNT1 A 0 A_QueueCorpse
        ZFOH E -1
		Stop
	}
}

