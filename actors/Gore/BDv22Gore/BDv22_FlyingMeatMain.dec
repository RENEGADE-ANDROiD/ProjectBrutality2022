	+NOGRAVITY
	States
	{
		Spawn:
			B22T G 10
			TNT1 A 0 ThrustThingZ(0, 1, 1, 1)
			TNT1 A 0 A_Jump(255, "Spawn1", "Spawn2", "Spawn3", "Spawn4")
		Spawn1:
			B22T OOOOOOOOOOOOOO 2 A_CheckFloor("Rest")
			Goto Death
		Spawn2:
			B22T OOOOOOOOOOOOOOOOOO 2 A_CheckFloor("Rest")
			Goto Death
		Spawn3:
			B22T OOOOOOOOOOOOOOOOOOOO 2 A_CheckFloor("Rest")
			Goto Death
		Spawn4:
			B22T OOOOOOOOOOOOOOOOOOOOOO 2 A_CheckFloor("Rest")
			Goto Death
		Death:
			TNT1 A 0
			TNT1 A 0 A_SpawnItem("BDv22_MeatChunk3NoStick")
			Stop
		Rest:
			B22T I 1
			TNT1 A 0 A_QueueCorpse
			TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
			B22T I -1
			Stop
		Vanish:
			TNT1 A 5
			Stop
	}
}

actor BDv22_CeilB22M3: BDv22_CeilB22M2
{
	States
	{
		Spawn:
			Goto Crash
		Death:
		Crash:
			TNT1 A 0
			TNT1 A 0 A_JUmp (255, "Live1", "Live2", "Live3")
			Goto Live1
		Live1:
			B22T JJJJJJJJJJJJJJ 4 ThrustThingZ(0, 20, 0, 1)
			Goto Fall
		Live2:
			B22T JJJJJJJJJJJJJJJJJJ 4 ThrustThingZ(0, 20, 0, 1)
			Goto Fall
		Live3:
			B22T JJJJJJJJJJ 4 ThrustThingZ(0, 20, 0, 1)
			Goto Fall
		Fall:
			B22T JJJJKKKLLM 2
			TNT1 A 0 A_SpawnItemEx("BDv22_MeatChunk3NoStick", 0, 0, 0, 0, 0, -1)
			B22T MMN 2
			Stop
		Splash:
			BLOD A 0
			Stop
	}
}

ACTOR BDv22_MeatChunk3NoStick : BDv22_MeatChunk2NoStick
{
	States
	{
		Spawn:
			TNT1 A 0 A_JumpIf(waterlevel > 1, "Splash")
			TNT1 A 0 A_CheckFloor("Death")
			B22T O 3
			Loop
		Death:
			TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 0, 0, random (0, 360), 2, random (40, 90))
			B22T I 1
			TNT1 A 0 A_QueueCorpse
			B22T I 3
			TNT1 A 0 A_SpawnItem("Brutal_BloodSpot",0,0,0,1)
			B22T I -1
			Stop
	}
}

ACTOR BDv22_RibCageA : BDv22_MeatChunk2
{
	Scale 1.0
	+DOOMBOUNCE
	BounceFactor 0.01
	Gravity 1.0
	WallBounceFactor 0.2
	States
	{
		Spawn:
			TNT1 A 0 A_JumpIf(waterlevel > 1, "Splash")
			B22R AAAAAA 4 A_CustomMissile ("Brutal_FlyingBloodTrail", 0, 0, random (0, 360), 2, random (0, 360))
			Loop
		Death:
			B22R B 1
			TNT1 A 0 A_QueueCorpse
			B22R B -1
			Stop
	}
}

ACTOR BDv22_RibCageB : BDv22_MeatChunk2
{
	DeathSound "misc/xdeath3"
	Scale 1.0
	Gravity 0.6
	Speed 4
	States
	{
		Spawn:
			TNT1 A 0 A_JumpIf(waterlevel > 1, "Splash")
			B22S A 4 A_CustomMissile ("Brutal_FlyingBloodTrail", 0, 0, random (0, 360), 2, random (0, 360))
			Loop
		Death:
			TNT1 AAAA 0 A_CustomMissile ("Brutal_FlyingBloodFaster", 0, 0, random (0, 360), 2, random (40, 90))
			TNT1 A 0 A_SpawnItemEx ("Brutal_BloodSpot", 0, 0, 1)
			B22S B 1
			TNT1 A 0 A_QueueCorpse
			B22S B -1
			TNT1 A 0
			B22S B 3
		Living:
			B22S B 800
			TNT1 A 0 A_JumpIfInventory("lowgraphicsmode", 1, "Vanish")
			Loop
		Vanish:
			TNT1 A 1
			Stop
	}
}

