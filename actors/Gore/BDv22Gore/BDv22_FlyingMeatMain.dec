ACTOR BDv22_MicroGib0 : XDeath1
{
	+CLIENTSIDEONLY
	+DONTSPLASH
	-BLOODLESSIMPACT
	-RIPPER
	Decal "None"
	Speed 10
	Radius 1
	Height 1
	Scale 0.4
	States
	{
		Spawn:
			B22E A 2 A_CustomMissile ("Brutal_FlyingBloodTrail", 0, 0, random (0, 360), 2, random (0, 360))
			Loop
		Death:
			B22E B 1
			TNT1 A 0 A_QueueCorpse
			B22E B -1
			Stop
	}
}

