// Big animated blood splat. BL00 A-R, BL01 A-Q (skips G), BL02 A-R,
// BL03 A-Z, BL04 A-N. Plays once, drops a Brutal_BloodSpot decal, then
// fades out. Original sprites by AWEZ (Brutal Pack V10).

ACTOR BPv10_BloodSplat0
{
    Radius 1
    Height 1
    Scale 0.6
    +CLIENTSIDEONLY
    +DONTSPLASH
    +NOBLOCKMAP
    +NOTELEPORT
    +NOGRAVITY
    +THRUACTORS
    +FORCEXYBILLBOARD
    +MOVEWITHSECTOR
    RenderStyle Translucent
    Alpha 0.85
    States
    {
    Spawn:
        BL00 A 1 NoDelay A_SpawnItemEx("Brutal_BloodSpot", 0, 0, 0, 0, 0, 0, 0, SXF_NOCHECKPOSITION)
        BL00 BCDEFGHIJKLMNOPQR 2
        Goto Linger
    Linger:
        BL00 R 1 A_FadeOut(0.006)
        Loop
    }
}

