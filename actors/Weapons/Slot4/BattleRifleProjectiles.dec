// Shared rifle bullet for the surviving Battle Rifle (BDPBattleRifle.zs).
// Originally lived in M41A.dec, relocated here when the M41A was removed.
Actor PB_762x51mm : FastProjectile
{
	Projectile
	Radius 2
	Height 2
	Speed 250
	Damage 40
	DamageType Bullet
	Decal "BulletChip"
	States
	{
	Spawn:
		TNT1 A 1
		Loop
	Death:
		TNT1 A 0 A_SpawnItem("HitPuff")
		Stop
	}
}
