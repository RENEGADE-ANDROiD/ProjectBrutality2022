Actor NailBlur       
{
  Height 8
  Radius 1
  Damage 0
  Scale 0.65
  Speed 0.2
  RenderStyle Translucent
  Alpha 0.5
  +NoGravity
  +DropOff
  +NoTeleport
  States
  {
  Spawn:
    NLPJ A 1 A_FadeOut(0.4)
    Loop
  }
}

Actor HotNailBlur : NailBlur     
{
  States
  {
  Spawn:
    NLPJ B 1 BRIGHT A_FadeOut(0.4)
    Loop
  }
}
