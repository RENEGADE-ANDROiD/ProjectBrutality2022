// Borrowed from Diamond Dragon
ACTOR SlayerGodModePowerup : InvulnerabilitySphere
{
	Inventory.MaxAmount 0
	powerup.duration -4
	Powerup.Type "Invulnerable"
	Powerup.Mode "Reflective"
	Powerup.Color "FF4466", 0.05
	+INVENTORY.AUTOACTIVATE
	States
	{
	Spawn:
		TNT1 A 1
		Loop
	}
}

ACTOR SlayerExplosionFire
{ 
	Radius 2
	Height 2
	Speed 5
	Scale 0.8
	Gravity 0.5
	RenderStyle Add
	+MISSILE
	+DROPOFF
	+NOTELEPORT
	+THRUACTORS
	+Noclip
	+THRUGHOST
	+DONTSPLASH
	States
	{
	Spawn:
		TNT1 A 0
		TNT1 A 0 A_CheckRange(1000,"GoAway")
		TNT1 A 0 A_Jump(128,2)
		TNT1 A 0 A_ChangeFlag(XFLIP, TRUE)
		FLME AB 2 BRIGHT A_Setscale(0.15)
		FLME CD 2 BRIGHT A_Setscale(0.35)
		FLME EFGHIJKLMNABCDEFGHIJKLMNABCDEFGHIJKLMNABCDEFGHIJKLMN 2 BRIGHT A_Setscale(0.5)
		FLME AB 2 BRIGHT A_Setscale(0.45)
		FLME CD 2 BRIGHT A_Setscale(0.4)
		FLME EF 2 BRIGHT A_Setscale(0.35)
		FLME GH 2 BRIGHT A_Setscale(0.3)
		FLME IJ 2 BRIGHT A_Setscale(0.25)
		FLME KL 2 BRIGHT A_Setscale(0.2)
		FLME MN 2 BRIGHT A_Setscale(0.1)
		Stop
	GoAway:
		TNT1 A 1
		Stop
	}
}

ACTOR Fire1 : SlayerExplosionFire
{ 
	Scale 0.6
	Speed 2.5
	alpha 0.8
	+Nogravity
	+NOINTERACTION
	+FORCEXYBILLBOARD
	+NOBLOCKMAP
	+FLOORCLIP
	+Dontsplash
	States
	{
	Spawn:
		TNT1 A 0
		TNT1 A 0 A_CheckRange(1000,"GoAway")
		TNT1 A 0 A_Jump(128,2)
		TNT1 A 0 A_ChangeFlag(XFLIP, TRUE)
		FIR9 ABCDEF 2 BRIGHT 
		FIR9 GHI 2 BRIGHT A_FadeOut(0.3)
		Stop
   }
}

ACTOR Fire2 : Fire1
{ 
	Scale 1
	States
	{
	Spawn:
		TNT1 A 0
		TNT1 A 0 A_CheckRange(1000,"GoAway")
		TNT1 A 0 A_Jump(128,2)
		TNT1 A 0 A_ChangeFlag(XFLIP, TRUE)
		FIR7 ABCD 3 BRIGHT
		FIR7 E 3 BRIGHT A_FadeOut(0.5)
		Stop
	}
}

ACTOR Fire3 : Fire1
{ 
	Scale 0.4
	States
	{
	Spawn:
		TNT1 A 0
		TNT1 A 0 A_CheckRange(1000,"GoAway")
		TNT1 A 0 A_Jump(128,2)
		TNT1 A 0 A_ChangeFlag(XFLIP, TRUE)
		FIR8 ABCDEFGHIJ 2 BRIGHT
		FIR8 KLM 2 BRIGHT A_FadeOut(0.3)
