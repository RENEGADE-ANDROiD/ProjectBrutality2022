Actor DSAttack3: FastProjectile
{
	Radius 25
	Height 50
	Mass 99999
	DamageType Freeze
   +RollSprite
   +MISSILE
   +NoBlockMap
   +LowGravity
   +DontSplash
   +FORCEXYBILLBOARD
   +FORCERADIUSDMG
