            TNT1 A 0
            DLI7 ABCDEFGHIJK 1 bright
            Stop
        Spawn2:
            TNT1 A 0
            DLI8 ABCDEFGHIJK 1 bright
            Stop
        Spawn3:
            TNT1 A 0
            DLI9 ABCDEFGHIJK 1 bright
            Stop
        Spawn4:
            TNT1 A 0
            DLI0 ABCDEFGHIJK 1 bright
            Stop
