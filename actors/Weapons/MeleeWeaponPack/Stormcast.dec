Actor Stunwall
{
	Game Doom
	Radius 6
	Height 16
	Speed 0
	Damage 0
	Health 9999
	Monster
	-SOLID
	-COUNTKILL
	+SHOOTABLE
    //+NOBLOCKMAP
    +NOTELEPORT
    +DONTSPLASH
    +CLIENTSIDEONLY
    //+NOINTERACTION
	//+NOCLIP
	+FORCEXYBILLBOARD
	+DONTBLAST
	+NOBLOOD
	+FRIENDLY
	+LOOKALLAROUND
