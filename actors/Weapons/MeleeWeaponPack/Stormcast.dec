		TNT1 A 0 A_ClearTarget
		TNT1 A 0 A_Chase
		TNT1 A 1 A_JumpIfCloser(64, "Ignite")
		TNT1 A 0 A_ClearTarget
		TNT1 A 0 A_Chase
