// Stormcast — Slot 9 energy / lightning weapon (Schism-line content in PB).
// Original: PB_MeleeWeaponPack CREDITS — Battle Axe & Shield / Stormcast by
// Dreo & Lord Lothar (Schism). PB 0.4.2+ rework: Renegade Android. PB 2022 fold.
//
// Weapon class: zscript/Weapons/MeleeWeaponPack/Stormcast.zc

// Ammmo Test
actor IsUsingStormcast : Inventory{Inventory.maxamount 1}
actor StormCastAmmoSmall : CustomInventory
{
	Game Doom
	Scale 0.45
	+DONTGIB
	+FLOORCLIP
	Inventory.PickupMessage "StormCast Ammo"
	Inventory.PickupSound "Ammocase/Open"
	States {
		Spawn:
			MSCR AABBCCBB 2 BRIGHT A_SpawnItem("PlasmaFlareSpawn",0,20)
			MSCR A 1 bright A_SpawnItem("StormcastElectroBlastTrail",0,30)
			Loop
		Pickup:
			TNT1 A 0 A_GiveInventory("PowerChargeStorm",10) 
			TNT1 A 20
			Stop	
		}
}

actor StormCastAmmoBig : StormCastAmmoSmall
{
	Game Doom
	Scale 2
	+DONTGIB
	+FLOORCLIP
	Inventory.PickupMessage "StormCast Ammo"
	Inventory.PickupSound "Ammocase/Open"
	States {
		Pickup:
			TNT1 A 0 A_GiveInventory("PowerChargeStorm",50) 
			TNT1 A 20
			Stop
		}
}

//Schism stuff
Actor Quickspell : Inventory {}

