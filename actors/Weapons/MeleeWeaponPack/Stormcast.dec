actor LightningPuff : BulletPuff
{
	obituary "%o accepts %k's shaft."
	damagetype lightning
	renderstyle add
	alpha 0.9
	Scale 1
	radius 0
	height 0
	+NOBLOCKMAP
	+NOGRAVITY
	Gravity 0.01
	+NOEXTREMEDEATH
	+FORCEXYBILLBOARD
	+DONTSPLASH
	-EXPLODEONWATER
  states
  {
  Spawn:
    TNT1 A 0
    TNT1 AAAA 0
  Melee:
    TNT1 A 1
	SH1K ABCDEFG 2 BRIGHT A_SpawnItem("BlueFlare",0,0)
	stop

Crash:
    TNT1 A 0
    TNT1 AAAA 0
XDeath:
    TNT1 A 1
	SH1K ABCDEFG 2 BRIGHT A_SpawnItem("BlueFlare",0,0)
Death:
    TNT1 A 0
    TNT1 AAAA 0
	Stop

	}
}

