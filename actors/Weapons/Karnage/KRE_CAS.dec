ACTOR EmptyBrass
{
	Height 2
	Radius 3
	Speed 7
	Scale 0.18
	Bouncetype "doom"
	-CANBOUNCEWATER
	-NOGRAVITY
	+CLIENTSIDEONLY
	+MOVEWITHSECTOR
	+MISSILE
	+NOBLOCKMAP
	-DROPOFF
	+NOTELEPORT
	+FORCEXYBILLBOARD
	+GHOST
	+FLOORCLIP
	+THRUACTORS
	BounceFactor 0.6
	Bouncecount 7
	BounceSound "CASINGSOUND"
	States
	{
	Spawn:
	  	BRAS BCDEFGHA 2
		loop
	Death:
	  	BRAS C 0 A_Jump(256,"Rest1","Rest2")
		Goto Rest1
 	Rest1:
		BRAS C 200
		BRAS C 4 A_Setscale(0.1)
		Stop
 	Rest2:
		BRAS G 200
		BRAS G 4 A_Setscale(0.1)
		Stop
	}
}

ACTOR 40mmshell
{
	Height 2
	Radius 3
	Speed 4
	Scale 0.4
	Bouncetype "doom"
	-CANBOUNCEWATER
	-NOGRAVITY
	+CLIENTSIDEONLY
	+MOVEWITHSECTOR
	+MISSILE
	+NOBLOCKMAP
	-DROPOFF
	+NOTELEPORT
	+FORCEXYBILLBOARD
	+GHOST
	+FLOORCLIP
	+THRUACTORS
	BounceFactor 0.6
	Bouncecount 7
	BounceSound "40MMbrass"
	//Translation "0:255=%[1.1.1],[1,0.1,0.1]"
	States
	{
	Spawn:
	  	BRAS BCDEFGHA 3
		loop
	Death:
	  	BRAS C 0 A_Jump(256,"Rest1","Rest2")
		Goto Rest1
 	Rest1:
		BRAS C 200
		BRAS C 4 A_Setscale(0.2)
		Stop
 	Rest2:
		BRAS G 200
		BRAS G 4 A_Setscale(0.2)
		Stop
	}
}

