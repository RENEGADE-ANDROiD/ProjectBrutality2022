ACTOR EmptyShell
{
	Height 2
	Radius 4
	Speed 6
	Scale 0.2
	Bouncetype "doom"
	-CANBOUNCEWATER
	-NOGRAVITY
	+CLIENTSIDEONLY
	+MOVEWITHSECTOR
	+MISSILE
	+NOBLOCKMAP
	-DROPOFF
	+NOTELEPORT
	+FORCEXYBILLBOARD
	+GHOST
	+FLOORCLIP
	+THRUACTORS
	BounceFactor 0.6
	Bouncecount 7
	BounceSound "CASINGSOUND"
	States
	{
	Spawn:
	  	RSLL ABCDEFOMNLG 1
		loop
	Death:
	  	BRAS C 0 A_Jump(256,"Rest1","Rest2")
		Goto Rest1
 	Rest1:
		RSLL C 200
		RSLL C 4 A_Setscale(0.1)
		Stop
 	Rest2:
		RSLL N 200
		RSLL N 4 A_Setscale(0.1)
		Stop
	}
}

