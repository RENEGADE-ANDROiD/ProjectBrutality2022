{
    Speed 25
    +NOCLIP
    States
    {
    Spawn:
		TNT1 A 0
		NULL A 0 A_CustomMissile ("Muzzlesmokeblast", -10, 0, 0, 1, frandom(80,100))
        Stop
    }
}


