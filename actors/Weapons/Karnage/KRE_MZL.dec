Actor muzzlesmoker
{
    Speed 25
    +NOCLIP
    States
    {
    Spawn:
		TNT1 A 0
		NULL A 0 A_CustomMissile ("GunSmoke", -10, 0, 0, 2, frandom(80,100))
        Stop
    }
}

