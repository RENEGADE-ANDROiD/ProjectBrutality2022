// M2 Plasma Rifle Pickup
ACTOR M2Plasma : CustomInventory{
	Inventory.PickupMessage "You got the UAC-M2 Heavy Plasma Rifle! (Slot 8)"
	Inventory.PickupSound "PLSDRAW"
	Scale 0.49
	//FloatBobStrength 0.5
	States
	{
	Spawn:
		M2PR A 2
		Loop
	/*Spawn: //Model not implemented yet
		VM2P A 0 NoDelay
		M2PR A 10 A_PbvpFramework("VM2P")
		"####" "#" 0 A_PbvpInterpolate()
		LOOP*/
	Pickup:
        TNT1 A 0 A_GiveInventory ("PB_M2Plasma")
		Stop
	}
}

