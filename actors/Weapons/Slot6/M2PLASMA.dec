}

Actor PB_M2Upgrade: Custominventory
{
//$Category Ammunition
	Game Doom
	SpawnID 9370
	Height 24
	Scale 0.49
	+INVENTORY.ALWAYSPICKUP
	+COUNTITEM
	Inventory.Pickupsound "PLSM2UP"
	Inventory.PickupMessage "You got the M2 Lightning Mode Upgrade!!"
	//FloatBobStrength 0.5
	States
	{
	Spawn:
		M2PR B 2
		Loop
	/*Spawn: //Model not implemented yet
		VM2P B 0 NoDelay
		M2PR B 10 A_PbvpFramework("VM2P")
		"####" "#" 0 A_PbvpInterpolate()
		LOOP*/
	
    Pickup:
      TNT1 A 0 A_GiveInventory ("PB_M2Plasma")
	  TNT1 A 0 A_GiveInventory("HasLightningGunUpgrade", 1)
	  TNT1 A 0 A_Print("\ctM2 upgrade:\c- \cfChain lightning \c-available â€” \ctWeapon Special\c-!", 4)
      Stop
	}
}

