Actor SilencerEquipped: Inventory
{Inventory.maxamount 1}

Actor PB_PistolWasEmpty: Inventory
{Inventory.maxamount 1}

Actor PB_PistolHasUnloaded: Inventory
{Inventory.maxamount 1}

ACTOR SwitchingFromDualWieldPistols : Inventory
{Inventory.MaxAmount 1}

ACTOR SwitchingToDualWieldPistols: Inventory
{Inventory.MaxAmount 1}

ACTOR DualWieldingPistols: Inventory
{Inventory.MaxAmount 1}

Actor PB_PistolFireAnimation1: Inventory
{Inventory.maxamount 1}

Actor PB_PistolFireAnimation2: Inventory
{Inventory.maxamount 1}

ACTOR RespectPistol : Inventory
{Inventory.MaxAmount 1}

ACTOR ToggledPistolBurstFire : Inventory
{Inventory.MaxAmount 1}

Actor PB_PrimaryPistolChamberEmpty: Inventory
{Inventory.maxamount 1}

Actor SelectSinglePistol: Inventory
{Inventory.maxamount 1}

Actor SelectPistolSuppressor: Inventory
{Inventory.maxamount 1}

Actor SelectDualWieldPistols: Inventory
{Inventory.maxamount 1}

Actor SelectPistolBurstFire: Inventory
{Inventory.maxamount 1}

Actor SelectPistolSemiFire: Inventory
{Inventory.maxamount 1}

ACTOR PB_Pistol : PB_Weapon Replaces Pistol
{
	SpawnID 9220
	Weapon.BobRangeX 0.3
	Weapon.BobRangeY 0.5
	Weapon.BobStyle InverseSmooth
	Weapon.BobSpeed 2.4
	Weapon.SlotNumber 2
	Weapon.SlotPriority 0
	Weapon.AmmoUse1 0
	Weapon.AmmoGive1 5
	Weapon.AmmoUse2 0
	Weapon.AmmoGive2 0
	Weapon.AmmoType1 "PistolBullets"
	Weapon.AmmoType2 "PrimaryPistolAmmo"
	Inventory.MaxAmount 3
	Inventory.Amount 1
	+FLOORCLIP
	+DONTGIB
	Obituary "%o was shot down by %k's Pistol"
    AttackSound "None"
	Tag "UAC .45 Pistol"
    Inventory.PickupSound "weapons/pistolup"
	Inventory.Pickupmessage "You got the UAC-B950 .45 Pistol! (Slot 2)"
	+WEAPON.WIMPY_WEAPON
    +WEAPON.NOAUTOAIM
    +WEAPON.NOAUTOFIRE
	+WEAPON.NOALERT
	+WEAPON.NO_AUTO_SWITCH
    Scale 0.44
	PB_WeaponBase.UnloaderToken "PB_PistolHasUnloaded"
	Inventory.AltHUDIcon "DEGTA0"
	PB_WeaponBase.respectItem "RespectPistol"
	FloatBobStrength 0.5
	States
	{
	
	Spawn:
		VEGT A 0 NoDelay
		DEGT A 10 A_PbvpFramework("VEGT")
		"####" A 0 A_PbvpInterpolate()
		LOOP

	Steady:
		TNT1 A 1
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 SetPlayerProperty(0,0,0)
		TNT1 A 0 SetPlayerProperty(0,0,PROP_TOTALLYFROZEN)
		Goto Ready

	Ready:
		TNT1 A 0
		D3GG ABCDEF 0
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 PB_RespectIfNeeded
	WeaponRespect:
		TNT1 A 0 {
			A_Giveinventory("RespectPistol",1);
			A_Giveinventory("PB_LockScreenTilt",1);
			A_PlaySoundEx("weapons/smg_magfly1", "Auto");
			A_SetCrosshair(5);
			}
		D0G0 ABCDEFGHIJK 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		TNT1 A 0 A_PlaySoundEx("Ironsights", "Auto")
		D0G0 LMNOPQRST 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		TNT1 A 0 A_PlaySoundEx("PSRLFIN", "Auto")
		D0G0 UVWXYZ 1 {
			A_Setroll(roll+0.5, SPF_INTERPOLATE);
			A_DoPBWeaponAction;
		}
		TNT1 A 0 A_PlaySoundEx("Ironsights", "Auto")
		D0G1 ABCDE 1 {
			A_Setroll(roll-0.6, SPF_INTERPOLATE);
			A_DoPBWeaponAction;
		}
		Goto Ready3
	SelectAnimation:
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolSelectAnim")
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols", 1, "SelectAnimationDualWield")
		TNT1 A 0 A_JumpIfInventory("SwitchingFromDualWieldPistols", 1, "FastSwitchFromDualWield2")
		DEGG E 1 { 
			A_PlaySound("weapons/pistolup");
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D3GG");}
			}
        DEGG DCB 1 {
			A_JumpIfInventory("GoFatality", 1, "Steady");
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D3GG");}
			}
	Ready3:
		TNT1 A 0 {
			A_SetRoll(0);
			A_TakeInventory("PB_LockScreenTilt",1);
			PB_HandleCrosshair(43);
			}
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolReady3")
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols", 1,"ReadyDualWield")
		TNT1 A 0 A_JumpIfInventory("PB_PistolWasEmpty", 1, "LoadChamber")
		TNT1 A 0 A_JumpIfInventory("Zoomed",1,"Ready2")
	ReadyToFire:
		DEGG A 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D3GG");
			}
		
			if (PressingFire() && PressingAltfire() && CountInv("PrimaryPistolAmmo") > 0){
					return state("Fire");
			}
			if (PressingFire() && CountInv("PrimaryPistolAmmo") > 0){
					return state("Fire");
			}
			return A_DoPBWeaponAction(WRF_ALLOWRELOAD, CheckUnloaded("PB_PistolHasUnloaded"));
		}
		Goto ReadyToFire
    Ready2:
		TNT1 A 0 {
			A_SetRoll(0, SPF_INTERPOLATE);
			A_SetCrosshair(5);
		}
	ReadyToFire2:
		D7GG F 1 {
			//Updated code for far superior smooth gameplay
			if(GetCvar("pb_toggle_aim_hold")) {
				if(!PressingAltfire() || JustReleased(BT_ALTATTACK)){
					return state("Zoomout");
				}
				if (PressingFire() && PressingAltfire() && CountInv("PrimaryPistolAmmo") > 0){
						return state("Fire2");
				}
				return A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOSECONDARY);
			}
			else {
				if (PressingFire() && CountInv("PrimaryPistolAmmo") > 0 ){
					return state("Fire2");
				}
				return A_DoPBWeaponAction(WRF_ALLOWRELOAD);
			}
			return state("");
		}
		Loop
		
	
	
	
	SelectAnimationDualWield:
		TNT1 A 0 A_PlaySoundEx("weapons/pistolup", "Auto")
		D2GT ABCDE 0
		D2GS ABCDE 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D2GT");
			}
		}
		TNT1 A 0 A_PlaySoundEx("weapons/pistolup", "Auto")
	ReadyDualWield:
		TNT1 A 0 {
			A_SetRoll(0);
			PB_HandleCrosshair(43);
			A_TakeInventory("PB_LockScreenTilt",1);
			if(CountInv("SecondaryPistolAmmo") < CountInv("PrimaryPistolAmmo")){
				A_GiveInventory("DualFiring",1);
			}
			if(CountInv("PistolBullets")>0){
				if(CountInv("SecondaryPistolAmmo")<=0){
					A_GiveInventory("DualFireReload",1);
				}
				if(CountInv("PrimaryPistolAmmo")<=0){
					A_GiveInventory("DualFireReload",1);
				}
			}
			A_SetFiringRightWeapon(False);
			A_SetFiringLeftWeapon(False);
			// ******** IMPORTANT, SET NOOVERRIDE TO FALSE ********
			A_Overlay(10, "IdleLeft_Overlay", false);
			A_Overlay(11, "IdleRight_Overlay", false);
			}
		D33L A 0
		D33R A 0
		DR3F ABCDE 0
		DL3F ABCDE 0
	ReadyToFireDualWield:
		TNT1 A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE)
		Loop
		
		
	IdleLeft_Overlay:
		D2GL A 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "D33L");
			}
			if(CountInv("SecondaryPistolAmmo")<=0 && CountInv("PrimaryPistolAmmo")>0){
				A_GiveInventory("DualFiring",1);
			}
			if(CountInv("DualFiring")==0 || (CountInv("DualFiring")==0 && CountInv("PrimaryPistolAmmo")<=0) || GetCvar("SingleDualFire")==1){
				if((PressingFire() || JustPressed(BT_ATTACK)) && !A_IsFiringLeftWeapon()){
					if(CountInv("SecondaryPistolAmmo") > 0){
						return state("FireLeft_Overlay");
					}
					else {
						A_PlaySoundEx("weapons/empty", "Auto");
						return state("");
					}
				}
			}
			return state("");
		}
		Loop
	IdleRight_Overlay:
		D2GR A 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "D33R");
			}
			if(CountInv("SecondaryPistolAmmo")>0 && CountInv("PrimaryPistolAmmo")<=0){
				A_TakeInventory("DualFiring",1);
			}
			if(CountInv("DualFiring")==1 || (CountInv("DualFiring")==1 && CountInv("SecondaryPistolAmmo")<=0)){
				if((PressingFire() || JustPressed(BT_ATTACK)) && !A_IsFiringLeftWeapon() && GetCvar("SingleDualFire")==0){
					if(CountInv("PrimaryPistolAmmo") > 0){
						return state("FireRight_Overlay");
					}
					else {
						A_PlaySoundEx("weapons/empty", "Auto");
						return state("");
					}
				}
			}
			if((PressingAltfire() || JustPressed(BT_ALTATTACK)) && !A_IsFiringRightWeapon() && GetCvar("SingleDualFire")==1){
				if(CountInv("PrimaryPistolAmmo") > 0){
					return state("FireRight_Overlay");
				}
				else {
					A_PlaySoundEx("weapons/empty", "Auto");
					return state("");
				}
			}
			return state("");
		}
		Loop
		
		
		
		
	FireRight_Overlay:
		"####" "#" 0 A_JumpIfInventory("ToggledPistolBurstFire",1,"FireRightBurst_Overlay")
		D2RF A 1 BRIGHT {
			A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -1,4);
			A_FireCustomMissile("GunFireSmoke", 0, 0, 4, 0, 0, 0);
			A_FireCustomMissile("PistolCasingSpawner",0,0,11,-1);
			A_ZoomFactor(0.985);
			A_Takeinventory("PrimaryPistolAmmo",1);
			A_GiveInventory("PB_PistolFireAnimation1",1); //Toggle gun animation from one pistol to the other.
			A_SetFiringRightWeapon(True);
			A_Overlay(-6, "RightFlash", true);
			A_GunFlash;
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
				A_SetOverlaySprite(11, "DR3F");
			}
			else {
				A_PlaySoundEx("weapons/pistol", "Weapon");
				A_AlertMonsters;
			}
            PB_WeaponRecoil(-0.84,-1.2);
		}
		D2RF B 1 BRIGHT {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "DR3F");
			}
			A_ZoomFactor(1.0);
            PB_WeaponRecoil(-0.84,-1.2);
		}
		
		D2RF C 1 {
            PB_WeaponRecoil(-0.84,-1.2);
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "DR3F");
			}
		}
		D2RF D 1 {
			if(CountInv("SecondaryPistolAmmo")>0 || CountInv("PrimaryPistolAmmo")<=0 ){
				A_TakeInventory("DualFiring",1);
			}
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "DR3F");
			}
			A_SetFiringRightWeapon(False);
		}
		D2GR AAAAA 1 {
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "D33R");
			}
		
			if(JustPressed(BT_ALTATTACK) && !A_IsFiringRightWeapon()){
				if(CountInv("PrimaryPistolAmmo") > 0){
					return state("FireRight_Overlay");
				}
				else {
					A_PlaySoundEx("weapons/empty", "Auto");
					return state("");
				}
			}
			return state("");
		}
		D2GR AA 1 {			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "D33R");
			}
		}
		TNT1 A 0 {
			if(CountInv("SecondaryPistolAmmo")<=0){
				A_GiveInventory("DualFireReload",1);
			}
		}
		Goto IdleRight_Overlay
		
	
	FireRightBurst_Overlay:
		D2RF A 1 BRIGHT {
			A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -1,4);
			A_FireCustomMissile("GunFireSmoke", 0, 0, 4, 0, 0, 0);
			A_FireCustomMissile("PistolCasingSpawner",0,0,11,-1);
			A_ZoomFactor(0.985);
			A_Takeinventory("PrimaryPistolAmmo",1);
			A_GiveInventory("PB_PistolFireAnimation1",1); //Toggle gun animation from one pistol to the other.
			A_SetFiringRightWeapon(True);
			A_Overlay(-6, "RightFlash", true);
			A_GunFlash;
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
				A_SetOverlaySprite(11, "DR3F");
			}
			else {
				A_PlaySoundEx("weapons/pistol", "Weapon");
				A_AlertMonsters;
			}
            PB_WeaponRecoil(-1.2,-1.4);
		}
		D2RF BC 1 BRIGHT {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "DR3F");
			}
			A_ZoomFactor(1.0);
            PB_WeaponRecoil(-1.2,-1.4);
		}
        "####" "#" 0 A_JumpIfInventory("PrimaryPistolAmmo",1,2)
		"####" "#" 0 A_PlaySoundEx("weapons/empty", "Auto")
        Goto StopRightBurst_Overlay
		D2RF A 1 BRIGHT {
			A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -1,4);
			A_FireCustomMissile("GunFireSmoke", 0, 0, 4, 0, 0, 0);
			A_FireCustomMissile("PistolCasingSpawner",0,0,11,-1);
			A_ZoomFactor(0.985);
			A_Takeinventory("PrimaryPistolAmmo",1);
			A_GiveInventory("PB_PistolFireAnimation1",1); //Toggle gun animation from one pistol to the other.
			A_SetFiringRightWeapon(True);
			A_Overlay(-6, "RightFlash", true);
			A_GunFlash;
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
				A_SetOverlaySprite(11, "DR3F");
			}
			else {
				A_PlaySoundEx("weapons/pistol", "Weapon");
				A_AlertMonsters;
			}
            PB_WeaponRecoil(-1.2,-1.4);
		}
		D2RF BC 1 BRIGHT {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "DR3F");
			}
			A_ZoomFactor(1.0);
            PB_WeaponRecoil(-1.2,-1.4);
		}
        "####" "#" 0 A_JumpIfInventory("PrimaryPistolAmmo",1,2)
		"####" "#" 0 A_PlaySoundEx("weapons/empty", "Auto")
        Goto StopRightBurst_Overlay
		D2RF A 1 BRIGHT {
			A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -1,4);
			A_FireCustomMissile("GunFireSmoke", 0, 0, 4, 0, 0, 0);
			A_FireCustomMissile("PistolCasingSpawner",0,0,11,-1);
			A_ZoomFactor(0.985);
			A_Takeinventory("PrimaryPistolAmmo",1);
			A_GiveInventory("PB_PistolFireAnimation1",1); //Toggle gun animation from one pistol to the other.
			A_SetFiringRightWeapon(True);
			A_Overlay(-6, "RightFlash", true);
			A_GunFlash;
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
				A_SetOverlaySprite(11, "DR3F");
			}
			else {
				A_PlaySoundEx("weapons/pistol", "Weapon");
				A_AlertMonsters;
			}
            PB_WeaponRecoil(-1.2,-1.4);
		}
		D2RF B 1 BRIGHT {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "DR3F");
			}
			A_ZoomFactor(1.0);
            PB_WeaponRecoil(-1.2,-1.4);
		}
	StopRightBurst_Overlay:
		D2RF C 1 {
			if(CountInv("SecondaryPistolAmmo")>0 || CountInv("PrimaryPistolAmmo")<=0 ){
				A_TakeInventory("DualFiring",1);
			}
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "DR3F");
			}
		}
		D2RF D 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "DR3F");
			}
			A_SetFiringRightWeapon(False);
		}
		D2GR AAAAA 1 {
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "D33R");
			}
		
			if(JustPressed(BT_ALTATTACK) && !A_IsFiringRightWeapon()){
				if(CountInv("PrimaryPistolAmmo") > 0){
					return state("FireRight_Overlay");
				}
				else {
					A_PlaySoundEx("weapons/empty", "Auto");
					return state("");
				}
			}
			return state("");
		}
		D2GR AA 1 {
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(11, "D33R");
			}
		}
		TNT1 A 0 {
			if(CountInv("SecondaryPistolAmmo")<=0){
				A_GiveInventory("DualFireReload",1);
			}
		}
		Goto IdleRight_Overlay
		
		
	FireLeft_Overlay:
		"####" "#" 0 A_JumpIfInventory("ToggledPistolBurstFire",1,"FireLeftBurst_Overlay")
		D2LF A 1 BRIGHT{
			A_Overlay(-5, "LeftFlash", true);
			A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -1,-4);
			A_FireCustomMissile("GunFireSmoke", 0, 0, -4, 0, 0, 0);
			A_FireCustomMissile("PistolCasingSpawner",0,0,-8,-1);
			A_TakeInventory("PB_PistolFireAnimation1",1);
			A_GiveInventory("PB_PistolFireAnimation2",1); //Toggle gun animation from one pistol to the other.
			A_Takeinventory("SecondaryPistolAmmo",1);
			A_ZoomFactor(0.985);
			A_SetFiringLeftWeapon(True);
			A_GunFlash;
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
				A_SetOverlaySprite(10, "DL3F");
			}
			else {
				A_AlertMonsters;
				A_PlaySoundEx("weapons/pistol", "Weapon");
			}
            PB_WeaponRecoil(-0.84,+1.2);
		}
		D2LF B 1 BRIGHT {
			A_ZoomFactor(1.0);
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "DL3F");
			}
            PB_WeaponRecoil(-0.84,+1.2);
		}
		D2LF C 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "DL3F");
			}
            PB_WeaponRecoil(-0.84,+1.2);
		}
		D2LF D 1 {
			if(CountInv("SecondaryPistolAmmo")<=0 || CountInv("PrimaryPistolAmmo")>0 ){
				A_GiveInventory("DualFiring",1);
			}
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "DL3F");
			}
			A_SetFiringLeftWeapon(False);
		}
		D2GL AAAAA 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "D33L");
			}
			if(JustPressed(BT_ATTACK) && !A_IsFiringLeftWeapon()){
				if(CountInv("SecondaryPistolAmmo") > 0){
					return state("FireLeft_Overlay");
				}
				else {
					A_PlaySoundEx("weapons/empty", "Auto");
					return state("");
				}
			}
			return state("");
		}
		D2GL AA 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "D33L");
			}
		}
		TNT1 A 0 {
			if(CountInv("PrimaryPistolAmmo")<=0){
				A_GiveInventory("DualFireReload",1);
			}
		}
		Goto IdleLeft_Overlay
		
	FireLeftBurst_Overlay:
		D2LF A 1 BRIGHT{
			A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -1,-4);
			A_FireCustomMissile("GunFireSmoke", 0, 0, -4, 0, 0, 0);
			A_FireCustomMissile("PistolCasingSpawner",0,0,-8,-1);
			A_TakeInventory("PB_PistolFireAnimation1",1);
			A_GiveInventory("PB_PistolFireAnimation2",1); //Toggle gun animation from one pistol to the other.
			A_Takeinventory("SecondaryPistolAmmo",1);
			A_ZoomFactor(0.985);
			A_SetFiringLeftWeapon(True);
			A_Overlay(-5, "LeftFlash", true);
			A_GunFlash;
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
				A_SetOverlaySprite(10, "DL3F");
			}
			else {
				A_AlertMonsters;
				A_PlaySoundEx("weapons/pistol", "Weapon");
			}
            PB_WeaponRecoilSpecial(-0.84,+1.4,-0.42,+0.7);
		}
		D2LF BC 1 BRIGHT {
			A_ZoomFactor(1.0);
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "DL3F");
			}
            PB_WeaponRecoilSpecial(-0.84,+1.4,-0.42,+0.7);
		}
        "####" "#" 0 A_JumpIfInventory("SecondaryPistolAmmo",1,2)
		"####" "#" 0 A_PlaySoundEx("weapons/empty", "Auto")
		Goto StopLeftBurst_Overlay
		D2LF A 1 BRIGHT{
			A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -1,-4);
			A_FireCustomMissile("GunFireSmoke", 0, 0, -4, 0, 0, 0);
			A_FireCustomMissile("PistolCasingSpawner",0,0,-8,-1);
			A_TakeInventory("PB_PistolFireAnimation1",1);
			A_GiveInventory("PB_PistolFireAnimation2",1); //Toggle gun animation from one pistol to the other.
			A_Takeinventory("SecondaryPistolAmmo",1);
			A_ZoomFactor(0.985);
			A_SetFiringLeftWeapon(True);
			A_Overlay(-5, "LeftFlash", true);
			A_GunFlash;
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
				A_SetOverlaySprite(10, "DL3F");
			}
			else {
				A_AlertMonsters;
				A_PlaySoundEx("weapons/pistol", "Weapon");
			}
            PB_WeaponRecoilSpecial(-0.84,+1.4,-0.42,+0.7);
		}
		D2LF BC 1 BRIGHT {
			A_ZoomFactor(1.0);
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "DL3F");
			}
            PB_WeaponRecoilSpecial(-0.84,+1.4,-0.42,+0.7);
		}
        "####" "#" 0 A_JumpIfInventory("SecondaryPistolAmmo",1,2)
		"####" "#" 0 A_PlaySoundEx("weapons/empty", "Auto")
		Goto StopLeftBurst_Overlay
		D2LF A 1 BRIGHT{
			A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -1,-4);
			A_FireCustomMissile("GunFireSmoke", 0, 0, -4, 0, 0, 0);
			A_FireCustomMissile("PistolCasingSpawner",0,0,-8,-1);
			A_TakeInventory("PB_PistolFireAnimation1",1);
			A_GiveInventory("PB_PistolFireAnimation2",1); //Toggle gun animation from one pistol to the other.
			A_Takeinventory("SecondaryPistolAmmo",1);
			A_ZoomFactor(0.985);
			A_SetFiringLeftWeapon(True);
			A_Overlay(-5, "LeftFlash", true);
			A_GunFlash;
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
				A_SetOverlaySprite(10, "DL3F");
			}
			else {
				A_AlertMonsters;
				A_PlaySoundEx("weapons/pistol", "Weapon");
			}
            PB_WeaponRecoilSpecial(-0.84,+1.4,-0.42,+0.7);
			}
		D2LF B 1 BRIGHT {
			A_ZoomFactor(1.0);
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "DL3F");
			}
            PB_WeaponRecoilSpecial(-0.84,+1.4,-0.42,+0.7);
		}
	StopLeftBurst_Overlay:
		D2LF C 1 {
			if(CountInv("SecondaryPistolAmmo")<=0 || CountInv("PrimaryPistolAmmo")>0 ){
				A_GiveInventory("DualFiring",1);
			}
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "DL3F");
			}
		}
		D2LF D 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "DL3F");
			}
			A_SetFiringLeftWeapon(False);
		}
		D2GL AAAAA 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "D33L");
			}
			if(JustPressed(BT_ATTACK) && !A_IsFiringLeftWeapon()){
				if(CountInv("SecondaryPistolAmmo") > 0){
					return state("FireLeft_Overlay");
				}
				else {
					A_PlaySoundEx("weapons/empty", "Auto");
					return state("");
				}
			}
			return state("");
		}
		D2GL AA 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetOverlaySprite(10, "D33L");
			}
		}
		TNT1 A 0 {
			if(CountInv("PrimaryPistolAmmo")<=0){
				A_GiveInventory("DualFireReload",1);
			}
		}
		Goto IdleLeft_Overlay
	
	GunFlash:
		TNT1 A 0 A_JumpIfInventory("SilencerEquipped", 1, 2)
		TNT1 A 0 A_Jump(256, "Flash1", "Flash2", "Flash3", "Flash4", "Flash5", "Flash6", "Flash7", "Flash8")
		TNT1 A 1
		Stop
	Flash1:
		DEGM A 1 Bright
		STOP
	Flash2:
		DEGM B 1 Bright
		STOP
	Flash3:
		DEGM C 1 Bright
		STOP
	Flash4:
		DEGM D 1 Bright
		STOP
	Flash5:
		DEGM E 1 Bright
		STOP
	Flash6:
		DEGM F 1 Bright
		STOP
	Flash7:
		DEGM G 1 Bright
		STOP
	Flash8:
		DEGM H 1 Bright
		STOP
	
	LeftFlash:
		TNT1 A 0 A_JumpIfInventory("SilencerEquipped", 1, 2)
		TNT1 A 0 A_Jump(256, "LeftFlash1", "LeftFlash2")
		TNT1 A 1
		Stop
	LeftFlash1:
		D2LM A 1 Bright
		TNT1 A 0 A_Jump(256, "LeftBigFlash1", "LeftBigFlash2", "LeftBigFlash3")
		Stop
	LeftFlash2:
		D2LM C 1 Bright
		TNT1 A 0 A_Jump(256, "LeftBigFlash1", "LeftBigFlash2", "LeftBigFlash3")
		Stop
	LeftBigFlash1:
		D2LM B 1 bright
		Stop
	LeftBigFlash2:
		D2LM D 1 bright
		Stop
	LeftBigFlash3:
		D2LM E 1 bright
		Stop
	RightFlash:
		TNT1 A 0 A_JumpIfInventory("SilencerEquipped", 1, 2)
		TNT1 A 0 A_Jump(256, "RightFlash1", "RightFlash2")
		TNT1 A 1
		Stop
	RightFlash1:
		D2RM A 1 Bright
		TNT1 A 0 A_Jump(256, "RightBigFlash1", "RightBigFlash2", "RightBigFlash3")
		Stop
	RightFlash2:
		D2RM C 1 Bright
		TNT1 A 0 A_Jump(256, "RightBigFlash1", "RightBigFlash2", "RightBigFlash3")
		Stop
	RightBigFlash1:
		D2RM B 1 bright
		Stop
	RightBigFlash2:
		D2RM D 1 bright
		Stop
	RightBigFlash3:
		D2RM E 1 bright
		Stop
		
	WeaponSpecial:
		TNT1 A 0 {
			A_GiveInventory("PB_LockScreenTilt",1);
			A_Takeinventory("GoWeaponSpecialAbility",1);
			A_Takeinventory("Zoomed",1);
			A_Takeinventory("ADSmode",1);
			PB_HandleCrosshair(43);
			A_ZoomFactor(1.0);
			A_ClearOverlays(10,11);
			A_PlaySoundEx("Ironsights", "Auto");
		}
		TNT1 A 0 A_JumpIfInventory("Select_PistolShieldLoadout", 1, "RS_PistolEnableShield")
		TNT1 A 0 A_JumpIfInventory("Select_PistolStandardLoadout", 1, "RS_PistolDisableShield")
		
		TNT1 A 0 A_JumpIfInventory("SelectDualWieldPistols", 1, "ToggleDualWield")
		TNT1 A 0 A_JumpIfInventory("SelectPistolSuppressor", 1, "ToggleSuppressor")
		TNT1 A 0 A_JumpIfInventory("SelectPistolBurstFire", 1, "ToggleBurstFire")
	ToggleDualWield:
		TNT1 A 0 {
			A_Takeinventory("SelectSinglePistol",1);
			A_Takeinventory("SelectPistolSuppressor",1);
			A_Takeinventory("SelectDualWieldPistols",1);
			A_Takeinventory("SelectPistolBurstFire",1);
			A_Takeinventory("SelectPistolSemiFire",1);
		}
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols", 1,"StopDualWield")
		TNT1 A 0 A_JumpIfINventory("PB_Pistol", 2, "SwitchToDualWield")
		TNT1 A 0 A_Print ("You need two pistols to dual wield!")
		Goto Ready3
	SwitchToDualWield:
		D2GT F 0 A_JumpIfInventory("SilencerEquipped",1,"2")
		D2GS F 0
		"####" FG 1 A_SetRoll(roll+.5, SPF_INTERPOLATE)
		"####" HI 1 A_SetRoll(roll-.5, SPF_INTERPOLATE)
		TNT1 A 0 A_GiveInventory("DualWieldingPistols",1)
		Goto ReadyDualWield
	StopDualWield:
		D2GT J 0 A_JumpIfInventory("SilencerEquipped",1,"2")
		D2GS J 0
		"####" JK 1 A_SetRoll(roll-0.2,SPF_INTERPOLATE)
		"####" LM 1 A_SetRoll(roll+0.2,SPF_INTERPOLATE)
		TNT1 A 0 A_TakeInventory("DualWieldingPistols", 1)
		Goto Ready3
		
	ToggleSuppressor:
		TNT1 A 0 {
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			PB_HandleCrosshair(43);
			A_TakeInventory("PB_LockScreenTilt",1);
			A_Takeinventory("SelectSinglePistol",1);
			A_Takeinventory("SelectPistolSuppressor",1);
			A_Takeinventory("SelectDualWieldPistols",1);
			A_Takeinventory("SelectPistolBurstFire",1);
			A_Takeinventory("SelectPistolSemiFire",1);
		}
		TNT1 A 0 A_Giveinventory("PB_LockScreenTilt",1)
		TNT1 A 0 A_JumpIfInventory("SilencerEquipped",1,"DetachSilencer")
		TNT1 A 0 A_GiveInventory ("SilencerEquipped",1)
		D5GA ABCDEFFFGHIJKLM 1 A_SetRoll(roll+.2, SPF_INTERPOLATE)
		TNT1 A 0 A_PlaySoundEx("weapons/pistolsuppressor_on", "Auto")
		D5GA NNNOPOPOQRRRSSS 1 A_SetRoll(roll-.2, SPF_INTERPOLATE)
		TNT1 A 0 A_PlaySoundEx("weapons/pistolup", "Auto")
		D5GA TUV 1
		TNT1 A 0 A_SetRoll(0, SPF_INTERPOLATE)
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols", 1, "SelectAnimationDualWield")
		D5GA WXY 1
		Goto Ready3
		
	DetachSilencer:
		TNT1 A 0 A_TakeInventory ("SilencerEquipped",1)
		D5GF ABCDEFG 1 A_SetRoll(roll+.2, SPF_INTERPOLATE)
		TNT1 A 0 A_PlaySoundEx("weapons/pistolsuppressor_off", "Auto")
		D5GF FHIJJKKLLMMNOP 1 A_SetRoll(roll-.1, SPF_INTERPOLATE)
		D5GF QRSTUUU 1
		TNT1 A 0 A_PlaySoundEx("weapons/pistolup", "Auto")
		D5GF VWX 1
		TNT1 A 0 A_SetRoll(0)
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols", 1, "SelectAnimationDualWield")
		D5GF YZ 1
		D5GG AB 1
		Goto Ready3
		
	ToggleBurstFire:
		TNT1 A 0 {
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			PB_HandleCrosshair(43);
			A_TakeInventory("PB_LockScreenTilt",1);
			A_Takeinventory("SelectSinglePistol",1);
			A_Takeinventory("SelectPistolSuppressor",1);
			A_Takeinventory("SelectDualWieldPistols",1);
			A_Takeinventory("SelectPistolBurstFire",1);
			A_Takeinventory("SelectPistolSemiFire",1);
		}
		TNT1 A 0 {
			if(CountInv("ToggledPistolBurstFire") >= 1) {
				A_TakeInventory("ToggledPistolBurstFire", 1);
			}
			else { 
				A_GiveInventory("ToggledPistolBurstFire", 1);
			}
		}
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols", 1, "DualToggle")
	SingleToggle:
		D5GE AB 0
		D5GD ZYXWVU 0
		
		D5GC BA 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D5GE");
			}
		}
		D5GB ZYXWWVV 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D5GD");
			}
		}
		TNT1 A 0 A_PlaySoundEx("LIGHTON", "Auto")
		D5GB WWXYZ 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D5GD");
			}
		}
		Goto Ready3
	DualToggle:
		D2GT ABCDE 0
        D2GS EDCBB 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D2GT");
			}
		}
		TNT1 A 0 A_PlaySoundEx("LIGHTON", "Auto")
        D2GS BBCDE 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D2GT");
			}
		}
		TNT1 A 0 A_PlaySoundEx("LIGHTON", "Auto")
		Goto Ready3
		
	Deselect:
		TNT1 A 0 {
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			PB_HandleCrosshair(43);
			A_TakeInventory("PB_LockScreenTilt",1);
			A_ClearOverlays(10,11);
			A_ZoomFactor(1.0); //Force out of ADS when deselecting weapon while on ADS
		}	    
		TNT1 A 0 A_Takeinventory("Unloading",1)
		TNT1 A 0 A_Takeinventory("PB_PistolWasEmpty", 1)
		TNT1 A 0 A_TakeInventory("ADSMode",1)
		TNT1 A 0 A_TakeInventory("Zoomed",1)
		TNT1 A 0 A_JumpIfInventory("GotMeatShield", 1, "GrabEnemy")
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolDeselect")
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols", 1, "DualWieldDeselect")
	NormalDeselect:
        DEGG BCDE 1	{
			if(CountInv("SilencerEquipped") == 1) {A_SetWeaponSprite("D3GG");}
			}
		Goto FinishDeselect
	DualWieldDeselect:
        D2GS EDCBA 1 {
			if(CountInv("SilencerEquipped") == 1) {A_SetWeaponSprite("D2GT");}
			}
	FinishDeselect:
		TNT1 AAAAAAAAAAAAAAAAAA 0 A_Lower
		Wait	
		
	Select:
		TNT1 A 0 {
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			PB_HandleCrosshair(43);
			A_TakeInventory("PB_LockScreenTilt",1);
			A_ClearOverlays(10,11);
		}
		Goto SelectFirstPersonLegs
		SelectContinue:
		TNT1 A 0 ACS_NamedExecuteAlways("ToggleRevolverUpgraded",0)
		TNT1 A 0 PB_WeapTokenSwitch("HandgunSelected")
		TNT1 AAAAAAAAAAAAAAAAAA 0 A_Raise
		TNT1 AAAAAAAA 1 A_Raise
		Wait
		
	Fire:
		"####" "#" 0 {
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			PB_HandleCrosshair(43);
			A_TakeInventory("PB_LockScreenTilt",1);
		}
		"####" "#" 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolFire")
		"####" "#" 0 A_JumpIfInventory("Zoomed", 1, "Fire2")
		//"####" "#" 0 A_JumpIfInventory("DualWieldingPistols", 1, "FireDualWield")
		//"####" "#" 0 A_JumpIfInventory("SilencerEquipped",1,"FireSilencer")
        "####" "#" 0 A_JumpIfInventory("PrimaryPistolAmmo",1,2)
		"####" "#" 0 A_PlaySoundEx("weapons/empty", "Auto")
        Goto Reload
		"####" "#" 0 A_JumpIfInventory("ToggledPistolBurstFire",1,"FireBurst")
		
		//Load sprites into virtual memory, hur-dur
		D3GF ABCD 0 
		DEGF A 1 BRIGHT { 
			// Fire as suppressor if equipped
			A_GunFlash;
			A_Overlay(-5, "GunFlash", true);
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D3GF");
				A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -2,0);
				A_ZoomFactor(0.985);
				A_FireCustomMissile("GunFireSmoke", 0, 0, 0, 0, 0, 0);
				A_FireCustomMissile("ShakeYourAssMinor", 270, 0, 0, 0);
				A_Takeinventory("PrimaryPistolAmmo",1);
				A_FireCustomMissile("PistolCasingSpawner", 0,0,0,-2);
				A_PlaySoundEx("weapons/suppressedpistol", "Weapon");
                PB_WeaponRecoil(-0.18,-0.08);
			}
			//Fire normally
			else {
				A_FireBullets (0.1, 0.1, -1, 17, "HitPuff", FBF_NORANDOM,8192,"Tracer", -2,0);
				A_ZoomFactor(0.985);
				A_AlertMonsters;
				A_FireCustomMissile("GunFireSmoke", 0, 0, 0, 0, 0, 0);
				A_FireCustomMissile("ShakeYourAssMinor", 0, 0, 0, 0);
				A_Takeinventory("PrimaryPistolAmmo",1);
				A_FireCustomMissile("PistolCasingSpawner", 0,0,0,-2);
				A_PlaySoundEx("weapons/pistol", "Weapon");
				A_FireCustomMissile("YellowFlareSpawn",0,0,0,0);
                PB_WeaponRecoil(-0.18,-0.08);
			}
			
		}
        DEGF D 1 {
		
			
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D3GF");
				A_ZoomFactor(0.99);
                PB_WeaponRecoil(-0.18,-0.08);
			}
		
			else {
				A_ZoomFactor(0.99);
                PB_WeaponRecoil(-0.18,-0.08);
			}
		}
        DEGF B 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D3GF");
				A_ZoomFactor(1.0);
				PB_WeaponRecoil(-0.18,-0.08);
			}
		
			else {
				A_ZoomFactor(1.0);
				PB_WeaponRecoil(-0.18,-0.08);
			}
		}
		DEGF D 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D3GF");
			}
			if (JustPressed(BT_ATTACK)){
					return state("Fire");
			}
			return A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOPRIMARY);
	
		}
		DEGG AAAAAAAA 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D3GG");
			}
			if (JustPressed(BT_ATTACK)){
					return state("Fire");
			}
			return A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOPRIMARY);
	
		}
		Goto ReadyToFire
		
