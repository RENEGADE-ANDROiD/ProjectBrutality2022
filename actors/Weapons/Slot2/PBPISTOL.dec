		TNT1 A 0 A_Takeinventory("PB_PistolWasEmpty",1)
		TNT1 A 0 A_PlaySoundEx("PSRLFIN", "Auto")
		D5GE CDEFGHIJKLMNOPQ 0
		D5GC CDEF 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
					A_SetWeaponSprite("D5GE");
			}
			A_SetRoll(roll+.6, SPF_INTERPOLATE);
		}
		D5GC GGHH 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
					A_SetWeaponSprite("D5GE");
			}
			A_SetRoll(roll+.6, SPF_INTERPOLATE);
		}

		D5GC I 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
					A_SetWeaponSprite("D5GE");
			}
		}
		D5GC JKLMNOPQ 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
					A_SetWeaponSprite("D5GE");
			}
			A_SetRoll(roll-.6, SPF_INTERPOLATE);
		}
		Goto Ready3
		
	// Unloading States
	AlreadyUnloaded:
		TNT1 A 0 A_Takeinventory("Unloading",1)
		Goto ReadyToFire
		
	Unload:
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolUnload")
		"####" "#" 0 A_Takeinventory("Unloading",1)
		"####" "#" 0 A_JumpIfInventory("DualWieldingPistols", 1, "UnloadDualWield")
		TNT1 A 0 A_JumpIfInventory("PB_PistolHasUnloaded", 1, "AlreadyUnloaded")
        TNT1 A 0 A_JumpIfInventory("PrimaryPistolAmmo",1,1)
        Goto Ready3
		TNT1 A 0 {
			A_SetCrosshair(5);
			A_Takeinventory("Zoomed",1);
			A_Takeinventory("ADSmode",1);
			A_ZoomFactor(1.0);
			A_Giveinventory("PB_LockScreenTilt",1);
			}
		D5GD A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D5GB A 0
		D5GB A 1  {
			if (CountInv("SilencerEquipped") == 1 ) {
					A_SetWeaponSprite("D5GD");
			}
			A_SetRoll(roll+.8, SPF_INTERPOLATE);
			A_WeaponReady(WRF_NOFIRE);
		}	
		D5GB BCD 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
					A_SetWeaponSprite("D5GD");
			}
			A_SetRoll(roll+.8, SPF_INTERPOLATE);
			A_WeaponReady(WRF_NOFIRE);
		}
		TNT1 A 0 A_PlaySoundEx("PSRLOUT", "Auto")
		D5GB EFGHIIJ 1 {
		
			if (CountInv("SilencerEquipped") == 1 ) {
					A_SetWeaponSprite("D5GD");
			}
			A_SetRoll(roll-.5, SPF_INTERPOLATE);
			A_WeaponReady(WRF_NOFIRE);
		}
		TNT1 A 0 A_FireCustomMissile("EmptyClipMP40",-80,0,3,-4,0,-45)
		D5GB KKLDCBA 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
					A_SetWeaponSprite("D5GD");
			}	
		}
	RemoveBullets:
		TNT1 A 0 A_JumpIfInventory("PrimaryPistolAmmo",1,1)
		Goto FinishUnload
		TNT1 A 0 {
			A_Takeinventory("PrimaryPistolAmmo",1);
			A_Giveinventory("PistolBullets",1);
			}
		Loop
	FinishUnload:
		TNT1 A 0 A_PlaySound("DryFire")
		TNT1 A 0 A_GiveInventory("PB_PistolHasUnloaded", 1)
		TNT1 A 0 A_Takeinventory("Unloading",1)
		Goto ReadyToFire
		
	UnloadDualWield:
		TNT1 A 0 {
			A_SetCrosshair(5);
			A_Takeinventory("Zoomed",1);
			A_Takeinventory("ADSmode",1);
			A_ZoomFactor(1.0);
			A_Giveinventory("PB_LockScreenTilt",1);
			A_ClearOverlays(10,11);
			A_PlaySoundEx("PSRLOUT", "Auto");
			}
		D6GA ABC 1 {
			if(CountInv("SilencerEquipped") == 1){A_SetWeaponSprite("D6GE");}
			}
		TNT1 A 0 A_PlaySoundEx("PSRLOUT", "Auto")
		D6GA DEFGHIJCCBA 1 {
			if(CountInv("SilencerEquipped") == 1){A_SetWeaponSprite("D6GE");}
			}
	RemoveBulletsDualWield1:
		TNT1 A 0 A_JumpIfInventory("PrimaryPistolAmmo",1,1)
		Goto RemoveBulletsDualWield2
		TNT1 A 0 {
			A_Takeinventory("PrimaryPistolAmmo",1);
			A_Giveinventory("PistolBullets",1);
			}
		Loop
	RemoveBulletsDualWield2:
		TNT1 A 0 A_JumpIfInventory("SecondaryPistolAmmo",1,1)
		Goto FinishUnloadDualWield
		TNT1 A 0 {
			A_Takeinventory("SecondaryPistolAmmo",1);
			A_Giveinventory("PistolBullets",1);
			}
		Loop
		
	FinishUnloadDualWield:
		TNT1 A 0 A_GiveInventory("PB_PistolHasUnloaded", 1)
		TNT1 A 0 A_Takeinventory("Unloading",1)
		Goto ReadyDualWield
					
	// Flash States
		
	FlashKicking:
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolFlashKicking")
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols",1,"FlashKickingDualWield")
		D5GV A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D5GU A 0
		"####" ABCDEFGHIJKLMN 1 A_DoPBWeaponAction
		D3GG A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		DEGG A 0
		"####" AA 1 A_DoPBWeaponAction// Pause?
		Goto Ready3	
		
	FlashAirKicking:
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolFlashAirKicking")
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols",1,"FlashKickingDualWield")
		D5GV A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D5GU A 0
		"####" ABCDEFGHIJKLMN 1 A_DoPBWeaponAction
		D3GG A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		DEGG A 0
		"####" AA 1 A_DoPBWeaponAction// Pause?
		Goto Ready3
		
	FlashSlideKicking:
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolFlashSlideKicking")
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols",1,"FlashSlideKickingDualWield")
		D5GZ A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D5GY A 0
		"####" ABCDEFGHIJKKKKLMNOPQRSTUV 1 A_DoPBWeaponAction
		Goto Ready3
		
	FlashSlideKickingStop:
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols",1,"FlashSlideKickingDualWieldStop")
		D5GZ W 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D5GY W 0
		"####" WXYZ 1 A_DoPBWeaponAction
		D3GG A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		DEGG A 0
		"####" AAA 1 A_DoPBWeaponAction
		Goto Ready3

	PDA_Preview_Pistol_HipFire:
		D3GF ABCD 0
		DEGF A 1 BRIGHT
		DEGF D 1
		DEGF B 1
		DEGF D 1
		DEGG A 2
		Stop
	PDA_Preview_Pistol_AdsFire:
		D7GG G 1 BRIGHT
		D7GG H 1
		D7GG I 1
		D7GG J 1
		Stop
	PDA_Preview_Pistol_BurstFire:
		DEGF A 1 BRIGHT
		DEGF B 1
		DEGF C 1
		Stop
	PDA_Preview_Pistol_AltAds:
		D7GG B 1
		D7GG C 1
		D7GG D 1
		D7GG E 1
		D7GG F 1
		Stop
	PDA_Preview_Pistol_Reload:
		D5GB A 1
		D5GB B 1
		D5GB C 1
		D5GB E 1
		D5GB F 1
		D5GB G 1
		D5GB M 1
		D5GB N 1
		D5GB Y 1
		Stop
		
	FlashPunching:
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolFlashPunching")
		TNT1 A 0 A_ClearOverlays(10,11)
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols",1,"FlashPunchingDualWield")
		D5GT A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D5GS A 0
		"####" ABCDEFGHIJKLMN 1 
		TNT1 A 0 A_ClearOverlays(PSP_FLASH, PSP_FLASH, false)
		Goto Ready3
		
	FlashPunchingDualWield:
		TNT1 A 15
		TNT1 A 0 A_ClearOverlays(PSP_FLASH, PSP_FLASH, false)
		Goto Ready3
		
	FlashKickingDualWield:
		TNT1 A 0 A_ClearOverlays(10,11)
		D6GH A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D6GG A 0
		"####" ABCDEFGHIJKLMN 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE)
		D2GT E 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D2GS E 0
		"####" EE 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE)
		Goto Ready3
		
	FlashAirKickingDualWield:
		TNT1 A 0 A_ClearOverlays(10,11)
		D6GH A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D6GG A 0
		"####" ABCDEFGHIJKLMN 1
		D2GT E 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D2GS E 0
		"####" EE 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE)// Pause
		Goto Ready3

	FlashSlideKickingDualWield:
		TNT1 A 0 A_ClearOverlays(10,11)
		D6GJ A 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D6GI A 0
		"####" ABCDEFGHIJKLMNOPQRSTUV 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE)
		Goto Ready3
		
	FlashSlideKickingDualWieldStop:
		TNT1 A 0 A_ClearOverlays(10,11)
		D6GJ W 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D6GI W 0
		"####" WXYZ 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE)
		D2GT E 0 A_JumpIfInventory("SilencerEquipped",1,2)
		D2GS E 0
		"####" EEE 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE)
		Goto Ready3

	RS_PistolSelectAnim:
		RSWR F 1 Offset(0,102)
		RSWR G 1 Offset(0,92)
		RSWR H 1 Offset(0,82)
		RSWR I 1 Offset(0,72)
		RSWR J 1 Offset(0,62)
		RSWR K 1 Offset(0,52)
		RSWF C 1 Offset(0,42)
		RSWG A 1 Offset(0,32)
		TNT1 A 0 { A_GunFlash; }
		Goto Ready3

	RS_PistolEnableShield:
		TNT1 A 0 A_JumpIfInventory("PB_RiotShieldModule", 1, 1)
		Goto Ready3
		TNT1 A 0 A_TakeInventory("Select_PistolShieldLoadout", 1)
		TNT1 A 0 A_TakeInventory("Select_PistolStandardLoadout", 1)
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "Ready3")
		TNT1 A 0 A_TakeInventory("DualWieldingPistols", 1)
		TNT1 A 0 A_TakeInventory("SwitchingToDualWieldPistols", 1)
		TNT1 A 0 A_TakeInventory("SwitchingFromDualWieldPistols", 1)
		TNT1 A 0 A_TakeInventory("ShieldModeA", 1)
		TNT1 A 0 A_TakeInventory("RiotShieldBlocking", 1)
		TNT1 A 0 A_TakeInventory("Zoomed", 1)
		TNT1 A 0 A_TakeInventory("ADSmode", 1)
		TNT1 A 0 A_ZoomFactor(1.0)
		RSWR F 1 Offset(0,102)
		RSWR G 1 Offset(0,92)
		RSWR H 1 Offset(0,82)
		RSWR I 1 Offset(0,72)
		RSWR J 1 Offset(0,62)
		RSWR K 1 Offset(0,52)
		RSWF C 1 Offset(0,42)
		RSWG A 1 Offset(0,32)
		TNT1 A 0 A_GiveInventory("PistolShieldLoadout", 1)
		TNT1 A 0 A_TakeInventory("RiotShieldUnloaded", 1)
		TNT1 A 0 A_Print("\ctLoadout:\c- \ccBallistic shield + pistol\c-")
		Goto RS_PistolReady3

	RS_PistolDisableShield:
		TNT1 A 0 A_TakeInventory("Select_PistolShieldLoadout", 1)
		TNT1 A 0 A_TakeInventory("Select_PistolStandardLoadout", 1)
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, 1)
		Goto Ready3
		TNT1 A 0 A_TakeInventory("ShieldModeA", 1)
		TNT1 A 0 A_TakeInventory("RiotShieldBlocking", 1)
		RSWG A 1 Offset(0,32)
		RSWF C 1 Offset(0,42)
		RSWR K 1 Offset(0,52)
		RSWR J 1 Offset(0,62)
		RSWR I 1 Offset(0,72)
		RSWR H 1 Offset(0,82)
		RSWR G 1 Offset(0,92)
		RSWR F 1 Offset(0,102)
		TNT1 A 0 A_TakeInventory("PistolShieldLoadout", 1)
		TNT1 A 0 A_Print("\ctLoadout:\c- \ccStandard pistol\c-")
		Goto Ready3

	RS_PistolDeselect:
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolDeselectShieldMode")
		RSWG A 1 Offset(0,32)
		RSWF C 1 Offset(0,42)
		RSWR K 1 Offset(0,52)
		RSWR J 1 Offset(0,62)
		RSWR I 1 Offset(0,72)
		RSWR H 1 Offset(0,82)
		RSWR G 1 Offset(0,92)
		RSWR F 1 Offset(0,102)
		TNT1 A 0 A_Lower
		Wait
	RS_PistolDeselectShieldMode:
		TNT1 A 0 A_TakeInventory("ShieldModeA", 1)
		RSWT F 1
		RSWT E 1
		RSWB FEDCBA 1
		RSWG A 1 Offset(0,32)
		RSWF C 1 Offset(0,42)
		RSWR K 1 Offset(0,52)
		RSWR J 1 Offset(0,62)
		RSWR I 1 Offset(0,72)
		RSWR H 1 Offset(0,82)
		RSWR G 1 Offset(0,92)
		RSWR F 1 Offset(0,102)
		TNT1 A 0 A_Lower
		Wait

	RS_PistolReady3:
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolReadyShield")
		TNT1 A 0 PB_HandleCrosshair(43)
		RSWG A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD, CheckUnloaded("RiotShieldUnloaded"))
		Loop

	RS_PistolReadyShield:
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 A_GiveInventory("RiotShieldBlocking", 1)
		RSWT A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		Loop

	RS_PistolFire:
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolShieldMelee")
		TNT1 A 0 A_JumpIfInventory("PrimaryPistolAmmo", 1, 1)
		Goto RS_PistolNoAmmo
		RSWF A 1 Bright
		{
			A_FireBullets(0.1,0.1,-1,17,"HitPuff",FBF_NORANDOM,8192,"Tracer",-1,4);
			A_FireCustomMissile("YellowFlareSpawn",0,0,4,0);
			A_FireCustomMissile("ShakeYourAssMinor",0,0,4,0);
			A_FireCustomMissile("GunFireSmoke",0,0,4,0);
			A_AlertMonsters;
			A_Overlay(-6,"RS_PistolRightFlash",1);
			A_GunFlash;
			A_FireCustomMissile("PistolCasingSpawner",0,0,11,-1);
			A_ZoomFactor(0.985);
			A_TakeInventory("PrimaryPistolAmmo",1);
			A_PlaySoundEx("weapons/pistol","Weapon");
			PB_WeaponRecoil(-0.84,-1.2);
		}
		RSWF B 1 Bright { PB_WeaponRecoil(-0.42,-0.6); }
		RSWF C 1 { A_ZoomFactor(0.99); }
		RSWF C 1 { A_ZoomFactor(1.0); }
		RSWF D 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWF E 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWG A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		TNT1 A 0 A_Refire("Fire")
		Goto RS_PistolReady3

	RS_PistolShieldMelee:
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 A_PlaySound("AXSWING")
		TNT1 A 0 A_CustomPunch(random(20,40),1,1,"Shield_melee",150)
		RSWT C 1
		RSWT D 1
		RSWT E 1
		RSWT F 1
		RSWT A 1
		Goto RS_PistolReadyShield

	RS_PistolAltFire:
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolUnShield")
		TNT1 A 0 A_GiveInventory("ShieldModeA", 1)
		RSWB ABCDEF 1
		RSWT F 1
		RSWT F 1
		Goto RS_PistolReadyShield
	RS_PistolUnShield:
		TNT1 A 0 A_TakeInventory("ShieldModeA", 1)
		TNT1 A 0 A_TakeInventory("RiotShieldBlocking", 1)
		RSWT F 1
		RSWT F 1
		RSWB FEDCBA 1
		Goto RS_PistolReady3

	RS_PistolReload:
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 A_JumpIfInventory("PrimaryPistolAmmo", 16, "RS_PistolReady3")
		TNT1 A 0 A_JumpIfInventory("PistolBullets", 1, 1)
		Goto RS_PistolReady3
		TNT1 A 0 A_PlaySoundEx("PSRLOUT","Auto")
		D5GB A 1 A_SetRoll(roll+0.5)
		TNT1 A 0 A_FireCustomMissile("EmptyClipMP40",-5,0,-6,-20)
		D5GB BCD 1 A_SetRoll(roll+0.5)
		D5GB EFGHI 1 A_SetRoll(roll-0.5)
		TNT1 A 0 A_PlaySoundEx("PSRLIN","Auto")
		D5GB KKLMNOPQRS 1 A_SetRoll(roll-0.1)
		D5GB TUVWX 1 A_SetRoll(roll+0.2)
		TNT1 A 0 A_SetRoll(0)
		TNT1 A 0 A_TakeInventory("RiotShieldUnloaded", 1)
	RS_PistolInsertBullets:
		TNT1 A 0 A_JumpIfInventory("PrimaryPistolAmmo", 16, "RS_PistolReady3")
		TNT1 A 0 A_JumpIfInventory("PistolBullets", 1, 1)
		Goto RS_PistolReady3
		TNT1 A 0
		{
			A_GiveInventory("PrimaryPistolAmmo",1);
			A_TakeInventory("PistolBullets",1);
		}
		Loop

	RS_PistolUnload:
		TNT1 A 0 A_JumpIfInventory("RiotShieldUnloaded", 1, "RS_PistolReady3")
		TNT1 A 0 A_JumpIfInventory("PrimaryPistolAmmo", 1, 1)
		Goto RS_PistolReady3
		TNT1 A 0 A_PlaySoundEx("PSRLOUT","Auto")
		RSWF D 2
		RSWR ABCDEEFFFF 1
		RSWR F 32
		RSWR EEDCB 1
		RSWR A 2
		RSWF CD 2
	RS_PistolRemoveBullets:
		TNT1 A 0 A_JumpIfInventory("PrimaryPistolAmmo", 1, 1)
		Goto RS_PistolFinishUnload
		TNT1 A 0
		{
			A_TakeInventory("PrimaryPistolAmmo",1);
			A_GiveInventory("PistolBullets",1);
		}
		Loop
	RS_PistolFinishUnload:
		TNT1 A 0 A_GiveInventory("RiotShieldUnloaded", 1)
		TNT1 A 0 A_TakeInventory("Unloading", 1)
		Goto RS_PistolReady3

	RS_PistolNoAmmo:
		RSWG A 5
		{
			A_ZoomFactor(1.0);
			A_TakeInventory("Zoomed",1);
			A_TakeInventory("ADSmode",1);
			A_PlaySound("weapons/empty");
		}
		Goto RS_PistolReady3

	RS_PistolRightFlash:
		TNT1 A 0 A_Jump(256,"RS_PistolRightFlash1","RS_PistolRightFlash2")
		Stop
	RS_PistolRightFlash1:
		D2RM A 1 Bright
		TNT1 A 0 A_Jump(256,"RS_PistolRightBigFlash1","RS_PistolRightBigFlash2","RS_PistolRightBigFlash3")
		Stop
	RS_PistolRightFlash2:
		D2RM C 1 Bright
		TNT1 A 0 A_Jump(256,"RS_PistolRightBigFlash1","RS_PistolRightBigFlash2","RS_PistolRightBigFlash3")
		Stop
	RS_PistolRightBigFlash1:
		D2RM B 1 Bright
		Stop
	RS_PistolRightBigFlash2:
		D2RM D 1 Bright
		Stop
	RS_PistolRightBigFlash3:
		D2RM E 1 Bright
		Stop

	RS_PistolFlashKicking:
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolFlashKickingShield")
		RSWG A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB B 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB C 6 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB B 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWG A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		Goto Ready3
	RS_PistolFlashKickingShield:
		RSWU A 1 A_DoPBWeaponAction
		RSWU B 1 A_DoPBWeaponAction
		RSWU C 1 A_DoPBWeaponAction
		RSWU D 3 A_DoPBWeaponAction
		RSWU E 3 A_DoPBWeaponAction
		RSWU F 3 A_DoPBWeaponAction
		RSWU E 1 A_DoPBWeaponAction
		RSWU D 1 A_DoPBWeaponAction
		RSWU C 1 A_DoPBWeaponAction
		RSWU B 1 A_DoPBWeaponAction
		RSWU A 1 A_DoPBWeaponAction
		RSWT A 1 A_DoPBWeaponAction
		Goto RS_PistolReadyShield

	RS_PistolFlashAirKicking:
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolFlashAirKickingShield")
		RSWG A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB B 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB C 7 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB B 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWG A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		Goto Ready3
	RS_PistolFlashAirKickingShield:
		RSWU A 1 A_DoPBWeaponAction
		RSWU B 1 A_DoPBWeaponAction
		RSWU C 1 A_DoPBWeaponAction
		RSWU D 3 A_DoPBWeaponAction
		RSWU E 3 A_DoPBWeaponAction
		RSWU F 3 A_DoPBWeaponAction
		RSWU E 1 A_DoPBWeaponAction
		RSWU D 1 A_DoPBWeaponAction
		RSWU C 1 A_DoPBWeaponAction
		RSWU B 1 A_DoPBWeaponAction
		RSWU A 1 A_DoPBWeaponAction
		RSWT A 1 A_DoPBWeaponAction
		Goto RS_PistolReadyShield

	RS_PistolFlashSlideKicking:
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolFlashSlideKickingShield")
		RSWG A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB B 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB C 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB D 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB E 14 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB D 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB C 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB B 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWB A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		RSWG A 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD)
		Goto Ready3
	RS_PistolFlashSlideKickingShield:
		RSWU A 1 A_DoPBWeaponAction
		RSWU B 1 A_DoPBWeaponAction
		RSWU C 1 A_DoPBWeaponAction
		RSWU D 3 A_DoPBWeaponAction
		RSWU E 3 A_DoPBWeaponAction
		RSWU F 3 A_DoPBWeaponAction
		RSWU E 1 A_DoPBWeaponAction
		RSWU D 1 A_DoPBWeaponAction
		RSWU C 1 A_DoPBWeaponAction
		RSWU B 1 A_DoPBWeaponAction
		RSWU A 1 A_DoPBWeaponAction
		RSWT A 1 A_DoPBWeaponAction
		Goto RS_PistolReadyShield

	RS_PistolFlashSlideKickingStop:
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolFlashSlideKickingStopShield")
		RSWG A 1 A_DoPBWeaponAction
		Goto Ready3
	RS_PistolFlashSlideKickingStopShield:
		RSWT A 1 A_DoPBWeaponAction
		Goto RS_PistolReadyShield

	RS_PistolFlashPunching:
		TNT1 A 0 A_JumpIfInventory("ShieldModeA", 1, "RS_PistolFlashPunchingShield")
		TNT1 A 15
		TNT1 A 0 A_ClearOverlays(PSP_FLASH, PSP_FLASH, false)
		Goto Ready3
	RS_PistolFlashPunchingShield:
		RSWU A 1 A_DoPBWeaponAction
		RSWU B 1 A_DoPBWeaponAction
		RSWU C 1 A_DoPBWeaponAction
		RSWU D 1 A_DoPBWeaponAction
		RSWU E 1 A_DoPBWeaponAction
		RSWU F 4 A_DoPBWeaponAction
		RSWU E 1 A_DoPBWeaponAction
		RSWU D 1 A_DoPBWeaponAction
		RSWU C 1 A_DoPBWeaponAction
		RSWU B 1 A_DoPBWeaponAction
		RSWU A 1 A_DoPBWeaponAction
		RSWT A 1 A_DoPBWeaponAction
		TNT1 A 0 A_ClearOverlays(PSP_FLASH, PSP_FLASH, false)
		Stop
	}
}

ACTOR PrimaryPistolAmmo: Ammo
{
   Inventory.Amount 0
   Inventory.MaxAmount 16
   Ammo.BackpackAmount 0
   Ammo.BackpackMaxAmount 16
   +INVENTORY.IGNORESKILL
   Inventory.Icon "DEGTA0"
}

ACTOR SecondaryPistolAmmo : Ammo // Is the left pistol
{
   Inventory.Amount 0
   Inventory.MaxAmount 16 //Your weapon's magazine ammo limit. Always leave one more bullet, so you can do the 12+1 effect.
   Ammo.BackpackAmount 0
   Ammo.BackpackMaxAmount 16
   +INVENTORY.IGNORESKILL
   Inventory.Icon "DEGTA0"
}
