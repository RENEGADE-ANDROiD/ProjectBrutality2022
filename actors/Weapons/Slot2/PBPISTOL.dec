	AltFire:
		D8GG ABC 0 
		TNT1 A 0 {
			A_GunFlash("LightDone",GFF_NOEXTCHANGE);
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			PB_HandleCrosshair(43);
			A_TakeInventory("PB_LockScreenTilt",1);
		}
		TNT1 A 0 A_JumpIfInventory("PistolShieldLoadout", 1, "RS_PistolAltFire")
		TNT1 A 0 A_JumpIfInventory("DualWieldingPistols", 1, "ReadyToFireDualWield")
		TNT1 A 0 A_StartSound("IronSights", 0)
		TNT1 A 0 A_JumpIfInventory("Zoomed",1,"Zoomout")
		TNT1 A 0 A_ZoomFactor(1.2)
        D7GG BC 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D8GG");
			}
		}
        D7GG DEF 1
		TNT1 A 0 {
			A_Giveinventory("Zoomed",1);
			A_Giveinventory("ADSmode",1);
			A_SetCrosshair(5);
			A_WeaponReady(WRF_NOSECONDARY);
			}
        Goto Ready2
	Zoomout:
		TNT1 A 0 {	
			A_GunFlash("LightDone",GFF_NOEXTCHANGE);
			A_Takeinventory("Zoomed",1);
			A_Takeinventory("ADSmode",1);
			PB_HandleCrosshair(43);
			A_ZoomFactor(1.0);
			}
        D7GG FED 1 
		D7GG CB 1 {
			if (CountInv("SilencerEquipped") == 1 ) {
				A_SetWeaponSprite("D8GG");
			}
		}
		TNT1 A 0 A_WeaponReady(WRF_NOSECONDARY)
        Goto Ready3
		
