ACTOR GuidedLaser: FastProjectile
{ 
	Decal "None"
    Mass 0
    Scale 0.2
    Radius 1
    Height 2
    +NOBLOCKMAP
    +NOGRAVITY
    +BLOODLESSIMPACT
    +ALWAYSPUFF
    +PUFFONACTORS
    +DONTSPLASH
    +FORCEXYBILLBOARD
    Renderstyle Add
    Alpha 0.8
    States
    {
	Spawn:
		LEYS GG 0
		LEYS G 1 BRIGHT
		Stop
	}
}

ACTOR Trail : GuidedLaser
{ 
	//Translation "112:116=199:203", "224:224=112:112"
    States
    {
    Spawn:
      LEYS O 250 BRIGHT
      stop
    }
}


