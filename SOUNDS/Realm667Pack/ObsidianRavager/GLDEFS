Pulselight ObsidianGlow
{
	color 0.4 0.0 0.0
	size 16
	secondarySize 20
	interval 2.0
	offset 0 64 0
}

Pulselight ObsidianProjectileGlowLarge
{
	color 1.0 0.0 0.0
	size 16
	secondarySize 18
	interval 2.0
	offset 0 0 0
}
Pulselight ObsidianProjectileGlowSmall
{
	color 1.0 0.0 0.0
	size 10
	secondarySize 12
	interval 2.0
	offset 0 0 0
}

object ObsidianRavager
{
    frame VSTL { light ObsidianGlow }
}

object ChaosBall
{
    frame BAL7 { light ObsidianProjectileGlowLarge }
}
object ChaosBarrage
{
    frame BAL7 { light ObsidianProjectileGlowSmall }
}

