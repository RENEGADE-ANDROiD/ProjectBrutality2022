ACTOR SlayerKnight 6135
{ 
    Health 500
    Radius 20 
    Height 56 
    Speed 14
    PainChance 50
    Mass 1000
	MeleeRange 64
    MONSTER 
	+FLOORCLIP
	Species BaronOfHell
    Obituary "%o was diced to bits by a Slayer Knight." 
    SeeSound "SlayerKnight/sight" 
    PainSound "knight/pain" 
    DeathSound "SlayerKnight/death" 
    ActiveSound "SlayerKnight/act"  
    States 
    { 
    Spawn: 
        SLKN AB 10 A_Look 
        Loop 
    See: 
        SLKN AABBCCDD 2 A_Chase 
        Loop 
	Melee:
        SLKN EF 6 A_FaceTarget
		SLKN G 6 A_CustomComboAttack ("SlayerKnightFlame", 32, 10 * random(1, 8), "baron/melee")
		Goto See
	Missile:
        SLKN EF 6 A_FaceTarget
		SLKN G 6 A_CustomComboAttack ("SlayerKnightFlame", 32, 10 * random(1, 8), "baron/melee")
		Goto See
    Pain: 
        SLKN H 5 
        SLKN H 5 A_Pain 
        Goto See 
    Death: 
        SLKN I 6 
        SLKN J 6 A_Scream 
        SLKN K 6 A_Fall 
        SLKN LMNO 6 
        SLKN P -1 
        Stop 
    Raise: 
        SLKN PONMLKJI 5 
        Goto See 
    } 
}

ACTOR SlayerKnightFlame : BaronBall
{
    Damage 4
	SeeSound "SlayerKnight/flame"
	DeathSound "baron/shotx"
	Decal "BaronScorch"
	States
	{
	Spawn:
		SKFB AAAABBBB 1 BRIGHT A_SpawnItemEx ("SKFlameTrail",0,0,0,0,0,0,0,128)
		Loop
	Death:
		TNT1 A 0 A_StopSound(6)
		SKFB CDE 3 BRIGHT
		Stop
	}
}

actor SKFlameTrail
{
	Renderstyle add
	Alpha 0.75
	+NOGRAVITY
	+FLOAT
	+CLIENTSIDEONLY
	+NOBLOCKMAP
	+DONTSPLASH
	+NOCLIP
	+NOINTERACTION
	+THRUACTORS
	Scale 0.85
	States
	{
	Spawn:
		SKFB AB 2 BRIGHT a_fadeout (0.25)
		Loop
	}
}